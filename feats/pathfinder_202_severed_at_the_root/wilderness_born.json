    "feat": {
        "name": "Wilderness Born",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You\u2019re at home in the wilderness and easily disappear into it. You gain a +1 circumstance bonus to Hide and Sneak in natural terrain, and a +1 circumstance bonus to Sense Direction in natural terrain. While in natural terrain, you\u2019re always considered to be Covering Tracks, even if you chose a different activity in exploration mode.",
        "level": 1,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
