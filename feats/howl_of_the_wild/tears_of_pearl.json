    "feat": {
        "name": "Tears of Pearl",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You weep, and your tears become gleaming pearls as they fall to the ground, so beautiful others can't help but grab at them. All creatures adjacent to you must attempt a Will save against the higher of your class DC or spell DC. The pearls dissolve at the start of your next turn, turning into salt water.",
        "level": 9,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
