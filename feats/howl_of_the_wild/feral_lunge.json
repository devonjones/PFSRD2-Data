    "feat": {
        "name": "Feral Lunge",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You spring on an unsuspecting opponent, tearing at them with your teeth. You Stride up to 10 feet and make a jaws Strike at the end of that movement. If you began this action hidden, you remain hidden until after this Strike. If you have a fly or swim Speed, you can Fly or Swim up to 10 feet instead of Stride.",
        "level": 10,
