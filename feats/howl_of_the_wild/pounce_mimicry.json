    "feat": {
        "name": "Pounce Mimicry",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You have mastered the art of stalking your prey and striking when they are most vulnerable. You Stride and then Strike. If you began this action hidden, you remain hidden until after the Strike. You can use Pounce Mimicry while Burrowing, Climbing, Flying, or Swimming instead of Striding if you have the corresponding movement type.",
        "level": 14,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
