    "feat": {
        "name": "Winged Warrior Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Through rigorous training, you have strengthened your wings, granting you enough thrust to gain additional altitude. When you make a horizontal Leap, increase the distance by 10 feet up to a maximum of your Speed. Any fly Speed granted by ancestry feats and other permanent wings increases by 5 feet.",
        "level": 2,
        "traits": [
