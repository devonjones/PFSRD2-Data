    "feat": {
        "name": "Ill Tide",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Some land dwellers say that merfolk are bad luck. You might not cause bad luck, but you can certainly keep it going. The next time the triggering creature attempts an attack roll, skill check, or saving throw, it must roll twice and use the worse result.",
        "level": 9,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Reaction"
        },
