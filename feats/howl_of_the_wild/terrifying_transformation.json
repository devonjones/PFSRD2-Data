    "feat": {
        "name": "Terrifying Transformation",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your flesh tears and warps as you transform. Attempt Intimidation checks to Demoralize each enemy within 30 feet. This Demoralize loses the auditory trait and gains the visual trait, and you don't take a penalty if a creature doesn't understand your language. Regardless of the results of your checks, each creature is temporarily immune to Terrifying Transformation for 1 minute.",
        "level": 8,
        "action_type": {
