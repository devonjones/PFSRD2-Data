    "feat": {
        "name": "Emit Defensive Odor",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "While athamarus' natural pheromones are typically used for communication, you have developed yours into a defense mechanism to ward off foes. You emit a thick spray of defensive pheromones at an adjacent creature, who takes 2d6 poison damage with a basic Fortitude save against your class DC.  \n  \n At 3rd level and every 2 levels thereafter, the damage increases by 1d6.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
