    "feat": {
        "name": "Petrifying Gaze Mimicry",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Either by witnessing or surviving the petrifying stare of a medusa or similar creature, you have learned to petrify those you lock eyes with. You stare at a creature you can see within 30 feet. The creature attempts a Fortitude save against the higher of your class DC or spell DC. You must wait 1d4 rounds before using this ability again.",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
