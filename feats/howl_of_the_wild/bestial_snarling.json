    "feat": {
        "name": "Bestial Snarling",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can convey the subtle menace of a low growl or predatory rumble. Attempt a Nature or Performance check, and compare it to the Will DC of each enemy adjacent to you. If you have an animal minion, such as an animal companion or summoned animal, you can also compare it to each enemy adjacent to them. For each creature that you succeed at, it's frightened 1 (or frightened 2 if it's an animal). Regardless of the result, each target is temporarily immune to your Bestial Snarling for 10 minutes.",
        "level": 2,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
