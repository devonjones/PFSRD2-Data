    "feat": {
        "name": "Rip and Tear",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You've learned to debilitate your enemies in the same way a hunter tears at their prey. Make an unarmed Strike against the same target. If the Strike hits and deals piercing or slashing damage, the target takes an additional 1d6 persistent bleed damage. If you're at least 12th level, increase this to 2d6 persistent bleed damage.",
        "level": 4,
