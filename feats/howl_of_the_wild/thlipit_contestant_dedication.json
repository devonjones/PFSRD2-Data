    "feat": {
        "name": "Thlipit Contestant Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Grueling practice has strengthened your tongue or tail to the point where it's become a formidable weapon. You gain a lash melee unarmed attack that is in the flail weapon group, deals 1d4 bludgeoning damage, and has the grapple and reach traits. The attack can be performed with any appendages you used to qualify for this feat.",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
