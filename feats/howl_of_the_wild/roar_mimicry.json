    "feat": {
        "name": "Roar Mimicry",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You unleash a roar so loud that it's felt as deeply as it's heard. All creatures within a 15-foot emanation take 8d6 sonic damage and must attempt a Fortitude save against the higher of your class DC or spell DC. This damage increases by 2d6 at 14th level and every 2 levels thereafter.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
