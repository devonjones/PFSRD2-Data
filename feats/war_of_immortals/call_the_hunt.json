    "feat": {
        "name": "Call The Hunt",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You instruct your allies on how best to defeat your prey. Until the start of your next turn, whenever your hunted prey is within reach of you and at least one of your allies, it is off-guard to all melee attacks. If you are sanctified, the unarmed attacks and weapon Strikes of you and all your allies gain the benefits of your sanctification against your hunted prey.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
