    "feat": {
        "name": "Zealous Inevitability",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You channel your zeal through a sacred weapon, bringing a foe closer to their demise. Strike a target with the required weapon. On a success, the target becomes doomed 1 or increases the value of their doomed condition by 1 (most living creatures die when they\u2019ve reached doomed 4). Creatures doomed in this way take a status penalty to their saving throws against divine spells equal to their doomed value.   \n  \nA creature that would become doomed 4 by this Strike can attempt a Will saving throw against your class DC to avoid increasing the value of their doomed condition. When this occurs, this ability gains the incapacitation trait.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
