    "feat": {
        "name": "Wildspell Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You gain the ability to tap into a powerful well of magic. You gain the *spellsurge* focus spell. This spell is of your main casting tradition.",
        "level": 12,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f31704572455b8d77a8bd97c0045fde6",
                "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ]
            },
            {
                "name": "Destiny",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "War of Immortals",
                        "link": {
                            "type": "link",
                            "name": "War of Immortals pg. 217",
                            "alt": "War of Immortals pg. 217",
                            "game-obj": "Sources",
                            "aonid": 232
                        },
                        "page": 217
                    }
                ],
                "game-obj": "Traits",
                "game-id": "30a17a5f1207df4047d5962485697c43",
                "text": "The destiny trait indicates the first feat in a mythic destiny. You must be a mythic character of 12th- level to select a destiny and cannot take subsequent feats in that mythic destiny without first taking the destiny feat."
            },
            {
                "name": "Mythic",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "War of Immortals",
                        "link": {
                            "type": "link",
                            "name": "War of Immortals pg. 69",
                            "alt": "War of Immortals pg. 69",
                            "game-obj": "Sources",
                            "aonid": 232
                        },
                        "page": 69
                    }
                ],
                "game-obj": "Traits",
                "game-id": "40b5d9c5e49dbe2aea5d7ecf38d950f3",
                "text": "Options with this trait grant or utilize mythic power. Feats with the mythic trait can only be taken by mythic characters, who are typically characters with a mythic Calling.  \n  \n Monsters with the mythic trait have access to a pool of Mythic Points and are particularly strong for creatures of their level. Many mythic monsters are either resistant or entirely immune to attacks from non-mythic creatures and weapons.  \n  \n Spells with the mythic trait require the expenditure of a Mythic Point in order to be cast, and items with the mythic trait require the expenditure of a Mythic Point in order to use their activated abilities.  \n  \n Weapons with the mythic trait overcome the resistances and immunities of mythic monsters."
            }
        ],
