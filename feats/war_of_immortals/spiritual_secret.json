    "feat": {
        "name": "Spiritual Secret",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You gain deeper insights into your patron\u2019s abandoned power, allowing you to draw on that power more directly. If your next action is to cast a witch cantrip or witch spell that deals damage, it deals spirit damage instead of its normal type. It also loses any traits related to its damage, such as the fire or mental trait, and gains the sanctified and spirit traits instead.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Free Action"
        },
