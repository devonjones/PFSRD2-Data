    "feat": {
        "name": "Aeonbound",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your lineage is influenced or directly tied to the supernatural inhabitants of the Perfect City of Axis, a realm of pure and absolute order. This energy suffuses your body and helps it maintain coherency, resisting effects that would undermine your function or mar your otherwise orderly form. You and your allies can Treat your Wounds without a healer's toolkit. Once per day, when someone rolls a failure or a critical failure on a check to Treat your Wounds, you can focus on your internal cohesion to increase the degree of success by one step.",
        "level": 1,
        "traits": [
            {
                "name": "Lineage",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 317,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "65f0a18afbed469efd23823e75c4cf70",
                "text": "A feat with this trait indicates a character\u2019s descendance from a particular type of creature. You can have only one lineage feat. You can select a lineage feat only at 1st level, and you can\u2019t retrain into or out of these feats."
            },
            {
                "name": "Nephilim",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
