                "text": "This indicates abilities from the exemplar class."
            },
            {
                "name": "Linguistic",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 101,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
