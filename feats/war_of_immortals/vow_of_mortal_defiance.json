                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature."
            }
        ],
        "prerequisite": "You are not *sanctified* with the *holy* or *unholy* trait.",
        "special": "If you take this feat, you can\u2019t become sanctified with the holy or unholy trait. Retraining out of this feat typically requires a major change of philosophy.",
