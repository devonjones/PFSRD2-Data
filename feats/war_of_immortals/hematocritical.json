    "feat": {
        "name": "Hematocritical",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You bathe in the arterial fluids of your enemy, drinking deep of their freed essence to empower your magic and increase your spellcasting efficacy. If your next action is to Cast a Spell that requires a spell attack roll, you roll the spell attack roll twice and use the better result; this is a fortune effect. Alternatively, if your next action is to cast a spell that requires the creature damaged by the triggering strike to attempt a save, they roll twice and take the lower result; this is a misfortune effect.",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Free Action"
        },
        "traits": [
