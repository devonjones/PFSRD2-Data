    "feat": {
        "name": "Shield the Faithful",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You and those closest to you are protected by your deity\u2019s power. For 1 minute, you and all allies within 10 feet of you gain a +1 item bonus to AC and resistance 10 to spirit damage. In addition, when a creature adjacent to you hits you with a melee attack, or when a creature touches you or hits you with an unarmed attack, that creature takes 5 spirit damage.  \n  \nAt 20th level, the spirit resistance increases to 15 and the spirit damage increases to 10.",
        "level": 14,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
