    "feat": {
        "name": "Herald's Weapon",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your weapon becomes a wrathful instrument of your deity\u2019s power. Choose a weapon you are currently wielding or an unarmed attack, which is wreathed in pure spiritual energy for 1 minute. For the duration, the chosen weapon and unarmed attack deals spirit damage instead of its regular damage. In addition, the chosen weapon or unarmed attack gains the sanctified trait and deals an additional 2d4 spirit damage.",
        "level": 14,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
