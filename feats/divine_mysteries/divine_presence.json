    "feat": {
        "name": "Divine Presence",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your spirit becomes one with your deity, granting you the bearing of a god. As long as you are in this stance, you have a 5-foot emanation that has the aura trait. Whenever you take an action, you can take it from your space or any space within the emanation as if it were the space you occupy. An enemy that ends its turn completely within the emanation is off-guard to your Strikes. You can Sustain the emanation to increase its radius by 5 feet, up to a maximum of 15 feet.",
        "level": 18,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
