    "feat": {
        "name": "Nothing Personal",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "When you\u2019re on a job, you can\u2019t allow anyone to stop you. Designate a single creature you can see as being an impediment to your active course of action. The first time you Strike your impediment in a round, you deal an extra die of weapon damage. At 14th level, this increases to two extra dice, and at 20th level, this increases to three extra dice.   \n  \nYou can have only one creature designated as an impediment at a time. If you use Nothing Personal against a creature when you already have a creature designated, the prior creature loses the designation, and the new impediment gains the designation. Otherwise, your designation lasts for 1 hour.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
