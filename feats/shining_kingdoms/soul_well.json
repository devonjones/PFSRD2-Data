    "feat": {
        "name": "Soul Well",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your brush your fingers across your *splinter of finality*, momentarily creating a metaphysical vortex from which mortal spirits struggle to escape. For the next minute, incorporeal undead treat all squares within 30 feet of you as difficult terrain and living creatures within the same area die from the dying condition at dying 5 rather than dying 4. As it comes close to tasting a living soul, the *splinter of finality* is empowered. If a living creature\u2019s dying value increases while within your Soul Well, your *spectral dagger* deals one additional weapon die of damage until the end of your next turn.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
