    "feat": {
        "name": "Soul Oubliette",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your mortal strike wrenches the soul from your victim\u2019s body and imprisons it in your *splinter of finality*, with the effects of *seize soul*. The *splinter of finality* can only hold one soul at a time, but you can release a trapped soul as a free action. If you don\u2019t free a soul willingly, it escapes automatically after 24 hours. However, if you touch the *splinter of finality* to an unbroken final blade while a soul is trapped within, the soul is transferred to the *final blade* and imprisoned indefinitely.   \n  \nWhile your *splinter of finality* contains a trapped soul, you gain fast healing 15.",
        "level": 20,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Reaction"
        },
