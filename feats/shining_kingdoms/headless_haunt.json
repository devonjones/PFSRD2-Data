    "feat": {
        "name": "Headless Haunt",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You were condemned to death and executed with one of Galt\u2019s infamous *final blades*, where your soul was trapped for years or even decades. You might have been released alongside a host of other spirits when your prison was destroyed after the Night of the Gray Death, or powerful magic or other unique circumstances might have facilitated your escape. Whatever the method, you have unfinished business preventing you from passing on to the afterlife. You gain the Remove Head action.   \n  \n**Remove Head** (manipulate)",
        "level": 4,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
