    "feat": {
        "name": "Fling Head",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You Interact to remove your head, if it isn\u2019t already detached, and fling it at an enemy within 30 feet, where it emits a bone-chilling wail before dematerializing and returning to your body. Your target must attempt a Will save against your class DC or spell DC, whichever is higher. You can affect one additional creature within 20 feet of your original target for each additional action you spend.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
