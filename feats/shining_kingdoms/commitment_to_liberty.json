    "feat": {
        "name": "Commitment to Liberty",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can\u2019t abide when a foe has one of your allies in its grip. Make a Strike against the required creature. If this Strike hits, the grabbed or restrained ally can immediately attempt to Escape as a free action. If the Strike was a critical hit, that ally gains a +2 circumstance bonus to their Escape attempt.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
