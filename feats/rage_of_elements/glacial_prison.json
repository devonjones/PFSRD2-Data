                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "2106d07ecaef4033d87e9e581a7b5c6a",
                "text": "Effects with this trait deal cold damage. Creatures with this trait have a connection to magical cold."
            },
            {
                "name": "Impulse",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Rage of Elements",
                        "link": {
                            "type": "link",
                            "name": "Rage of Elements pg. 15",
                            "alt": "Rage of Elements pg. 15",
                            "game-obj": "Sources",
                            "aonid": 205
                        },
                        "page": 15,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 205
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f83779b12b3f1e7096ae9a32ca68ea4f",
                "text": "The primary magical actions kineticists use are called impulses. You can use an impulse only if your kinetic aura is active and channeling that element, and only if you have a hand free to shape the elemental flow. The impulse trait means the action has the concentrate trait unless another ability changes this. If an impulse allows you to choose an element, you can choose any element you're channeling, and the impulse gains that element's trait.",
                "links": [
                    {
                        "type": "link",
                        "name": "concentrate",
                        "alt": "concentrate",
                        "game-obj": "Traits",
                        "aonid": 32
                    }
                ]
            },
            {
                "name": "Incapacitation",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 93,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 457",
                            "alt": "Player Core pg. 457",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 457,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "b26076555c07646f046dd58e7d5b3885",
                "text": "An ability with this trait can take a character completely out of the fight or even kill them, and it\u2019s harder to use on a more powerful character. If a spell has the incapacitation trait, any creature of more than twice the spell\u2019s rank treats the result of their check to prevent being incapacitated by the spell as one degree of success better, or the result of any check the spellcaster made to incapacitate them as one degree of success worse. If any other effect has the incapacitation trait, a creature of higher level than the item, creature, or hazard generating the effect gains the same benefits."
            },
            {
                "name": "Kineticist",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Rage of Elements",
                        "link": {
                            "type": "link",
                            "name": "Rage of Elements pg. 237",
                            "alt": "Rage of Elements pg. 237",
                            "game-obj": "Sources",
                            "aonid": 205
                        },
                        "page": 237,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 205
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "721afce0c1e219e9edd3709db105bb4e",
                "text": "This indicates abilities from the kineticist class.",
                "links": [
                    {
                        "type": "link",
                        "name": "kineticist",
                        "alt": "kineticist",
                        "game-obj": "Classes",
                        "aonid": 23
                    }
                ]
            },
            {
                "name": "Overflow",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Rage of Elements",
                        "link": {
                            "type": "link",
                            "name": "Rage of Elements pg. 15",
                            "alt": "Rage of Elements pg. 15",
                            "game-obj": "Sources",
                            "aonid": 205
                        },
                        "page": 15,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 205
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "ad03e04f8b701bd9c018b87e35173733",
                "text": "Powerful impulses temporarily overdraw the energy of your kinetic gate. When you use an impulse that has the overflow trait, your kinetic aura deactivates until you revitalize it (typically with Channel Elements). Extinguishing your element this severely is taxing, and consequently, you can use only one overflow impulse per round, even if you reactivate your kinetic gate.",
                "links": [
                    {
                        "type": "link",
                        "name": "Channel Elements",
                        "alt": "Channel Elements",
                        "game-obj": "Actions",
                        "aonid": 2124
                    }
                ]
            },
            {
                "name": "Primal",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 134,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 460",
                            "alt": "Player Core pg. 460",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 460,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "60a4f011afd1e0fac8211bd01108d104",
                "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic."
            },
            {
                "name": "Water",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 165,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 463",
                            "alt": "Player Core pg. 463",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 463,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "28b3ffaf7df1fef23da1eb1d9c63267d",
                "text": "Effects with the water trait either manipulate or conjure water. Those that manipulate water have no effect in an area without water. Creatures with this trait consist primarily of water or have a connection to magical water.  \n  \nPlanes with this trait are mostly liquid. Visitors who can\u2019t breathe water or reach an air pocket likely drown. The rules for aquatic combat aquatic combat usually apply, including the inability to cast fire spells or use actions with the fire trait. Creatures with a weakness to water take damage equal to double their weakness at the end of each round.",
                "links": [
                    {
                        "type": "link",
                        "name": "aquatic combat",
                        "alt": "aquatic combat",
                        "game-obj": "Rules",
                        "aonid": 2438
                    }
                ]
            }
        ],
        "critical_success": "The target is unaffected.",
        "success": "The target is slowed 1 until the end of its next turn.",
        "failure": "The target is frozen solid. It can't act, its AC is 9, it has Hardness 5, and it's immune to other cold effects, critical hits, and precision damage. This lasts until the end of your next turn, but if the target is affected by a hostile action, this effect ends immediately after that action.",
        "critical_failure": "As failure, but after becoming unfrozen, the creature is slowed 1 until the end of its next turn.",
        "links": [
            {
                "type": "link",
                "name": "slowed 1",
                "alt": "slowed 1",
                "game-obj": "Conditions",
                "aonid": 35
            }
        ]
    },
