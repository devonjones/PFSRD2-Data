    "feat": {
        "name": "Read the Roots",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "The root systems of trees are a far-reaching network of information, and you know how to access them and extract their secrets. You Seek within 30 feet using tremorsense, an imprecise sense, instead of one of your own senses. You can also detect subjects touching or burrowing through the surface you are standing on in this way.",
        "level": 5,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
