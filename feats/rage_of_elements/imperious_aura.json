    "feat": {
        "name": "Imperious Aura",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your glowing and majestic kinetic aura marks you as a true child of the elements. Use a stance impulse that affects your kinetic aura.",
        "level": 16,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Free Action"
        },
        "traits": [
            {
                "name": "Impulse",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Rage of Elements",
                        "link": {
                            "type": "link",
                            "name": "Rage of Elements pg. 15",
                            "alt": "Rage of Elements pg. 15",
                            "game-obj": "Sources",
                            "aonid": 205
                        },
                        "page": 15,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 205
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f83779b12b3f1e7096ae9a32ca68ea4f",
                "text": "The primary magical actions kineticists use are called impulses. You can use an impulse only if your kinetic aura is active and channeling that element, and only if you have a hand free to shape the elemental flow. The impulse trait means the action has the concentrate trait unless another ability changes this. If an impulse allows you to choose an element, you can choose any element you're channeling, and the impulse gains that element's trait.",
                "links": [
                    {
                        "type": "link",
                        "name": "concentrate",
                        "alt": "concentrate",
                        "game-obj": "Traits",
                        "aonid": 32
                    }
                ]
            },
            {
                "name": "Kineticist",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Rage of Elements",
                        "link": {
                            "type": "link",
                            "name": "Rage of Elements pg. 237",
                            "alt": "Rage of Elements pg. 237",
                            "game-obj": "Sources",
                            "aonid": 205
                        },
                        "page": 237,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 205
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "721afce0c1e219e9edd3709db105bb4e",
                "text": "This indicates abilities from the kineticist class.",
                "links": [
                    {
                        "type": "link",
                        "name": "kineticist",
                        "alt": "kineticist",
                        "game-obj": "Classes",
                        "aonid": 23
                    }
                ]
            },
            {
                "name": "Primal",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 134,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 460",
                            "alt": "Player Core pg. 460",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 460,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "60a4f011afd1e0fac8211bd01108d104",
                "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic."
            }
        ],
        "prerequisite": "one or more *stance* *impulses* that affect your kinetic aura",
        "trigger": "Your turn begins.",
