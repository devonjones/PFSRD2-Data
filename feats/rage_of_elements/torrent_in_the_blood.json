    "feat": {
        "name": "Torrent in the Blood",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "A healing wave splashes across creatures in a 30-foot cone, its cleansing water driving afflictions from the body. Each creature in the area regains 3d8 Hit Points and can attempt a new save against one poison or disease affliction affecting it; on a failed save, the condition doesn't worsen.  \n  \n Each creature that benefited from this impulse becomes temporarily immune to Torrent in the Blood for 10 minutes.\n\n---\n\n**Level (+2)** The healing increases by 1d8.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
        "traits": [
            {
                "name": "Healing",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 89,
                    "alternate_type": "legacy"
