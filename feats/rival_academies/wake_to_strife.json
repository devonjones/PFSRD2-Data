    "feat": {
        "name": "Wake to Strife",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You summon the explosive power of a geyser beneath a foe. The required creature must attempt a Fortitude save against your class DC as elemental water confounds their senses; if the creature is prone, they can Stand as a free action.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
