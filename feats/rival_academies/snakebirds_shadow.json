    "feat": {
        "name": "Snakebird's Shadow",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Ganhil developed this technique through observing the sharp-beaked darters fishing Prada Hanam\u2019s waters, seeking to match their speed and suppleness with the elemental flash of his blade. Make a melee Strike with the required weapon against each enemy in a 15-foot line as razor-sharp shadows of water surge from your blade. Each attack counts toward your multiple attack penalty, but you do not increase your penalty until you have made all your attacks.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
        "traits": [
            {
