    "feat": {
        "name": "Martyr's Parry",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You intercede to absorb the triggering attack. Your bonded partner gains a +2 circumstance bonus to their AC. If the attack still hits, you take the triggering attack\u2019s damage instead of your bonded partner, though the attack still uses your bonded partner\u2019s defenses for the purposes of determining if it hit or critically hit.",
        "level": 8,
        "action_type": {
