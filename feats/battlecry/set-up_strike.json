    "feat": {
        "name": "Set-up Strike",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your attack makes it difficult for your enemy to defend themselves against your allies' attacks. Attempt a Strike against an enemy. If the Strike is successful, the target is off guard against the next attack that one of your allies attempts against it before the start of your next turn.",
        "level": 2,
        "action_type": {
