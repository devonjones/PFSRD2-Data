          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "547077cdd16c0713d32f0ce213943fbd",
        "game-obj": "Traits",
        "name": "Flourish",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
