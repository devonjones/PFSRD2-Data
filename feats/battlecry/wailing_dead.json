    "feat": {
        "name": "Wailing Dead",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "The voices of the spirits you command spark fear in the hearts of your enemies. You Sustain your horde and command those spirits to shriek in unison. Each living enemy within a 20 foot emanation from your horde takes 5d10 mental damage, depending on its Will saving throw against your spell DC. This damage increases by 1d10 at 14th level and every 2 levels thereafter.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
