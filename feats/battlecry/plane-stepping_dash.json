    "feat": {
        "name": "Plane-Stepping Dash",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You move with magical swiftness, treading between planar boundaries to shorten your journey. Stride once; this Stride does not trigger reactions normally triggered by movement. Once this Stride is complete, you gain a +5-foot status bonus to your Speed until the start of your next turn.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
