    "game-obj": "Feats",
    "feat": {
        "name": "Banner's Inspiration",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You wave your banner, inspiring allies to throw off the shackles of fear. Each ally currently benefiting from your commander's banner reduces their frightened condition by 1 and can immediately attempt a new saving throw against any one mental effect currently affecting them. Regardless of the result, any ally that attempts this save is temporarily immune to Banner's Inspiration for 10 minutes.",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Brandish",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Battlecry!",
                        "link": {
                            "type": "link",
                            "name": "Battlecry! pg. 23",
                            "alt": "Battlecry! pg. 23",
                            "game-obj": "Sources",
                            "aonid": 268
                        },
                        "page": 23
                    }
                ],
                "game-obj": "Traits",
                "game-id": "69c28086901195895730705339cd6c3f",
                "text": "The brandish trait indicates an ability that involves you waving or otherwise actively displaying your banner. To use an ability that has the brandish trait, you must be holding your banner in one hand or wielding a weapon it is attached to. Since you have to be actively signaling with your banner to direct your squadmates while using a tactic with the brandish trait, you cannot use free actions or reactions granted as part of a brandish tactic unless specifically noted otherwise."
            },
            {
                "name": "Commander",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Battlecry!",
                        "link": {
                            "type": "link",
                            "name": "Battlecry! pg. 219",
                            "alt": "Battlecry! pg. 219",
                            "game-obj": "Sources",
                            "aonid": 268
                        },
                        "page": 219
                    }
                ],
                "game-obj": "Traits",
                "game-id": "67bb49765c467db678d75ae3ac7d79ed",
                "text": "This trait indicates abilities from the commander class.",
                "links": [
                    {
                        "type": "link",
                        "name": "commander",
                        "alt": "commander",
                        "game-obj": "Classes",
                        "aonid": 66
                    }
                ]
            },
            {
                "name": "Emotion",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 60,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 455",
                            "alt": "Player Core pg. 455",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 455,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "fb5f8b3d849b073e1514a6a025810470",
                "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects."
            },
            {
                "name": "Flourish",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 73,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 139",
                            "alt": "Player Core pg. 139",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 139,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "547077cdd16c0713d32f0ce213943fbd",
                "text": "Actions with the flourish trait are special techniques that require too much exertion for you to perform frequently. You can use only one action with the flourish trait per round."
            },
            {
                "name": "Mental",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 106,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature."
            },
