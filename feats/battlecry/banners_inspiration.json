{
    "name": "Banner's Inspiration",
    "type": "feat",
    "pfs": {
        "type": "stat_block_section",
        "subtype": "pfs",
        "availability": "Standard",
        "note": "Banner\u2019s Inspiration allows a new saving throw, so anything that happens on a failed save still occurs if a PC fails."
    },
