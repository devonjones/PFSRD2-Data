    "feat": {
        "name": "In the Horde's Grip",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "When your skeletons and zombies attack, their skeletal claws and rotting hands clutch and tear flesh. Weaker foes are caught in their grip. You command your horde to perform a Mobbing Assault. Instead of being off-guard, a creature who takes physical damage from failing the saving throw is grabbed by your horde (restrained on a critical failure). The DC to Escape from your horde is equal to your spell DC. Creatures grabbed by your horde that fail a saving throw against the horde's Mobbing Assault take 2d6 persistent bleed damage.",
        "level": 14,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
