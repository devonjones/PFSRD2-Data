    "feat": {
        "name": "Hampering Stance",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You make it difficult for enemies to move past you. While you are in this stance, squares in a 5-foot emanation are difficult terrain for your enemies.",
        "level": 2,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
