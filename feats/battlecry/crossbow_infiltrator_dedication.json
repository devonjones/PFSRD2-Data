    "feat": {
        "name": "Crossbow Infiltrator Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You have mastered stealthy weapons that allow you to strike carefully from a distance far enough to avoid reprisal, yet close enough to confirm your kills. You have familiarity with the gauntlet bow, hand crossbow, and repeating hand crossbow, treating the repeating hand crossbow as a martial weapon for the purposes of proficiency and the gauntlet bow as a simple weapon for the purposes of proficiency. If you're at least an expert in any of these weapons, you gain access to that weapon's critical specialization effect. You also gain the Infiltrator's Draw action.   \n  \n**Infiltrator's Draw**",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
