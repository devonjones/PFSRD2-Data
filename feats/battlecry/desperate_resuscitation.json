    "feat": {
        "name": "Desperate Resuscitation",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can use your training in combat medicine to revive the recently deceased. Attempt a DC 40 Medicine check to revive a dead creature that has been dead for no more than 3 rounds. If you succeed, the target returns to life with the effects of raise dead, except it still has the wounded condition it had before dying, increased by 1 (or wounded 1 if it wasn't wounded before dying). Whether you succeed or fail, the target is temporarily immune to Desperate Resuscitation for 1 day.",
        "level": 14,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Three Actions"
        },
