    "feat": {
        "name": "Rallying Banner",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your banner waves high, reminding your allies that the fight can still be won. You restore 4d6 Hit Points to each ally within the aura of your commander's banner. This healing increases by an additional 1d6 at 10th level and every 2 levels thereafter. Since this healing relies on drawing from your allies' morale and adrenaline, the healing it grants is halved when used outside of combat.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Brandish",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Battlecry!",
                        "link": {
                            "type": "link",
                            "name": "Battlecry! pg. 23",
                            "alt": "Battlecry! pg. 23",
                            "game-obj": "Sources",
                            "aonid": 268
                        },
                        "page": 23
                    }
                ],
                "game-obj": "Traits",
                "game-id": "69c28086901195895730705339cd6c3f",
                "text": "The brandish trait indicates an ability that involves you waving or otherwise actively displaying your banner. To use an ability that has the brandish trait, you must be holding your banner in one hand or wielding a weapon it is attached to. Since you have to be actively signaling with your banner to direct your squadmates while using a tactic with the brandish trait, you cannot use free actions or reactions granted as part of a brandish tactic unless specifically noted otherwise."
            },
            {
                "name": "Commander",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
