{
    "name": "Additional Follower",
    "type": "feat",
    "sections": [
        {
            "name": "Multiple Followers",
            "type": "section",
            "text": "The captain archetype gives you the opportunity to have multiple followers at one time\u2014up to four followers\u2014 but only one of those followers, your \u201cactive follower,\u201d participates in combat or exploration activities; the rest hang back, ready to be called upon if needed. As soon as you gain a second follower from the captain archetype, you also gain Call Follower to switch your active follower.",
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "ability_type": "called",
                    "name": "Call Follower",
                    "link": {
                        "type": "link",
