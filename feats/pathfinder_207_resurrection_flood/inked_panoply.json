    "feat": {
        "name": "Inked Panoply",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your tattoos can briefly animate and extend from your skin, granting you a spectral shieldbearer who protects you from harm. Doing so expends one use of your storied skin, granting you a +1 circumstance bonus to AC against the triggering attack. In addition, you gain resistance to mental, spirit, and void damage equal to twice your number of tattooed historian feats against the triggering attack.",
        "level": 4,
