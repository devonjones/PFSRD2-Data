    "feat": {
        "name": "Infused with Belkzen's Might",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your tattoos immortalize the conquests of orc war leaders, such as Belkzen besieging the dwarven Sky Citadel of Koldukar. You can expend one use of your storied skin\u2019s Living History ability to channel this power into your own weapons. Until the end of your next turn, you deal additional spirit damage with weapons and unarmed attacks equal to 1 plus half the number of Tattooed Historian feats you have.",
        "level": 6,
