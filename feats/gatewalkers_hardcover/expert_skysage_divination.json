    "feat": {
        "name": "Expert Skysage Divination",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your studies of the stars have taught you about the mysteries of the cosmos. You choose one of the following 4th-rank spells to add to your spell repertoire: *clairvoyance* or *read omens*. At 12th level, choose one of the following 5th-rank spells to add to your spell repertoire: *mind probe* or *scouting eye*. At 14th level, choose one of the following 6th-rank spells to add to your spell repertoire: *scrying* or *truesight*. You become an expert with spell attack rolls and spell DCs for occult spells.",
        "level": 10,
        "traits": [
