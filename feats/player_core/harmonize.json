    "feat": {
        "name": "Harmonize",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can perform multiple compositions simultaneously, typically by performing in multiple ways at the same time, using special vocal techniques to double your voice, or creating occult magic that replicates your song or speech. If your next action is to cast a composition, it becomes a harmonized composition. Unlike a normal composition, a harmonized composition doesn\u2019t end if you cast another composition, and you can cast another composition on the same turn as a harmonized one. Casting another harmonized composition ends any harmonized composition you already have in effect.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
