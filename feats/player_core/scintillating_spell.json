    "feat": {
        "name": "Scintillating Spell",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your spells become a radiant display of light and color. If your next action is to Cast a Spell that doesn\u2019t have the darkness trait, has no duration, and requires creatures to attempt a Reflex save, the spell explodes in a spray of scintillating lights, in addition to its other effects. Each creature that failed its Reflex save against the spell is dazzled for 1 round, and those who critically failed are instead blinded for 1 round.",
        "level": 16,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Concentrate",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
