    "feat": {
        "name": "Swipe",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You make a wide, arcing swing. Make a melee Strike and compare the attack roll result to the AC of up to two foes, each of whom must be within your melee reach and adjacent to each other. Roll damage only once and apply it to each creature you hit. A Swipe counts as two attacks for your multiple attack penalty.  \n  \nIf you\u2019re using a weapon with the sweep trait, its modifier applies to all your Swipe attacks.",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
