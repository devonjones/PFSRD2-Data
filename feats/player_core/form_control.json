    "feat": {
        "name": "Form Control",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "With additional care and effort, you can take on an alternate shape for a longer period of time. If your next action is to cast untamed form, the spell\u2019s rank is 2 lower than normal (minimum 1st rank), but you can remain transformed for up to 1 hour or the listed duration (whichever is longer). You can still Dismiss untamed form as normal.",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Druid",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
