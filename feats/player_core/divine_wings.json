    "feat": {
        "name": "Divine Wings",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "With effort, you can call forth magical wings from your back, similar in appearance to those of your extraplanar forebear, whether they be elegantly feathered wings or ominous bat wings. These wings remain for 10 minutes. You gain a fly Speed equal to your Speed while you\u2019ve manifested your wings.",
        "level": 9,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
        "traits": [
            {
                "name": "Divine",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 48,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 455",
                            "alt": "Player Core pg. 455",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 455,
                        "errata": {
