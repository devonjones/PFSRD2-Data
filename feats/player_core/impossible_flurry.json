    "feat": {
        "name": "Impossible Flurry",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You forgo precision to attack at an impossible speed. Make three melee Strikes with each of the required weapons. Your first attack with each weapon takes the multiple attack penalty as though you had already made one attack this turn. All of the remaining Strikes take the maximum multiple attack penalty.",
        "level": 18,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Three Actions"
        },
