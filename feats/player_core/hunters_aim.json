    "feat": {
        "name": "Hunter's Aim",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "When you focus on aiming, your attack becomes particularly accurate. Make a ranged weapon Strike against your hunted prey. On this Strike, you gain a +2 circumstance bonus to the attack roll and ignore your prey\u2019s concealed condition and any lesser cover.",
        "level": 2,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
