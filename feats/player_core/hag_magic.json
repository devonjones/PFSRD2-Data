    "feat": {
        "name": "Hag Magic",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Through your heritage, you can replicate a hag\u2019s magic. Choose one common spell of 4th rank or lower from those available to a coven, including the spells contributed to a coven by a hag of your mother\u2019s type. You can cast this spell once per day as a 4th-rank occult innate spell.  \n  \nSpells available to all covens are augury, charm, clairaudience, clairvoyance, dream message, and illusory disguise. The eligible spells granted by the most prominent types of hag are: **Cuckoo Hag** nightmare, spellwrack; **Iron Hag** earthbind, *spellwrack*; **Sea Hag** humanoid form, mariner's curse, water walk; **Sweet Hag** *charm*, *honeyed words*, outcast's curse",
        "level": 13,
        "traits": [
            {
                "name": "Changeling",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 212,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
