    "feat": {
        "name": "Fiendish Magic",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You possess fiendish magic. Choose two of the following spells: *disguise magic*, *false vitality*, *invisibility*, *see the unseen*, *shatter*, or *paranoia*. You can use each of the chosen spells once per day as 2nd-rank divine innate spells. Grimspawn typically take *false vitality* and *see the unseen*, pitborn typically take *paranoia* and *shatter*, and hellspawn typically take *invisibility* and *disguise*.",
        "level": 9,
        "traits": [
            {
                "name": "Nephilim",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 459",
                            "alt": "Player Core pg. 459",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 459,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "27ca8b4b9ae555e42be4e1605a9eb530",
                "text": "A creature with this trait has the nephilim versatile heritage. Nephilim are planar scions descended from immortal beings from other planes. An ability with this trait can be used or selected only by nephilim."
            }
        ],
        "prerequisite": "*Grimspawn*, *Pitborn*, or *Hellspawn*, or another lineage feat associated with fiends",
