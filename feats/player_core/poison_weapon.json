    "feat": {
        "name": "Poison Weapon",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You apply a contact poison or injury poison to the required weapon; if you have a free hand, you can Interact to draw a poison as part of this action. This poison can be one of the simple injury poisons you can create due to this feat (see Special), or another contact or injury poison you\u2019ve acquired (such as those in GM Core).",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Manipulate",
                "type": "trait",
