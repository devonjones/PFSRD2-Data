    "feat": {
        "name": "Plant Shape",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can take the shape of a plant creature. If you don't have untamed form, you can cast *plant form* once per day, heightened to the same rank as your highest-rank druid spell slot.  \n  \nIf you do have untamed form, add the shapes listed in plant form to your untamed form list, and whenever you're polymorphed into another shape using untamed form, you gain resistance 5 to poison.",
        "level": 10,
