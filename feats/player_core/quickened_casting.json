    "feat": {
        "name": "Quickened Casting",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "If your next action is to cast a cantrip or a spell that is at least 2 ranks lower than the highest-rank spell slot you have, reduce the number of actions to cast it by 1 (minimum 1 action).",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Free Action"
        },
