    "feat": {
        "name": "Reach Spell",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can extend your spells\u2019 range. If the next action you use is to Cast a Spell that has a range, increase that spell\u2019s range by 30 feet. As is standard for increasing spell ranges, if the spell normally has a range of touch, you extend its range to 30 feet.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
