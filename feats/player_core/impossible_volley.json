    "feat": {
        "name": "Impossible Volley",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You fire a volley at all foes in an area. Make one Strike with a \u20132 penalty against each enemy within a 10-foot-radius burst centered at or beyond your weapon\u2019s volley range. Roll the damage only once for all targets.  \n  \nEach attack counts toward your multiple attack penalty, but do not increase your penalty until you have made all your attacks.",
        "level": 18,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Three Actions"
        },
