    "feat": {
        "name": "Verduran Shadow Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your awareness of primal energies allows you to explore forests with preternatural ease. You become an expert in Survival. You can substitute your proficiency in Survival for your proficiency in Stealth when meeting feat prerequisites and gaining additional benefits from feats for being an expert, master, or legendary in Stealth; however, unless you also fulfill the Stealth prerequisite, you can only use those feats in forest terrain. While in forests, you can use your Survival modifier in place of your Stealth modifier when you Avoid Notice, Hide, Sneak, or would use Stealth to roll initiative.",
        "level": 2,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
