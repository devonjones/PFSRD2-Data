    "feat": {
        "name": "Sense the Strike",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You sense how an incoming attack moves through ambient primal energy, predicting how best to dodge. The triggering attack targets your Survival DC instead of your AC. Though this allows you to avoid taking penalties to your AC, it doesn\u2019t remove any conditions or other effects causing such penalties. For example, an enemy with sneak attack would still deal extra damage to you for being off-guard, even though you wouldn\u2019t take the \u20132 circumstance penalty when defending against the attack.",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Reaction"
        },
