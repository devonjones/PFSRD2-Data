    "feat": {
        "name": "Death from Above",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You leap down on your target, using their body to cushion your fall and your momentum to empower your attack. Attempt an Athletics check to Leap to a space adjacent to the target. If you land adjacent to the target, compare the Athletics check result against your target\u2019s Reflex DC.   \n  \nWhen you leap onto a creature in this way, you do not also deal damage for falling on a creature. Regardless of your result, the target is temporarily immune to your Death from Above for 1 minute.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
