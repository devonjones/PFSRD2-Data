    "feat": {
        "name": "Meditate on This!",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You meditate to alter your qi, coloring it with your resentment and anger. Until the start of your next turn, whenever you hit a creature with an unarmed Strike, or an adjacent creature deals piercing, slashing, or bleed damage to you, the creature that you hit or that damaged you must attempt a Will save against your class DC. The creature is then temporarily immune for 1 minute.",
        "level": 14,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
