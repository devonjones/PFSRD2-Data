    "feat": {
        "name": "Shadowplay",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "As your blow lands, you detach from your shadow to get the drop on your enemy. You attempt to Tumble Through the opponent\u2019s space, with a +2 circumstance bonus to the Acrobatics check. If you succeed, your shadow rises up from the ground, flanking your opponent until the beginning of your next turn.",
        "level": 5,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
