    "feat": {
        "name": "Ricochet Shot",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You bounce your shot off a nearby surface to strike your opponent from an unexpected angle. Attempt a Strike with a firearm or crossbow. When determining whether a target has cover from this Strike, you can choose one solid surface within your weapon\u2019s first range increment to ricochet your shot off of. If you do, you determine the target\u2019s cover from the point where you ricochet your shot instead of from you.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
