    "feat": {
        "name": "Unexpected Sharpshooter Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Who needs skill when you've got dumb luck? Sometimes your shots hit miraculously, regardless of the fact that you seemed to slip when you pulled the trigger or that you weren't aiming at your foe when you fired. You gain the Accidental Shot activity.  \n  \n **Accidental Shot** (fortune)",
        "level": 2,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f31704572455b8d77a8bd97c0045fde6",
                "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ]
            },
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 12,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
