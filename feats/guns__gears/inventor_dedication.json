    "name": "Inventor Dedication",
    "prerequisite": "Intelligence +3",
    "subtype": "feat",
    "text": "You become trained in Crafting and inventor class DC. You gain the Inventor skill feat, even if you don't meet the skill feat's requirements. Choose an innovation. You gain that innovation, though you don't gain any other abilities that modify or use that innovation, such as modifications or Explode.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 12,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "52ef9cda2d54e07ee757696e4f8df79e",
        "game-obj": "Traits",
        "name": "Archetype",
        "sources": [
          {
