    "feat": {
        "name": "Grit and Tenacity",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You call upon deep reserves of toughness and mental fortitude to power through an otherwise debilitating effect. Reroll the triggering save with a +2 circumstance bonus; you must use the second result.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Reaction"
        },
