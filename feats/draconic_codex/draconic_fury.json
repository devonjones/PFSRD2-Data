    "feat": {
        "name": "Draconic Fury",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You briefly summon spectral claws that lash out in a flurry. All creatures in a 15-foot cone take 2d6 slashing damage with a basic Reflex save against the higher of your class DC or spell DC. A creature that critically fails the save also takes 1d4 persistent bleed damage. If you are Channeling Draconic Essence, your spectral dragon\u2019s space can be the origin of the cone.   \n  \nAt 8th level and every 4 levels thereafter, the initial damage increases by 1d6 and the persistent bleed damage on a critical failure increases by 1d4.",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
