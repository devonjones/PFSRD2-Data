    "feat": {
        "name": "War Rider Stance",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your dragon\u2019s constant breath threatens your foes. While in this stance, your dragon companion has an aura in a 5-foot emanation. Each creature that starts its turn in the aura takes the damage listed under the dragon\u2019s support benefit with a basic Reflex save against your mount\u2019s Athletics DC.",
