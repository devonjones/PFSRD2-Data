    "feat": {
        "name": "Debilitating Breath",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your breath causes lasting hindrance to those it harms. Creatures who fail their saves against your Breath of the Dragon gain one of the following conditions, based on the damage type of your breath: clumsy 1 (electricity, cold, fire, or sonic damage), enfeebled 1 (acid, physical, or poison damage), or stupefied 1 (force, mental, spirit, vitality, or void damage). The condition lasts until the end of your next turn.",
        "level": 13,
