    "feat": {
        "name": "Dracomancer",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "The power infused into you by your draconic benefactor\u2019s presence allows you to manifest their most iconic spells. Choose one 1st-rank spell and one 2nd-rank spell from those listed for a dragon spellcaster of your draconic benefactor\u2019s type, such as those presented here (for example, *fear* and *invisibility* for a conspirator dragon benefactor). You can cast each of these spells once per day as innate spells of the same tradition as your draconic benefactor. You gain the trained proficiency rank in the spell attack modifier and spell DC statistics, and your key spellcasting attribute is Charisma.",
        "level": 9,
        "traits": [
            {
                "name": "Kobold",
                "type": "trait",
                "alternate_link": {
