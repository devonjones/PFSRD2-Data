    "feat": {
        "name": "Drake Rider Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You gain the service of a young riding drake, riding dragonet, or another animal companion with the dragon trait you have access to. Your bond with your dragon companion lets you communicate and issue commands to it telepathically with a range of 100 feet. You must still use the Command an Animal action to direct it but don\u2019t require words or gestures to do so.",
        "level": 2,
        "traits": [
            {
