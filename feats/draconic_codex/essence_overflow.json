    "feat": {
        "name": "Essence Overflow",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Uncontainable power explodes from your spectral dragon. Your Channel Draconic Essence ends, and all creatures (except you) in a 10-foot emanation from your spectral dragon take 6d6 damage with a basic Reflex save against the higher of your class DC or spell DC. The damage\u2019s type matches the breath of your draconic benefactor. You then can\u2019t use Essence Overflow again for 1d4 rounds.  \n  \nAt 8th level and every 2 levels thereafter, the damage increases by 1d6.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
