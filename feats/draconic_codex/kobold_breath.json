    "feat": {
        "name": "Kobold Breath",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You channel the power of your draconic benefactor to expel a torrent of energy from your mouth that manifests as a 30-foot line or a 15-foot cone, dealing 1d4 damage. Each creature in the area must attempt a basic saving throw against the higher of your class DC or spell DC. You can\u2019t use this ability again for 1d4 rounds.  \n  \nAt 3rd level and every 2 levels after that, the damage increases by 1d4. The breath shape, damage type, and the saving throw match those of your draconic benefactor, such as those shown on the Draconic Benefactors table here. This activity has the traits associated with the magical tradition of your draconic benefactor and the type of damage the breath deals.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
