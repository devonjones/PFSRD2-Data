    "feat": {
        "name": "Flair Rider Stance",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You spend little time in your saddle as you flip unpredictably around your dragon mount, dodging attacks. While mounted and in this stance, your mount always provides you with lesser cover and you don\u2019t take the \u20132 circumstance penalty to Reflex saves while mounted.",
        "level": 6,
        "action_type": {
