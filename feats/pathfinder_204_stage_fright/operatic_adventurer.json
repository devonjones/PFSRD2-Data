    "feat": {
        "name": "Operatic Adventurer",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your training has focused you for the opera, and it certainly shows. You become master in Performance, and at 15th level your skill in Performance increases to Legendary. You also become expert in Theater Lore or become master in Theater Lore if you were already expert. When you\u2019re on a stage, in an arena, or otherwise at the focus of a crowd there to see you perform, your eagerness to begin grants a +3 circumstance bonus to initiative rolls if you roll Acrobatics, Intimidation, or Performance for initiative.",
        "level": 12,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f31704572455b8d77a8bd97c0045fde6",
                "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ]
            },
