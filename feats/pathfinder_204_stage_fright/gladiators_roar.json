    "feat": {
        "name": "Gladiator's Roar",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can project your voice into a high-pitched screech that damages your foes. Your roar can be heard twice as far as normal, and creatures within a 15-foot-cone take 6d10 sonic damage and must attempt a Fortitude save against your class DC or spell DC, whichever is higher. If your Gladiator\u2019s Roar triggers Play to the Crowd, you gain a +2 status bonus to your Performance check to do so.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
