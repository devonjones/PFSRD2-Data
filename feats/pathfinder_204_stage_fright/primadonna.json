    "feat": {
        "name": "Primadonna",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "The spotlight should always be on you and you alone. Attempt a Performance check against the Will DCs of all enemies within 30 feet who can see or hear you. On a success, the targets focus on you and gain a +1 circumstance bonus to hit you, but they\u2019re off-guard to all creatures other than yourself. On a critical success, the effect lasts for 3 rounds.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
