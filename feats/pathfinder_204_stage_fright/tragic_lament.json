    "feat": {
        "name": "Tragic Lament",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You dramatically cry out in poetic verse about the tragedies that led to your doom at this very moment, instilling guilt in your attacker. The Strike deals normal damage rather than critical damage as your foe relents on their attack at the last moment as they\u2019re moved by your words, though other effects that happen on a critical hit still occur. The creature that made the triggering Strike must then succeed on a Will save against your Class DC or be slowed 1 for 1 round by guilt at its actions against you.",
        "level": 18,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Reaction"
        },
        "traits": [
