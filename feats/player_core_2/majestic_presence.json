    "feat": {
        "name": "Majestic Presence",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "By taking an impressive stance, the full force of your personality cows lesser beings. Each creature in a 20- foot emanation must attempt a Will save against the higher of your class DC or spell DC. Regardless of the result of the saving throw, the creature is temporarily immune to your Majestic Presence for 24 hours.",
