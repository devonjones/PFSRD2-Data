    "feat": {
        "name": "Archer Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You have familiarity with all weapons in the bow and crossbow weapon groups. For the purposes of proficiency, treat any of these that are martial weapons as simple weapons and any that are advanced weapons as martial weapons.  \n  \nIf you are at least an expert in the bow or crossbow you are using, you get the critical specialization effect of that weapon when you get a critical hit with it.",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 12,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
