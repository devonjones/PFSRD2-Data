    "feat": {
        "name": "Investigator Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You gain the on the case class feature, which grants you both the Pursue a Lead activity and Clue In reaction. You become trained in Society and another skill of your choice. If you were already trained in Society, you instead become trained in an additional skill of your choice. You also become trained in investigator class DC.",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 12,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 452,
                        "errata": {
