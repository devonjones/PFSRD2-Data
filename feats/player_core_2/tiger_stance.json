    "feat": {
        "name": "Tiger Stance",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You enter the stance of a tiger and can make tiger claw attacks. These deal 1d8 slashing damage; are in the brawling group; and have the agile, finesse, nonlethal, and unarmed traits. On a critical success with your tiger claws, if you deal damage, the target takes 1d4 persistent bleed damage.  \n  \n As long as your Speed is at least 20 feet while in Tiger Stance, you can Step 10 feet.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Monk",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 112,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
                            "alt": "Player Core pg. 282",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 282,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e49c1bdcc98f1599543bede27eff8919",
                "text": "Abilities with this trait are from the monk class. A weapon with this trait is primarily used by monks.",
                "links": [
                    {
                        "type": "link",
                        "name": "monk",
                        "alt": "monk",
                        "game-obj": "Classes",
                        "aonid": 8
                    }
                ]
            },
            {
                "name": "Stance",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 152,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 139",
                            "alt": "Player Core pg. 139",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 139,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9035508c239ef7305f5fce73844742d8",
                "text": "A stance is a general combat strategy that you enter by using an action with the stance trait, and you remain in for some time. A stance lasts until you get knocked out, until its requirements (if any) are violated, until the encounter ends, or until you use a stance action again, whichever comes first. After you take an action with the stance trait, you can\u2019t take another one for 1 round. You can enter or be in a stance only in encounter mode. You can Dismiss a stance."
            }
        ],
