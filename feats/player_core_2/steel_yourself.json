    "feat": {
        "name": "Steel Yourself!",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You encourage an ally to toughen up, giving them a fighting chance. Choose one ally in your marshal\u2019s aura. The ally gains temporary Hit Points equal to your Charisma modifier and a +2 circumstance bonus to Fortitude saves. Both benefits last until the start of your next turn.",
        "level": 4,
