        "prerequisite": "trained in *Diplomacy*",
        "abilities": [
            {
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "called",
                "name": "Influence Rumor",
                "link": {
                    "type": "link",
                    "name": "Influence Rumor",
                    "alt": "Influence Rumor",
                    "game-obj": "Actions",
                    "aonid": 2980
                },
                "text": "(downtime) You spend at least 1 day of downtime attempting to manipulate the course, tone, or content of a rumor to your benefit. You need to succeed at a Diplomacy check to shift the rumor as you intend. The difficulty is determined by the GM based on the size of the community, the relative perceptiveness of the inhabitants, and the agency of other rumormongers, but it typically is no lower than DC 15 for a small village, DC 20 for a town, DC 30 for a city, or DC 40 for a metropolis.",
                "links": [
                    {
                        "type": "link",
                        "name": "downtime",
                        "alt": "downtime",
                        "game-obj": "Traits",
                        "aonid": 580
                    }
                ]
            }
        ],
