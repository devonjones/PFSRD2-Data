    "game-obj": "Feats",
    "feat": {
        "name": "Celebrity Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "The more people you have looking at you, the more content you are, and you take every opportunity to show up others when their performances are less than perfect. You gain the Upstage reaction. In addition, when you Earn Income, if the level of the task is higher than your level, you gain a +1 circumstance bonus to your check to Earn Income.",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 12,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 452,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "52ef9cda2d54e07ee757696e4f8df79e",
                "text": "This feat belongs to an archetype."
            },
            {
                "name": "Dedication",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 41,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 215",
                            "alt": "Player Core pg. 215",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 215,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "d161ff4222f1e361de4583ab5e7afdee",
                "text": "Each archetype\u2019s dedication feat represents your character\u2019s dedicated effort learning a new set of abilities, making it impossible to split your focus and pursue another archetype at the same time. Once you take a dedication feat, you can\u2019t select a different dedication feat until you complete your dedication by taking two other feats from your current archetype. You can\u2019t retrain a dedication feat as long as you have any other feats from that archetype."
            }
        ],
        "archetype": [
            {
