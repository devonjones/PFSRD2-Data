    "feat": {
        "name": "Furious Sprint",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You rush forward. Stride up to five times, or up to eight times if you used 3 actions. All this movement must be in a straight line (though the GM might allow reasonable variance). You can replace any of these Strides with a Balance action if you need to, which you attempt using an Athletics check instead of an Acrobatics check, using the same DC.",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
