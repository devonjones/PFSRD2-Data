    "feat": {
        "name": "Weapon Improviser Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You don't take the normal \u20132 penalty to attack rolls with improvised weapons. Improvised weapons you use have a minimum weapon damage die of 1d6, or 1d4 if the improvised weapon is agile.",
