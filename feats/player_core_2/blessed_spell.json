    "feat": {
        "name": "Blessed Spell",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "When you focus your magic on an ally, you can remove harmful conditions. If your next action is to Cast a Spell from a spell slot, and that spell targets only a single ally, you can also attempt to remove a harmful condition from that ally. The condition must be one that could be removed by your Mercy feat, including those granted by later feats such as Greater Mercy. Attempt a counteract check based on the spell\u2019s DC and rank. This effect is in addition to the normal effects of your spell.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
