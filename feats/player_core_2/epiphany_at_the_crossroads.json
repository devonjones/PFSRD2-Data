    "feat": {
        "name": "Epiphany at the Crossroads",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "The crossroads between life and death is a place that can reveal many secrets. You gain the effects of an *augury* spell in a strange, near-death vision. Empowered by the realization, you then lose the dying condition (becoming wounded 1 or increasing your wounded value by 1, as normal), regain a number of Hit Points equal to twice your level, and can Stand.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Free Action"
        },
