    "feat": {
        "name": "Martial Artist Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You have trained to use your fists as deadly weapons and can deliver devastatingly powerful blows with them. The damage die for your fist unarmed attacks becomes 1d6 instead of 1d4. You don\u2019t take the \u20132 circumstance penalty for making a lethal attack with your nonlethal unarmed attacks.",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
