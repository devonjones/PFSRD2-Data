    "feat": {
        "name": "Resuscitate",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You resuscitate the dead. Attempt a DC 40 Medicine check to revive a dead creature who has been dead for no more than 3 rounds and whose body is mostly intact. If you succeed, the target returns to life with the effects of *raise dead*, except it still has the wounded condition it had before dying, increased by 1 (or wounded 1 if it wasn\u2019t wounded before dying). Whether you succeed or fail, the target is temporarily immune to Resuscitate for 1 day.",
        "level": 16,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Three Actions"
        },
