    "feat": {
        "name": "Linguist Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You have studied languages and their development. You become trained in Society; if you were already trained in Society, you instead become an expert in Society. You gain the Multilingual skill feat twice.",
