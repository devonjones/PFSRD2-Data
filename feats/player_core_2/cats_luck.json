    "feat": {
        "name": "Cat's Luck",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You instinctively twist away from danger. Reroll the triggering saving throw and use the better result.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
