    "feat": {
        "name": "Iruxi Armaments",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your weapons are those you were born with. Choose one of the following options: \n* **Claws** Your claw attack deals 1d6 slashing damage instead of 1d4 and gains the versatile P trait.\n* **Fangs** You gain a fangs unarmed attack that deals 1d8 piercing damage and is in the brawling group.\n* **Tail** You gain a tail unarmed attack that deals 1d6 bludgeoning damage, is in the brawling group, and has the sweep trait.\nAt 5th level, whenever you get a critical hit with one of the unarmed attacks you have gained or improved with this feat, you get its critical specialization effect.",
        "level": 1,
        "traits": [
            {
                "name": "Lizardfolk",
                "type": "trait",
                "alternate_link": {
