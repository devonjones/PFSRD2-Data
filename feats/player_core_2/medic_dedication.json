    "feat": {
        "name": "Medic Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You become an expert in Medicine. When you succeed with Battle Medicine or Treat Wounds, the target gains a circumstance bonus to the number of Hit Points they regain equal to 5 HP at DC 20, 10 HP at DC 30, or 15 HP at DC 40.   \n Once per day, you can use Battle Medicine on a creature that\u2019s temporarily immune due to having already been treated with Battle Medicine. If you\u2019re a master in Medicine, you can do so once per hour.",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
