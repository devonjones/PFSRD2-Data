    "feat": {
        "name": "Beastmaster's Call",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You quickly call in a primal projection of a non-active companion to provide the companion\u2019s support benefit. The projection arrives in an unoccupied square of your choice within 30 feet of you, grants you its support benefit, and then disappears at the start of your next turn. The projection has the same AC and saving throw modifiers as the real companion, and if it would take any damage before your next turn, it disappears, and the support benefit ends immediately.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
