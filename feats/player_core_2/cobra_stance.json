    "feat": {
        "name": "Cobra Stance",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You enter a tightly coiled stance, with your hands poised as venomous fangs. While in this stance, the only Strikes you can make are cobra fang unarmed attacks. These deal 1d4 piercing damage; are in the brawling group; and have the agile, deadly d10, finesse, unarmed, and venomous traits.  \n  \n While in Cobra Stance, you gain a +1 circumstance bonus to Fortitude saves and your Fortitude DC, and you gain poison resistance equal to half your level.",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
