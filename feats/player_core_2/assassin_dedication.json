    "feat": {
        "name": "Assassin Dedication",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You've trained to assassinate your foes, and you do so with tenacity and precision. You gain the Mark for Death activity.   \n  \n  **Mark for Death** (concentrate)",
        "level": 2,
        "traits": [
            {
                "name": "Archetype",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
