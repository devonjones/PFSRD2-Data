    "feat": {
        "name": "Trampling Charge",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You urge your mount to charge into the fray, trampling all enemies who stand in your path. You command your mount to Stride up to double its Speed (or to Burrow, Climb, Fly, or Swim, if it has the corresponding movement type), moving through the spaces of any foes in your path up to one size smaller than your mount. Your mount deals the damage of one of its melee Strikes to each creature whose space you move through, with a basic Reflex save against your mount\u2019s Athletics DC. On a critical failure, the creature also becomes off-guard until the end of your next turn. Roll the damage only once. You can damage a given creature only once during this movement.",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Three Actions"
        },
