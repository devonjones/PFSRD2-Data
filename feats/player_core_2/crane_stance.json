    "feat": {
        "name": "Crane Stance",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Your arms flutter like a crane's wings. You gain a +1 circumstance bonus to AC, but the only Strikes you can make are crane wing attacks. These deal 1d6 bludgeoning damage; are in the brawling group; and have the agile, finesse, nonlethal, and unarmed traits.  \n  \n While in Crane Stance, reduce the DC for High Jump and Long Jump by 5, and when you Leap, you can move an additional 5 feet horizontally or 2 feet vertically.",
        "level": 1,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Monk",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 112,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
                            "alt": "Player Core pg. 282",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 282,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e49c1bdcc98f1599543bede27eff8919",
                "text": "Abilities with this trait are from the monk class. A weapon with this trait is primarily used by monks.",
                "links": [
                    {
                        "type": "link",
                        "name": "monk",
                        "alt": "monk",
                        "game-obj": "Classes",
                        "aonid": 8
                    }
                ]
            },
            {
                "name": "Stance",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 152,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 139",
                            "alt": "Player Core pg. 139",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 139,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9035508c239ef7305f5fce73844742d8",
                "text": "A stance is a general combat strategy that you enter by using an action with the stance trait, and you remain in for some time. A stance lasts until you get knocked out, until its requirements (if any) are violated, until the encounter ends, or until you use a stance action again, whichever comes first. After you take an action with the stance trait, you can\u2019t take another one for 1 round. You can enter or be in a stance only in encounter mode. You can Dismiss a stance."
            }
        ],
