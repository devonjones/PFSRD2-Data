    "feat": {
        "name": "Invigorating Elixir",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can mix an aromatic salve into an elixir with the healing trait to soothe physical maladies. In addition to its normal effects, the elixir can be imbibed by a creature prevented from doing so (such as a sickened creature). In addition to its other effects, the elixir attempts to counteract an effect imposing one of the following conditions of the imbiber's choice: clumsy, enfeebled, sickened, or stupefied. Use half your level rounded up for the counteract rank and your class DC \u2013 10 for the counteract modifier. The imbiber is then temporarily immune to the effects of this additive for 10 minutes. The additive can't counteract curses, diseases, or conditions that are part of the creature's normal state.",
        "level": 4,
        "traits": [
            {
                "name": "Additive",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 4,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core 2",
                        "link": {
                            "type": "link",
                            "name": "Player Core 2 pg. 61",
                            "alt": "Player Core 2 pg. 61",
                            "game-obj": "Sources",
                            "aonid": 227
                        },
                        "page": 61,
                        "errata": {
                            "type": "link",
                            "name": "1.1",
                            "alt": "1.1",
                            "game-obj": "Sources",
                            "aonid": 227
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "4fd05e11c1af1412c574a7ea7620bdc1",
                "text": "Feats with the additive trait allow you to add special substances to alchemical consumables you create when you use Quick Alchemy to create a consumable (you can't use additives with quick vials). You can add only one additive to a single alchemical item, you can add an additive only once per round, and most additive abilities specify a subset of alchemical consumables you can add them to.",
                "links": [
                    {
                        "type": "link",
                        "name": "Quick Alchemy",
                        "alt": "Quick Alchemy",
                        "game-obj": "Actions",
                        "aonid": 2801
                    }
