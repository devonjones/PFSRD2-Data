    "feat": {
        "name": "Terrifying Howl",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You unleash a terrifying howl. Attempt Intimidation checks to Demoralize each enemy within 30 feet: you don't take a penalty if the creature doesn't understand your language. Regardless of the results of your checks, each target is then temporarily immune to Terrifying Howl for 1 minute.",
        "level": 10,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Auditory",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
