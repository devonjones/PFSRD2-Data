    "feat": {
        "name": "Keep Pace",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "Once you are upon your prey, they can\u2019t escape. Stride up to your Speed, following the foe and keeping it in reach throughout its movement until it stops moving or you\u2019ve moved your full Speed. You can use Keep Pace to Burrow, Climb, Fly, or Swim instead of Stride if you have the corresponding movement type.",
        "level": 6,
