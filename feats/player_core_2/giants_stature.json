                        "alt": "magical",
                        "game-obj": "Traits",
                        "aonid": 103
                    },
                    {
                        "type": "link",
                        "name": "manipulate",
                        "alt": "manipulate",
                        "game-obj": "Traits",
                        "aonid": 104
                    }
                ]
            },
