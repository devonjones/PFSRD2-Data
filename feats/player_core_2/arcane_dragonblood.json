    "feat": {
        "name": "Arcane Dragonblood",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You descend from a dragon that wields mastery of their magical abilities, such as a fortune dragon or mirage dragon. As such, you can instinctively grasp the intricacies of magic. You gain the trained proficiency rank in Arcana. If you would automatically become trained in Arcana (from your background or class, for example), you instead become trained in a skill of your choice. You gain the Arcane Sense skill feat. If you choose a draconic exemplar, you must choose an arcane dragon.",
        "level": 1,
        "traits": [
            {
                "name": "Dragonblood",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core 2",
                        "link": {
                            "type": "link",
                            "name": "Player Core 2 pg. 317",
                            "alt": "Player Core 2 pg. 317",
                            "game-obj": "Sources",
                            "aonid": 227
                        },
                        "page": 317,
                        "errata": {
                            "type": "link",
                            "name": "1.1",
                            "alt": "1.1",
                            "game-obj": "Sources",
                            "aonid": 227
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "7dfb9504a0de31158e6d9920400a79af",
                "text": "A creature with this trait has the dragonblood versatile heritage. These creatures are born of draconic lineage and often have draconic appearances.",
