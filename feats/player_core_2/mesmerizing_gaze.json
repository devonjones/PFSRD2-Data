    "feat": {
        "name": "Mesmerizing Gaze",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "When you meet someone's gaze, they're unable to look away from you. Choose one target creature you can see and that can see you. That creature must succeed at a Will save or be fascinated with you until the end of your next turn; the DC is the higher of your class DC or spell DC. If the creature succeeds at its save or its fascination ends due to a hostile action, it becomes temporarily immune to your Mesmerizing Gaze for 1 day.",
        "level": 6,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
