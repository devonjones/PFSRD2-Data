    "feat": {
        "name": "Debilitating Bomb",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You can add a crystalline additive to an alchemical bomb to have it undermine your enemy. Choose dazzled, deafened, off-guard, or a \u20135-foot status penalty to Speeds. If the attack with the bomb hits, in addition to the bomb's normal effects, the target must succeed at a Fortitude saving throw or take that effect until the start of your next turn. Use your class DC for this saving throw, even if someone else throws the bomb.",
        "level": 6,
        "traits": [
            {
                "name": "Additive",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 4,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
