    "feat": {
        "name": "Debilitating Dichotomy",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You reveal a glimpse of the impossible conflicts between the divine anathema behind your curse, forcing you to reckon with another's conflicts as well. You and one creature within 30 feet each take 9d6 mental damage with a basic Will save, and the target is stunned 1 if it critically fails its save. You get a degree of success one better than you rolled for your saving throw. At 10th level, and every 2 levels thereafter, the damage increases by 3d6.",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Two Actions"
        },
        "traits": [
            {
