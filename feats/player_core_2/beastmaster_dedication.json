                    "name": "Player Core pg. 456",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 456,
                  "type": "source"
                }
              ],
              "text": "An activity with this trait takes more than a turn to use, and can usually be used only during exploration mode.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
      "links": [
        {
          "alt": "animal companions",
          "aonid": 2113,
          "game-obj": "Rules",
