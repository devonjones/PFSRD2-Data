    "feat": {
        "name": "Play to the Crowd",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You show off for the crowd. Attempt a Performance check; the DC is determined by the GM but is typically the standard DC for your level or the DC to Make an Impression on the spectators, whichever is higher. On a success, choose one of the following benefits to gain; on a critical success, choose two benefits: \n* A number of temporary Hit Points equal to your character level. These last for 1 minute.\n* A +1 circumstance bonus to AC until the end of your next turn.\n* A +1 circumstance bonus to your next attack roll before the end of your next turn.",
        "level": 4,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "Reaction"
        },
