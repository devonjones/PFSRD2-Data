    "feat": {
        "name": "Animalistic Brutality",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You deepen the connection into your animal instincts. Your unarmed attack from bestial rage gains one of the following traits until you stop raging: backswing, forceful, parry, razing, or sweep. You can't use this ability again until the next time you Rage. You can choose a different trait each time you use Animalistic Brutality",
        "level": 8,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Barbarian",
