                            "aonid": 227
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "cfbc6f759ad293f46e5f41637c570f78",
                "text": "You must be raging to use abilities with the rage trait, and they end automatically when you stop raging.",
