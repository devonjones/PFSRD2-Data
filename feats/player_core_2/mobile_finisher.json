    "feat": {
        "name": "Mobile Finisher",
        "type": "stat_block_section",
        "subtype": "feat",
        "text": "You attack in motion. Stride and then Strike. You can use Mobile Finisher while Burrowing, Climbing, Flying, or Swimming instead of Striding if you have the corresponding movement type.",
        "level": 12,
        "action_type": {
            "type": "stat_block_section",
            "subtype": "action_type",
            "name": "One Action"
        },
        "traits": [
            {
                "name": "Finisher",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
