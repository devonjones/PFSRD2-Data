    "spell": {
        "name": "Confusing Cry",
        "type": "stat_block_section",
        "text": "You give an unsettling, warbling cry that causes nearby creatures to lash out without control. Each creature in the area that can hear must attempt a Will save.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 5,
        "traits": [
            {
                "name": "Auditory",
                "type": "trait",
