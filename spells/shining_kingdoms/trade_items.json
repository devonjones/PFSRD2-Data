    "spell": {
        "name": "Trade Items",
        "type": "stat_block_section",
        "text": "You magically swap an item you\u2019re holding for another that someone else has. The second item appears in the hand you were holding the first item (or it falls to the ground in your square if you\u2019re unable to hold it), and the first item appears in the same place on the other creature\u2019s possession where the second item was (held in a hand or attached to a belt, for instance). If the second item is in the possession of a creature unwilling to relinquish it, they can prevent the transposition with a successful Reflex save.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 3,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
