    "spell_type": "spell",
    "subtype": "spell",
    "text": "You teleport to an unoccupied space within range, leaving behind a faint echo of your form that explodes with magical force. Each creature within a 10-foot emanation from your previous location takes 4d8 force damage.",
    "traits": [
      {
        "alternate_link": {
