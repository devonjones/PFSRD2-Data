    "spell": {
        "name": "Spiritual Transport",
        "type": "stat_block_section",
        "text": "You call upon the spiritual energies surrounding you to teleport you to an unoccupied space within range that you can see. Any items you\u2019re wearing and holding come with you. Your familiar or animal companion, if you have one that\u2019s sharing your space or adjacent to your space, is transported with you, but any other creature sharing your space remains in that space.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 5,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
