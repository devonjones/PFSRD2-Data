    "name": "Garden of Healing",
    "rank": 1,
    "spell_type": "focus",
    "subtype": "spell",
    "text": "Spirits of comfort and respite swirl around you, trailing visions of growing grass and blooming blossoms. When you cast this spell and the first time you Sustain it on each subsequent round, you generate a pulse of renewing energy that heals each creature within the emanation for 1d4 Hit Points. The calm of this effect lingers; once this spell ends, any creature that has been affected by its healing gains a +1 circumstance bonus to saves against emotion effects for 10 minutes but does not receive any healing from additional castings of the spell while the bonus persists.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "edition": "remastered",
        "game-id": "a8b98a07847bafcb0b61dfeed4f11953",
        "game-obj": "Traits",
        "name": "Animist",
        "sources": [
          {
            "link": {
              "alt": "War of Immortals pg. 216",
              "aonid": 232,
              "game-obj": "Sources",
              "name": "War of Immortals pg. 216",
              "type": "link"
            },
            "name": "War of Immortals",
            "page": 216,
            "type": "source"
          }
        ],
        "text": "This indicates abilities from the animist class.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 206,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "5315505cfd3f3ba2685e9747898193b2",
        "game-obj": "Traits",
        "name": "Aura",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 453",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 453",
              "type": "link"
            },
            "name": "Player Core",
            "page": 453,
            "type": "source"
          }
        ],
        "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 60,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "fb5f8b3d849b073e1514a6a025810470",
        "game-obj": "Traits",
        "name": "Emotion",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
        "type": "trait"
      },
      {
        "edition": "remastered",
        "game-id": "fa2fb2457d86745d5bb218b3ca99b8ca",
        "game-obj": "Traits",
        "name": "Focus",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 456",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 456",
              "type": "link"
            },
            "name": "Player Core",
            "page": 456,
            "type": "source"
          }
        ],
        "text": "A spell you can cast by spending a Focus Point, and that is automatically heightened to half your level rounded up.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 89,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "46d51374c2ada72347818dbac1edd7a3",
        "game-obj": "Traits",
        "name": "Healing",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 457",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 457",
              "type": "link"
            },
            "name": "Player Core",
            "page": 457,
            "type": "source"
          }
        ],
        "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 106,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
