                            "name": "Player Core pg. 460",
                            "alt": "Player Core pg. 460",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 460,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "680bd3734c18812987be2fa9e5ec524a",
                "text": "Effects with this trait determine what is likely to happen in the near future."
            }
        ],
