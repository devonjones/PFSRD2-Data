                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 401",
                            "alt": "Player Core pg. 401",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 401,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "5d523efde5119e0095a1b86f45c637a8",
                "text": "A misfortune effect detrimentally alters how you roll your dice. You can never have more than one misfortune effect alter a single roll. If multiple misfortune effects would apply, the GM decides which is worse and applies it. If a fortune effect and a misfortune effect would apply to the same roll, the two cancel each other out, and you roll normally.",
                "links": [
                    {
                        "type": "link",
                        "name": "fortune",
                        "alt": "fortune",
                        "game-obj": "Traits",
                        "aonid": 76
                    }
                ]
            },
            {
                "name": "Void",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 118,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 463",
                            "alt": "Player Core pg. 463",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 463,
                        "errata": {
                            "type": "link",
