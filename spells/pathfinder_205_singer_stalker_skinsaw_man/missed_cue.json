    "spell": {
        "name": "Missed Cue",
        "type": "stat_block_section",
        "text": "You make the spell\u2019s target believe they had something incredibly important to say but forgot to say it, and now they\u2019ve missed their opportunity. Sensations of overwhelming panic akin to stage fright flood the target\u2019s mind, causing them to suffer excruciating mental anguish and take 12d6 mental damage. The target might even become filled with the conviction that they\u2019ve doomed themselves by missing their cue. The target must attempt a Will save.",
        "subtype": "spell",
