          "aonid": 60,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "fb5f8b3d849b073e1514a6a025810470",
        "game-obj": "Traits",
        "name": "Emotion",
        "sources": [
          {
