    "spell": {
        "name": "Vibrant Vibrato",
        "type": "stat_block_section",
        "text": "Your voice trills in perfect vibrato. When casting the spell, you can make the area any radius you choose, up to 40 feet. The reverberations of your voice continue to shimmer and hang in the air as long as you Sustain the spell but can\u2019t be heard at all outside of the area. A creature must attempt a Will save if it\u2019s within the area when you Cast the Spell or as soon as it enters the area while the spell is in effect. Once a creature has attempted the save, it uses the same result for that casting of *vibrant vibrato*.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 7,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
