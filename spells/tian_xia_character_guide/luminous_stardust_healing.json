    "spell": {
        "name": "Luminous Stardust Healing",
        "type": "stat_block_section",
        "text": "You scatter twinkling sparks from your sentinel weapon, replenishing your allies\u2019 fighting spirit and driving out evil. The target regains 16 Hit Points. If they were affected by a possession effect, you attempt to counteract the effect, casting out the possessing entity on a success and preventing them from possessing the target again for 1 week. If you fail, the entity is immune to being cast out by this spell for 1 week, though you can still heal the target as normal.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 2,
        "traits": [
            {
