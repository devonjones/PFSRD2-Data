    "spell": {
        "name": "One with Stone",
        "type": "stat_block_section",
        "text": "You can either transform into a stone or merge with stone. This spell has the same effects as *one with plants*, but lets you merge with or turn into stone. A stone you turn into has AC 23. You can Dismiss this spell.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 3,
