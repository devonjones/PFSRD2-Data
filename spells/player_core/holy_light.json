    "spell": {
        "name": "Holy Light",
        "type": "stat_block_section",
        "text": "You shine a blazing ray of light tinged with holy energy. Make a ranged spell attack. The ray deals 5d6 fire damage. If the target has the unholy trait, you deal an extra 5d6 spirit damage.",
