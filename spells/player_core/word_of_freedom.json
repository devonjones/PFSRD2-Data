    "spell": {
        "name": "Word of Freedom",
        "type": "stat_block_section",
        "text": "You utter a liberating word of power that frees a creature. You suppress one of the following conditions of your choice: confused, frightened, grabbed, paralyzed, or restrained. The target isn't affected by the chosen condition, and if you suppress the grabbed or restrained condition, the target automatically breaks free from the grab or restraint when you Cast the Spell.  \n  \n If you don't remove the effect that provided the condition, the condition returns after the spell ends. For example, if a spell was making the target confused for 1 minute, *word of freedom* would let the target act normally for a round, but the confused condition would return afterward.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 4,
