                "game-obj": "Traits",
                "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
                "schema_version": 1.1
            }
        ],
        "range": "touch",
        "targets": "1 object or willing creature",
        "duration": "unlimited",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 4,
                "text": "You can add a simple sensory component to emphasize the message, such as an odor, visual effect, or physical sensation. This addition is obviously illusory and part of the message, lasting only while the message is being read."
            },
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 6,
                "text": "As 4th rank, but you can choose how many times the spell repeats the message before it ends; there is no limit to the number of repetitions."
            }
        ],
