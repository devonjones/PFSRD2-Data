        "range": "touch",
        "targets": "1 corpse",
        "duration": "until your next daily preparations",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 5,
                "text": "The spell's duration is unlimited, but the spell takes one more action to cast and requires a cost (embalming fluid worth 6 gp)."
