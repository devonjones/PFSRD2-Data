    "spell": {
        "name": "Patron's Puppet",
        "type": "stat_block_section",
        "text": "At your unspoken plea, your patron temporarily assumes control over your familiar. You Command your familiar, allowing it to take its normal actions this turn. Your Command does not have the auditory or concentrate traits; your patron simply moves its agent directly.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 1,
