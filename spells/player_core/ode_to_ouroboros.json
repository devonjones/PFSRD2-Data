    "spell": {
        "name": "Ode to Ouroboros",
        "type": "stat_block_section",
        "text": "Your ode staves off death. The target's dying condition remains 1 below the value at which it dies. This doesn't help prevent death from effects that kill the target without increasing its dying condition, such as *disintegrate* and death effects.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 5,
