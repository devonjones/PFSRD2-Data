    "spell": {
        "name": "Magic Passage",
        "type": "stat_block_section",
        "text": "You create a visible tunnel through the wall in the chosen area, replacing the area with empty space. If the wall is thicker than 10 feet, the tunnel ends 10 feet in. Even a small layer of metal in the wall prevents this spell from functioning. This spell doesn't reduce the integrity of the structure. When the spell ends, anyone inside the tunnel is shunted to the nearest exit.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 5,
