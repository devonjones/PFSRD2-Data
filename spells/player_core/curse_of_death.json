    "spell": {
        "name": "Curse of Death",
        "type": "stat_block_section",
        "text": "Your patron wraps a hand around your target's heart. The target must attempt a Fortitude saving throw. Regardless of the result, the target is temporarily immune to all *curses of death* for 1 day.",
        "subtype": "spell",
        "spell_type": "focus",
