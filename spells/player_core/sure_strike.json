    "spell": {
        "name": "Sure Strike",
        "type": "stat_block_section",
        "text": "The next time you make an attack roll before the end of your turn, roll it twice and use the better result. The attack ignores circumstance penalties to the attack roll and any flat check required due to the target being concealed or hidden. You are then temporarily immune to sure strike for 10 minutes.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 1,
        "traits": [
