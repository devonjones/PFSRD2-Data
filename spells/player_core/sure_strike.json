            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An action with this trait requires a degree of mental concentration and discipline.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 76,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "7adeee5fc9bf211a4db10de37045506c",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "misfortune",
            "aonid": 110,
            "game-obj": "Traits",
            "name": "misfortune",
            "type": "link"
          }
        ],
        "name": "Fortune",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 401",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 401",
              "type": "link"
            },
            "name": "Player Core",
            "page": 401,
            "type": "source"
          }
        ],
        "text": "A fortune effect beneficially alters how you roll your dice. You can never have more than one fortune effect alter a single roll. If multiple fortune effects would apply, you have to pick which to use. If a fortune effect and a misfortune effect would apply to the same roll, the two cancel each other out, and you roll normally.",
        "type": "trait"
      }
    ],
    "type": "stat_block_section"
  },
  "type": "spell"
