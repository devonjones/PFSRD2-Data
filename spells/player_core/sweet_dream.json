          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
        "game-obj": "Traits",
        "name": "Linguistic",
        "sources": [
          {
