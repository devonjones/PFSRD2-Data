    "spell": {
        "name": "Wails of the Damned",
        "type": "stat_block_section",
        "text": "You howl a lament of damned souls. Each living enemy in the area takes 8d10 void damage depending on its Fortitude save.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 9,
