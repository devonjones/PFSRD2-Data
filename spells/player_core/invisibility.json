            "link": {
              "alt": "Player Core pg. 460",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 460",
              "type": "link"
            },
            "name": "Player Core",
            "page": 460,
            "type": "source"
          }
        ],
        "text": "A spell with the subtle trait can be cast without incantations and doesn't have obvious manifestations.",
