    "spell_type": "spell",
    "subtype": "spell",
    "targets": "1 creature",
    "text": "Illusions bend light around the target, rendering it invisible. This makes it undetected to all creatures, though the creatures can attempt to find the target, making it hidden to them instead. If the target uses a hostile action, the spell ends after that hostile action is completed.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 92,
