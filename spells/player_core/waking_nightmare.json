    "targets": "1 creature",
    "text": "You fill the creature's mind with a terrifying vision. The target must attempt a Will save. A creature frightened by this spell takes 1 additional mental damage each time it's hit by a Strike.",
    "traits": [
      {
        "alternate_link": {
