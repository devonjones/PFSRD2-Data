    "spell": {
        "name": "Earthbind",
        "type": "stat_block_section",
        "text": "Using the weight of earth, you hamper a target's flight, with effects based on its Fortitude save. If the creature reaches the ground safely, it doesn't take falling damage.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 3,
