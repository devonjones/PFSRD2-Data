    "spell_type": "cantrip",
    "subtype": "spell",
    "targets": "1 creature",
    "text": "Your patron's resentment manifests in a baleful, envious gaze. The target becomes sickened 1 if it fails a Will save (or sickened 2 on a critical failure). This condition value can't be reduced below 1 while the spell is active and you can see the target.",
    "traits": [
      {
        "alternate_link": {
