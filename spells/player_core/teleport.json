                "game-obj": "Traits",
                "game-id": "10dff3f305dbeeffcd4e5ca933a7e270",
                "text": "Teleportation effects instantaneously move something from one point in space to another. Teleportation does not usually trigger reactions based on movement.",
                "schema_version": 1.1
            }
        ],
        "range": "100 miles",
        "targets": "you and up to 4 targets touched, either willing creatures or objects roughly the size of a creature",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 7,
                "text": "You and the other targets can travel to any location within 1,000 miles."
            },
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 8,
                "text": "You and the other targets can travel to any location on the same planet. If you travel more than 1,000 miles, you arrive only 10 miles off target."
            },
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 9,
                "text": "You and the other targets can travel to any location on another planet within the same solar system. If you have accurate knowledge of the location's position and appearance, you arrive on the new planet 100 miles off target."
            },
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 10,
                "text": "As the 9th-rank version, but you and the other targets can travel to any planet within the same galaxy."
            }
        ],
