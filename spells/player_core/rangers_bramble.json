    "rank": 3,
    "spell_type": "focus",
    "subtype": "spell",
    "text": "You cause plants in the area to entangle your foes, with the effects of *entangling flora*. A creature that critically fails the save takes 2d4 persistent bleed damage in addition to being immobilized. Escaping your bramble doesn't end the bleed damage.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
