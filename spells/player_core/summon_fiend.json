    "spell": {
        "name": "Summon Fiend",
        "type": "stat_block_section",
        "text": "You summon a creature that has the fiend trait and whose level is 5 or lower to fight for you. The GM might determine your deity restricts the specific types of fiends you can summon in certain cases. For instance, archdevils typically allow their followers to summon devils, but not other fiends.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 5,
