    "spell": {
        "name": "Detect Magic",
        "type": "stat_block_section",
        "text": "You send out a pulse that registers the presence of magic. You receive no information beyond the presence or absence of magic. You can choose to ignore magic you're fully aware of, such as the magic items and ongoing spells of you and your allies.  \n  \n You detect illusion magic only if that magic's effect has a lower rank than the rank of your *detect magic* spell. However, items that have an illusion aura but aren't deceptive in appearance (such as an *invisibility potion*) typically are detected normally.",
        "subtype": "spell",
        "spell_type": "cantrip",
        "rank": 1,
        "traits": [
            {
                "name": "Cantrip",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 22,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
