    "spell": {
        "name": "Heal Animal",
        "type": "stat_block_section",
        "text": "You heal an animal's wounds, restoring 1d8 Hit Points to the target. The number of actions spent Casting this Spell determines its effect.  \n  \n The spell has a range of touch.  \n (concentrate) The spell has a range of 30 feet and restores an additional 8 Hit Points to the target.",
