    "spell": {
        "name": "Mountain Resilience",
        "type": "stat_block_section",
        "text": "The target's skin hardens like the stone of a mountain face. It gains resistance 5 to physical damage, except adamantine. Each time the target is hit by a bludgeoning, piercing, or slashing attack, *mountain resilience's* duration decreases by 1 minute.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 4,
