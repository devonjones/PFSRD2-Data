    "spell_type": "spell",
    "subtype": "spell",
    "targets": "1 willing creature",
    "text": "You grace the target's mind, boosting its mental defenses and healing its wounds. The target regains 1d10+4 Hit Points when you Cast the Spell and gains a +2 status bonus to saves against mental effects for the duration.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 32,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "e32d877417a40fe977d27634dc14f99f",
        "game-obj": "Traits",
        "name": "Concentrate",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 454",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 454",
              "type": "link"
            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An action with this trait requires a degree of mental concentration and discipline.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 60,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "fb5f8b3d849b073e1514a6a025810470",
        "game-obj": "Traits",
        "name": "Emotion",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 89,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "46d51374c2ada72347818dbac1edd7a3",
        "game-obj": "Traits",
        "name": "Healing",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 457",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 457",
              "type": "link"
            },
            "name": "Player Core",
            "page": 457,
            "type": "source"
          }
        ],
        "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 104,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
        "game-obj": "Traits",
        "name": "Manipulate",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 106,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "6a1f80610baa3617c1597f49c6406313",
        "game-obj": "Traits",
        "name": "Mental",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
        "type": "trait"
      }
    ],
    "type": "stat_block_section"
  },
