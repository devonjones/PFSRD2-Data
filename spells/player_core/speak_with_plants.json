    "spell": {
        "name": "Speak with Plants",
        "type": "stat_block_section",
        "text": "You can ask questions of and receive answers from plants and fungi, but the spell doesn't make them more friendly or intelligent than normal. Most normal plants and fungi have a distinctive view of the world around them, so they don't recognize details about creatures or know anything about the world beyond their immediate vicinity. Cunning plant or fungus monsters are likely to be terse and evasive, while less intelligent ones often make inane comments.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 3,
        "traits": [
            {
                "name": "Concentrate",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
