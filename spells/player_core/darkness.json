    "spell": {
        "name": "Darkness",
        "type": "stat_block_section",
        "text": "You create a shroud of darkness that prevents light from penetrating or emanating within the area. Light does not enter the area and any non-magical light sources, such as a torch or lantern, do not emanate any light while inside the area, even if their light radius would extend beyond the darkness. This also suppresses magical light of your *darkness* spell's rank or lower. Light can't pass through, so creatures in the area can't see outside. From outside, it appears as a globe of pure darkness.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 2,
        "traits": [
            {
                "name": "Concentrate",
                "type": "trait",
                "alternate_link": {
