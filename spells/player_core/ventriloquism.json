                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
                "schema_version": 1.1
            }
        ],
        "duration": "10 minutes",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 2,
                "text": "The spell's duration increases to 1 hour, and you can also change the tone, quality, and other aspects of your voice. Before a creature can attempt to disbelieve your illusion, it must actively attempt a Perception check or otherwise use actions to interact with the sound."
            }
        ],
