        "game-id": "fb5f8b3d849b073e1514a6a025810470",
        "game-obj": "Traits",
        "name": "Emotion",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
