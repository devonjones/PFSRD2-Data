    "defense": {
      "critical_failure": "As failure, except the target believes that everyone it sees is a mortal enemy. It uses its reactions and free actions against everyone, regardless of whether they were previously its allies, as determined by the GM. It otherwise acts as rationally as it normally does and likely prefers to attack creatures that are actively attacking or hindering it over those leaving it alone.",
      "critical_success": "The target is unaffected.",
      "failure": "As success, but the effect lasts 1 minute.",
      "links": [
        {
          "alt": "unfriendly",
          "aonid": 40,
          "game-obj": "Conditions",
          "name": "unfriendly",
          "type": "link"
        },
        {
          "alt": "hostile",
          "aonid": 23,
          "game-obj": "Conditions",
          "name": "hostile",
          "type": "link"
        }
      ],
      "save_type": "Will",
      "subtype": "spell_defense",
      "success": "The target believes everyone it sees is a potential threat. It becomes unfriendly to all creatures to which it wasn't already hostile, even those that were previously allies. It treats no one as an ally. The spell ends after 1 round.",
      "type": "stat_block_section"
    },
    "duration": "1 minute",
