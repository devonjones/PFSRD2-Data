        "range": "touch",
        "targets": "1 willing creature",
        "duration": "1 minute",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 4,
                "text": "The spell creates an aura in a 10-foot emanation around the touched creature, silencing all sound in or passing through it. While within the aura, creatures are subject to the same effects as the target. Depending upon the position of the effect, a creature might notice the lack of sound reaching it (blocking off the noise coming from a party, for example)."
            }
