    "spell_type": "cantrip",
    "subtype": "spell",
    "targets": "1 creature",
    "text": "You mouth words quietly, but instead of coming out of your mouth, they're transferred directly to the ears of the target. While others can't hear your words any better than if you normally mouthed them, the target can hear your words as if they were standing next to you. The target can give a brief response as a reaction, or as a free action on their next turn if they wish, but they must be able to see you and be within range to do so. If they respond, their response is delivered directly to your ear, just like the original message.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 16,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "84c09922ddd30f2144494f2cb6f19412",
        "game-obj": "Traits",
        "name": "Auditory",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 453",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 453",
              "type": "link"
            },
            "name": "Player Core",
            "page": 453,
            "type": "source"
          }
        ],
        "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 22,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "4aca14cf8cab083df4fac852c200b456",
        "game-obj": "Traits",
        "name": "Cantrip",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 453",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 453",
              "type": "link"
            },
            "name": "Player Core",
            "page": 453,
            "type": "source"
          }
        ],
        "text": "A spell you can cast at will that is automatically heightened to half your level rounded up.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 32,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
