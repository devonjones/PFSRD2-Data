    "spell": {
        "name": "Implosion",
        "type": "stat_block_section",
        "text": "You crush the target by causing it to collapse in on itself, dealing 75 damage. The first time each round you Sustain the spell, you must choose a new target to be subject to the same effect; the same creature can never be targeted more than once with a single casting of this spell. You also can't affect more than one creature per turn with *implosion*. You can't target a creature that's incorporeal, gaseous, or liquid, or otherwise lacking a solid form.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 9,
