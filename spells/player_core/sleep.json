        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 4,
                "text": "The creatures fall unconscious for 1 round on a failure or 1 minute on a critical failure. They fall prone and release what they're holding, and they can't attempt Perception checks to wake up. When the duration ends, the creature is sleeping normally instead of automatically waking up.",
                "links": [
                    {
                        "type": "link",
                        "name": "prone",
                        "alt": "prone",
                        "game-obj": "Conditions",
                        "aonid": 31
                    }
                ]
            }
        ],
        "critical_success": "The creature is unaffected.",
        "success": "The creature takes a \u20131 status penalty to Perception checks for 1 round.",
        "failure": "The creature falls unconscious. If it's still unconscious after 1 minute, it wakes up automatically.",
        "critical_failure": "The creature falls unconscious. If it's still unconscious after 1 hour, it wakes up automatically."
    },
    "game-id": "448b17395365a57cd2dcfc7fac0ec0bc",
    "spell_type": "spell",
    "rank": 1,
    "text": "Each creature in the area becomes drowsy, possibly nodding off. A creature that falls unconscious from this spell doesn't fall prone or release what it's holding. This spell doesn't prevent creatures from waking up due to a successful Perception check, limiting its utility in combat.",
