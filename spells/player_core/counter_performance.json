    "spell": {
        "name": "Counter Performance",
        "type": "stat_block_section",
        "text": "Your performance protects you and your allies. Roll a Performance check for a type you know\u2014it must be an auditory performance if the trigger was auditory or a visual one for a visual trigger, and this action gains the traits for the type of performance (page 243). You and allies in the area can use the better result between your Performance check and the saving throw.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 1,
        "traits": [
