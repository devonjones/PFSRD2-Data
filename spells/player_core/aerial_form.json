                        "game-obj": "Traits",
                        "aonid": 104
                    }
                ],
                "schema_version": 1.1
            }
        ],
        "duration": "1 minute",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 5,
                "text": "Your battle form is Large and your fly Speed gains a +10-foot status bonus. You instead gain 10 temporary HP, attack modifier +18, damage bonus +8, and Acrobatics +20."
            },
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 6,
                "text": "Your battle form is Huge, your fly Speed gains a +15-foot status bonus, and your attacks have 10-foot reach. You instead gain AC = 21 + your level, 15 temporary HP, attack modifier +21, damage bonus +4 and double damage dice (including persistent damage), and Acrobatics +23."
            }
        ],
