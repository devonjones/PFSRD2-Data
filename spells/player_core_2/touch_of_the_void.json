    "spell": {
        "name": "Touch of the Void",
        "type": "stat_block_section",
        "text": "You infuse the target with void energy, healing undead or damaging a living creature. \n* **Willing Undead Creature** The target regains 6 Hit Points. If the target is yourself, you also gain a +2 status bonus to damage rolls for 1 round.\n* **Living Creature** The target takes 1d6 void damage with a basic Fortitude save; on a failure, the target also takes a \u20132 status penalty to AC for 1 round.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 1,
