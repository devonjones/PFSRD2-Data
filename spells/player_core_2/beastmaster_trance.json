    "spell": {
        "name": "Beastmaster Trance",
        "type": "stat_block_section",
        "text": "You enter a trance that allows you to see through the senses of the target companion. You attempt Perception checks using your own Perception, but you share special senses the target has, such as low-light vision. This spell grants no special method of communication with the chosen animal.  \n  \n For the duration of the trance, your own senses are muted. This lack of awareness makes you off-guard. You can't take actions with the attack or move traits.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 3,
        "traits": [
