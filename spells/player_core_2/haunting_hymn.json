    "spell_type": "cantrip",
    "subtype": "spell",
    "text": "You echo a jarring hymn that only creatures in the area can hear. The hymn deals 1d8 sonic damage, with a basic Fortitude save. If a target critically fails the save, it's also deafened for 1 minute.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 16,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "84c09922ddd30f2144494f2cb6f19412",
        "game-obj": "Traits",
        "name": "Auditory",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 453",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 453",
              "type": "link"
            },
            "name": "Player Core",
            "page": 453,
            "type": "source"
          }
        ],
        "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 22,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "4aca14cf8cab083df4fac852c200b456",
        "game-obj": "Traits",
        "name": "Cantrip",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 453",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 453",
              "type": "link"
            },
            "name": "Player Core",
            "page": 453,
            "type": "source"
          }
        ],
        "text": "A spell you can cast at will that is automatically heightened to half your level rounded up.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 32,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "e32d877417a40fe977d27634dc14f99f",
        "game-obj": "Traits",
        "name": "Concentrate",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 454",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 454",
              "type": "link"
            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An action with this trait requires a degree of mental concentration and discipline.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 104,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
        "game-obj": "Traits",
        "name": "Manipulate",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 147,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "062d349c50c70477d316b8620025454e",
        "game-obj": "Traits",
        "name": "Sonic",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 461",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 461",
              "type": "link"
            },
            "name": "Player Core",
            "page": 461,
            "type": "source"
          }
        ],
        "text": "An effect with the sonic trait functions only if it makes sound, meaning it has no effect in an area of silence or in a vacuum. This is different from an auditory spell, which is effective only if the target can hear it. A sonic effect might deal sonic damage.",
        "type": "trait"
      }
    ],
    "type": "stat_block_section"
  },
  "type": "spell"
