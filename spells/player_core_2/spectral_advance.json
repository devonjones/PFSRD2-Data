                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 301",
                            "alt": "Player Core pg. 301",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 301,
                        "errata": {
                            "type": "link",
