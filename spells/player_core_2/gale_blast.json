    "spell": {
        "name": "Gale Blast",
        "type": "stat_block_section",
        "text": "Wind flows from your outstretched hands and whirls around you in a 5-foot emanation. Each creature in the area takes 1d6 bludgeoning damage, with a Fortitude save.",
        "subtype": "spell",
        "spell_type": "cantrip",
        "rank": 1,
        "traits": [
            {
                "name": "Air",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
