              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 457",
              "type": "link"
            },
            "name": "Player Core",
            "page": 457,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait involve false sensory stimuli.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 104,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "edition": "remastered",
        "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
        "game-obj": "Traits",
        "name": "Manipulate",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
