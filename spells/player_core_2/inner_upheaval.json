    "spell": {
        "name": "Inner Upheaval",
        "type": "stat_block_section",
        "text": "You focus your qi into devastating magical attacks. Make an unarmed Strike or Flurry of Blows (this doesn't change the limit on using only one flourish per turn). You gain a +1 status bonus to your attack rolls with the Strikes, and the Strikes deal 1d6 extra damage. This damage can be any of the following types of your choice, chosen each time you Strike: force, spirit, vitality, or void.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 1,
