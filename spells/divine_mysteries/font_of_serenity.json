            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An action with this trait requires a degree of mental concentration and discipline.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
