    "spell": {
        "name": "Adapt Self",
        "type": "stat_block_section",
        "text": "You make subtle changes to your body to adapt to the situation. Choose one of the following options that applies to you. \n* If you are in water, you gain a swim Speed equal to half your Speed.\n* If you are in water, you become able to breathe water.\n* If it\u2019s too dark for you to see, you gain darkvision.\n* If you are in an environment of severe heat or severe cold, you are protected from the effects of severe heat or severe cold, and the spell lasts 10 minutes.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 1,
