        ],
        "range": "120 feet",
        "area": "20-foot burst",
        "duration": "1 minute",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 4,
                "text": "Creatures seen through the area are concealed to creatures outside the area. Creatures with light blindness can continue to be blinded by the field as long as the field is visible, even when outside of the field.",
