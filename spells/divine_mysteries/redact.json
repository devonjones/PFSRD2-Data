        "range": "30 feet",
        "targets": "unattended written materials of up to 1 Bulk",
        "duration": "1 day",
        "heightened": [
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 3,
                "text": "Instead of striking out a given name, you can replace it with a different name you choose. Epithets and references are substituted with similar ones relating to the replacement name. Anyone reading the text can attempt a Perception or Society check against your spell DC to notice the altered text, though that doesn\u2019t tell them what the original said."
            },
            {
                "type": "stat_block_section",
                "subtype": "heightened",
                "level": 4,
                "text": "At your choice, the duration is unlimited."
            }
        ],
