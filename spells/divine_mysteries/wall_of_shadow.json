    "spell": {
        "name": "Wall of Shadow",
        "type": "stat_block_section",
        "text": "You form a wall of pure darkness in a straight line up to 60 feet long and 10 feet high. You must create the wall in an unbroken open space so its edges don\u2019t pass through any creatures or objects, or the spell is lost. The wall stands vertically and, if you wish, can be of a shorter length or height. The wall prevents light from passing through and appears as a sheet of pure darkness to creatures observing it. Creatures without darkvision or those unable to see through darkness can\u2019t see creatures on the other side of the wall. The wall is too thin for creatures to Hide in the darkness itself, but creatures can Hide from creatures on the other side of the wall as normal.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 3,
        "traits": [
            {
                "name": "Concentrate",
                "type": "trait",
