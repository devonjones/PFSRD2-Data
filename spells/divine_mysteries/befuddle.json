    "targets": "1 creature",
    "text": "You sow seeds of confusion in your target\u2019s mind, causing its actions and thoughts to become clumsy.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 32,
          "game-obj": "Traits",
          "type": "alternate_link"
