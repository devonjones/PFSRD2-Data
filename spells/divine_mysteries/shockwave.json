        "name": "Shockwave",
        "type": "stat_block_section",
        "text": "You create a wave of energy that ripples through the earth. Terrestrial creatures in the affected area must attempt a Reflex save to avoid stumbling as the shockwave shakes the ground.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 1,
