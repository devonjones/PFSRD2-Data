    "spell": {
        "name": "Tireless Worker",
        "type": "stat_block_section",
        "text": "You suppress your choice of one of the following conditions that\u2019s affecting the target: clumsy, encumbered, enfeebled, or fatigued. The duration of the condition doesn\u2019t elapse while it is suppressed, so if you don\u2019t remove the effect that caused the condition, the condition returns after the spell\u2019s duration expires.",
