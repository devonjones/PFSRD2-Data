    "spell": {
        "name": "Share Vision",
        "type": "stat_block_section",
        "text": "Your patron temporarily links your vision with that of another, causing both of you to be able to see through each other\u2019s eyes. For the duration of the hex, the two of you share any vision-based senses (such as darkvision or low-light vision) and gain a +2 status bonus to Perception checks, but if either of you are blinded or dazzled, you both are.  \n  \nIf you cast *share vision* while a previous casting of this hex is still in effect, the previous effect ends.",
        "subtype": "spell",
        "spell_type": "cantrip",
        "rank": 1,
