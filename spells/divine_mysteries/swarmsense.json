    "spell": {
        "name": "Swarmsense",
        "type": "stat_block_section",
        "text": "You extend your senses through a multitude of crawling and flying creatures. You create a crawling swarm in your square. You can hear through the swarm as if using your normal auditory senses. When you Cast this Spell and the first time you Sustain it each round, you can move the swarm 10 feet along the ground in any direction. The swarm has AC 15 and a +0 bonus to its saves. Any damage dealt to the swarm destroys it and ends the spell.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 1,
        "traits": [
