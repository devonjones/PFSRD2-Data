    "spell": {
        "name": "Pact Broker",
        "type": "stat_block_section",
        "text": "You offer to broker a pact of peace. If the target accepts and doesn\u2019t take hostile actions against you and your allies during the hex\u2019s duration, you take a \u20131 status penalty to Deception checks to Lie to them. If they refuse and take a hostile action against you or an ally during the hex\u2019s duration, they must first attempt a Will save. If they accepted the offer and then take a hostile action against you or an ally during the hex\u2019s duration, they must first attempt a Will save and treat the result as one category worse. Regardless of the outcome, the target is then temporarily immune for 1 minute.",
        "subtype": "spell",
        "spell_type": "cantrip",
        "rank": 1,
        "traits": [
