                        "link": {
                            "type": "link",
                            "name": "Howl of the Wild pg. 218",
                            "alt": "Howl of the Wild pg. 218",
                            "game-obj": "Sources",
                            "aonid": 226
                        },
                        "page": 218,
                        "errata": {
                            "type": "link",
                            "name": "2.1",
                            "alt": "2.1",
                            "game-obj": "Sources",
                            "aonid": 226
                        }
