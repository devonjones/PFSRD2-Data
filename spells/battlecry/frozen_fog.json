    "spell": {
        "name": "Frozen Fog",
        "type": "stat_block_section",
        "text": "You conjure a chilling mist that settles into the bones and makes it difficult to move. This has the effects of *mist*, except that you can Sustain the spell once per round to move the fog up to 10 feet. A creature that starts its turn in the area takes 6d8 cold damage with a basic Fortitude save. A creature that fails its save is also clumsy 1 for 1 minute (clumsy 2 on a critical failure) and takes a \u201310-foot status penalty to Speeds for as long as it\u2019s clumsy.",
        "subtype": "spell",
        "spell_type": "spell",
