    "spell": {
        "name": "Wings of the Valkyrie",
        "type": "stat_block_section",
        "text": "Powerful feathered wings\u2014usually vibrant white or jet black\u2014 emerge from your back, granting you a fly Speed equal to your Speed. You can use these wings to attempt to Shove a creature; you don\u2019t need a free hand to do so, and you can roll using your spell attack modifier instead of your Athletics skill for the check. When this spell\u2019s duration ends, if you\u2019re still flying, you float to the ground, as *gentle landing*.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 3,
