    "spell": {
        "name": "Siege Weapon's Blessing",
        "type": "stat_block_section",
        "text": "You trace a magic rune onto the body of a siege weapon, calling upon fate or your faith to guide the attacks your allies make with this machine. For the spell\u2019s duration, any skill checks attempted to Load the siege weapon can be rolled twice, taking the better result; these skill checks gain the fortune trait. In addition, any saving throws attempted by creatures caught in the siege weapon\u2019s Launch area must be rolled twice, taking the worse result; these saving throws gain the misfortune trait.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 6,
        "traits": [
