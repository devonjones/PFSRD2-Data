    "spell": {
        "name": "Lashunta's Life Bubble",
        "type": "stat_block_section",
        "text": "You create a replenishing protective bubble of fresh, temperate air around the target. The shell of air enables the target to breathe even underwater or in a vacuum, protects from severe cold and heat, and grants a +1 status bonus to the target\u2019s saves against inhaled dangers such as inhaled poisons and *toxic cloud*.",
        "subtype": "spell",
        "spell_type": "spell",
