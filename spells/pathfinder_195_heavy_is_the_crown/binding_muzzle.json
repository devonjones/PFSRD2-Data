    "spell": {
        "name": "Binding Muzzle",
        "type": "stat_block_section",
        "text": "A shimmering muzzle of pure magical force clamps the target's mouth shut. The target can attempt a Fortitude save to resist the muzzle. For targets with more than one mouth, the caster must target a single mouth.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 2,
