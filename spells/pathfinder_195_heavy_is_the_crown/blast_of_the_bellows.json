    "spell": {
        "name": "Blast of the Bellows",
        "type": "stat_block_section",
        "text": "You create a churning eddy of warm air that makes it difficult to fly within the area. This area is difficult terrain for flying creatures. Each time a flying creature enters the area or ends its turn there, it must attempt an Acrobatics check to Maneuver in Flight.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 2,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
