                "game-obj": "Traits",
                "game-id": "7c548a9e0a2647c082989720b3de0a87",
                "text": "Effects with the wood trait conjure or manipulate wood. Those that manipulate wood have no effect in an area without wood. Creatures with this trait consist primarily of wood or have a connection to magical wood.  \n  \nThese planes consist of trees and other flora latticed in organic patterns. Wood planes are often perfectly constructed to match their desired purpose or environment but aren\u2019t usually outright hostile to visitors.",
                "schema_version": 1.1
            }
        ],
        "range": "60 feet",
        "targets": "1 unattended object of up to 8 Bulk, or Medium or smaller creature that is currently on the ground",
        "duration": "sustained up to 1 minute (see text)",
        "cast": {
            "type": "stat_block_section",
            "subtype": "spell_cast",
            "action_type": {
                "type": "stat_block_section",
                "subtype": "action_type",
                "name": "Two Actions"
            }
        },
        "defense": {
            "type": "stat_block_section",
            "subtype": "spell_defense",
            "save_type": "Ref",
            "critical_success": "The target is unaffected and the spell ends.",
            "success": "The target is grabbed until the end of your next turn unless it Escapes (the vine\u2019s Escape DC is equal to your spell DC) or destroys the vine (the vine has AC 15 and 10 Hit Points), at which point the spell ends.",
            "failure": "The target is grabbed until it Escapes or destroys the vine, at which point the spell ends. The first time each round you Sustain this spell, you can Reposition the grabbed target up to 5 feet.",
            "critical_failure": "As failure, and you can immediately Reposition the target up to 10 feet.",
