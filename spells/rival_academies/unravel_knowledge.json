    "spell": {
        "name": "Unravel Knowledge",
        "type": "stat_block_section",
        "text": "Your patron reaches into the target\u2019s mind, plucking out their past training like pulling a thread from a cloth. Choose a single action, activity, or spell you know the target can use, such as from seeing it previously or identifying the creature\u2019s capabilities with a Recall Knowledge check. You could select, for example, the Strike action, the Disarm action, a dragon\u2019s breath, or the *haste* spell if you were aware the target could use them. The target attempts a Will save.",
        "subtype": "spell",
        "spell_type": "focus",
        "rank": 3,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
