    "spell": {
        "name": "Frost Pillar",
        "type": "stat_block_section",
        "text": "Ice crystallizes around a creature, imprisoning it within an icy pillar. On a successful saving throw, the creature is pushed to an adjacent space of its choice; otherwise, it's frozen inside the pillar and becomes restrained as its body can barely move within the ice. The ice has AC 10, Hardness 10, and 60 Hit Point; it's immune to critical hits, cold damage, and precision damage, and it has weakness 15 to fire. If the ice is destroyed, the creature within is freed and the spell immediately ends.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 6,
