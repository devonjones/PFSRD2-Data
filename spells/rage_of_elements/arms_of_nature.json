    "spell": {
        "name": "Arms of Nature",
        "type": "stat_block_section",
        "text": "All wood, dead or alive, is your armory. When you cast this spell, you draw forth a *+1* weapon of your choice from the target. The weapon must be 2 Bulk or less. This weapon is of the same material as the target.",
