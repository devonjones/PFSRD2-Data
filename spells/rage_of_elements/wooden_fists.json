    "spell": {
        "name": "Wooden Fists",
        "type": "stat_block_section",
        "text": "Your arms and hands swell with new growth, transforming into tree trunks twice as big as their current size. Your fists deal 1d6 bludgeoning damage, lose the nonlethal trait, and have reach.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 1,
