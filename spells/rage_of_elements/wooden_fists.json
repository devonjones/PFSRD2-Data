                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e32d877417a40fe977d27634dc14f99f",
                "text": "An action with this trait requires a degree of mental concentration and discipline.",
                "schema_version": 1.1
            },
            {
                "name": "Manipulate",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 104,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
