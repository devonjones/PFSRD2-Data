        "name": "Two Actions",
        "subtype": "action_type",
        "type": "stat_block_section"
      },
      "subtype": "spell_cast",
      "type": "stat_block_section"
    },
    "defense": {
      "critical_failure": "As failure, but the DC on the target's flat check to remove persistent bleed damage increases to 20 (15 with particularly effective assistance).",
      "critical_success": "The target is unaffected.",
      "failure": "As success, but the curse has an unlimited duration.",
      "links": [
        {
          "alt": "persistent bleed damage",
          "aonid": 29,
          "game-obj": "Conditions",
          "name": "persistent bleed damage",
          "type": "link"
        }
      ],
      "save_type": "Will",
      "subtype": "spell_defense",
      "success": "The target is marked by Achaekek's symbol. For 1 minute, the first time per round that the target gains persistent bleed damage, they immediately take that amount of slashing damage as the mantis claws grow off the symbol and rake them.",
      "type": "stat_block_section"
    },
    "name": "Achaekek's Clutch",
    "range": {
      "range": 30,
      "subtype": "range",
      "text": "30 feet",
      "type": "stat_block_section",
      "unit": "feet"
    },
    "rank": 4,
    "spell_type": "focus",
    "subtype": "spell",
    "targets": "1 creature",
    "text": "You mark the holy symbol of Achaekek in a visible location on the target\u2019s body.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
