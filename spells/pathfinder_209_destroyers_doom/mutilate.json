    "spell": {
        "name": "Mutilate",
        "type": "stat_block_section",
        "text": "You cut your own body in a ritualistic manner, causing similar damage to a creature in your line of sight. These cuts are superficial and cause 1d4 slashing damage to you; however, the wounds that open up on our target\u2019s body are far deeper. The targeted creature takes 5d8 slashing damage; a creature that critically fails this saving throw also takes 1d8 persistent bleed damage. If you cast this as a three-action spell, the spell instead affects a 5-foot burst.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 4,
