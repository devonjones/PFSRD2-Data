    "spell": {
        "name": "Life's Flowing River",
        "type": "stat_block_section",
        "text": "You create a volume of faint shimmering light that resembles a flowing river and sheds dim light for 10 feet on each side. The river begins in an adjacent square to you and extends in a straight 5-foot path to its maximum range or until it hits a solid wall, whichever comes first. A creature that begins its turn in the river or enters one of the river's spaces must attempt a Will save.",
        "subtype": "spell",
        "spell_type": "spell",
        "rank": 4,
