                "classes": [
                    "uncommon"
                ]
            },
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 98,
                    "alternate_type": "legacy"
