          ],
          "effect": "You flip the hourglass upside down then immediately right it again, rewinding time by a few moments. Reroll the saving throw with a +4 circumstance bonus. You must use the results of this new saving throw.",
          "frequency": "once per day",
          "name": "Activate",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 48,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
              "game-obj": "Traits",
              "name": "Divine",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 76,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "7adeee5fc9bf211a4db10de37045506c",
              "game-obj": "Traits",
              "links": [
                {
                  "alt": "misfortune",
                  "aonid": 110,
