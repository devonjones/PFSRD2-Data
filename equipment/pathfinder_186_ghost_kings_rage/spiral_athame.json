          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 48,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
              "game-obj": "Traits",
              "name": "Divine",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
              "type": "trait"
            },
            {
              "edition": "legacy",
              "game-id": "43f6a564e13fcacc75648269d2f58f98",
              "game-obj": "Traits",
              "name": "Necromancy",
              "sources": [
                {
                  "errata": {
                    "alt": "4.0",
                    "aonid": 1,
                    "game-obj": "Sources",
                    "name": "4.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Core Rulebook pg. 634",
                    "aonid": 1,
                    "game-obj": "Sources",
                    "name": "Core Rulebook pg. 634",
                    "type": "link"
                  },
                  "name": "Core Rulebook",
                  "page": 634,
                  "type": "source"
                }
              ],
              "text": "Effects and magic items with this trait are associated with the necromancy school of magic, typically involving forces of life and death.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
