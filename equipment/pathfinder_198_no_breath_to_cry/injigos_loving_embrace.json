            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You spin the net in the direction of an incorporeal creature within 30 feet that you can see. Lines of silken force whip out to lash around the incorporeal creature, who must attempt a DC 25 Reflex save to avoid becoming immobilized until the end of your next turn. You can Sustain this activation for up to 1 minute, and the creature must succeed at a DC 25 check to Escape the net.",
                    "links": [
                        {
                            "type": "link",
                            "name": "immobilized",
                            "alt": "immobilized",
                            "game-obj": "Conditions",
                            "aonid": 81
                        },
                        {
                            "type": "link",
                            "name": "Escape",
                            "alt": "Escape",
                            "game-obj": "Actions",
                            "aonid": 2296
                        }
                    ],
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "envision"
                        },
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "interact"
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "frequency": "once per week",
                    "effect": "You wrap the net around you like a blanket as you prepare to sleep. As long as you get 8 hours of sleep or analogous rest, you dream of writing love letters to someone you adore: this could be an actual paramour, someone you're interested in, or someone unknown whose identity you don't recall after waking. When you wake, you're filled with a sense of melancholia about those unsent letters, but these feelings distract you from other, more unpleasant thoughts, granting you resistance 5 to mental damage and a +1 item bonus to saving throws against mental effects for the next 8 hours.",
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "envision"
                        },
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "interact"
                        }
                    ],
                    "activation_time": "10 minutes"
                }
            ]
        },
