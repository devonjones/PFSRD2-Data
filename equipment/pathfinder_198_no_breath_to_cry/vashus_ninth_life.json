    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking ghost touch katana* is made from a whisker stolen from the king of cats over three hundred years ago by a catfolk rogue named Vashu Vigaru. He sought the magic of the whisker to preternaturally extend his life, and some believe he still lives, having successfully divested himself of the sword to escape the king's wrath in the end.",
        "level": 9,
        "image": {
            "type": "image",
            "name": "Vashu's Ninth Life",
            "image": "Vashus_Ninth_Life.webp"
        },
