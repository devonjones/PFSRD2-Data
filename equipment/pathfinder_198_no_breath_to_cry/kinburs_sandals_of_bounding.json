            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per hour",
                    "effect": "You loudly boast about your grace and agility, then take any combination of two High Jumps or Long Jumps. You do not need to Stride first, and between the two jumps, you need only to come into contact with a physical object before making the second jump; this object doesn't need to be one that can bear your weight, or even be attached to the ground\u2014you can jump off from a floating feather or a thin branch or even off a paper wall as needed. The sandals' item bonus increases to +2 for these jumps."
                }
            ]
        },
