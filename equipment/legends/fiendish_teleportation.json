        }
    ],
    "pfs": "Limited",
    "aonid": 760,
    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "You tap into the fiendish ability to slip through space. When you Stride, you gain a +3 item bonus to Armor Class against reactions triggered by your movement. Once per day, from any distance, Abrogail Thrune II can call on a provision in your Thrune contract as a single action, causing you to become paralyzed for 1 hour or until Abrogail releases you, whichever comes first.",
        "level": 11,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e4b0e4f5f4b3d4cad3bea67ec077e297",
                "text": "This rarity indicates that a rules element is very difficult to find in the game world. A rare feat, spell, item or the like is available to players only if the GM decides to include it in the game, typically through discovery during play. Creatures with this trait are rare. They typically can't be summoned. The DC of Recall Knowledge checks related to these creatures is increased by 5.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "schema_version": 1.1,
                "classes": [
                    "rare"
                ]
            },
            {
                "name": "Conjuration",
                "type": "trait",
                "edition": "legacy",
                "sources": [
                    {
                        "type": "source",
                        "name": "Core Rulebook",
                        "link": {
                            "type": "link",
                            "name": "Core Rulebook pg. 630",
                            "alt": "Core Rulebook pg. 630",
                            "game-obj": "Sources",
                            "aonid": 1
                        },
                        "page": 630,
                        "errata": {
                            "type": "link",
                            "name": "4.0",
                            "alt": "4.0",
                            "game-obj": "Sources",
                            "aonid": 1
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9011037bb4a11ca6cf2d16fa8a657bf5",
                "text": "Effects and magic items with this trait are associated with the conjuration school of magic, typically involving summoning, creation, teleportation, or moving things from place to place.",
                "links": [
                    {
                        "type": "link",
                        "name": "summoning",
                        "alt": "summoning",
                        "game-obj": "Traits",
                        "aonid": 154
                    },
                    {
                        "type": "link",
                        "name": "teleportation",
                        "alt": "teleportation",
                        "game-obj": "Traits",
                        "aonid": 156
                    }
                ],
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Contract",
                "type": "trait",
                "edition": "legacy",
                "sources": [
                    {
                        "type": "source",
                        "name": "Legends",
                        "link": {
                            "type": "link",
                            "name": "Legends pg. 10",
                            "alt": "Legends pg. 10",
                            "game-obj": "Sources",
                            "aonid": 40
                        },
                        "page": 10
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9b1412649bade212276b4bc5db25d991",
                "text": "A contract is a type of item that magically establishes an agreement between multiple parties and typically grants magical benefits.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 98,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
                        "link": {
                            "type": "link",
                            "name": "GM Core pg. 219",
                            "alt": "GM Core pg. 219",
                            "game-obj": "Sources",
                            "aonid": 218
                        },
                        "page": 219,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
                "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
                "links": [
                    {
                        "type": "link",
                        "name": "invest",
                        "alt": "invest",
                        "game-obj": "Actions",
                        "aonid": 2799
                    }
                ],
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            }
        ],
