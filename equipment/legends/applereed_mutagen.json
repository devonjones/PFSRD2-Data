    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This gummy liquid disproportionately lengthens your legs, causing you to grow but making your movement awkward. The effect is very noticeable unless your clothes can adequately conceal it.  \n   \n **Benefit** You gain an item bonus to Athletics checks and you gain the listed status bonus to your Speed. In addition, you grow one size larger, but your larger size does not have any additional effects beyond the potential change in space.  \n   \n **Drawback** You take a \u20131 penalty to AC and a \u20132 penalty to Reflex saves.",
        "level": 4,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
