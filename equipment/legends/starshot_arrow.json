                    "text": "55 gp",
                    "value": 55,
                    "currency": "gp"
                },
                "text": "The target must be within the maximum range of your weapon.",
                "sources": [
                    {
                        "type": "source",
                        "name": "Legends",
                        "link": {
                            "type": "link",
                            "name": "Legends pg. 48",
                            "alt": "Legends pg. 48",
