                            "aonid": 40
                        },
                        "page": 48
                    }
                ]
            },
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Starshot Arrow (Greater)",
                "level": 14,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "800 gp",
                    "value": 800,
                    "currency": "gp"
                },
                "text": "You can fire at any creature you can detect, regardless of range. The arrow travels instantly, hitting your target as soon as you fire the arrow. This is a teleportation effect.",
                "links": [
                    {
                        "type": "link",
                        "name": "teleportation",
                        "alt": "teleportation",
                        "game-obj": "Traits",
                        "aonid": 156
                    }
                ],
                "sources": [
