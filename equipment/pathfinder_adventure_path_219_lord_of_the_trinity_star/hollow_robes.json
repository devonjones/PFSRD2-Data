    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "These heavy cloth garments function as a set of +2 *resilient explorer\u2019s clothing*. They feature multiple stylish layers, voluminous sleeves, and long strings of Thassilonian runes along the hems. The robes employ potent illusion magic, sufficient to convince the wearer and any attackers that a devastating blow is nothing more than a flesh wound.",
        "level": 13,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
