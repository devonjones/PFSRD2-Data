            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "effect": "The ribbon spins and swirls, creating a circular loop in the air through which you can spy on a creature on another plane. This has the effects of a  *scrying* spell (DC 40) against the creature but functions more as a mundane \u2014albeit interplanar\u2014window; a similar loop appears before the target, and for the duration, both sides can clearly see and hear each other through the created portal, but nothing can pass through. You can Sustain the Activation to gain the effects of Sustaining the Spell. This activation has the scrying trait.",
                    "links": [
                        {
                            "type": "link",
                            "name": "scrying",
                            "alt": "scrying",
                            "game-obj": "Spells",
                            "aonid": 268
                        },
                        {
                            "type": "link",
                            "name": "scrying",
                            "alt": "scrying",
                            "game-obj": "Traits",
                            "aonid": 141
                        }
                    ],
