    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The crown of a *candlecap* is stitched leather sewn in the shape of a small bowl. Fixed inside the bowl is a melted nub of wax with a small black wick.",
        "level": 1,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
