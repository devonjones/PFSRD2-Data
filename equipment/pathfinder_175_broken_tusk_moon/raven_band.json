    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This armband is woven from overlapping raven feathers, including one large feather from a kadlaka. As long as you wear it, you understand what ravens are saying, but you can't speak to ravens unless you activate the *raven band*.",
        "level": 3,
