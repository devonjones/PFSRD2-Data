    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Designed by a gunsmith as a personal challenge, a *howler pistol* strikes a miniature version of the sonic horn siege weapon\u2019s resonating orb with its hammer to generate beams of sonic energy. A *howler pistol* is a *+1 striking dragon mouth pistol* that deals sonic damage instead of piercing damage and doesn\u2019t have the concussive trait.",
        "level": 10,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
