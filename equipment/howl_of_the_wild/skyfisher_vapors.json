    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*Skyfisher vapors* are only visible via their effect on a *toxic cloud* spell, or apparent lack thereof. These gases cause the conjured cloud to be as transparent as a sky fisher. The cloud is invisible, meaning it does not provide concealment, but it requires a successful Perception check against your spell DC to notice the cloud by faint distortions in the air. Your magical connection to the cloud means you always know where it is. This has no effect on its damage.",
        "level": 5,
        "traits": [
            {
                "name": "Catalyst",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 396,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Howl of the Wild",
                        "link": {
                            "type": "link",
