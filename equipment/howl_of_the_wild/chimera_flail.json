    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The three spiked heads of this *+1 striking war flail* are fashioned to resemble the heads of a chimera. Preserved fragments of bone from the creature are fused with the metal of each head, replacing the typical weight at the end of the chain. Each head has been shrunk and preserved for use. You can have only one head slotted at a time and can use only the ability of the currently slotted head, while the other two hang off the pommel. Switching between heads requires an Interact action.",
        "sections": [
            {
                "name": "Dragon",
                "type": "section",
                "text": "This head does piercing damage instead of the normal bludgeoning damage, plus 1 damage type based on the magical tradition of the chimera\u2019s dragon head. (**Arcane** force; **Divine** spirit; **Occult** mental; **Primal** acid, cold, electricity, fire, sonic, or poison, chosen at item creation)"
            }
        ],
        "level": 9,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
