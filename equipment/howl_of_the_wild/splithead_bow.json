                            ],
                            "game-obj": "Traits",
                            "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                            "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions."
                        }
                    ],
                    "activation_name": "Two-Headed Arrow"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You make a powerful Strike propelled by the ferocity of a hydra at a target within your first range increment. If your Strike is successful, the arrow deals damage as normal and then passes through the target, splitting into four pieces. Choose four other targets within 30 feet of the original target and make a single ranged Strike with your multiple attack penalty, comparing the result to each secondary target\u2019s AC. After using this ability, you do not regain Hit Points from wielding the bow until after your next daily preparations.",
