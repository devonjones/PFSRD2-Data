            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "effect": "You imbue your arrow with the properties of a hydra, splitting it in two and sending each at a different foe. Make two ranged Strikes, each against a separate target. Both targets must be in your line of sight, and within 50 feet of you. Both Strikes count toward your multiple attack penalty, but the penalty doesn\u2019t increase until after you\u2019ve made both attacks. Additionally, after using this ability, you do not regain Hit Points from wielding the bow on your next turn.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Strikes",
                            "alt": "Strikes",
                            "game-obj": "Actions",
                            "aonid": 2306
                        }
                    ],
