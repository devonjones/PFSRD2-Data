          "trait"
        ],
        "edition": "remastered",
        "game-id": "b767873f1e57f8326b773c8d1e27cc5c",
        "game-obj": "Traits",
        "name": "Electricity",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
