          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 32,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "e32d877417a40fe977d27634dc14f99f",
              "game-obj": "Traits",
              "name": "Concentrate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 454",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 454,
                  "type": "source"
                }
              ],
              "text": "An action with this trait requires a degree of mental concentration and discipline.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 100,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "dd40587ebc07c2b386aa95d93fdcc130",
              "game-obj": "Traits",
              "name": "Light",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "Light effects overcome non-magical darkness in the area and can counteract magical darkness. You must usually target darkness magic with your light magic directly to counteract the darkness, but some light spells automatically attempt to counteract darkness.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 106,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a1f80610baa3617c1597f49c6406313",
              "game-obj": "Traits",
              "name": "Mental",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 163,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "abcdb0d656f37cebdbee9dca267ef899",
              "game-obj": "Traits",
              "name": "Visual",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 463",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 463",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 463,
                  "type": "source"
                }
              ],
              "text": "A visual effect can affect only creatures that can see it. This applies only to visible parts of the effect, as determined by the GM.",
              "type": "trait"
            }
