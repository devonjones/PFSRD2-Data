    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking klar* is fashioned from the skull of a hippopotamus, with one of its canines acting as the blade. While wielding a *hippopotamus klar*, you gain a +1 item bonus to Intimidation checks.",
        "level": 10,
