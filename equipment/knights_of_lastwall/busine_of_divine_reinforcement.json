    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This long, straight, trumpet-like instrument is made of well-polished brass and adorned with imagery of angels fighting demons or religious symbols. When played as an instrument, the busine generates powerful and harmonious notes and grants a +2 item bonus to Performance checks.",
        "level": 15,
