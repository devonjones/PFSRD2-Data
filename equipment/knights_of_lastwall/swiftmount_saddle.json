    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This sturdy leather saddle was designed to improve communication between mount and rider, allowing even inexperienced knights to command their mounts in battle. A swiftmount saddle grants a +2 item bonus to Nature checks made to Command an Animal for anyone who is riding the creature wearing it.",
        "level": 7,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
