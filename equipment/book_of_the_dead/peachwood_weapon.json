    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Peachwood weapons have an auburn tinge in direct sunlight. Peachwood is treated as duskwood for undead creatures' resistances or weaknesses related to duskwood (bypassing a jiang-shi's resistance, for example). In addition, peachwood weapons bypass a small portion of the resistances of any undead creature. Strikes with a peachwood weapon treat an undead's resistances against physical damage as 2 lower for standard-grade peachwood, and 4 lower for high-grade.",
        "level": 12,
        "traits": [
            {
