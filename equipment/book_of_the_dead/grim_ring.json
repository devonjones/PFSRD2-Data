                    "frequency": "once per day",
                    "trigger": "You gain the drained condition from an undead creature",
                    "links": [
                        {
                            "type": "link",
                            "name": "drained",
                            "alt": "drained",
                            "game-obj": "Conditions",
                            "aonid": 10
                        }
                    ],
                    "effect": "Reduce the value of the drained condition you gain by 1, and the undead that caused the condition takes 2d6 positive damage.",
                    "traits": [
                        {
                            "name": "Vitality",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 128,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 463",
                                        "alt": "Player Core pg. 463",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 463,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
