    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A stock carved of enchanted wood forms the base for a *musket staff*, a magic weapon used by a gunwitch as both a powerful firearm and magical staff. Many other variants exist with different spells. This *+1 flintlock musket* has a reinforced stock permanently attached to it, and the musket's *weapon potency rune* (and any other runes) applies to Strikes with the stock as well. The musket staff also contains spells and can be prepared following the same rules as a staff.\n* **Cantrip** *shield*\n* **1st** *force barrage*",
        "level": 4,
        "image": {
            "type": "image",
            "name": "Musket Staff of Force",
            "image": "Musket_Staff_of_Force.webp"
        },
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
