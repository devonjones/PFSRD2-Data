    "subtype": "equipment",
    "text": "This pressurized iron casing bursts open when struck, releasing cold iron shrapnel. The bomb deals the listed piercing damage and piercing splash damage from a cold iron source. Many types grant a bonus to attack rolls.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
