    "craft_requirements": "Supply a casting of *splinter volley* of the appropriate level.",
    "level": 6,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *splinter volley* of the indicated rank. Each splinter contains some of the despair felt by cruelly harvested trees, causing any creature damaged by this spell to become stupefied 2 for a number of rounds equal to the spell rank. On a critical success on the attack roll, the target also weeps, becoming slowed 1 for the same duration.",
          "frequency": "once per day plus overcharge",
          "links": [
            {
              "alt": "splinter volley",
              "aonid": 1410,
              "game-obj": "Spells",
              "name": "splinter volley",
              "type": "link"
            },
            {
              "alt": "slowed",
              "aonid": 92,
              "game-obj": "Conditions",
              "name": "slowed",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This wooden wand is roughly cut, as if it had been crudely chopped from a tree and left forgotten. When held, the wand imparts feelings of deep sorrow.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
