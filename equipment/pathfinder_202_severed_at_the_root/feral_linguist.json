                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f31704572455b8d77a8bd97c0045fde6",
                "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "classes": [
                    "uncommon"
                ]
            },
            {
                "name": "Catalyst",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 396,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Howl of the Wild",
                        "link": {
                            "type": "link",
                            "name": "Howl of the Wild pg. 216",
                            "alt": "Howl of the Wild pg. 216",
                            "game-obj": "Sources",
                            "aonid": 226
                        },
                        "page": 216,
                        "errata": {
                            "type": "link",
                            "name": "2.1",
                            "alt": "2.1",
                            "game-obj": "Sources",
                            "aonid": 226
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e9c88caef9c7846682faee282ccd47d6",
                "text": "Items with the catalyst trait are consumables that alter or magnify specific spells. Using a catalyst adds the manipulate trait to the spell. Activating a catalyst is part of Casting the Spell. The catalyst might increase the number of actions required to Cast the Spell, as indicated in the catalyst's Activate entry. You can draw the catalyst as part of Casting the Spell.",
                "links": [
                    {
                        "type": "link",
                        "name": "manipulate",
                        "alt": "manipulate",
                        "game-obj": "Traits",
                        "aonid": 645
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
