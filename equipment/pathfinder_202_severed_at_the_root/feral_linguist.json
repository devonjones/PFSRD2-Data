    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This wooden whistle is stuffed with cotton and carved with images of bellowing stags, howling wolves, and chirping birds. You can blow on this whistle to use it as a catalyst when casting an *animal form* spell. When you do, you gain the listed benefit for the duration of the spell.",
        "level": 1,
        "image": {
            "type": "image",
            "name": "Feral Linguist",
            "image": "Feral_Linguist.webp"
        },
