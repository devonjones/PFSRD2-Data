    "subtype": "equipment",
    "text": "Golden images of heroic deeds decorate the black plates of this *+1 resilient full plate*. You gain resistance 5 to mental damage and a +1 status bonus to saves against fear.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 137,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
