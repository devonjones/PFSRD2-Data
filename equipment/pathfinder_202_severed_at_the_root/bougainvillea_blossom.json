                        "link": {
                            "type": "link",
                            "name": "Howl of the Wild pg. 216",
                            "alt": "Howl of the Wild pg. 216",
                            "game-obj": "Sources",
                            "aonid": 226
                        },
                        "page": 216,
                        "errata": {
                            "type": "link",
