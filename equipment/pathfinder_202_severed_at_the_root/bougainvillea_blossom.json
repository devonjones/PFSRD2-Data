    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This pink flower has long, slender thorns along the stem. The flower can be used as a catalyst when casting an *entangling flora* spell, which causes the affected plants to sprout long thorns and vibrant pink blossoms. The area becomes hazardous terrain, dealing the listed piercing damage to an enemy each time it enters an affected square.",
        "level": 3,
        "traits": [
