                ]
            },
            {
                "name": "Light",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 100,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
