    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This crystal phial was created from Brilliance, a condensed planar fragment of the plane of Nirvana which is trapped within Gloaming Arbor. A *paradise light* glows brightly, shedding bright light in a 30-foot radius and dim light to a further 30 feet. A PC that looks into the paradise light sees images of Nirvana, an idyllic pastoral paradise. A paradise light is required to navigate the heart of the forest in Gloaming Arbor.   \n   \nA paradise light automatically attempts to counteract any magical darkness that it\u2019s light enters. When the paradise light successfully counteracts an area of magical darkness, that area becomes overlain by a reflection of Nirvana, changing the appearance of the area. This illusory transformation lasts for 1 hour.",
        "level": 10,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
