        "type": "stat_block",
        "subtype": "equipment",
        "text": "This small limestone pendant is typically carved in the shape of clasped hands. When activated, the affixed weapon gains the nonlethal trait for the triggering attack and all other attacks for 1 minute.",
        "level": 3,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
