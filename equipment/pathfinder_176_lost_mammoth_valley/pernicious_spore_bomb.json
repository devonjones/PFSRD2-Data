    "subtype": "equipment",
    "text": "This flask contains fast-growing mold spores, which quickly take root but just as quickly rot away. A pernicious spore bomb deals the listed poison damage, persistent piercing damage, and splash damage. Many types grant an item bonus to attack rolls.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
