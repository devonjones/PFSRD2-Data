    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This copper coin dangles from a leather strip strung through a hole drilled in the center. Until activated, the coin becomes invisible for a few seconds at random intervals every few minutes. When you activate the coin, it casts a 2nd-rank *invisibility* spell on you, lasting until the end of your next turn.",
        "level": 10,
        "traits": [
            {
                "name": "Consumable",
