    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_name": "Masquerade",
          "activation_time": "1 minute",
          "effect": "You arrange the scarf over your lower face, and it casts a 1st-rank *illusory disguise* spell on you, which ends immediately if the scarf is removed. You can alter the scarf's appearance or make it invisible as part of the *illusory disguise*, but it can still be felt if touched.",
          "frequency": "once per day",
          "links": [
            {
              "alt": "illusory disguise",
              "aonid": 1568,
              "game-obj": "Spells",
              "name": "illusory disguise",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "worn",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This delicately embroidered scarf matches with every outfit and can even complete a costume or disguise with illusions.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "invest",
            "aonid": 2799,
            "game-obj": "Actions",
            "name": "invest",
            "type": "link"
          }
        ],
        "name": "Invested",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 219",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 219",
              "type": "link"
            },
            "name": "GM Core",
            "page": 219,
            "type": "source"
          }
        ],
        "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      }
    ],
