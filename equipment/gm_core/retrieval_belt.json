            "name": "One Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "activation_name": "Store Item",
          "effect": "One item you're holding with a Bulk of 1 or less vanishes into the belt's extradimensional space.",
          "name": "Activate",
          "requirement": "There is room for an item in the belt",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        },
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "Free Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "activation_name": "Retrieve Item",
          "effect": "The item stored in the belt appears in your hand. Neither Store Item nor Retrieve Item can be activated again for 1 minute.",
          "name": "Activate",
          "requirement": "An item is stored in the belt and you have a free hand",
          "subtype": "activation",
          "traits": [
            {
