    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This hat comes in many forms, such as a colorful turban or a pointy hat with a brim, and is adorned with symbols or runes. It grants you a +1 item bonus to Arcana checks and allows you to cast the *prestidigitation* cantrip as an arcane innate cantrip.",
        "level": 3,
        "traits": [
            {
                "name": "Arcane",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 11,
                    "alternate_type": "legacy"
                },
