    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The most rare and valuable skymetal, orichalcum is coveted for its incredible time-related magical properties. This dull, coppery metal isn't as physically sturdy as adamantine, but orichalcum's time-bending properties protect it, granting it greater Hardness and Hit Points. If an orichalcum item takes damage but isn't destroyed, it repairs itself completely 24 hours later.",
        "sections": [
            {
                "name": "Orichalcum Items",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Orichalcum Items** | **Hardness** | **HP** | **BT** |\n| **Thin Items** |  |\n| High-grade | 16 | 64 | 32 |\n| **Items** |  |\n| High-grade | 18 | 72 | 36 |\n| **Structure** |  |\n| High-grade | 35 | 140 | 70 |\n\n   \n *Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Orichalcum Armor*   \n *Orichalcum Shield*   \n *Orichalcum Weapon*",
                        "links": [
                            {
                                "type": "link",
                                "name": "Orichalcum Armor",
                                "alt": "Orichalcum Armor",
                                "game-obj": "Equipment",
                                "aonid": 2802
                            },
                            {
                                "type": "link",
                                "name": "Orichalcum Shield",
                                "alt": "Orichalcum Shield",
                                "game-obj": "Equipment",
                                "aonid": 2816
                            },
                            {
