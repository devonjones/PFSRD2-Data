                                "name": "Orichalcum Weapon",
                                "alt": "Orichalcum Weapon",
                                "game-obj": "Equipment",
                                "aonid": 2859
                            }
                        ]
                    }
                ]
            }
        ],
        "level": 17,
        "traits": [
