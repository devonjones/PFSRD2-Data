    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Duskwood is a very lightweight wood found primarily in old-growth forests in south-central Avistan; it is dark as ebony but has a slight purple tint. A duskwood item's Bulk is reduced by 1 (or to light Bulk if its normal Bulk is 1, with no effect on an item that normally has light Bulk). The Price of an item made of duskwood is based on the item's normal Bulk, not its reduced Bulk for being made of duskwood, but reduce the Bulk before making any further Bulk adjustments for the size of the item.",
        "sections": [
            {
                "name": "Duskwood",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Duskwood Items** | **Hardness** | **HP** | **BT** |\n| **Thin Items** |  |\n| Standard-grade | 5 | 20 | 10 |\n| High-grade | 8 | 32 | 16 |\n| **Items** |  |\n| Standard-grade | 7 | 28 | 14 |\n| High-grade | 10 | 40 | 20 |\n| **Structure** |  |\n| Standard-grade | 14 | 56 | 28 |\n| High-grade | 20 | 80 | 40 |\n\n  \n*Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Duskwood Armor*  \n*Duskwood Shield*  \n*Duskwood Weapon*",
                        "links": [
                            {
                                "type": "link",
                                "name": "Duskwood Armor",
                                "alt": "Duskwood Armor",
                                "game-obj": "Equipment",
