    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *thundering* weapon lets out a peal of thunder when it hits, dealing an extra 1d6 sonic damage on a successful Strike. On a critical hit, the target must succeed at a DC 24 Fortitude save or be deafened for 1 minute (or 1 hour on a critical failure).",
        "level": 8,
