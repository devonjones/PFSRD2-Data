    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Weapons made from cold iron are deadly to demons and fey alike. Cold iron looks like normal iron but is mined from particularly pure sources and shaped with little or no heat. This process is extremely difficult, especially for high-grade cold iron items.",
        "sections": [
            {
                "name": "Cold Iron Items",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Cold Iron Items** | **Hardness** | **HP** | **BT** |\n| **Thin Items** |  |\n| Low-grade | 5 | 20 | 10 |\n| Standard-grade | 7 | 28 | 14 |\n| High-grade | 10 | 40 | 20 |\n| **Items** |  |\n| Low-grade | 9 | 36 | 18 |\n| Standard-grade | 11 | 44 | 22 |\n| High-grade | 14 | 56 | 28 |\n| **Structure** |  |\n| Low-grade | 18 | 72 | 36 |\n| Standard-grade | 22 | 88 | 44 |\n| High-grade | 28 | 112 | 56 |\n\n  \n*Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Cold Iron Armor*  \n*Cold Iron Shield*  \n*Cold Iron Weapon*",
                        "links": [
                            {
                                "type": "link",
                                "name": "Cold Iron Armor",
                                "alt": "Cold Iron Armor",
                                "game-obj": "Equipment",
                                "aonid": 2798
