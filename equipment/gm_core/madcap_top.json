        "type": "stat_block",
        "subtype": "equipment",
        "text": "This top has 20 divisions, painted in a chaotic mess of clashing colors. When spun, the top quickly settles on a side and generates a strange magical effect based on the side that lands face-up.",
        "level": 8,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
