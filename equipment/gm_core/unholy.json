    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "An unholy rune instills fiendish power into the etched weapon. Strikes made with it gain the unholy trait and deal an extra 1d4 spirit damage, or an extra 2d4 against a holy target. If you are holy, you are enfeebled 2 while carrying or wielding this weapon.",
