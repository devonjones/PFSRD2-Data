    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This plain silver ring has an almost oily sheen. While wearing the ring, you gain a +2 item bonus to Deception checks.",
        "level": 10,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
