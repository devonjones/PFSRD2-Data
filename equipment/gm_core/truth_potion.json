    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "For 10 minutes after drinking this astringent potion, you can't intentionally lie and may be compelled to tell the truth. Upon drinking the potion, attempt a DC 19 Will save. You can voluntarily fail or critically fail.",
        "level": 6,
