    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This grisly molar hangs from a cord threaded through a hole just above its dried, exposed root. When you activate this talisman, make a melee Strike against an adjacent creature. That creature is off-guard against the Strike and until the end of your turn.",
        "level": 8,
