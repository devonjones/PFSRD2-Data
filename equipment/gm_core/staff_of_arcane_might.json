    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This staff of magically hardened wood is topped with a silver sculpture depicting magical runic symbols. A staff of arcane might is a *+1 striking staff*.",
        "level": 12,
        "image": {
            "type": "image",
            "name": "Staff of Arcane Might",
            "image": "Staff_of_Power.webp"
        },
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
