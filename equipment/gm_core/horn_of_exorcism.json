            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "frequency": "once per hour",
                    "effect": "Blowing into the horn frightens ghosts and evil spirits who can hear its call. Make an Intimidation check to Demoralize against all creatures with the undead or unholy trait in a 30-foot emanation. This can affect even a mindless creature with that trait, and you don't take a penalty when you attempt to Demoralize a creature that doesn't understand your language.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Demoralize",
                            "alt": "Demoralize",
                            "game-obj": "Actions",
                            "aonid": 53
                        }
                    ],
                    "traits": [
                        {
                            "name": "Auditory",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 16,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 453",
                                        "alt": "Player Core pg. 453",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 453,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "84c09922ddd30f2144494f2cb6f19412",
                            "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                            "schema_version": 1.1
                        },
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
