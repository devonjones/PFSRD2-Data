    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "When you apply this thick, viscous oil to a weapon or suit of armor, that item immediately becomes magically potent. If the item is a weapon, it temporarily becomes a *+1 striking* weapon, or, if it's armor, it temporarily becomes +1 resilient armor. This lasts for 1 minute.",
        "level": 2,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
                            "alt": "Player Core pg. 454",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 454,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "07336d377bbfcf8d760f34f32f513526",
                "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Oil",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 121,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
                        "link": {
                            "type": "link",
                            "name": "GM Core pg. 257",
                            "alt": "GM Core pg. 257",
                            "game-obj": "Sources",
                            "aonid": 218
                        },
                        "page": 257,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "ae3604d98ffc303ee0eb84f9c3281d28",
                "text": "Oils are magical gels, ointments, pastes, or salves that are typically applied to an object and are used up in the process.",
                "classes": [
                    "trait"
                ]
            }
        ],
