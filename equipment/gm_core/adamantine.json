    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Mined from rocks that fell from the heavens, adamantine is one of the hardest metals known. It has a shiny, black appearance, and it is prized for its amazing resiliency and ability to hold an incredibly sharp edge.",
        "sections": [
            {
                "name": "Adamantine Items",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Adamantine Items** | **Hardness** | **HP** | **BT** |\n| **Thin Items** |  |\n| Standard-grade | 10 | 40 | 20 |\n| High-grade | 13 | 52 | 26 |\n| **Items** |  |\n| Standard-grade | 14 | 56 | 28 |\n| High-grade | 17 | 68 | 34 |\n| **Structure** |  |\n| Standard-grade | 28 | 112 | 56 |\n| High-grade | 34 | 136 | 68 |\n\n   \n *Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Adamantine Armor*   \n *Adamantine Shield*   \n *Adamantine Weapon*",
                        "links": [
                            {
                                "type": "link",
                                "name": "Adamantine Armor",
                                "alt": "Adamantine Armor",
                                "game-obj": "Equipment",
                                "aonid": 2797
                            },
                            {
                                "type": "link",
                                "name": "Adamantine Shield",
