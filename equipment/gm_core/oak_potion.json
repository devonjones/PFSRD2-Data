                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "After you drink this bitter draft, your skin thickens like bark. You gain the effects of a 2nd-rank *oaken resilience* spell for 10 minutes.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 36,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "07336d377bbfcf8d760f34f32f513526",
        "game-obj": "Traits",
        "name": "Consumable",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 454",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 454",
              "type": "link"
            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 125,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "651e06f09e5aea780d7c70a36ce5b1f2",
        "game-obj": "Traits",
        "name": "Plant",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 459",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 459",
              "type": "link"
            },
            "name": "Player Core",
            "page": 459,
            "type": "source"
          }
        ],
        "text": "Vegetable creatures have the plant trait. They are distinct from normal plants. Magical effects with this trait manipulate or conjure plants or plant matter in some way. Effects that manipulate plants have no effect in an area with no plants.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 130,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "6046ffa09feee37a486ec66f5e30d7a7",
        "game-obj": "Traits",
        "name": "Potion",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 459",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 459",
              "type": "link"
            },
            "name": "Player Core",
            "page": 459,
            "type": "source"
          }
        ],
        "text": "A potion is a consumable magical liquid activated when you drink it.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 134,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "60a4f011afd1e0fac8211bd01108d104",
        "game-obj": "Traits",
        "name": "Primal",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 460",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 460",
              "type": "link"
            },
            "name": "Player Core",
            "page": 460,
            "type": "source"
          }
        ],
        "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "7c548a9e0a2647c082989720b3de0a87",
        "game-obj": "Traits",
        "name": "Wood",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 463",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 463",
              "type": "link"
            },
            "name": "Player Core",
            "page": 463,
            "type": "source"
          }
        ],
        "text": "Effects with the wood trait conjure or manipulate wood. Those that manipulate wood have no effect in an area without wood. Creatures with this trait consist primarily of wood or have a connection to magical wood.  \n  \nThese planes consist of trees and other flora latticed in organic patterns. Wood planes are often perfectly constructed to match their desired purpose or environment but aren\u2019t usually outright hostile to visitors.",
        "type": "trait"
      }
    ],
    "type": "stat_block"
