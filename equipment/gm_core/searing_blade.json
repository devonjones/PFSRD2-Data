    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+2 greater striking flaming longsword* has an ornate brass hilt and a blade shaped like stylized flames. When wielded, the blade projects illumination resembling shimmering firelight, emitting dim light in a 10-foot radius.",
