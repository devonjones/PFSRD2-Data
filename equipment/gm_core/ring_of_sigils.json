    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This silver band is carved with the personal sigils of different individuals, adding one to represent you when you invest it. The ring allows you to cast *sigil* as an arcane innate cantrip.",
        "level": 1,
        "traits": [
            {
                "name": "Arcane",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 11,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 452,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "6a30ff50ed821ab5b9699b2f3d68c0d6",
                "text": "This magic comes from the arcane tradition, which is built on logic and rationality. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to arcane magic.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 98,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
                        "link": {
                            "type": "link",
                            "name": "GM Core pg. 219",
                            "alt": "GM Core pg. 219",
                            "game-obj": "Sources",
                            "aonid": 218
                        },
                        "page": 219,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
                "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
                "links": [
                    {
                        "type": "link",
                        "name": "invest",
                        "alt": "invest",
                        "game-obj": "Actions",
                        "aonid": 2799
                    }
                ],
                "classes": [
                    "trait"
                ]
            }
        ],
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "worn"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "frequency": "once per 10 minutes",
                    "effect": "You detect the general direction toward the most recent *sigil* you created using the ring. This activation fails if the *sigil* is more than 5 miles away or if there's lead or running water between you and the *sigil*.",
                    "traits": [
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                            "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions."
                        }
                    ],
                    "activation_name": "Track Sigil"
                }
            ]
        },
