    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "When you activate this alabaster pendant, attempt to Administer First Aid using Medicine with a +1 item bonus to the check. If you succeed, and you were trying to stabilize, the target regains 1 Hit Point, losing the dying condition and becoming conscious as normal. If you succeed, and you were trying to stop bleeding, the bleeding ends.",
        "level": 2,
