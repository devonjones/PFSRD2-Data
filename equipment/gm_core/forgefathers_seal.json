                        "name": "Reaction"
                    },
                    "frequency": "once per day",
                    "trigger": "You are hit by an attack",
                    "effect": "The  *Forgefather's seal* glows and your armor shakes as it absorbs the blow. The attack's damage is reduced by 100 and you cast  *earthquake* (DC 40), centered directly on the triggering creature. You decide the area of the earthquake when you Cast the Spell, from as small as the size of the creature and up to a 60-foot burst.",
                    "links": [
                        {
                            "type": "link",
                            "name": "earthquake",
                            "alt": "earthquake",
                            "game-obj": "Spells",
                            "aonid": 95
                        }
                    ],
                    "traits": [
                        {
