    "subtype": "equipment",
    "text": "This item looks like a normal trident carved with Gozren motifs. If thrown without being activated, it wobbles in the air and fails to strike true. When you Activate the trident, the carvings crackle with electricity. You then hurl the trident. It shatters immediately after leaving your hand and unleashes its magic as a 4th-rank *lightning bolt* originating from your space. The bolt deals 5d12 electricity damage and has a basic Reflex save DC of 25.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 36,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "07336d377bbfcf8d760f34f32f513526",
        "game-obj": "Traits",
        "name": "Consumable",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 454",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 454",
              "type": "link"
            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 56,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "b767873f1e57f8326b773c8d1e27cc5c",
        "game-obj": "Traits",
        "name": "Electricity",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "Effects with this trait deal electricity damage. A creature with this trait has a connection to magical electricity.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
