    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Silver weapons are a bane to creatures ranging from devils to werewolves. Silver items are less durable than steel items, and low-grade silver items are usually merely silver-plated.",
        "sections": [
            {
                "name": "Silver Items",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Silver Items** | **Hardness** | **HP** | **BT** |\n| **Thin Items** |  |\n| Low-grade | 3 | 12 | 6 |\n| Standard-grade | 5 | 20 | 10 |\n| High-grade | 8 | 32 | 16 |\n| **Items** |  |\n| Low-grade | 5 | 20 | 10 |\n| Standard-grade | 7 | 28 | 14 |\n| High-grade | 10 | 40 | 20 |\n| **Structure** |  |\n| Low-grade | 10 | 40 | 20 |\n| Standard-grade | 14 | 56 | 28 |\n| High-grade | 20 | 80 | 40 |\n\n   \n *Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
