    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *striking rune* stores destructive magic in the weapon, increasing the weapon damage dice it deals to two instead of one. For instance, a *+1 striking dagger* would deal 2d4 damage instead of 1d4 damage.  \n You can upgrade the *striking rune* already etched on a weapon to a stronger version, increasing the values of the existing rune to those of the new rune. The Price of the upgrade is the difference between the two runes' Prices.",
        "level": 4,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
