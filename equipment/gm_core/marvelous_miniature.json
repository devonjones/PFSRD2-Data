        "variants": [
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Marvelous Miniature (Campfire)",
                "level": 1,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "1 gp",
                    "value": 1,
                    "currency": "gp"
                },
                "text": "When activated, this miniature transforms into an active campfire. The campfire doesn't require attending and remains fully lit for 8 hours, though it can be quenched as any other campfire.",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
