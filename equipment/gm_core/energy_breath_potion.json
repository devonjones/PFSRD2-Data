    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Distilled from the energy of dangerous spells, an *energy breath potion* grants you the Energy Breath action for 1 hour after you imbibe the concoction. The potency of the breath depends on the potion's type, based on how long the distilled ingredients were aged. This potion has the trait matching the damage type.",
        "level": 7,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
