    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The religious symbol of Torag, the forge god\u2014an ornate hammer of dwarven construction\u2014adorns the face of this *lesser reinforcing steel shield* (Hardness 8, HP 72, BT 36). The shield is a religious symbol of Torag.  \n You and any adjacent allies have fire resistance 5 while you have the shield raised. When used for a Shield Block, the *forge warden* rings out like the hammer strike of a blacksmith, and the symbol glows as if lit by the fires of a furnace.",
        "level": 10,
        "image": {
            "type": "image",
            "name": "Forge Warden",
            "image": "Forge_Warden.webp"
        },
