    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *force barrage* of the indicated level. After you cast the spell, an additional missile or missiles are released from the wand at the start of each of your turns, as though you cast the 1-action version of *force barrage*. Choose targets each time. This lasts for 1 minute, until you\u2019re no longer wielding the wand, or until you try to activate the wand again.",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "force barrage",
              "aonid": 1536,
              "game-obj": "Spells",
              "name": "force barrage",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This wand features a carved dragon\u2019s head at its top and a polished metal sphere set in its midsection.",
    "traits": [
