      "type": "stat_block_section",
      "value": null
    },
    "craft_requirements": "Supply a casting of a spell of the appropriate rank. The spell must have a casting time of [#] or [##] and a duration no less than 10 minutes and no greater than 1 hour.",
    "level": 5,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You Cast the Spell, and its duration is increased by half.",
          "frequency": "once per day, plus overcharge; the activation takes [##] if the spell normally takes [#] to cast, or [###] if the spell normally takes [##]",
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This wand increases a spell\u2019s duration. Yellow embers spiral over its surface until the spell ends.",
    "traits": [
