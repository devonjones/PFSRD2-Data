    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This leather collar's almost threadbare look belies its magical nature. When your companion wears and invests the collar, it gains the ability to change its appearance from that of a ferocious animal into a more inconspicuous form.",
        "level": 8,
        "traits": [
