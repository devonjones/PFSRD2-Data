    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "These white silk gloves are adorned in red hearts that glow faintly whenever you are adjacent to someone you feel particularly strongly toward. They buoy your spirit, giving you a +1 item bonus to Diplomacy checks.",
        "level": 8,
        "image": {
            "type": "image",
            "name": "Lover's Gloves",
            "image": "Lovers_Gloves.webp"
        },
        "traits": [
            {
                "name": "Emotion",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
