    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *holy* weapon commands powerful celestial energy. Strikes made with it gain the holy trait and deal an extra 1d4 spirit damage, or an extra 2d4 against an unholy target. If you are unholy, you are enfeebled 2 while carrying or wielding this weapon.",
        "level": 11,
        "traits": [
            {
                "name": "Holy",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
