        "destruction": "If 10 *shots of the First Vault* are all fired at the same group of keketar or izfiitar proteans within 1 minute of each other, each shot was a hit, and the shots are then recalled, the shots collide as they attempt to re-form and crumble to dust.",
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "effect": "You recall the  *shot of the First Vault* , which automatically reloads itself into your weapon. If the shot had fragmented, the fragments violently dislodge themselves, dealing 15 persistent bleed damage to each creature in which they were embedded. The fragments then unite to re-form the  *shot of the First Vault* , which automatically reloads itself into your weapon.",
                    "requirement": "The shot is loaded in your ranged weapon, or at hand if your ranged weapon has a reload of 0",
                    "traits": [
                        {
                            "name": "Concentrate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 32,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 454",
                                        "alt": "Player Core pg. 454",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 454,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "e32d877417a40fe977d27634dc14f99f",
                            "text": "An action with this trait requires a degree of mental concentration and discipline.",
                            "schema_version": 1.1
                        }
                    ],
                    "activation_name": "Reload Order"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    },
                    "effect": "You line up a perfectly aimed attack directly toward the First Vault. You Strike a creature, then the  *shot of the First Vault* attempts to bring your target with it as it returns to the First Vault. Unless your attack roll is a critical failure, the creature must attempt a DC 45 Reflex save; this effect has the incapacitation trait. Regardless, the  *shot of the First Vault* returns to the First Vault.",
                    "links": [
                        {
                            "type": "link",
                            "name": "incapacitation",
                            "alt": "incapacitation",
                            "game-obj": "Traits",
                            "aonid": 93
                        },
                        {
                            "type": "link",
                            "name": "moved",
                            "alt": "moved",
                            "game-obj": "Rules",
                            "aonid": 451
                        },
                        {
                            "type": "link",
                            "name": "Axis",
                            "alt": "Axis",
                            "game-obj": "Planes",
                            "aonid": 14
                        }
                    ],
                    "critical_success": "The creature is unaffected.",
                    "success": "The creature is moved 1d20x50 feet in the direction you fired. If this causes it to hit a solid object, it takes 50 bludgeoning damage.",
                    "failure": "The creature is transported to a random location on the plane of Axis .",
                    "critical_failure": "The creature is transported to the First Vault. Unless it is capable of eluding Abadar's precautions, it is likely unable to escape the Vault on its own.",
                    "traits": [
                        {
                            "name": "Manipulate",
                            "type": "trait",
