            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "effect": "You cause the body to decompose into a pile of fertile soil. The creature's body is completely destroyed at the start of your next turn, and it can only be returned to life with the use of powerful magic such as  *miracle* or  *wish* .",
                    "links": [
                        {
                            "type": "link",
                            "name": "miracle",
                            "alt": "miracle",
                            "game-obj": "Spells",
                            "aonid": 196
                        },
                        {
                            "type": "link",
                            "name": "wish",
                            "alt": "wish",
                            "game-obj": "Spells",
                            "aonid": 377
                        },
                        {
                            "type": "link",
                            "name": "undead",
                            "alt": "undead",
                            "game-obj": "Traits",
                            "aonid": 160
                        }
                    ],
                    "requirement": "Your last action was a melee Strike that killed a living creature or destroyed an undead creature",
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "envision"
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "frequency": "once per hour",
                    "effect": "You pull a seed from the mask and throw it into the soil, where it sprouts. You cast  *summon plant or fungus* ; the spell is heightened to a level equal to one-half of the slain creature's level, rounded up. When the spell's duration ends, the plant creature returns to the soil, where it roots itself and becomes a non-creature piece of flora.",
                    "links": [
                        {
                            "type": "link",
                            "name": "summon plant or fungus",
                            "alt": "summon plant or fungus",
                            "game-obj": "Spells",
                            "aonid": 325
                        }
                    ],
                    "requirement": "You are adjacent to the body of a creature you killed that has decomposed into soil",
                    "destruction": "If the progenitor of all mokele-mbembes stomps on the mask, it is crushed to splinters.",
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "interact"
                        }
                    ]
                }
            ]
        },
