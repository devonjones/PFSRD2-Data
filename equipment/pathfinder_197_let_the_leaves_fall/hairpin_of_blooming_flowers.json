    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The flower that adorns this hairpin is a blooming lotus flower that varies in color; it regrows in a day after the item is activated. Whether or not the hairpin's flower is in bloom, as long as you wear it and it's invested, it grants a +1 item bonus to Diplomacy checks.",
        "level": 7,
