    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This black slime is carefully culled from coffins and sarcophagi used by the undead, and is then distilled and combined with necromantic energy, creating a dangerous sludge that leeches life force as aggressively as it rots flesh.",
        "level": 15,
        "traits": [
            {
