    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Stupor poison is a more potent distillation of lethargy poison. Further exposure to stupor poison doesn\u2019t require the target to attempt additional saving throws; only failing a saving throw against an ongoing exposure can progress its stage.",
        "level": 7,
