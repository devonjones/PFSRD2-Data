    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A glass tube of mercury is contained within this golden clasp that's fitted in front of a firearm's trigger. On the triggering Strike, the mercury turns briefly to gold, reducing the effect of recoil, allowing you to ignore the circumstance penalty of the attached weapon's kickback weapon trait.",
        "level": 5,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
