    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "An alchemical fuse is a length of treated cord that can be used to time the detonation of an alchemical bomb or a stick of pyronite, or simply as a timer\u2014at the GM's option, fuses can be used as timers to trigger other devices that can be triggered with a single appropriate action, as well.",
        "level": 1,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
