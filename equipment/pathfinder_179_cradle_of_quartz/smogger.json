    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Some mutants savor the acrid smog of Alkenstar and the Gunworks. A *smogger* recreates this pollution by sucking in clean air and spewing it back out as pungent smog.",
        "level": 9,
        "traits": [
