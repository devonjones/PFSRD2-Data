    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This treated rabbit\u2019s foot has shockingly blue fur and is often carried by vagabonds who worship Desna. When you activate the foot, reroll the triggering Reflex save. If you fail the second roll as well, you can Stride up to your Speed.",
        "level": 10,
