    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Contained in a specially enchanted small leather or hide sack, *deteriorating dust* is a potent caustic agent and a prized item among Rovagug\u2019s more discreet followers.",
        "level": 4,
        "traits": [
            {
