                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "effect": "You swing the thurible around you, spreading inky black smoke in a 20-foot emanation that has the effect of *obscuring mist*. Undead creatures can see through the smoke as if it didn\u2019t exist. Negative energy also disrupts the magic of the smoke; anyone who uses a negative effect, along with creatures affected by a negative effect, can see through the smoke for 1 round.",
                    "links": [
                        {
                            "type": "link",
                            "name": "obscuring mist",
                            "alt": "obscuring mist",
                            "game-obj": "Spells",
                            "aonid": 210
                        },
                        {
