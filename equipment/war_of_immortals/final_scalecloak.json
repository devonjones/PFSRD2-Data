              "alt": "GM Core pg. 300",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 300",
              "type": "link"
            },
            "name": "GM Core",
            "page": 300,
            "type": "source"
          }
        ],
        "text": "Items with this trait are artifacts. These magic items can't be crafted by normal means, and they can't be damaged by normal means. Artifacts are always rare or unique.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "invest",
            "aonid": 2799,
            "game-obj": "Actions",
            "name": "invest",
            "type": "link"
          }
        ],
        "name": "Invested",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 219",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 219",
              "type": "link"
            },
            "name": "GM Core",
            "page": 219,
            "type": "source"
          }
        ],
        "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "40b5d9c5e49dbe2aea5d7ecf38d950f3",
        "game-obj": "Traits",
        "name": "Mythic",
        "sources": [
          {
            "link": {
              "alt": "War of Immortals pg. 69",
              "aonid": 232,
              "game-obj": "Sources",
              "name": "War of Immortals pg. 69",
              "type": "link"
            },
            "name": "War of Immortals",
            "page": 69,
            "type": "source"
          }
        ],
        "text": "Options with this trait grant or utilize mythic power. Feats with the mythic trait can only be taken by mythic characters, who are typically characters with a mythic Calling.  \n  \n Monsters with the mythic trait have access to a pool of Mythic Points and are particularly strong for creatures of their level. Many mythic monsters are either resistant or entirely immune to attacks from non-mythic creatures and weapons.  \n  \n Spells with the mythic trait require the expenditure of a Mythic Point in order to be cast, and items with the mythic trait require the expenditure of a Mythic Point in order to use their activated abilities.  \n  \n Weapons with the mythic trait overcome the resistances and immunities of mythic monsters.",
        "type": "trait"
      }
    ],
    "type": "stat_block"
  },
  "type": "equipment"
