            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Cursed Immaculate Instrument",
                "level": 12,
                "traits": [
                    {
                        "name": "Cursed",
                        "type": "trait",
                        "alternate_link": {
                            "type": "alternate_link",
                            "game-obj": "Traits",
                            "aonid": 274,
                            "alternate_type": "legacy"
                        },
                        "edition": "remastered",
                        "sources": [
                            {
                                "type": "source",
                                "name": "GM Core",
                                "link": {
                                    "type": "link",
                                    "name": "GM Core pg. 306",
                                    "alt": "GM Core pg. 306",
                                    "game-obj": "Sources",
                                    "aonid": 218
                                },
                                "page": 306,
                                "errata": {
                                    "type": "link",
                                    "name": "2.0",
                                    "alt": "2.0",
                                    "game-obj": "Sources",
                                    "aonid": 218
                                }
                            }
                        ],
                        "game-obj": "Traits",
                        "game-id": "93177649f9920e9a2a4a80ada85b7ab1",
                        "text": "An item with this trait is cursed to cause trouble for its owner. A curse isn\u2019t detected when the item is identified, though a critical success reveals both the presence and exact nature of the curse. Cursed items can\u2019t be discarded once they\u2019ve been triggered or invested the first time. The item can be removed only if the curse is removed.",
                        "schema_version": 1.1,
                        "classes": [
                            "trait"
                        ]
                    }
                ],
                "bulk": {
                    "type": "stat_block_section",
                    "subtype": "bulk",
                    "value": null,
                    "text": "L"
                },
                "text": "This immaculate instrument has been cursed by the sublime breath it was taken from, causing it to warp, rust, or tarnish, though the holder of the instrument cannot perceive this and rationalizes away any attempt to explain the instrument's obviously cursed nature. Whenever the cursed immaculate instrument is used to produce a work, the holder must succeed on a DC 16 flat check or the work fails, leaving the holder frustrated and raising the DC of subsequent flat checks by 1. When the DC reaches 20, the work fails as normal, but the holder continues to attempt it fruitlessly to the exclusion of all other activities, including eating, drinking, and sleep, until they expire or the curse is broken.",
                "links": [
                    {
                        "type": "link",
                        "name": "sublime breath",
                        "alt": "sublime breath",
                        "game-obj": "Monsters",
                        "aonid": 3408
                    }
                ],
                "sources": [
                    {
                        "type": "source",
                        "name": "War of Immortals",
                        "link": {
                            "type": "link",
                            "name": "War of Immortals pg. 203",
                            "alt": "War of Immortals pg. 203",
                            "game-obj": "Sources",
                            "aonid": 232
                        },
                        "page": 203
                    }
                ]
            }
        ],
