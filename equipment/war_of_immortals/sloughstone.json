    "sections": [
      {
        "name": "Sloughstone",
        "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Sloughstone Items** | **Hardness** | **HP** | **BT** |\n| Thin Items |\n| Standard-grade | 8 | 36 | 18 |\n| High-grade | 11 | 48 | 24 |\n| Items |\n| Standard-grade | 12 | 50 | 25 |\n| High-grade | 15 | 62 | 31 |",
        "type": "section"
      }
    ],
    "subtype": "equipment",
    "text": "Weapons made from sloughstone exploit Verex-That-Was's hatred of his unwilling transformation, turning his own flesh against him. Processing sloughstone is difficult and unpleasant, increasing the DC to craft an item with the material by 4. Structures can't be made out of sloughstone.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 137,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "rare"
        ],
        "edition": "remastered",
        "game-id": "e4b0e4f5f4b3d4cad3bea67ec077e297",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Rare",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "This rarity indicates that a rules element is very difficult to find in the game world. A rare feat, spell, item or the like is available to players only if the GM decides to include it in the game, typically through discovery during play. Creatures with this trait are rare. They typically can't be summoned. The DC of Recall Knowledge checks related to these creatures is increased by 5.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 131,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "b55483844b400b317f798bf6000f2f95",
        "game-obj": "Traits",
        "name": "Precious",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 332",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 332",
              "type": "link"
            },
            "name": "GM Core",
            "page": 332,
            "type": "source"
          }
        ],
        "text": "Valuable materials with special properties have the precious trait. They can be substituted for base materials when you Craft items.",
        "type": "trait"
      }
    ],
