                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Mythic",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "War of Immortals",
                        "link": {
                            "type": "link",
                            "name": "War of Immortals pg. 69",
                            "alt": "War of Immortals pg. 69",
                            "game-obj": "Sources",
                            "aonid": 232
                        },
                        "page": 69
                    }
                ],
                "game-obj": "Traits",
                "game-id": "40b5d9c5e49dbe2aea5d7ecf38d950f3",
                "text": "Options with this trait grant or utilize mythic power. Feats with the mythic trait can only be taken by mythic characters, who are typically characters with a mythic Calling.  \n  \n Monsters with the mythic trait have access to a pool of Mythic Points and are particularly strong for creatures of their level. Many mythic monsters are either resistant or entirely immune to attacks from non-mythic creatures and weapons.  \n  \n Spells with the mythic trait require the expenditure of a Mythic Point in order to be cast, and items with the mythic trait require the expenditure of a Mythic Point in order to use their activated abilities.  \n  \n Weapons with the mythic trait overcome the resistances and immunities of mythic monsters.",
                "classes": [
                    "trait"
                ]
            }
        ],
