        "type": "stat_block",
        "subtype": "equipment",
        "text": "This black cooking pot can produce a feast fit for undead.",
        "level": 10,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
