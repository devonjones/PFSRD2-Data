    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This snare releases a stream of grease that coats the area, making movement difficult and potentially making the target slippery and clumsy. The square with the snare, as well as three adjacent squares you determine when you set the snare, become difficult terrain when a creature triggers the snare. The triggering creature must attempt a DC 22 Reflex saving throw. A creature can use three Interact actions to wipe away the grease from a single square or from the triggering creature; removing the grease from the triggering creature ends the effects on it.",
        "level": 5,
        "traits": [
