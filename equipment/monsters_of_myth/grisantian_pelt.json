    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Highly desired for the prestige, the pelt of the grogrisant also has invaluable properties. Standard-grade items can be made from the pelt of a grisantian lion, but high-grade items require the pelt of the grogrisant itself.  \n   \nThis supernaturally tough animal skin is gold and shines in sunlight. It can be used to make any item usually made of cloth, leather, or hide. This material is immune to fire, and its Hardness is doubled against piercing or slashing damage. Up to 4 Bulk of grisantian pelt can be harvested from a single creature (this is usually more than enough for 4 suits of standard grade armor or 2 suits of high-grade armor).",
        "sections": [
            {
                "name": "Grisantian Pelt Items",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Thin Items** | **Hardness** | **HP** | **BT** |\n| Standard-grade | 6 | 24 | 12 |\n| High-grade | 8 | 32 | 16 |\n| **Items** | **Hardness** | **HP** | **BT** |\n| Standard-grade | 9 | 36 | 18 |\n| High-grade | 11 | 44 | 22 |\n\n   \n *Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Grisantian Pelt Armor*",
                        "links": [
                            {
                                "type": "link",
                                "name": "Grisantian Pelt Armor",
                                "alt": "Grisantian Pelt Armor",
                                "game-obj": "Equipment",
                                "aonid": 1475
                            }
                        ]
                    }
                ]
            }
        ],
