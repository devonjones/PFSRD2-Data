    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This white, slender rod bears intricately carved reliefs of magnificent animals that bow and dance to some unseen commander. The baton enables you to command constructs.",
        "level": 13,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
