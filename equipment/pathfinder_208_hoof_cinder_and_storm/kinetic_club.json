    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Embedded along the length of this *+1 striking greatclub* are the teeth and scales of a zetogeki, a giant lizard that can absorb and then release bursts of kinetic energy. The more momentum a wielder builds up while swinging the weapon, the more forceful the impact when it finally makes contact.",
        "level": 7,
        "traits": [
            {
