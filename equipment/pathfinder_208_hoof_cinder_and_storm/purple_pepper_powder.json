    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This nearly black purple powder is made from the extremely spicy Kuthite\u2019s kiss pepper and is a favorite among the Sklar-Quah. When you eat a meal flavored with this purple pepper powder, you gain resistance 10 to fire and resistance 5 to poison for 1 hour.",
        "level": 8,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
