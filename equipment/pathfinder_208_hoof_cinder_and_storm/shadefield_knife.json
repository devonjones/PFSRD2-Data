    "subtype": "equipment",
    "text": "This *+1 striking dagger* made of black stone is carved from the bloodstained earth of the Shadefields and carries the grudge of the Shoanti who perished on that battlefield.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 137,
          "game-obj": "Traits",
