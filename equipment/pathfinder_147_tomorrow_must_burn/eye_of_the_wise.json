    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This fist-sized, 12-rayed black star sapphire is sacred to Yuelral, the elven goddess of magic and jewels, and most accounts of its creation attribute its crafting to a circle of her worshippers. In addition to the abilities listed below, the gem functions as a portal key for Jewelgate at Alseta's Ring.",
        "level": 11,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
