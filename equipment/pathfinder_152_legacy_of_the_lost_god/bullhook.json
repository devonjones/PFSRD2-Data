    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *bullhook* is a stout rod about 4 feet long with a blunt hook on the end. Too dull to be useful as a weapon, a *bullhook* is instead used to direct animals in training or in performing their tasks. A *bullhook* grants you an item bonus to Nature checks to Command an Animal while you are holding it.",
        "level": 3,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
