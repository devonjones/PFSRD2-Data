    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Woven from swaths of rich brocade silk and embroidered with ancient Azlanti script in golden thread, this stole imparts a noble appearance to even the homeliest of individuals when draped over the shoulders. While wearing a stole of civility, you receive a +2 item bonus to Diplomacy checks to Make an Impression with humans or Make a Request of humans, and a +2 item bonus to Intimidation checks against humans. The stole also grants you full understanding of the Azlanti language.",
        "level": 9,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
