    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This finely cut garnet brooch fills your mind with vigor and occasional bursts of mental clarity. While wearing the brooch, you gain a +1 item bonus to checks to Recall Knowledge with Lore skills.",
        "level": 8,
        "traits": [
