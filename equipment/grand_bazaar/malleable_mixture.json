    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Your bones, muscles, and organs become vastly softer and more pliable. You can fit into and through small or narrow spaces as though you were smaller than your normal size, and you gain an item bonus to your Fortitude and Reflex DCs against attempts to Grapple, Shove, or Trip you.",
        "level": 8,
