    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "You can sprinkle popdust in an empty square adjacent to you. The first creature that applies pressure to the popdust, such as by moving into that square, causes it to emit a series of thunderous cracks.",
        "level": 1,
        "traits": [
            {
                "name": "Uncommon",
