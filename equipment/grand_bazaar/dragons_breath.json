            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Free Action"
                    },
                    "effect": "If your next action is to Cast a Spell with an area of effect that deals the same type of damage as the depicted dragon's breath weapon, the spell gains the effects of the Widen Spell feat. The rune can only affect spells of a specific level or lower, determined by the type of rune.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Widen Spell",
                            "alt": "Widen Spell",
                            "game-obj": "Feats",
                            "aonid": 315
                        }
                    ],
                    "requirement": "You're receiving a bonus to AC from your  *dragon's breath* cape or shield",
                    "traits": [
                        {
                            "name": "Spellshape",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 107,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 302",
                                        "alt": "Player Core pg. 302",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 302,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "771980a2b2ed7b7e83f96ac0cf2001b5",
                            "text": "Actions with the spellshape trait tweak the properties of your spells. You must use a spellshape action directly before casting the spell you want to alter. If you use any action (including free actions and reactions) other than casting a spell directly after, you waste the benefits of the spellshape action. The benefit is also lost if your turn ends before you cast the spell. Any additional effects added by a spellshape action are part of the spell's effect, not of the spellshape action itself.",
                            "schema_version": 1.1
                        }
                    ],
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "envision"
                        }
                    ]
                }
            ]
        },
