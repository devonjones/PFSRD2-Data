    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "With its standard-grade mithral polished to a mirrorlike sheen, this *+2 resilient glamered mithral breastplate* features the religious symbols of the goddesses of the Prismatic Ray pantheon\u2014Desna, Sarenrae, and Shelyn\u2014surrounded by a rainbow-colored set of gems.",
        "level": 17,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
