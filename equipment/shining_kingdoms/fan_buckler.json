    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "When collapsed, a *fan buckler* appears to be no more than an elegant wooden fan. Any attempts to discern that there\u2019s more to the item require a successful Perception check against the Deception DC of the wielder.",
