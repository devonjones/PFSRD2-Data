    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+2 greater striking flintlock musket* is an innovation of the Platinum Wing, and possession of one by a civilian is a high crime in Andoran. The gun\u2019s secret is the chip of a warshard used as the hammer in the striking mechanism.",
        "level": 13,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
