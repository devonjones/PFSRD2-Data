    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This oversized greataxe, infamous for the chilling laughter it emits whenever it takes a life, was crafted by the frost giant sorcerer Jorngarl from the *final blade* named Toothy Morris after it was stolen in an attack on a Gray Gardener convoy. It functions as a *+3 major striking* *vorpal* *greataxe* that retains the unique properties of a *final blade*, trapping the souls of any it slays and preventing them from being returned to life by any means short of divine intervention, even a *wish* ritual or similar magic.",
        "level": 20,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 161,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
