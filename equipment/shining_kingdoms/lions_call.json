                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You cast  *locate* at 5th rank to learn the location of one of the following of your choice: the nearest Lion Blade safe house, shadow school, Lion Blade agent, Lion Blade kith, or a person other than yourself who\u2019s in possession of a  *lion\u2019s call* .",
                    "links": [
                        {
                            "type": "link",
                            "name": "locate",
                            "alt": "locate",
                            "game-obj": "Spells",
                            "aonid": 1588
                        }
