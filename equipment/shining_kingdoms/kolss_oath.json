    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This filigree grants you, as the clan dagger\u2019s owner, a +1 item bonus to Society checks and to Diplomacy checks to Request. Additionally, once per day, the filigree symbol can be activated to compel an enemy to act.",
        "level": 5,
