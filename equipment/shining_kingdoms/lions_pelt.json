                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "frequency": "once per hour",
                    "effect": "You cast *message* at 1st rank to a target that you know is also wearing a *lion\u2019s pelt* uniform. If you and the target share an insignia, the spell is heightened to 3rd rank.",
                    "links": [
                        {
