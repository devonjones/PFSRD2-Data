        "subtype": "pfs",
        "availability": "Standard",
        "note": "Characters from Kyonin have access to this option. When using a shawl of seasons, the season is the current season where the player is located."
    },
    "aonid": 3775,
    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This woven shawl changes its color, material, and abilities with the seasons. In its usual state, it reflects the current season of the environment the wearer is in. The handsome embroidery grants you a +2 item bonus to Diplomacy checks to Make an Impression.",
        "level": 5,
        "traits": [
