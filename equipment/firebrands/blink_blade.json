    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The blade of this *+2 striking dagger* is etched with whirling portals, and a single blue sapphire adorns its hilt. It feels lightweight and is always slightly warm to the touch.",
        "level": 12,
        "traits": [
            {
                "name": "Uncommon",
