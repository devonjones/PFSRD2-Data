        "type": "stat_block",
        "subtype": "equipment",
        "text": "This small vial of viscous, clear, soapy solution comes with a wand, attached to the inside of the vial's cap, with a little loop at its end. A vial has enough solution to be used 10 times.",
        "level": 3,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
