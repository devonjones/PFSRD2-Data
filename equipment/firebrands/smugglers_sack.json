      "value": 1
    },
    "level": 4,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "One Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "command"
            }
          ],
          "effect": "You speak a secret command word. Depending on which word you use, the sack either opens up to the mundane sack or the extradimensional pocket. You can Interact to put items in or remove them as normal.",
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "access": {
        "subtype": "access",
        "text": "Second-mark members of the Firebrands have access to this item.",
        "type": "stat_block_section"
      },
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 2 hands",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This specialized version of a bag of holding appears to be a plain, leather bag that opens at the top, with a thin leather cord attached to cinch the sack closed. The sack's magic allows you to access either its mundane space or an extradimensional pocket. The mundane space inside the sack always holds 5 Bulk. The pocket's capacity varies with the type of sack. Anyone searching the bag can notice a thin, magical seam indicating the existence of the extradimensional space with a successful DC 18 Perception check.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "uncommon"
        ],
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "9011037bb4a11ca6cf2d16fa8a657bf5",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "summoning",
            "aonid": 154,
            "game-obj": "Traits",
            "name": "summoning",
            "type": "link"
          },
          {
            "alt": "teleportation",
            "aonid": 156,
            "game-obj": "Traits",
            "name": "teleportation",
            "type": "link"
          }
        ],
        "name": "Conjuration",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 630",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 630",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 630,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait are associated with the conjuration school of magic, typically involving summoning, creation, teleportation, or moving things from place to place.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 67,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "46827b9b4aa4cfb0f4976f396f641f0e",
        "game-obj": "Traits",
        "name": "Extradimensional",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 456",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 456",
              "type": "link"
            },
            "name": "Player Core",
            "page": 456,
            "type": "source"
          }
        ],
        "text": "This effect or item creates an extradimensional space. An extradimensional effect placed inside another extradimensional space ceases to function until it is removed.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      }
    ],
