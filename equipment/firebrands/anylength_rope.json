    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This 50-foot length of silk rope is lightweight and appears to be inlaid with golden threads. The rope can hold up to 3,000 pounds and is particularly durable, with a Hardness of 5 and 24 Hit Points.",
        "level": 3,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
