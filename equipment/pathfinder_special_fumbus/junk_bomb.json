    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This volatile-looking bomb is cobbled together from jagged metal scrap, broken glass, and other bits of razor-sharp fragments, lashed around a core of explosive alchemical slag. A junk bomb deals the listed slashing damage, persistent bleed damage, and piercing splash damage. Many types grant an item bonus to attack rolls.",
        "level": 1,
        "traits": [
