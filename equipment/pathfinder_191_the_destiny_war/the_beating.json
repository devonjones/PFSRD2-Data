    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*The Beating* symbolizes attack from all sides. If you have *The Beating* invested, whenever you and an ally are flanking a foe, your melee Strikes gain a +2 item bonus to damage. This increases to a +3 item bonus at 17th level.",
