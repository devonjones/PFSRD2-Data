    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*The Marriage* symbolizes a union of body, mind, spirit, or any of the three. When *The Marriage* is invested, you gain a +2 item bonus to attempts made to Request. This increases to a +3 item bonus at 17th level.",
        "level": 20,
