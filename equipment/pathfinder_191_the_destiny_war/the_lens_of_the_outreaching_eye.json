    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "As long as you have the *Lens of the Outreaching Eye* invested, the Harrowed Realm's impediments to magic don't apply to you, and you gain a +3 item bonus on all checks made to resolve divination effects.",
        "level": 20,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
