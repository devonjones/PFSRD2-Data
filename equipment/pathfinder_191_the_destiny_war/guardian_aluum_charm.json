                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "The charm grants you control over an aluum you can see within 60 feet, as long as the target aluum is level 13 or less. This has the effect of *dominate* and allows a DC 28 Will save. If the aluum is currently under the control of someone wearing its linked charm, its saving throw is one degree higher than what is rolled. You can control only one aluum at a time with this activation, and controlling a new aluum ends the effect for one you had previously affected.",
                    "links": [
                        {
                            "type": "link",
                            "name": "dominate",
                            "alt": "dominate",
                            "game-obj": "Spells",
                            "aonid": 87
                        }
                    ],
