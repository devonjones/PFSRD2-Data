    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This set of bronze bells bear engravings with symbols representing the word \u201cawaken.\u201d Among kotodama magic users, who seek to touch the souls of objects using the power of words, the peals of these bells are known to awaken the spirits of even inanimate objects.",
        "level": 4,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f31704572455b8d77a8bd97c0045fde6",
                "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "classes": [
                    "uncommon"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            }
        ],
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "held in 1 hand"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You ring the bell and focus on an object of negligible Bulk within 10 feet. The bell\u2019s toll animates the object for 24 hours. The object becomes a minion that can\u2019t attack but can move and take simple Interact actions appropriate for an item of its type, as determined by the GM. For example, a piece of chalk can write a message or draw a symbol, a hand fan can open or fan in a particular direction, or a magnifying glass can set itself up to dramatically reveal incriminating evidence. The animated item has AC 5, 5 Hit Points, a Speed of 10 feet, and automatically fails all saves. If the object is broken , it can no longer move, though it can still Interact as appropriate for an item of its type. As normal with minions you control, you must Command the object to grant it actions.",
                    "links": [
                        {
                            "type": "link",
                            "name": "minion",
                            "alt": "minion",
                            "game-obj": "Traits",
                            "aonid": 653
                        },
                        {
                            "type": "link",
                            "name": "Interact",
                            "alt": "Interact",
                            "game-obj": "Actions",
                            "aonid": 2297
                        },
                        {
                            "type": "link",
                            "name": "broken",
                            "alt": "broken",
                            "game-obj": "Conditions",
                            "aonid": 60
                        }
                    ],
                    "traits": [
                        {
                            "name": "Auditory",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 16,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 453",
                                        "alt": "Player Core pg. 453",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 453,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "84c09922ddd30f2144494f2cb6f19412",
                            "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound."
                        },
                        {
                            "name": "Concentrate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 32,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 454",
                                        "alt": "Player Core pg. 454",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 454,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "e32d877417a40fe977d27634dc14f99f",
                            "text": "An action with this trait requires a degree of mental concentration and discipline."
                        },
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                            "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions."
                        }
                    ],
                    "activation_name": "Awaken the Soul"
                }
