    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Peachwood, often cultivated by Pharasmin priests, can ward against undead\u2014even incorporeal ones. However, the wood loses its magical properties when it comes in contact with metal, requiring advanced carpentry to make full use of it.",
        "sections": [
            {
                "name": "",
                "type": "section",
                "text": "| Peachwood Items | Hardness | HP | BT |\n| --- | --- | --- | --- |\n| **Thin Items** |  |\n| Standard-grade | 4 | 16 | 6 |\n| High-grade | 24 | 32 | 12 |\n| **Items** |  |\n| Standard-grade | 5 | 20 | 10 |\n| High-grade | 8 | 32 | 16 |\n| **Structures** |  |\n| Standard-grade | 12 | 48 | 24 |\n| High-grade | 18 | 64 | 32 |\n\n   \n*Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Peachwood Weapon*",
                        "links": [
