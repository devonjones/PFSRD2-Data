    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "White, pillowy dough surrounds an interior containing minced meats, spices, and herbs. The dough is steamed with elemental magic to make it light and airy while keeping the meaty center moist. When you consume a bun, a set of small clouds form around your feet that grant you a *fly* Speed of 30 feet or your speed, whichever is lower, for 1 round.",
        "level": 4,
        "image": {
            "type": "image",
            "name": "Cloud Buns",
            "image": "Cloud_Buns.webp"
        },
        "traits": [
            {
