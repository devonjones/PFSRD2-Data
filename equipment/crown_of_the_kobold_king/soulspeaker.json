                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "7a03232791db31528747d8a9f9463fd9",
                "text": "Effects and magic items with this trait involve false sensory stimuli.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 98,
