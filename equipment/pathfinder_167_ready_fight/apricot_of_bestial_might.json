                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core 2",
                        "link": {
                            "type": "link",
                            "name": "Player Core 2 pg. 289",
                            "alt": "Player Core 2 pg. 289",
                            "game-obj": "Sources",
                            "aonid": 227
                        },
                        "page": 289,
                        "errata": {
                            "type": "link",
