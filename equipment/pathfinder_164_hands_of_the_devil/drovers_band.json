    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This black leather wrist guard has a bright red gem on the inside of the wrist. Faint glyphs and words of domination in Infernal swim inside the gem. Your words become harsh and clipped when you have this magic item invested.",
        "level": 7,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
