    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This complex toxin makes the muscles beneath a creature's skin loose and malleable, which fleshwarpers find useful in their work. Rough or jerky movements the victim performs concentrate the toxin in subdermal muscles and eventually cause skin and muscle to slough away.",
        "level": 7,
        "traits": [
