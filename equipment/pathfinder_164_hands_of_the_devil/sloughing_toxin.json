            "stages": [
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 1",
                    "text": "1d6 poison damage for each action with the attack or move trait the victim uses (1 round)"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 2",
                    "text": "1d6 poison damage and 1d6 slashing damage for each action with the attack, manipulate, or move trait the victim uses (1 round)"
                },
