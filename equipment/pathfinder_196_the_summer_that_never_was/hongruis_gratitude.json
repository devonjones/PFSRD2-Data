            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    },
                    "frequency": "once per day",
                    "effect": "With a wave of the cloak to the left, you cause the image of the lantern-holding companion on the cloak to vanish. A floating red lantern appears at your side and follows you at an arm's length while casting bright light in a 20-foot radius (and dim light for the next 20 feet) like a torch . For 1 hour, while the light from this lantern is active, you gain a +1 item bonus to Diplomacy checks. You can Activate the cloak again to dismiss the torch.",
                    "links": [
                        {
                            "type": "link",
                            "name": "bright light",
                            "alt": "bright light",
                            "game-obj": "Rules",
                            "aonid": 407
                        },
                        {
                            "type": "link",
                            "name": "dim light",
                            "alt": "dim light",
                            "game-obj": "Rules",
                            "aonid": 408
                        },
                        {
                            "type": "link",
                            "name": "torch",
                            "alt": "torch",
                            "game-obj": "Equipment",
                            "aonid": 60
                        },
                        {
                            "type": "link",
                            "name": "Diplomacy",
                            "alt": "Diplomacy",
                            "game-obj": "Skills",
                            "aonid": 6
                        }
                    ],
                    "requirement": "You don't have the umbrella activation of this cloak active",
                    "traits": [
                        {
                            "name": "Evocation",
                            "type": "trait",
                            "edition": "legacy",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Core Rulebook",
                                    "link": {
                                        "type": "link",
                                        "name": "Core Rulebook pg. 631",
                                        "alt": "Core Rulebook pg. 631",
                                        "game-obj": "Sources",
                                        "aonid": 1
