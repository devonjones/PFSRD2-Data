                                    "page": 631,
                                    "errata": {
                                        "type": "link",
                                        "name": "4.0",
                                        "alt": "4.0",
                                        "game-obj": "Sources",
                                        "aonid": 1
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "01bf3e53d6c0fc7f70419341635bfe8f",
                            "text": "Effects and magic items with this trait are associated with the evocation school of magic, typically involving energy and elemental forces.",
                            "schema_version": 1.1
                        },
                        {
                            "name": "Light",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 100,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "dd40587ebc07c2b386aa95d93fdcc130",
                            "text": "Light effects overcome non-magical darkness in the area and can counteract magical darkness. You must usually target darkness magic with your light magic directly to counteract the darkness, but some light spells automatically attempt to counteract darkness.",
                            "schema_version": 1.1
                        }
                    ],
