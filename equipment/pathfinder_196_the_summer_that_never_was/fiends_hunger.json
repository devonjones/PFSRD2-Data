          "name": "Activate",
          "subtype": "activation",
          "success": "The creature becomes distracted by vengeful spirits and becomes flat-footed until the start of your next turn.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 48,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
              "game-obj": "Traits",
              "name": "Divine",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
              "type": "trait"
            },
            {
              "edition": "legacy",
              "game-id": "67a22784fdff12403013a5af60fb8621",
              "game-obj": "Traits",
              "name": "Enchantment",
              "sources": [
                {
                  "errata": {
                    "alt": "4.0",
                    "aonid": 1,
                    "game-obj": "Sources",
                    "name": "4.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Core Rulebook pg. 631",
                    "aonid": 1,
                    "game-obj": "Sources",
                    "name": "Core Rulebook pg. 631",
                    "type": "link"
                  },
                  "name": "Core Rulebook",
                  "page": 631,
                  "type": "source"
                }
              ],
              "text": "Effects and magic items with this trait are associated with the enchantment school of magic, typically involving mind control, emotion alteration, and other mental effects.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 106,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a1f80610baa3617c1597f49c6406313",
              "game-obj": "Traits",
              "name": "Mental",
              "sources": [
                {
