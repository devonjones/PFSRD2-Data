    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The blade of this *+1 low-grade silver dagger* has a sickly red tinge. Though once used to send souls to empower Kugaptee, the fury of those slain by the blade now allow its wielder to periodically strike back against fiends.",
        "level": 4,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
