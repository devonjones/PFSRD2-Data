                            "name": "slowed 1",
                            "alt": "slowed 1",
                            "game-obj": "Conditions",
                            "aonid": 35
                        }
                    ],
                    "failure": "As success, but the creature is also slowed 1 for 1 round.",
                    "critical_failure": "As failure, but the creature is slowed 1 for 1 minute.",
