        "variants": [
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Exploration Lens (Detecting)",
                "level": 10,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "1,000 gp",
                    "value": 1000,
                    "currency": "gp"
                },
                "text": "When held up to light, this lens sparkles as though infused with glitter. While Detecting Magic in exploration mode, when the lantern's light falls upon something you detect as magical, it pulsates faintly. This makes it easier to triangulate the magic, since you can use the cone of the bull's-eye lantern instead of the circular pulse of detect magic . You also gain a +2 item bonus to checks to Identify Magic within the light.",
                "links": [
                    {
                        "type": "link",
                        "name": "Detecting Magic",
                        "alt": "Detecting Magic",
                        "game-obj": "Actions",
                        "aonid": 513
                    },
                    {
                        "type": "link",
                        "name": "detect magic",
                        "alt": "detect magic",
                        "game-obj": "Spells",
                        "aonid": 66
                    },
                    {
                        "type": "link",
                        "name": "Identify Magic",
                        "alt": "Identify Magic",
                        "game-obj": "Actions",
                        "aonid": 24
                    }
                ],
                "sources": [
