    "subtype": "equipment",
    "text": "*Red Hand\u2019s Satchel* is an *alchemist\u2019s haversack*, with a main section containing an extradimensional space like that of a *type IV spacious pouch*.  \n  \nOnce restored, the satchel gains the following activation.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 161,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "unique"
        ],
        "edition": "remastered",
        "game-id": "a179d6a05b0c814096f81ec4373a54f6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Unique",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 253,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "19f6eb51879c14d91e272262da89e4b5",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "rare",
            "aonid": 137,
            "game-obj": "Traits",
            "name": "rare",
            "type": "link"
          },
          {
            "alt": "unique",
            "aonid": 161,
            "game-obj": "Traits",
            "name": "unique",
            "type": "link"
          }
        ],
        "name": "Artifact",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 300",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 300",
              "type": "link"
            },
            "name": "GM Core",
            "page": 300,
            "type": "source"
          }
        ],
        "text": "Items with this trait are artifacts. These magic items can't be crafted by normal means, and they can't be damaged by normal means. Artifacts are always rare or unique.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 48,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
        "game-obj": "Traits",
        "name": "Divine",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 67,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "46827b9b4aa4cfb0f4976f396f641f0e",
        "game-obj": "Traits",
        "name": "Extradimensional",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 456",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 456",
              "type": "link"
            },
            "name": "Player Core",
            "page": 456,
            "type": "source"
          }
        ],
        "text": "This effect or item creates an extradimensional space. An extradimensional effect placed inside another extradimensional space ceases to function until it is removed.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
