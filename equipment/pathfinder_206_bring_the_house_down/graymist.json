    "subtype": "equipment",
    "text": "*Graymist* functions as a *shadowmist cape*.  \n  \nOnce restored, *Graymist* gains these activations.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 161,
          "game-obj": "Traits",
          "type": "alternate_link"
