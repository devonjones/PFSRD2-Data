              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 10,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "8e708d4bca8c2edff7145cfce00a706e",
        "game-obj": "Traits",
        "name": "Apex",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 270",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 270",
              "type": "link"
            },
            "name": "GM Core",
            "page": 270,
            "type": "source"
          }
        ],
        "text": "When you Invest an Item that has the apex trait, it improves one of your attributes, either increasing the attribute\u2019s modifier by 1 or to a total of +4, whichever would give you a higher score. This gives you all the benefits of the new attribute modifier until the investiture runs out: increasing Intelligence lets you become trained in an additional skill and learn a new language, increasing Constitution gives you more Hit Points, and so on.  \n  \nAn apex item grants this benefit only the first time it\u2019s invested within a 24-hour period, and you can benefit from only one apex item at a time. If you attempt to invest an apex item when you already have one invested, you don\u2019t gain the attribute modifier increase, though you do gain any other effects of Investing the Item.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 253,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "19f6eb51879c14d91e272262da89e4b5",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "rare",
            "aonid": 137,
            "game-obj": "Traits",
            "name": "rare",
            "type": "link"
          },
          {
            "alt": "unique",
            "aonid": 161,
            "game-obj": "Traits",
            "name": "unique",
            "type": "link"
          }
        ],
        "name": "Artifact",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 300",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 300",
              "type": "link"
            },
            "name": "GM Core",
            "page": 300,
            "type": "source"
          }
        ],
        "text": "Items with this trait are artifacts. These magic items can't be crafted by normal means, and they can't be damaged by normal means. Artifacts are always rare or unique.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 48,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
        "game-obj": "Traits",
        "name": "Divine",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 280,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "79cfb7c5696e4ac278aba88f7237a815",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "rare",
            "aonid": 137,
            "game-obj": "Traits",
            "name": "rare",
            "type": "link"
          },
          {
            "alt": "unique",
            "aonid": 159,
            "game-obj": "Traits",
            "name": "unique",
            "type": "link"
          }
        ],
        "name": "Intelligent",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 304",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 304",
              "type": "link"
            },
            "name": "GM Core",
            "page": 304,
            "type": "source"
          }
        ],
        "text": "An item with this trait is intelligent and has its own will and personality, as well as several statistics that most items don\u2019t have. Intelligent items can\u2019t be crafted by normal means, and they are always rare or unique.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "invest",
            "aonid": 2799,
            "game-obj": "Actions",
            "name": "invest",
            "type": "link"
          }
        ],
        "name": "Invested",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 219",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 219",
              "type": "link"
            },
            "name": "GM Core",
            "page": 219,
            "type": "source"
          }
        ],
        "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
        "type": "trait"
      }
    ],
