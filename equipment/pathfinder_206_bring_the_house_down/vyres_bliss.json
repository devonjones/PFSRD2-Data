                "game-obj": "Traits",
                "game-id": "31b1fcebcaa04711c9f0d282aa02bfee",
                "text": "An effect with this trait delivers a poison or deals poison damage. An item with this trait is poisonous and might cause an affliction.",
                "schema_version": 1.1,
