    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking tekko-kagi* resembles a clawed skeletal hand that fits over your own. Embedded in the back of the bony hand is an onyx gemstone held in place by fine silver chains. When the claws tear into a living creature, the gem pulses with negative energy. The *skeletal claw* deals an additional 1d4 persistent negative damage to living creatures (1d10 persistent negative damage on a critical hit).",
        "level": 9,
        "traits": [
