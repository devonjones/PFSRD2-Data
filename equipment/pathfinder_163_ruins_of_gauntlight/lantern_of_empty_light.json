            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You direct the lantern's light upon a single living creature within 60 feet. That creature must attempt a DC 20 Will save to resist the light's effects.",
                    "critical_success": "The creature is unaffected and realizes that you attempted to mentally influence them with the light.",
                    "success": "The creature is unaffected but thinks the light was harmless, unless it knows the true nature of the lantern already.",
                    "failure": "The creature becomes fascinated by the lantern's light, and remains fascinated as long as you Sustain the Activation, up to 10 minutes.",
                    "links": [
                        {
                            "type": "link",
                            "name": "fascinated",
                            "alt": "fascinated",
                            "game-obj": "Conditions",
                            "aonid": 14
                        }
                    ],
                    "critical_failure": "As failure, but you can Sustain the Activation for up to 1 hour. When the effect ends, the fascinated creature remembers any events that took place while fascinated only as indistinct, dream-like memories.",
                    "traits": [
                        {
                            "name": "Emotion",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 60,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 455",
                                        "alt": "Player Core pg. 455",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 455,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "fb5f8b3d849b073e1514a6a025810470",
                            "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects."
                        },
                        {
                            "name": "Visual",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
