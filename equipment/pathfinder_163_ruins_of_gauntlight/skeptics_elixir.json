    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This elixir sharpens your mind and allows you to see through lies, falsehoods, and magical trickery. You gain an item bonus to Perception checks and Perception DCs to notice falsehoods, whether they're spoken lies or written deceit. You gain this same item bonus to Will saves.",
        "level": 1,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
