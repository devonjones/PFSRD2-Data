                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per hour",
                    "effect": "You read aloud a phrase from the book and target a single incorporeal undead creature within 30 feet. That undead creature takes 5d6 positive damage (DC 27 basic Will save) as portions of their incorporeal being are consumed in patches of seven equally spaced holes. Each time you use this ability after the first in a 24-hour period, you are exposed to the Empty Death.",
