    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This sharp-taloned *+1 striking spiked gauntlet* appears to have been crafted from dragon scales, with claws built from iron. In addition to the typical weapon traits, a *Cinderclaw gauntlet* has the versatile S trait.  \n  \n On a critical hit, the *Cinderclaw gauntlet* deals an additional 1d6 fire damage.",
        "level": 5,
        "traits": [
