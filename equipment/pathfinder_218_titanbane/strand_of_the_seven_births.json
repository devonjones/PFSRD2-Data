                            "name": "auditory",
                            "alt": "auditory",
                            "game-obj": "Traits",
                            "aonid": 541
                        },
                        {
                            "type": "link",
                            "name": "fascinated",
                            "alt": "fascinated",
                            "game-obj": "Conditions",
                            "aonid": 72
                        },
