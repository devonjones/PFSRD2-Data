    "subtype": "equipment",
    "text": "This stout staff is made from gnarled hawthorn. When used as a weapon, a *staff of nature's vengeance* permanently has the effects of *shillelagh*.",
    "traits": [
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "01bf3e53d6c0fc7f70419341635bfe8f",
        "game-obj": "Traits",
        "name": "Evocation",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
