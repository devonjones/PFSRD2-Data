                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "effect": "You transfer the scroll\u2019s energy into the scroll case, consuming the scroll, and you can immediately begin casting one of the scroll case\u2019s spells. If you use any action other than to Cast a Spell from the scroll case after activating the  *scroll case of simplicity* , the scroll and its energy are lost.",
                    "requirement": "The scroll case contains a single scroll of a 1st-level spell",
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "interact"
                        }
                    ]
                }
            ]
        },
