            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "frequency": "once per day",
                    "effect": "While conversing or otherwise casually interacting with other creatures, you can adjust the mantle\u2019s clasp to modify those creatures\u2019 recollections of the last 5 minutes of their interaction with you. Each creature must attempt a DC 25 Will save.",
                    "requirement": "You are Impersonating someone else",
                    "critical_success": "The creature recalls the interaction clearly and realizes you were trying to alter their memory.",
                    "success": "The creature recalls the interaction clearly.",
                    "failure": "You decide whether or not the creature recalls the interaction. You can also alter minor details the creature recalls about the interaction, such as the time, place, and whether the interaction was favorable, as determined by the GM.",
                    "critical_failure": "You decide whether or not the creature recalls the interaction. You can also alter major details the creature recalls about the interaction, such as believing you to be another individual or that the creature agreed to a favor, as determined by the GM.",
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "envision"
                        },
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "interact"
                        }
                    ],
                    "activation_time": "1 minute"
                }
            ]
        },
