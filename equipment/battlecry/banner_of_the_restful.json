    "subtype": "equipment",
    "text": "This peach-colored magical banner offers the promise of a good watch and a comfortable sleep. You and allies within the banner\u2019s aura gain a +1 item bonus to Perception DCs and protection from severe cold and heat.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
