    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "When you are wearing this armor, you\u2019re a veritable battering ram. This *+3 greater resilient fortification full plate* is topped with a reinforced helmet shaped like a ram\u2019s head that enables you to smash through doors and gates.",
        "level": 19,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
