    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 studded leather armor* was specially designed for removing locusts and similar vermin that had swarmed over portions of the battlefield. It\u2019s fully sealed along all of its seams with extra stitching and care, granting a +1 item bonus to Reflex saving throws against Swarming Bites, Swarming Stings, and similar abilities from swarms. In addition, you can create a cloud of smoke that can drive swarms from the area.",
        "level": 8,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 98,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
                        "link": {
