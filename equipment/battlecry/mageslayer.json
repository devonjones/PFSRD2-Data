    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This roughly forged *+1 striking scimitar* is a favorite instrument of battlefield operatives seeking to weaken an enemy\u2019s forces by strategically eliminating their magical support. A mageslayer deals an additional 1d6 spirit damage to any creature it Strikes that\u2019s capable of casting spells from the arcane tradition. When wearing or wielding a mageslayer, you gain resistance 5 to damage from spells from the arcane tradition.",
        "level": 8,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
