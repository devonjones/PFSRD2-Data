    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Gaudy and sparkling, these intricately decorated epaulets have clearly never seen a battlefield. Worn by officers with more schooling or connections than actual fighting experience, these epaulets grant you a +1 item bonus to Society and Warfare Lore checks.",
        "level": 5,
        "traits": [
            {
                "name": "Fortune",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 76,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
