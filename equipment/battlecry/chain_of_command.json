    "subtype": "equipment",
    "text": "This *+1 striking spiked chain*, strung with bloodied military insignia and other grisly trophies harvested from slain soldiers, is commonly used by hobgoblin commandants to motivate their troops. On a critical hit, the chain of command deals an additional 1d6 mental damage.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
