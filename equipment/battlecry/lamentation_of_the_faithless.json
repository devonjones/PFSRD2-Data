                            "alt": "slowed",
                            "game-obj": "Conditions",
                            "aonid": 92
                        },
                        {
                            "type": "link",
                            "name": "blinded",
                            "alt": "blinded",
                            "game-obj": "Conditions",
                            "aonid": 59
                        }
                    ],
                    "critical_success": "The creature is unaffected.",
                    "success": "The creature is stricken by crushing despair. It becomes slowed 1 as it sobs uncontrollably, and it can\u2019t use reactions while it\u2019s slowed.",
                    "failure": "As success, but the creature is also blinded for 1 round.",
                    "critical_failure": "As failure, but the duration of the blinded condition is 1 minute.",
                    "traits": [
                        {
                            "name": "Manipulate",
                            "type": "trait",
