            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "frequency": "once per day",
                    "effect": "A gas-filled balloon pops out of the back of your armor and begins to inflate. It takes 10 minutes for the balloon to fully inflate and lift you and up to 5 additional Bulk 5 feet off the ground. By taking another 10 minutes, this balloon can be deflated and properly stowed in the back of your armor. Once inflated, you can spend an action that has the manipulate and move traits to adjust the height you are hovering up or down by up to 20 feet each time. If the balloon takes damage (AC 10, Hardness 0), it will quickly deflate and cause you to fall to the ground. The balloon magically repairs itself at the start of each day.",
                    "links": [
                        {
                            "type": "link",
                            "name": "manipulate",
                            "alt": "manipulate",
                            "game-obj": "Traits",
                            "aonid": 645
                        },
                        {
                            "type": "link",
                            "name": "move",
                            "alt": "move",
                            "game-obj": "Traits",
                            "aonid": 658
                        }
                    ],
                    "traits": [
                        {
                            "name": "Air",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 5,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 452",
                                        "alt": "Player Core pg. 452",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 452,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "8ca8a0ac0e16b3c136f09ca48d8578bb",
                            "text": "Effects with the air trait either manipulate or conjure air. Those that manipulate air have no effect in a vacuum or an area without air. Creatures with this trait consist primarily of air or have a connection to magical air.   \n  \nPlanes with this trait consist mostly of open spaces and air of various levels of turbulence, though they also contain rare islands of floating stone and other elements and energies. Air planes usually have breathable atmospheres, though they might include clouds of acidic or toxic gas. Earth creatures often find themselves at a disadvantage within air planes, as there\u2019s little solid ground for them to gain their bearings, which tends to at least make them uncomfortable."
                        },
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                            "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions."
                        }
                    ],
                    "activation_time": "10 minutes",
                    "activation_name": "Inflate"
                }
            ]
        },
