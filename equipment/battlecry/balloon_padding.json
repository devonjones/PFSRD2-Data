    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 padded armor* enables you to hover above the ground and either drift with the wind or be pulled along by another creature or vehicle.",
        "level": 8,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
