    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This white vest has a large crimson bloodstain that can never be removed. Imbued with the anguish of a comrade who bled to death in the creator\u2019s arms, a *bloodstained waistcoat* helps prevent you and your fellow soldiers from suffering the same fate. Your flat check to remove persistent bleed damage is DC 10 instead of DC 15, which is reduced to DC 5 if another creature uses a particularly appropriate action to help.",
        "level": 4,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
