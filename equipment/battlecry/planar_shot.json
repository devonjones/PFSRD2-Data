    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Within each planar shot is a small gem magically linked to one of the following elemental planes: air (electricity), earth (acid), fire (fire), metal (electricity), water (cold), or wood (vitality), chosen when the shot is crafted. This gem shatters upon impact, dealing an additional 1d10 damage of the corresponding type. Any creature that critically fails its Reflex save also takes 1d10 persistent damage of the same type.",
        "level": 8,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
