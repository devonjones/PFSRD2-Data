                    ],
                    "effect": "Your collar inflates, giving you something to breathe from. You can breathe underwater for 1 minute.",
                    "traits": [
                        {
                            "name": "Air",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 5,
