            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Free Action"
                    },
                    "trigger": "You hit and damage an undead creature with an  *undead scourge*",
                    "links": [
                        {
                            "type": "link",
                            "name": "undead",
                            "alt": "undead",
                            "game-obj": "Traits",
                            "aonid": 722
                        },
                        {
                            "type": "link",
                            "name": "counteracts",
                            "alt": "counteracts",
                            "game-obj": "Rules",
                            "aonid": 3280
                        }
                    ],
                    "effect": "You disrupt the undead\u2019s connection to void energy. For 1 minute, the undead damaged with the dagger can\u2019t be healed by void energy unless the effect attempting to heal the undead first counteracts the undead scourge\u2019s effect, which has a counteract rank of 4th and a DC of 25. Vitality energy still has the usual effects on the undead.",
                    "traits": [
                        {
                            "name": "Concentrate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 32,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 454",
                                        "alt": "Player Core pg. 454",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 454,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "e32d877417a40fe977d27634dc14f99f",
                            "text": "An action with this trait requires a degree of mental concentration and discipline."
                        },
                        {
                            "name": "Divine",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 48,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 455",
                                        "alt": "Player Core pg. 455",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 455,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
                            "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic."
                        },
                        {
                            "name": "Vitality",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 128,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 463",
                                        "alt": "Player Core pg. 463",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 463,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6571a8a0a7aae945b34252db53de1861",
                            "text": "Effects with this trait heal living creatures with energy from the Forge of Creation, deal vitality energy damage to undead, or manipulate vitality energy.  \n  \nThese planes are awash with life energy. Colors are brighter, fires are hotter, noises are louder, and sensations are more intense. At the end of each round, an undead creature takes at least minor vitality environmental damage. In the strongest areas of a vitality plane, they could take moderate or even major vitality damage instead. While this might seem safe for living creatures, vitality planes present a different danger. Living creatures regain an amount of HP each round equal to the environmental damage undead take in the same area. If this would bring the living creature above their maximum HP, any excess becomes temporary HP. Unlike normal, these temporary HP combine with each other, and they last until the creature leaves the plane. If a creature\u2019s temporary HP from a vitality plane ever exceeds its maximum HP, it explodes in a burst of overloaded vitality energy, spreading across the area to birth new souls.",
                            "links": [
                                {
                                    "type": "link",
                                    "name": "undead",
                                    "alt": "undead",
                                    "game-obj": "Traits",
                                    "aonid": 160
                                }
                            ]
                        }
                    ],
                    "activation_name": "Sever from the Void"
                }
            ]
        },
