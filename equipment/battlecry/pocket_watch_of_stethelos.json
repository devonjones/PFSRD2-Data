    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This brass pocket watch has an unusually complex winding mechanism, and the name inscribed on the back, as well as the numbers on the face, are written in a language no one can identify. Repeated use of the pocket watch attracts the attention of terrible creatures of the Dimension of Time.",
        "level": 8,
