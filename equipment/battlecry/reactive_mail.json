    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Often heavily battle scared from use, this chain mail is commonly issued to frontline soldiers who are tasked with battling through enemies to reach high-value targets across the battlefield.",
        "level": 5,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
