            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Reaction"
                    },
                    "frequency": "once per hour",
                    "trigger": "A creature within 15 feet uses a manipulate action",
                    "links": [
                        {
                            "type": "link",
                            "name": "manipulate",
                            "alt": "manipulate",
                            "game-obj": "Traits",
                            "aonid": 645
