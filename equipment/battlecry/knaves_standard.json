    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This magical banner is dip-dyed in an ombre from black to red, mottled and uneven. Whenever you or an ally within the banner\u2019s aura critically succeeds with a Strike against an off-guard target, the Strike deals an additional 1d4 precision damage.",
        "level": 4,
