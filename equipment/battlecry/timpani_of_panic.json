          },
          "activation_name": "Sustain Dread",
          "critical_failure": "As failure, and it becomes frightened 1.",
          "critical_success": "The creature is unaffected.",
          "effect": "You beat a march on the timpani that continuously increases in tempo. Enemies within a 30-foot emanation must attempt a DC 26 Will save.",
          "failure": "The target can\u2019t reduce its frightened value below 1 for 1 minute.",
          "frequency": "once per day",
