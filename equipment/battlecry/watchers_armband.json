    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Soldiers who wear this burgundy armband serve as law enforcement within the ranks of a nation\u2019s military, seeking out those who would commit crimes while in uniform. While wearing the armband, you gain a +2 item bonus to your Perception DC against Deception checks to Lie to you. In addition, you can cast ring of truth once per day as an innate 3rd-rank occult spell.",
        "level": 8,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
