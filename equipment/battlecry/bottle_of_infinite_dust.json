    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This plain, faintly green bottle full of sand looks deceptively mundane, though it contains a near endless supply of sand. A very slow but steady stream of sand can be poured from the bottle. Up to 1 pound of sand can be produced a day this way.",
        "level": 7,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            }
        ],
        "price": {
            "type": "stat_block_section",
            "subtype": "price",
            "text": "350 gp",
            "value": 350,
            "currency": "gp"
        },
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "held in 1 hand"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per hour",
                    "effect": "You aim the bottle and unleash a blast of sand. Scouring grit is released in a 15-foot cone, dealing 4d4 slashing damage to all creatures in the area (DC 23 basic Reflex save).",
                    "links": [
                        {
                            "type": "link",
                            "name": "cone",
                            "alt": "cone",
                            "game-obj": "Rules",
                            "aonid": 2386
                        }
                    ],
                    "traits": [
                        {
                            "name": "Earth",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 55,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 455",
                                        "alt": "Player Core pg. 455",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 455,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "c0ece3ed45c1990f2753e00341d335da",
                            "text": "Effects with the earth trait either manipulate or conjure earth. Those that manipulate earth have no effect in an area without earth. Creatures with this trait consist primarily of earth or have a connection to magical earth.  \n  \nThese planes are mostly solid. Travelers arriving upon an earth plane risk suffocation if they don\u2019t reach a cavern or some other air pocket within the plane\u2019s solid matter. Creatures who can\u2019t burrow are entombed in the plane\u2019s substance and must attempt to dig their way toward an air pocket. Air creatures are ill at ease, as they rarely have the space to move freely through even the loftiest warrens."
                        },
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                            "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions."
                        },
                        {
                            "name": "Primal",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 134,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 460",
                                        "alt": "Player Core pg. 460",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 460,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "60a4f011afd1e0fac8211bd01108d104",
                            "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic."
                        }
                    ],
                    "activation_name": "Grit Geyser"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You dump out the bottle, creating a swirling sandstorm around you. A 20-foot emanation is filled with blowing sand that obscures vision. This has the effects of mist. The air within the sandstorm is unbreathable; creatures in the area must hold their breath. Creatures entering or starting their turn in the sandstorm take 2d4 slashing damage (DC 23 basic Reflex save). Creatures with the water trait or that are primarily made of liquid take double damage. This sandstorm lasts 10 minutes or until the bottle is corked with an Interact action, whichever comes first.",
                    "links": [
