    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This magical banner has glittery, arcane threads crosswoven into the fabric, causing it to reflect light in little sparkles. While holding an *arcane standard*, you can use the following ability.",
        "level": 10,
        "traits": [
            {
                "name": "Uncommon",
