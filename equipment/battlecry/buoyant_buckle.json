    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 leather armor* has several large pouches along the sides of the torso as well as the front and back sides of the legs. While wearing this armor, you can quickly inflate these large pouches with air, allowing you to float in water.",
        "level": 6,
