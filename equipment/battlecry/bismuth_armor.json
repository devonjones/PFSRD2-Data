    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This silvery, pink-tinged *+2 resilient full plate* is polished to the point that its surface is completely reflective. This armor can reflect some of the light generated by magical attacks.",
        "level": 13,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
