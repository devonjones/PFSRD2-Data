    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This lantern is made of weathered tin and is cold and moist to the touch. The interior of the lantern, where a wick or candle would normally be placed, is filled with thick, black smoke, and there\u2019s no way to open the lantern.",
        "level": 12,
        "traits": [
