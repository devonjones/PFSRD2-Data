    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "These iron rings filled with kaleidoscopic glass are popular among Shelynites. A *chroma kaleidoscope\u2019s* effects last for 1 hour. When you critically Strike a creature with a weapon under the effects of a *chroma kaleidoscope*, a blast of color from the weapon forces them to attempt a Will saving throw against your class DC or spell DC, whichever is higher, with the following effects.",
        "level": 7,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
                            "alt": "Player Core pg. 454",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 454,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "07336d377bbfcf8d760f34f32f513526",
                "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Whetstone",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Battlecry!",
                        "link": {
                            "type": "link",
                            "name": "Battlecry! pg. 222",
                            "alt": "Battlecry! pg. 222",
                            "game-obj": "Sources",
                            "aonid": 268
                        },
                        "page": 222
                    }
                ],
                "game-obj": "Traits",
                "game-id": "eae12b4b690b9f41e14e88fb855ded66",
                "text": "Whetstones are magically enhanced items designed to increase a weapon\u2019s effectiveness, sometimes taking the form of literal stones, but often instead constructed of materials with a metaphorical link to the whetstone\u2019s effect. They\u2019re similar to talismans, though unlike talismans, they don\u2019t need to be Affixed ahead of time. Whetstones have the whetstone trait. \n \n*Click here for the full rules on Whetstones.*",
                "links": [
                    {
                        "type": "link",
                        "name": "whetstone",
                        "alt": "whetstone",
                        "game-obj": "Traits",
                        "aonid": 861
                    },
                    {
                        "type": "link",
                        "name": "Click here for the full rules on Whetstones.",
                        "alt": "Click here for the full rules on Whetstones.",
                        "game-obj": "Rules",
                        "aonid": 3420
                    }
                ],
                "classes": [
                    "trait"
                ]
            }
        ],
