          "trait"
        ],
        "edition": "remastered",
        "game-id": "5315505cfd3f3ba2685e9747898193b2",
        "game-obj": "Traits",
        "name": "Aura",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
