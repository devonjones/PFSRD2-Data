    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 leather armor* has two medium-sized pockets just above the waist where you might normally place your hands if they were cold. Each pocket is covered with a leather flap that surprisingly remains closed even with dynamic movement and heavy winds. Each individual pocket functions as a *type I spacious pouch*.",
        "level": 6,
        "traits": [
            {
