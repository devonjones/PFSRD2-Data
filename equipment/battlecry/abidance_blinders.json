    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "While many skilled cavalry units have their own beloved mounts, troops often need to make do with whatever animals are available for mounted combat. These blinders, made of dark brown leather, nearly cover an animal\u2019s eyes and prevent it from seeing the dangers around them. It takes 1 minute to affix the blinders on an animal, whose attitude toward you must be indifferent or better. These blinders can be used only on a domesticated animal that doesn\u2019t have combat training or the minion trait. Animals with these blinders on do not suffer from the frightened condition due to being in combat, nor do they automatically flee combat, as would be normal for an animal without combat training. Unless mounted by a rider with the paired headband, which is braided from the same dark brown leather, the animal\u2019s speed is reduced to 10 feet.",
        "level": 2,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
