    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This satchel is made of finely worked leather and stitched with golden thread. A complex pattern of trees, leaves, and vines covers its surface. The satchel always contains a bulk of seeds, and drawing one from the bag results in a random tree or crop plant seed.",
        "level": 8,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
