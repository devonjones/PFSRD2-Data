    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking lance* bears a pennant that displays a standard, heraldry, or other symbols desired by its original creator. When mounted and wielding a cavalry commander\u2019s lance, you gain a +2 circumstance bonus to Diplomacy checks when interacting with anyone loyal to the nation or cause represented by your pennant\u2019s imagery.",
        "level": 6,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
