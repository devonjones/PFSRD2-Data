    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 leather armor* has a metal exoskeleton that runs along your back and limbs and grants you increased strength for lifting and carrying. While wearing this armor, you can carry 2 more Bulk than normal before becoming encumbered and up to a maximum of 4 more Bulk.",
        "level": 8,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
