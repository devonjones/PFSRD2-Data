            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "effect": "You touch the metal plates of the saddle, which begin to unfold around the creature, covering your mount in heavy barding that extends from a simple-looking saddle. The Bulk of the saddle is the same in either form, but your mount isn\u2019t affected by the restrictions or the benefits of wearing barding while it\u2019s in saddle form. If the mount is already wearing barding, this has no effect. You return the barding to saddle form by using the same activity.",
                    "links": [
                        {
                            "type": "link",
                            "name": "barding",
                            "alt": "barding",
                            "game-obj": "Equipment",
                            "aonid": 2778
                        }
                    ],
                    "traits": [
                        {
                            "name": "Manipulate",
