          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 32,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "e32d877417a40fe977d27634dc14f99f",
              "game-obj": "Traits",
              "name": "Concentrate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 454",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 454,
                  "type": "source"
                }
              ],
              "text": "An action with this trait requires a degree of mental concentration and discipline.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 48,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
              "game-obj": "Traits",
              "name": "Divine",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            },
            {
              "edition": "remastered",
              "game-id": "6309897c89780f17449b984cbb6d26cb",
              "game-obj": "Traits",
              "links": [
                {
                  "alt": "holy",
                  "aonid": 517,
                  "game-obj": "Traits",
                  "name": "holy",
                  "type": "link"
                }
              ],
              "name": "Unholy",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 462",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 462",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 462,
                  "type": "source"
                }
              ],
              "text": "Effects with the unholy trait are tied to powerful magical forces of cruelty and sin. They often have stronger effects on holy creatures. Creatures with this trait are strongly devoted to unholy causes, and often have weakness to holy. If a creature with weakness to unholy uses an unholy item or effect, it takes damage from its weakness.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
      "access": {
