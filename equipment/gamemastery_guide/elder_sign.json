                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "effect": "The  *elder sign* casts a 10th-level  *banishment* spell on an eldritch creature. Even if the creature isn\u2019t extraplanar, the  *elder sign* can still banish it, sending it back to the part of the Material Plane from which it originated. If the creature is a Great Old One, the  *elder sign* banishes it automatically (as if it critically failed its save) but is then forever destroyed.",
                    "links": [
                        {
                            "type": "link",
                            "name": "banishment",
                            "alt": "banishment",
                            "game-obj": "Spells",
                            "aonid": 19
                        }
                    ],
                    "activation_types": [
                        {
