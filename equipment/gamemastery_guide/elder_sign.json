                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "effect": "The  *elder sign* casts  *dispel magic* on an effect from an eldritch creature, using a counteract level of 10 and +30 modifier for the roll.",
                    "links": [
                        {
                            "type": "link",
                            "name": "dispel magic",
