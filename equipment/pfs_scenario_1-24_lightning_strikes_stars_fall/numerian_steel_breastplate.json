    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 resilient breastplate* is constructed from the salvaged armor plating of one of Numeria's large robots. It protects the wearer from harsh elements and common laser fire, granting the wearer fire resistance 5.",
