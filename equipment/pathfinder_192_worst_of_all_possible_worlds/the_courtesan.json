    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*The Courtesan* represents political intrigue and social niceties. As long as *The Courtesan* is invested, you gain a +2 item bonus to Diplomacy checks to Make an Impression. This increases to a +3 item bonus if you are at least 17th level.",
        "level": 20,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 161,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
