{
    "name": "The Wanderer",
    "type": "equipment",
    "sources": [
        {
            "type": "source",
            "name": "Pathfinder #192: Worst of All Possible Worlds",
            "link": {
                "type": "link",
                "name": "Pathfinder #192: Worst of All Possible Worlds pg. 79",
                "alt": "Pathfinder #192: Worst of All Possible Worlds pg. 79",
                "game-obj": "Sources",
