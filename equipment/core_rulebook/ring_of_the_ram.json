          "ability_type": "offensive",
          "action_type": {
            "name": "One Action or more",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "critical_failure": "The target takes double damage and is pushed twice the distance.",
          "critical_success": "The target is unaffected.",
          "effect": "A ram-shaped blast of force slams into one foe that you can see within 60 feet. The number of actions you spend to Activate this Item (from 1 to 3) determines the intensity of the force. The blow deals 2d6 force damage per action spent and pushes the target 5 feet per action spent. The target must attempt a DC 22 Fortitude save.",
          "failure": "The target takes full damage and is pushed the full distance.",
          "frequency": "once per minute",
          "name": "Activate",
          "subtype": "activation",
          "success": "The target takes half damage and is pushed half the distance.",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "worn",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This heavy iron ring is shaped to look like the head of a ram, with curling horns.",
    "traits": [
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "01bf3e53d6c0fc7f70419341635bfe8f",
        "game-obj": "Traits",
        "name": "Evocation",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 631",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 631",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 631,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait are associated with the evocation school of magic, typically involving energy and elemental forces.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 75,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "6a7f58e477505403e58cc11dfbae82ee",
        "game-obj": "Traits",
        "name": "Force",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 456",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 456",
              "type": "link"
            },
            "name": "Player Core",
            "page": 456,
            "type": "source"
          }
        ],
        "text": "Effects with this trait deal force damage or create objects made of pure magical force.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "invest",
            "aonid": 2799,
            "game-obj": "Actions",
            "name": "invest",
            "type": "link"
          }
        ],
        "name": "Invested",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 219",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 219",
              "type": "link"
            },
            "name": "GM Core",
            "page": 219,
            "type": "source"
          }
        ],
        "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      }
    ],
