    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This ornate silver ring bears two competing geometric designs of brightly colored and wildly clashing inlaid gemstones. A spellcaster can cast a single spell into this ring as long as no spell is currently stored within, expending the normal time, costs, and so forth to Cast the Spell. The spell\u2019s effect doesn\u2019t occur; the spell\u2019s power is instead stored within the ring.  \n   \n When you invest a *ring of counterspells*, you immediately know the name and level of the spell stored inside, if any. A *ring of counterspells* found as treasure has a 50% chance of having a spell stored in it. The GM determines that spell.",
        "level": 10,
        "image": {
            "type": "image",
            "name": "Ring of Counterspells",
            "image": "Ring_of_Counterspells.webp"
        },
        "traits": [
            {
