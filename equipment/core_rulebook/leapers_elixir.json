    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This tingly solution increases the elasticity and contraction of your leg muscles. For 1 minute after drinking this elixir, you can High Jump or Long Jump as a single action instead of 2 actions. If you do, you don\u2019t perform the initial Stride (nor do you fail if you don\u2019t Stride 10 feet).",
        "level": 1,
        "traits": [
            {
