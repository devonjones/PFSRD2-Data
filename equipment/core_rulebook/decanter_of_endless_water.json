    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This item looks like an ordinary glass flask full of water. The stopper can\u2019t be removed unless you speak one of the item\u2019s three command words, each of which causes water to pour forth in a different way. Pulling the stopper straight out creates fresh water, and rotating it as you pull creates salt water. Any effect of the decanter lasts until the decanter is plugged (with its own stopper, a finger, or the like).",
        "level": 7,
        "image": {
            "type": "image",
            "name": "Decanter of Endless Water",
            "image": "Decanter_of_Endless_Water.webp"
        },
        "traits": [
            {
                "name": "Conjuration",
                "type": "trait",
                "edition": "legacy",
                "sources": [
                    {
                        "type": "source",
                        "name": "Core Rulebook",
                        "link": {
                            "type": "link",
                            "name": "Core Rulebook pg. 630",
                            "alt": "Core Rulebook pg. 630",
                            "game-obj": "Sources",
                            "aonid": 1
                        },
                        "page": 630,
                        "errata": {
                            "type": "link",
                            "name": "4.0",
                            "alt": "4.0",
                            "game-obj": "Sources",
                            "aonid": 1
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9011037bb4a11ca6cf2d16fa8a657bf5",
                "text": "Effects and magic items with this trait are associated with the conjuration school of magic, typically involving summoning, creation, teleportation, or moving things from place to place.",
                "links": [
                    {
                        "type": "link",
                        "name": "summoning",
