                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "effect": "Speaking \u201cfountain,\u201d you cause water to pour out in a 5-foot-long stream at a rate of 5 gallons per round.",
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "command"
