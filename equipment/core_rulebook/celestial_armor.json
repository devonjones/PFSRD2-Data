    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This suit of *+2 resilient chain mail* is made of fine white links of a strange and slightly translucent pale metal, and the sleeves and skirt are fashioned into smaller trails that resemble feathers. Unlike normal chain mail, celestial armor has no Speed reduction, its armor check penalty is 0, and its Bulk is 1.   \n  \n You gain a +1 circumstance bonus to AC and saving throws against fiends. You appear radiant while you wear the armor, giving you a +2 item bonus to Diplomacy checks against all creatures except fiends.  \n  \n If you are not good, you are drained 2 while wearing *celestial armor*. You can\u2019t recover from this condition while wearing the armor.",
        "level": 13,
        "image": {
            "type": "image",
            "name": "Celestial Armor",
            "image": "Celestial_Armor.webp"
        },
        "traits": [
            {
                "name": "Divine",
                "type": "trait",
                "alternate_link": {
