    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The Flood Truce is a season of relative peace, and this tattoo of a river can soothe your temper when you might otherwise lash out. You gain a +1 item bonus to Diplomacy checks made against orcs who honor the Flood Truce.",
