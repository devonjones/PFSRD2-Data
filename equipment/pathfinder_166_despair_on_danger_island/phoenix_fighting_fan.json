            "game-obj": "Traits",
            "name": "unique",
            "type": "link"
          }
        ],
        "name": "Artifact",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
