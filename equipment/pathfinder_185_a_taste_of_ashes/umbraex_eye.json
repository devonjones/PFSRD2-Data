    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Like the rest of its form, the eyes of the legendary umbraex darvakka (page 83) collapse into ashes when the creature is destroyed. Rarely, when the umbraex wishes to impart information beyond its ashen reconstitution, it ejects one of its eyes at the moment of destruction. This large orb hardens into an obsidian-like substance that swirls with captivated motes of darkness deep within. While you hold the *umbraex eye*, you have lifesense (imprecise) 120 feet.",
        "level": 19,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
