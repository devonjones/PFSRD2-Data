    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Used by soldiers who battle on the borderlands of Elysium, particularly in Gorum\u2019s realm of Clashing Shore, these bronze spyglasses are somewhat plain-looking save for a single diamond set into the largest cylinder. An Elysian clairglass functions like a typical spyglass, but you can see twenty times farther while looking through it, rather than eight times farther. It also grants a +3 item bonus to Perception checks to notice details at a distance.",
        "level": 17,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
