    "subtype": "equipment",
    "text": "This 1-inch tall figurine depicts a crouched praying mantis. It\u2019s usually carved from green jade, crimson marble, or purple porphyry. Regardless of the figurine\u2019s material composition, its gemstone eyes are always a dull ruby red that seems to drink light.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "uncommon"
        ],
