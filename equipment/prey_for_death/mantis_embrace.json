    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "These stylized red gloves are constructed from plates of leather that have been treated to resemble insect chitin. The gloves grant the wearer a +2 item bonus to Athletics checks to Grapple or Shove.",
