    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This bizarre substance is fashioned from the raw, chaotic quintessence of the Maelstrom. It can be fashioned into weapons and items, but is too unstable to make into useful armor or shields.   \n   \n Raw warpglass is an opalescent glassy material with surprising strength. When worked, it changes its appearance\u2014though not its properties\u2014to appear as random striations of other metals and types of stone.",
        "sections": [
            {
                "name": "",
                "type": "section",
                "text": "|  |  |  |  |\n| --- | --- | --- | --- |\n| **Warpglass Items** | **Hardness** | **HP** | **BT** |\n| **Thin Items** |  |\n| High-grade | 8 | 32 | 16 |\n| **Items** |  |\n| High-grade | 12 | 48 | 24 |\n| **Structures** |  |\n| High-grade | 24 | 96 | 48 |\n\n   \n *Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Warpglass Weapon*",
                        "links": [
