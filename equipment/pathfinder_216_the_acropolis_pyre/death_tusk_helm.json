    "subtype": "equipment",
    "text": "Slivers of boar tusk are sewn into this leather cap, creating a scaled helmet that channels dozens of boars' ferocity into the wearer.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
