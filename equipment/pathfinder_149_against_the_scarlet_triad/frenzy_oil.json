    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This oil, which is pressed from vrock spores and mixed with a combination of acacia ash and thistle seeds, seeps into the skin of living creatures, initially inspiring irritability that unpredictably manifests as berserk rage.",
        "level": 16,
