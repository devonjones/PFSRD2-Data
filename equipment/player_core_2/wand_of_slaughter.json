    "subtype": "equipment",
    "text": "This polished black wand has a green gem at the tip, and anyone who looks into it sees a reflection of a grinning skull.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
