    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Lethargy poison is commonly used in hit-and-run tactics by attackers who want their victims alive; the ambusher retreats until the poison sets in and the victim falls unconscious. Further exposure to lethargy poison doesn't require the target to attempt additional saving throws; only failing a saving throw against an ongoing exposure can progress its stage.",
        "level": 2,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
