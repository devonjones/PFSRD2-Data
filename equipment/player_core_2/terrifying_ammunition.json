    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This black-and-gray ammunition is etched with occult symbols and tiny, grinning skulls. When activated *terrifying ammunition* damages a creature, the creature's mind is filled with visions of its failures, its tragedies, and eventually, its own death. The creature must attempt a DC 20 Will save.",
