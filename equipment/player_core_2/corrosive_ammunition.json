                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "fb459e6b30d3a0203a9af62959b02df5",
                "text": "Effects with this trait deal acid damage. Creatures with this trait have a connection to magical acid.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Consumable",
                "type": "trait",
