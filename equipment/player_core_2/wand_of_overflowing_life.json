    },
    "craft_requirements": "Supply a casting of *heal* of the appropriate rank.",
    "level": 9,
    "links": [
      {
        "alt": "heal",
        "aonid": 1554,
        "game-obj": "Spells",
        "name": "heal",
        "type": "link"
      }
    ],
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *heal* at the indicated rank. After you cast the spell, at the start of your next turn, excess healing magic wells up from the wand and heals you, as though you cast the 1-action version of *heal* on yourself at the same spell rank. You gain this benefit only once per turn, even if you cast multiple *heal* spells from wands of *overflowing life* in the same turn.",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "heal",
              "aonid": 1554,
              "game-obj": "Spells",
              "name": "heal",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This alabaster wand has a clear crystal at the tip.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 89,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "46d51374c2ada72347818dbac1edd7a3",
        "game-obj": "Traits",
        "name": "Healing",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 457",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 457",
              "type": "link"
            },
            "name": "Player Core",
            "page": 457,
            "type": "source"
          }
        ],
        "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 128,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "6571a8a0a7aae945b34252db53de1861",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "undead",
            "aonid": 160,
            "game-obj": "Traits",
            "name": "undead",
            "type": "link"
          }
        ],
        "name": "Vitality",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 463",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 463",
              "type": "link"
            },
            "name": "Player Core",
            "page": 463,
            "type": "source"
          }
        ],
        "text": "Effects with this trait heal living creatures with energy from the Forge of Creation, deal vitality energy damage to undead, or manipulate vitality energy.  \n  \nThese planes are awash with life energy. Colors are brighter, fires are hotter, noises are louder, and sensations are more intense. At the end of each round, an undead creature takes at least minor vitality environmental damage. In the strongest areas of a vitality plane, they could take moderate or even major vitality damage instead. While this might seem safe for living creatures, vitality planes present a different danger. Living creatures regain an amount of HP each round equal to the environmental damage undead take in the same area. If this would bring the living creature above their maximum HP, any excess becomes temporary HP. Unlike normal, these temporary HP combine with each other, and they last until the creature leaves the plane. If a creature\u2019s temporary HP from a vitality plane ever exceeds its maximum HP, it explodes in a burst of overloaded vitality energy, spreading across the area to birth new souls.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 164,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f7fe46b3a30bfb0e9bfbe655396afc22",
        "game-obj": "Traits",
        "name": "Wand",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 463",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 463",
              "type": "link"
            },
            "name": "Player Core",
            "page": 463,
            "type": "source"
          }
        ],
        "text": "A wand contains a single spell which you can cast once per day.",
        "type": "trait"
      }
    ],
