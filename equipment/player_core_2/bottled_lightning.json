    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Bottled lightning is packed with volatile reagents that create a blast of electricity when they're exposed to air. Bottled lightning deals the listed electricity damage and electricity splash damage. On a hit, the target becomes off-guard until the start of your next turn. Many types grant an item bonus to attack rolls.",
        "level": 1,
        "image": {
            "type": "image",
            "name": "Bottled Lightning",
            "image": "Bottled_Lightning.webp"
        },
