    "subtype": "equipment",
    "text": "This elaborate helmet is emblazoned with the divine symbols of a deity chosen when the helmet was crafted. You gain a +2 item bonus to that deity's Divine Skill.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 48,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
        "game-obj": "Traits",
        "name": "Divine",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 74,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "53acdd8ebe1bdd9a5939d96ad87d005a",
        "game-obj": "Traits",
        "name": "Focused",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 221",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 221",
              "type": "link"
            },
            "name": "GM Core",
            "page": 221,
            "type": "source"
          }
        ],
        "text": "An item with this trait can give you an additional Focus Point. This focus point is separate from your focus pool and doesn\u2019t count toward the cap on your focus pool. You can gain this benefit only if you have a focus pool, and there might be restrictions on how the point can be used. You can\u2019t gain more than 1 Focus Point per day from focused items.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "invest",
            "aonid": 2799,
            "game-obj": "Actions",
            "name": "invest",
            "type": "link"
          }
        ],
        "name": "Invested",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 219",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 219",
              "type": "link"
            },
            "name": "GM Core",
            "page": 219,
            "type": "source"
          }
        ],
        "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
        "type": "trait"
      }
    ],
