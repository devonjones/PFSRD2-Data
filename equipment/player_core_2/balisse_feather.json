                            "game-obj": "Sources",
                            "aonid": 218
                        },
                        "page": 263,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "ff9aabb4704b8d99cb4cd097aeab3b19",
                "text": "A talisman is a small object affixed to armor, a shield, or a weapon (called the affixed item). You must be wielding or wearing an item to activate a talisman attached to it. Once activated, a talisman burns out permanently.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            }
