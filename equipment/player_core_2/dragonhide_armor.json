    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Dragonhide armor is immune to one damage type based on the type of dragon it's made from. Wearing armor made from dragonhide also grants you a +1 circumstance bonus to your AC and saving throws against attacks and spells that deal the corresponding damage type.",
        "sections": [
            {
                "name": "",
                "type": "section",
                "text": "| Dragon Tradition | Damage |\n| --- | --- |\n| Arcane | Force |\n| Divine | Spirit |\n| Occult | Mental |\n| Primal | Poison |"
            }
        ],
