        "type": "stat_block",
        "subtype": "equipment",
        "text": "Sometimes called \u201cdeadly nightshade,\u201d belladonna is a widely available toxin produced from a plant similar to a tomato.",
        "level": 2,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 6,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
