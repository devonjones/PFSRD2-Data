                "game-obj": "Traits",
                "game-id": "2106d07ecaef4033d87e9e581a7b5c6a",
                "text": "Effects with this trait deal cold damage. Creatures with this trait have a connection to magical cold.",
                "classes": [
                    "trait"
                ]
            },
