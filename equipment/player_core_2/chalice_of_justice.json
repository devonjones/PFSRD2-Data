    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This gleaming golden sword is a *+2 greater striking holy cold iron longsword* given only to the worthiest heroes of a holy faith. It's made of a sacred, secret alloy that makes the blade both cold iron and silver. If you're unholy, you're drained 2 while holding a chalice of justice. You can't recover from this condition while holding the weapon.",
        "level": 14,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
