    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This miniature club is typically affixed to a weapon by an iron chain. When you activate the cudgel, you use Brutal Finish, as the fighter feat. You must meet the normal requirements, including those of the press trait.   \nIf you have the Brutal Finish feat, add an additional weapon damage die on a success or a failure to the normal results.",
        "level": 14,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
