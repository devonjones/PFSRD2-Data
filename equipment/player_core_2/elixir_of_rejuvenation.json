    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The elixir of rejuvenation restores a creature to full health and eradicates toxins affecting it. When you drink this elixir, you\u2019re restored to your maximum Hit Points, and all afflictions of 20th level or lower affecting you are removed.  \n   \nYou can instead administer this elixir to a creature that has been dead for a week or less. When you do, that creature is instantly brought back to life with 1 Hit Point and no spell slots, Focus Points, or other daily resources.",
        "level": 20,
        "image": {
            "type": "image",
            "name": "Elixir of Rejuvenation",
            "image": "Elixir_of_Rejuvenation.webp"
        },
