              "name": "GM Core pg. 332",
              "type": "link"
            },
            "name": "GM Core",
            "page": 332,
            "type": "source"
          }
        ],
        "text": "Valuable materials with special properties have the precious trait. They can be substituted for base materials when you Craft items.",
        "type": "trait"
      }
