    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The hide and scales of a dragon can be used to Craft any item normally made of ordinary leather or hide. Dragonhide varies in color and texture, depending on the dragon it came from. Due to dragonhide's resiliency, it can also be used to Craft armor usually made out of metal plates (such as a breastplate, half plate, and full plate), allowing such armor to be made without metal. Dragonhide objects are immune to one damage type, depending on the tradition associated with the dragon.",
        "sections": [
            {
                "name": "",
                "type": "section",
                "text": "| Dragonhide Items | Hardness | HP | BT |\n| --- | --- | --- | --- |\n| **Thin Items** |  |\n| Standard-grade | 4 | 16 | 8 |\n| High-grade | 8 | 32 | 16 |\n| **Standard Items** |  |\n| Standard-grade | 7 | 28 | 14 |\n| High-grade | 11 | 44 | 22 |\n\n   \n *Rules for Special Materials*",
                "links": [
                    {
                        "type": "link",
                        "name": "Rules for Special Materials",
                        "alt": "Rules for Special Materials",
                        "game-obj": "Rules",
                        "aonid": 3190
                    }
                ],
                "sections": [
                    {
                        "name": "Material Uses",
                        "type": "section",
                        "text": "*Dragonhide Armor*   \n *Dragonhide Shield*",
                        "links": [
                            {
                                "type": "link",
                                "name": "Dragonhide Armor",
                                "alt": "Dragonhide Armor",
                                "game-obj": "Equipment",
                                "aonid": 3269
                            },
                            {
                                "type": "link",
                                "name": "Dragonhide Shield",
                                "alt": "Dragonhide Shield",
                                "game-obj": "Equipment",
                                "aonid": 3270
                            }
                        ]
                    }
                ]
            }
        ],
