    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Bitterblood elixir is a pale pink color, like that of water tinted by a few drops of blood. After you drink this elixir, your blood becomes dangerous for other creatures to consume. For the next hour, whenever a creature drinks your blood, the elixir changes your blood into a foul-tasting acid as it mixes with the drinker\u2019s saliva. You\u2019re unharmed by this transformation, but the blood drinker must attempt a DC 20 Fortitude save.",
        "level": 6,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
