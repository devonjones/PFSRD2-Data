    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This silver brooch features an enormous freshwater pearl pulled from the depths of Lake Encarthan. They are often given to trading partners among Drumish merchants as a sign of favor\u2014not as favored as a fellow Kalistocrat, but nonetheless worth treating well. Openly wearing a Drumish pearl token can work wonders when traveling through Druma, whether on legitimate mercantile business or not, but those who flaunt the token inappropriately must beware of repercussions from the Drumish government! The wearer of a Drumish pearl token benefits from a +2 item bonus to Diplomacy checks to Make an Impression and to their Perception DC when someone attempts to Lie to them.",
        "level": 11,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
