    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The blade of this *+1 sickle* is engraved to look like the curving feather of a particularly elaborate quill. The wooden handle has a pen nib at the base. You can use the *wordreaper's* handle as an ink pen and it never runs out of ink.",
        "level": 3,
        "traits": [
            {
                "name": "Uncommon",
