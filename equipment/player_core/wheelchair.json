                            "aonid": 226
                        }
                    }
                ]
            },
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Wheelchair (Land-Delver's Chair)",
                "level": 0,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "5 gp",
                    "value": 5,
                    "currency": "gp"
                },
                "bulk": {
                    "type": "stat_block_section",
                    "subtype": "bulk",
                    "value": 2,
                    "text": "2"
                },
                "text": "A supramarine chair is a wheeled, water-filled bath or tank, originally designed by merfolk, for assisting aquatic people's mobility on land. The heavier-duty land-delver's chair functions as a traveler's chair. You increase your Speed to 20 feet or your swim Speed, whichever is lower.",
                "sources": [
                    {
                        "type": "source",
