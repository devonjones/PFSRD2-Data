    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *submersible helmet* is a streamlined sallet with a visor and a flanged rear. While wearing the helmet with the visor down, you can see, hear, and speak clearly underwater. You also have a +1 item bonus to Athletics checks to Swim.",
        "level": 9,
