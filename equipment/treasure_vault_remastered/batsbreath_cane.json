    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A specialized *+1 striking thundering probing cane* made from strengthened spruce wood, a *batsbreath cane* is distinctive for its brass tip. The tip covers a small hollow in the wood that houses quartz crystals infused with latent storm magic.",
        "level": 10,
