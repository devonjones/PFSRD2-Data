  "stat_block": {
    "bulk": {
      "subtype": "bulk",
      "text": "L",
      "type": "stat_block_section",
      "value": null
    },
    "craft_requirements": "Supply a casting of *holy light* of the appropriate rank.",
    "level": 8,
    "links": [
      {
        "alt": "bright light",
        "aonid": 407,
        "game-obj": "Rules",
        "name": "bright light",
        "type": "link"
      },
      {
        "alt": "dim light",
        "aonid": 408,
        "game-obj": "Rules",
        "name": "dim light",
        "type": "link"
      }
    ],
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *holy light* of the indicated rank, dazzling your target with the beam\u2019s intensity. A creature that takes damage from the spell is blinded for 1 round and dazzled for a number of rounds equal to the spell rank. On a critical success on the attack roll, the target is also blinded for as long as it\u2019s dazzled from the spell. However, it can attempt a Fortitude saving throw against your spell DC at the end of each of its turns, ending the blinded condition on a success (but remaining dazzled).",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "holy light",
              "aonid": 1557,
              "game-obj": "Spells",
              "name": "holy light",
              "type": "link"
            },
            {
              "alt": "blinded",
              "aonid": 59,
              "game-obj": "Conditions",
              "name": "blinded",
              "type": "link"
            },
            {
              "alt": "dazzled",
              "aonid": 65,
              "game-obj": "Conditions",
              "name": "dazzled",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "Solidified radiance comprises this slender, featureless wand. It sheds bright light in a 20-foot radius and dim light for the next 20 feet. After you Activate the wand, the light fades, so it only sheds dim light in a 20-foot radius. The wand returns to its original brightness each dawn.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 72,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "974c2ceb862b6781b4ebac590bd83913",
        "game-obj": "Traits",
        "name": "Fire",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 456",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 456",
              "type": "link"
            },
            "name": "Player Core",
            "page": 456,
            "type": "source"
          }
        ],
        "text": "Effects with the fire trait deal fire damage or either conjure or manipulate fire. Those that manipulate fire have no effect in an area without fire. Creatures with this trait consist primarily of fire or have a connection to magical fire.  \n  \nPlanes with this trait are composed of flames that continually burn with no fuel source. Fire planes are extremely hostile to non-fire creatures. Unprotected wood, paper, cloth, and other flammable materials catch fire almost immediately, and creatures wearing unprotected flammable clothing catch fire, typically taking 1d6 persistent fire damage. Extraplanar creatures take moderate environmental fire damage at the end of each round (sometimes minor environmental damage in safer areas, or major or massive damage in even more fiery areas). Ice creatures are extremely uncomfortable on a fire plane, assuming they don\u2019t outright melt in the heat.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "2f3295840cd39bc5926fa41d78f26885",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "unholy",
            "aonid": 521,
            "game-obj": "Traits",
            "name": "unholy",
            "type": "link"
          }
        ],
        "name": "Holy",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 457",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 457",
              "type": "link"
            },
            "name": "Player Core",
            "page": 457,
            "type": "source"
          }
        ],
        "text": "Effects with the holy trait are tied to powerful magical forces of benevolence and virtue. They often have stronger effects on unholy creatures. Creatures with this trait are strongly devoted to holy causes and often have weakness to unholy. If a creature with weakness to holy uses a holy item or effect, it takes damage from its weakness.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 100,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "dd40587ebc07c2b386aa95d93fdcc130",
        "game-obj": "Traits",
        "name": "Light",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Light effects overcome non-magical darkness in the area and can counteract magical darkness. You must usually target darkness magic with your light magic directly to counteract the darkness, but some light spells automatically attempt to counteract darkness.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 164,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f7fe46b3a30bfb0e9bfbe655396afc22",
        "game-obj": "Traits",
        "name": "Wand",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 463",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 463",
              "type": "link"
            },
            "name": "Player Core",
            "page": 463,
            "type": "source"
          }
        ],
        "text": "A wand contains a single spell which you can cast once per day.",
        "type": "trait"
      }
    ],
