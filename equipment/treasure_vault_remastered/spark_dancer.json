    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+2 greater striking pepperbox* cycles through several magical cores, swapping in new ones while the previous ones cool. The gun deals fire or electricity damage, alternating with each attack as it rotates cores. Arcadian gunslingers liken the rotating cores to a group of dancers, each taking their turn in the spotlight.",
        "level": 13,
        "image": {
            "type": "image",
            "name": "Spark Dancer",
            "image": "Spark_Dancer.webp"
        },
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
