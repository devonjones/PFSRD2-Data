    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This white mint with a chalky coating appears to be a normal candy unless someone examining it succeeds at a DC 15 Crafting check to Identify Alchemy. If the crafter has the powerful alchemy class feature, this DC is their class DC instead, if it's higher. The mint's crafter can imbue a missive mint with a message containing up to 25 words while creating it. Someone who consumes the missive mint hears the message in a fizzing voice as the mint's coating bubbles away, which takes the same amount of time as it would to speak the message. The mint's eater has no way of knowing who the original sender was, what they sound like, or who the message was intended for.",
        "level": 1,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 6,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
