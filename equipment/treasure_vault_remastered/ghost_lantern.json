    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Crafted from cold iron, this black hooded lantern has gray glass and lenses that emit a pale gray light when the lantern is lit. Anything this light falls on looks gray or desaturated. The lantern uses oil as a standard hooded lantern. The lantern\u2019s light shines within the Ethereal Plane as well as the Universe. On any other plane, the light functions as a normal hooded lantern.",
        "level": 12,
        "image": {
            "type": "image",
            "name": "Ghost Lantern",
            "image": "Ghost_Lantern.webp"
        },
        "traits": [
            {
                "name": "Light",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
