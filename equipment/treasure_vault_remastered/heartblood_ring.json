    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Sealed inside the hidden compartment of a gold ring, heartblood has an unmistakable coppery taste, along with a thick mouth feel. A whiff of the concoction is pleasantly stimulating.",
        "level": 15,
        "image": {
            "type": "image",
