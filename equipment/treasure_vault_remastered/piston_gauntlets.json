        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "The striking surface of this *+2 greater striking flaming pantograph gauntlet* releases a puff of fire each time it reaches the end of its linkage.",
    "traits": [
      {
        "alternate_link": {
