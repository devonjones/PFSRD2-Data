    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Woven by fey seamstresses as rewards for servants of nature, countless leaves continually changing colors in autumnal hues comprise autumn's embrace, a suit of *+2 invisibility resilient leaf weave*. Leaves shed from the armor as they might fall in autumn. When activating the armor's *invisibility* property rune, you disappear in a swirl of colorful leaves.",
        "level": 12,
        "image": {
            "type": "image",
            "name": "Autumn's Embrace",
            "image": "Autumns_Embrace.webp"
        },
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
