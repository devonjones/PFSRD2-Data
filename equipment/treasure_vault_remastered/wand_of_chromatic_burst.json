              "aonid": 561,
              "game-obj": "Traits",
              "name": "concentrate",
              "type": "link"
            },
            {
              "alt": "light",
              "aonid": 640,
              "game-obj": "Traits",
              "name": "light",
              "type": "link"
            },
            {
              "alt": "magical",
              "aonid": 644,
              "game-obj": "Traits",
              "name": "magical",
              "type": "link"
            }
          ],
          "name": "Chromatic Armor Burst",
          "requirement": "You're affected by *chromatic armor* created by the *wand of chromatic burst*",
          "subtype": "ability",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
