    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This bone statuette of a sneering gremlin crumbles to dust when activated, imparting a fraction of its subject's infamous misfortune on those you strike. The damaged creature must attempt a DC 33 Will save.",
        "level": 14,
        "traits": [
            {
