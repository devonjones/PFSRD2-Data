    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This ornate locket, usually containing a faceless, humanoid portrait, is typically worn on a chain around the neck or attached to your clothing. When activated, the charm casts a DC 26 *rewrite memory* spell against a single target of the check, removing all memory of your failed attempt and potentially allowing you to make another attempt. The effect can\u2019t remove more than 3 minutes of memories from its target.",
        "level": 9,
        "image": {
            "type": "image",
