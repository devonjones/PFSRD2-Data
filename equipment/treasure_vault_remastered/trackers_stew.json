    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Alchemical reagents add punch to tracker's stew: a rich, fiery mixture of tomatoes, ground nuts, onions, and tubers, often with poultry added. It's usually served with or over rice or noodles. Once you've eaten the stew, it improves your ability to sense and follow tracks for 24 hours or until you make your next daily preparations, whichever comes first. You gain a +1 item bonus to Survival checks to Cover Tracks and Track. You can do either while moving at full speed or both while moving at half speed.",
        "level": 3,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 6,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 452,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9fde9d3adae06c502c6263570964463e",
                "text": "Alchemical items are powered by reactions of alchemical reagents. Unless otherwise noted, alchemical items aren\u2019t magical and don\u2019t radiate a magical aura.  \n  \nAlchemical creatures are partially powered by alchemical reactions.",
                "links": [
                    {
                        "type": "link",
                        "name": "magical",
                        "alt": "magical",
                        "game-obj": "Traits",
                        "aonid": 644
                    }
