      "value": null
    },
    "craft_requirements": "Supply a casting of *Oaken Resilience* of the appropriate rank.",
    "level": 6,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *oaken resilience* of the indicated rank, and the target sprouts long thorns like those of a hawthorn tree. While *oaken resilience* lasts, any creature that hits the target with an unarmed Strike or otherwise touches it takes piercing damage from the thorns, with the amount determined by the wand\u2019s type. A creature that has engulfed or swallowed the target takes this damage as well at the start of each of the target\u2019s turns.",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "oaken resilience",
              "aonid": 1617,
              "game-obj": "Spells",
              "name": "oaken resilience",
              "type": "link"
            },
            {
              "alt": "engulfed",
              "aonid": 61,
              "game-obj": "MonsterAbilities",
              "name": "engulfed",
              "type": "link"
            },
            {
              "alt": "swallowed",
              "aonid": 77,
              "game-obj": "MonsterAbilities",
              "name": "swallowed",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "Carved from a hawthorn branch, this wand has a smooth handle, but the shaft remains covered in bark and long thorns. Polished red stones, arranged like a cluster of berries, decorate the pommel.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 125,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "651e06f09e5aea780d7c70a36ce5b1f2",
        "game-obj": "Traits",
        "name": "Plant",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 459",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 459",
              "type": "link"
            },
            "name": "Player Core",
            "page": 459,
            "type": "source"
          }
        ],
        "text": "Vegetable creatures have the plant trait. They are distinct from normal plants. Magical effects with this trait manipulate or conjure plants or plant matter in some way. Effects that manipulate plants have no effect in an area with no plants.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 164,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
