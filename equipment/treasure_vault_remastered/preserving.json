    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*Preserving* runes are common among merchants and other travelers who are on the road for weeks or months at a time. Any non-magical food and drink inside a container with a *preserving* rune remains fresher for longer, taking ten times as long to spoil. This feature doesn't prolong the duration of alchemical items.",
        "level": 3,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
