            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "frequency": "once per day, plus overcharge",
                    "effect": "You cast  *chromatic ray* of the indicated rank. After you cast the spell, if you hit the target, the light refracts to another creature within 30 feet of the first target. Roll your spell attack roll and to determine the ray's color separately for each target. The ray continues to refract each time it hits. The refraction ceases if you miss any target, and you can end the refraction at any point. You can't target the same creature more than once, and you must have line of effect to all targets.",
                    "links": [
                        {
