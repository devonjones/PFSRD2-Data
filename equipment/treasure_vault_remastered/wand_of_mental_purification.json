  "stat_block": {
    "bulk": {
      "subtype": "bulk",
      "text": "L",
      "type": "stat_block_section",
      "value": null
    },
    "craft_requirements": "Supply a casting of *soothe* of the appropriate rank.",
    "level": 4,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *soothe* of the indicated rank, and can attempt to counteract one mental effect on the same target. Treat the *soothe* spell's level as 1 higher for this counteract check.",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "soothe",
              "aonid": 291,
              "game-obj": "Spells",
              "name": "soothe",
              "type": "link"
            },
            {
              "alt": "counteract",
              "aonid": 371,
              "game-obj": "Rules",
              "name": "counteract",
              "type": "link"
            },
            {
              "alt": "mental",
              "aonid": 106,
              "game-obj": "Traits",
              "name": "mental",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "Red feathers hang from the handle of this ivory wand. Holding it brings a sense of gentle calm.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 60,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "fb5f8b3d849b073e1514a6a025810470",
        "game-obj": "Traits",
        "name": "Emotion",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 89,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "46d51374c2ada72347818dbac1edd7a3",
        "game-obj": "Traits",
        "name": "Healing",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 457",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 457",
              "type": "link"
            },
            "name": "Player Core",
            "page": 457,
            "type": "source"
          }
        ],
        "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 106,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "6a1f80610baa3617c1597f49c6406313",
        "game-obj": "Traits",
        "name": "Mental",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 164,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f7fe46b3a30bfb0e9bfbe655396afc22",
        "game-obj": "Traits",
        "name": "Wand",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
