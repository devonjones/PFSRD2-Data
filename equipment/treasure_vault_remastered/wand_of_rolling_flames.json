        "name": "Wand",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 463",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 463",
              "type": "link"
            },
            "name": "Player Core",
            "page": 463,
            "type": "source"
          }
        ],
        "text": "A wand contains a single spell which you can cast once per day.",
        "type": "trait"
      }
