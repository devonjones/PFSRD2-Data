  "stat_block": {
    "bulk": {
      "subtype": "bulk",
      "text": "L",
      "type": "stat_block_section",
      "value": null
    },
    "craft_requirements": "Supply a casting of *floating flame* of the appropriate rank.",
    "level": 6,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *floating flame* of the indicated rank. If you create the flame on the ground, the ground in the sphere\u2019s square and all adjacent squares are coated in rolling flames until the start of your next turn. These are difficult terrain and hazardous terrain. A creature that moves on the ground takes fire damage for every square of rolling flames it moves into, with the amount determined by the wand\u2019s type. If a creature in the flames doesn\u2019t move on its turn, it takes the damage for each of the squares it\u2019s in at the end of its turn. The first time you Sustain the Spell each round, the sphere creates rolling flames again in its new location (or the same location if you chose not to move it), provided it\u2019s on the ground.",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "floating flame",
              "aonid": 1533,
              "game-obj": "Spells",
              "name": "floating flame",
              "type": "link"
            },
            {
              "alt": "difficult terrain",
              "aonid": 2366,
              "game-obj": "Rules",
              "name": "difficult terrain",
              "type": "link"
            },
            {
              "alt": "hazardous terrain",
              "aonid": 2368,
              "game-obj": "Rules",
              "name": "hazardous terrain",
              "type": "link"
            },
            {
              "alt": "Sustain the Spell",
              "aonid": 2631,
              "game-obj": "Actions",
              "name": "Sustain the Spell",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "The luminous design of red-orange cracks on this black obsidian wand suggests cooling lava.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 72,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "974c2ceb862b6781b4ebac590bd83913",
        "game-obj": "Traits",
        "name": "Fire",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 456",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 456",
              "type": "link"
            },
            "name": "Player Core",
            "page": 456,
            "type": "source"
          }
        ],
        "text": "Effects with the fire trait deal fire damage or either conjure or manipulate fire. Those that manipulate fire have no effect in an area without fire. Creatures with this trait consist primarily of fire or have a connection to magical fire.  \n  \nPlanes with this trait are composed of flames that continually burn with no fuel source. Fire planes are extremely hostile to non-fire creatures. Unprotected wood, paper, cloth, and other flammable materials catch fire almost immediately, and creatures wearing unprotected flammable clothing catch fire, typically taking 1d6 persistent fire damage. Extraplanar creatures take moderate environmental fire damage at the end of each round (sometimes minor environmental damage in safer areas, or major or massive damage in even more fiery areas). Ice creatures are extremely uncomfortable on a fire plane, assuming they don\u2019t outright melt in the heat.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 164,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f7fe46b3a30bfb0e9bfbe655396afc22",
