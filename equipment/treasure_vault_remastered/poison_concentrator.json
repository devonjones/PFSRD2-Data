      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 6,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "9fde9d3adae06c502c6263570964463e",
        "game-obj": "Traits",
