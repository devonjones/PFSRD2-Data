    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Repurposing and enchanting a helmet worn by a battlefield commander can create a *tactician\u2019s helm*, imparting knowledge of battlefield tactics that feeds off your minor victories. The helm grants you a +1 item bonus to Warfare Lore checks. Also, a jewel adorns the brow of the helmet. This jewel becomes charged each time you hit a creature with a Reactive Strike. A *tactician\u2019s helm* can hold up to 2 charges, and its charges reset to 0 when you invest it.",
        "level": 5,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
