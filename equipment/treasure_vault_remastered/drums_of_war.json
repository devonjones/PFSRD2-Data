    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This handheld snare drum is adorned with garish scenes of battle and triumph. When played, no matter what rhythm, it always gives the impression of a marching beat, invoking armies on the move. While playing the drums, you gain a +1 item bonus to Performance checks and a +5-foot status bonus to your Speed.",
        "level": 4,
        "traits": [
            {
                "name": "Coda",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Treasure Vault",
                        "link": {
                            "type": "link",
                            "name": "Treasure Vault pg. 217",
                            "alt": "Treasure Vault pg. 217",
                            "game-obj": "Sources",
                            "aonid": 191
                        },
                        "page": 217,
                        "errata": {
                            "type": "link",
