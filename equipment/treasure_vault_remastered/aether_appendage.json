    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This otherworldly prosthetic arm is the product of psychopomp magic. An *aether appendage* is incorporeal so long as no item is being held in the hand or worn on the arm.",
        "level": 5,
        "traits": [
            {
                "name": "Uncommon",
