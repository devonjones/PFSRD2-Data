    "craft_requirements": "Supply one casting of all listed levels of all listed spells.",
    "level": 7,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "One Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "You change the shape and appearance of this staff to that of an ordinary handheld accessory of your choosing of the same Bulk. The staff\u2019s statistics don\u2019t change. Only a creature benefiting from *truesight* or a similar effect can attempt to disbelieve this illusion, with a DC of 27.",
          "links": [
            {
              "alt": "truesight",
              "aonid": 1727,
              "game-obj": "Spells",
              "name": "truesight",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 32,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "e32d877417a40fe977d27634dc14f99f",
              "game-obj": "Traits",
              "name": "Concentrate",
