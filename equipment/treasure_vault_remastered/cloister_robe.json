    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The most devoted, cloistered clerics wear a *cloister robe*. Decorations symbolic of a specific deity adorn the robe, and the robe's colors and the complexity of its construction fit the deity's outlook. The robe serves as a religious symbol of that deity, and it doesn't need to be wielded to provide that benefit.  \n  \n The robe is *+1 resilient explorer's clothing* and grants a +1 item bonus to Religion checks. The robe doesn't grant any benefits to a wearer who doesn't worship the deity tied to the robe. In addition, when you cast a domain spell from one of the deity's domains, you gain resistance to damage from divine spells until the end of your next turn. This resistance is equal to half the robe's level.",
        "level": 9,
        "image": {
            "type": "image",
            "name": "Cloister Robe",
            "image": "Cloister_Robe.webp"
        },
        "traits": [
            {
                "name": "Divine",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 48,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
