        "type": "stat_block",
        "subtype": "equipment",
        "text": "These goggles feature highly reflective lenses. While wearing the goggles, you gain a +1 item bonus to visual Perception checks and to saving throws against visual effects.",
        "level": 5,
        "traits": [
            {
                "name": "Invested",
                "type": "trait",
