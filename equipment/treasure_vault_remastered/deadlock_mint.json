    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*Deadlock mint* is a species of mint with small, green flowers, said to grow on battlefields where the opposing sides were equally matched. Sprigs of the flowers blow gently in a breeze of their own creation. If you cast *mystic armor* using *deadlock mint*, you release a small blast of concussive air in an emanation of a size that depends on the catalyst\u2019s type. Unattended objects up to a certain Bulk limit are pushed away from you. Large or smaller creatures must succeed at a Fortitude save equal to your spell save DC or be pushed the same distance away from you.",
        "level": 3,
        "image": {
            "type": "image",
            "name": "Deadlock Mint",
            "image": "Bralani_Breath.webp"
        },
        "traits": [
            {
                "name": "Catalyst",
