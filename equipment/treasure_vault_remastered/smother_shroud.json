                    "text": "2d4 poison damage and dazzled (1 round)"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 2",
                    "text": "3d4 poison damage, dazzled, a \u20134 status penalty to Perception checks to hear and smell, and must succeed at a DC 10 flat check to take actions with the auditory trait or the action is lost (1 round)"
                },
