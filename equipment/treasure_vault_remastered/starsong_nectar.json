    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A liquid with the appearance of an expressive night sky and a taste that\u2019s sheer pleasure, *starsong nectar* grants you cheerful confidence and incredible luck for 10 minutes after you drink it. However, if you show too much caution at any point during this time (GM\u2019s discretion), you must succeed at a DC 6 flat check or the potion\u2019s effects end. While the potion lasts, you gain a +3 status bonus to attack rolls, Perception checks, saving throws, and skill checks, and you aren\u2019t off-guard to creatures due to them flanking you or being hidden from or undetected by you. You are temporarily immune to this potion for 24 hours once its effects end.  \n   \nWhile the potion lasts, though, if you take a moment to imagine the future, you choose the best courses of action. This aspect of the potion grants you the following activation.",
        "level": 20,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
