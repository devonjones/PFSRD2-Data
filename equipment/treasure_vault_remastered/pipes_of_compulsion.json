        ],
        "edition": "remastered",
        "game-id": "f6cdd9b53ed4b4a360df284df4503b27",
        "game-obj": "Traits",
        "name": "Staff",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
