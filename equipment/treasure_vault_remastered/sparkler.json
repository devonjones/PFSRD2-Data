    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A sparkler gives off colorful sparks, burning for 1 minute. It provides bright light in a 10-foot radius (and dim light for the next 10 feet). While the sparkler burns, you can use it as an improvised weapon, dealing 1 fire damage on a hit. On a critical hit, you cause the target to become dazzled for 1 round.  \n   \n You can touch a sparkler to a flammable object as part of the same Interact action you use to Activate it or as an Interact action while the sparkler is already activated. If you do so, the sparkler can ignite flammable objects the way a matchstick does.",
        "level": 1,
        "image": {
            "type": "image",
            "name": "Sparkler",
            "image": "Sparkler.webp"
        },
        "traits": [
            {
