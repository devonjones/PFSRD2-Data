    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This suit of *+1 hide armor* is sickly green and covered in thick warts and nodules, fashioned from the hide of a trollhound and imbued with some of the beast's vitality. Wearing this armor gives you a \u20131 circumstance penalty to all checks made using Diplomacy to interact with trolls and a +1 circumstance bonus to Diplomacy checks used to Make an Impression in communities traditionally plagued by troll attacks.",
        "level": 6,
