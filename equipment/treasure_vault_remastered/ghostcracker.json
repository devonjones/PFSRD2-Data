    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *ghostcracker* pops and smokes when consumed. When you throw the *ghostcracker* down in your space as part of casting an *illusory creature* spell, the appearance of the creature twists nightmarishly. When an enemy\u2019s attack or spell ends the *illusory creature* spell, the creature \u201cdies\u201d in a disturbing fashion, rendering the enemy frightened 1. From this effect, the *ghostcracker* adds the emotion, fear, and mental traits to the spell.",
        "level": 5,
        "image": {
            "type": "image",
            "name": "Ghostcracker",
            "image": "Fearcracker.webp"
        },
        "traits": [
            {
                "name": "Catalyst",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 396,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Howl of the Wild",
                        "link": {
                            "type": "link",
                            "name": "Howl of the Wild pg. 216",
                            "alt": "Howl of the Wild pg. 216",
                            "game-obj": "Sources",
                            "aonid": 226
                        },
                        "page": 216,
                        "errata": {
                            "type": "link",
                            "name": "2.1",
                            "alt": "2.1",
                            "game-obj": "Sources",
                            "aonid": 226
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e9c88caef9c7846682faee282ccd47d6",
                "text": "Items with the catalyst trait are consumables that alter or magnify specific spells. Using a catalyst adds the manipulate trait to the spell. Activating a catalyst is part of Casting the Spell. The catalyst might increase the number of actions required to Cast the Spell, as indicated in the catalyst's Activate entry. You can draw the catalyst as part of Casting the Spell.",
                "links": [
                    {
                        "type": "link",
                        "name": "manipulate",
                        "alt": "manipulate",
                        "game-obj": "Traits",
                        "aonid": 645
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
                            "alt": "Player Core pg. 454",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 454,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "07336d377bbfcf8d760f34f32f513526",
                "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
