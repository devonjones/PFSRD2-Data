    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This tangy gum cracks and pops in your mouth as you chew it. While you're chewing crackling bubble gum, for up to 10 minutes, you have an item bonus to saving throws against auditory and sonic effects.",
        "level": 5,
        "image": {
            "type": "image",
