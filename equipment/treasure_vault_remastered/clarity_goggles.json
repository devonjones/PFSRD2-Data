    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*Clarity goggles* feature faceted lenses that filter your surroundings from several slightly different angles at once, giving you a sharper picture of them. While wearing the goggles, you gain a +1 item bonus to visual Perception checks.",
        "level": 8,
        "image": {
            "type": "image",
            "name": "Clarity Goggles",
            "image": "Clarity_Goggles.webp"
        },
