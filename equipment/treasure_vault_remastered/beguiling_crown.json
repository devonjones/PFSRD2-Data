    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This hugely massive crown is bedazzled with glimmering jewels and enchanted with powerful magics that make the gold seem to ripple and surge like strange glimmering tide pools. While uncomfortable to wear, the crown beguiles those within the wearer's presence. Creatures within 30 feet of you automatically improve their attitude toward you by one step (up to friendly). This doesn't prevent hostile creatures from attacking you, but it might give you a chance to talk to them before they strike. The dazzling nature of the crown makes it hard for you to read the intentions of others, and you take a \u20134 status penalty to your Perception DC when someone uses Deception against you. When you invest the crown, you either increase your Charisma modifier by 1 or increase it to +4, whichever would give you a higher value.",
        "level": 20,
        "image": {
            "type": "image",
            "name": "Beguiling Crown",
            "image": "Beguiling_Crown.webp"
        },
        "traits": [
            {
                "name": "Uncommon",
