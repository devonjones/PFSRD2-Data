        "type": "stat_block",
        "subtype": "equipment",
        "text": "Hunters all over Golarion favor curare, a potent paralytic derived from boiled tree bark.",
        "level": 8,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
