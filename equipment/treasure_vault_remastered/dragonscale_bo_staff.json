    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking bo staff* is covered in scales shed by or harvested from a dragon. When benefiting from the circumstance bonus to AC granted by the bo staff\u2019s parry trait, you also gain a +1 circumstance bonus to saving throws against magical effects of the tradition matching the dragon who provided the scales, plus resistance 5 to a damage type determined by that tradition: force for arcane, spirit for divine, mental for occult, or fire for primal. For instance, a dragonscale bo staff made with scales taken from an omen dragon would provide a +1 circumstance bonus to saves against occult effects and resistance 5 to mental damage.",
        "level": 6,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
