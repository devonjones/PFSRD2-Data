    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Initially crafted by a gifted inventor who no longer had the use of their legs, the *inventor's chair* is a traveler's chair. It's a marvel of engineering, utilizing clockwork mechanisms to maneuver about. The chair comes equipped with wheel blades, and portions of its frame contain sterling artisan's tools. The *inventor's chair* might be a family heirloom or a gift from someone who inherited it. It could instead sit unused in its inventor's abandoned estate, awaiting another user.**Minor Gifts**: emotion surge, muse (Crafting)  \n **Major Gifts**: emotion conduit, enthralling   \n **Grand Gift**: artistic perfection (Crafting)",
        "level": 4,
        "image": {
            "type": "image",
            "name": "Inventor's Chair",
            "image": "Inventors_Chair.webp"
        },
