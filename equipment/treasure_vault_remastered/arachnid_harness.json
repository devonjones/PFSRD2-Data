    "subtype": "equipment",
    "text": "This *+1 leather armor* has four knobbed ribs that wrap around the torso. The armor grants you resistance 2 to poison damage.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
