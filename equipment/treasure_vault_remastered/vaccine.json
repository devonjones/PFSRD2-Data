        "game-id": "46d51374c2ada72347818dbac1edd7a3",
        "game-obj": "Traits",
        "name": "Healing",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
