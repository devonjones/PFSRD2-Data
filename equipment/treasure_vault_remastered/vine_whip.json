    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking whip* is crafted from the vine of a dangerous plant creature. It deals bludgeoning or slashing damage, according to the vine attack of the creature it was harvested from. For example, collecting a vine from an assassin vine would result in a *vine whip* that deals bludgeoning damage, while one from a mandragora or viper vine would deal piercing damage.",
        "level": 8,
        "image": {
