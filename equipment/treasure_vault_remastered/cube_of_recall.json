    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This small cube has smooth matte sides. One side is black, the opposite side is white, and the other four are various shades of gray. Each side can be attuned to a location and then teleport you back to that spot in the blink of an eye.",
        "level": 19,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
