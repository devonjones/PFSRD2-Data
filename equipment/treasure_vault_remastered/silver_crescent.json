    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A piquant tamarind and chili-lime flavor infuses a silver crescent, which was first created to aid those battling the undead. For 1 hour, you shed cool, white light like a torch, and you gain an item bonus to saving throws against olfactory effects according to the crescent's type. While shedding this light, you can't be concealed if you're visible, and if you're invisible, you're concealed instead rather than being undetected.",
        "level": 6,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 6,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 452,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "9fde9d3adae06c502c6263570964463e",
                "text": "Alchemical items are powered by reactions of alchemical reagents. Unless otherwise noted, alchemical items aren\u2019t magical and don\u2019t radiate a magical aura.  \n  \nAlchemical creatures are partially powered by alchemical reactions.",
                "links": [
                    {
                        "type": "link",
                        "name": "magical",
                        "alt": "magical",
                        "game-obj": "Traits",
                        "aonid": 644
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
                            "alt": "Player Core pg. 454",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 454,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "07336d377bbfcf8d760f34f32f513526",
                "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Light",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 100,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "dd40587ebc07c2b386aa95d93fdcc130",
                "text": "Light effects overcome non-magical darkness in the area and can counteract magical darkness. You must usually target darkness magic with your light magic directly to counteract the darkness, but some light spells automatically attempt to counteract darkness.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Lozenge",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Treasure Vault",
                        "link": {
                            "type": "link",
                            "name": "Treasure Vault pg. 220",
                            "alt": "Treasure Vault pg. 220",
                            "game-obj": "Sources",
                            "aonid": 191
                        },
                        "page": 220,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 191
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "a25dd121b634f42137a3571dc23cf95e",
                "text": "You Activate an alchemical lozenge by putting it in your mouth. It stays there, slowly dissolving and releasing its ingredients over time. You can bite a lozenge for a secondary effect. The action this takes is noted in the item. As soon as this secondary effect is over, the lozenge is used up and its benefits for you end. You can drink elixirs, potions, and beverages with a lozenge in your mouth, but you can't benefit from more than one lozenge at a time. If you have two lozenges in your mouth at the same time, both become inert. You can also spit out a lozenge as a single action to end its effect and make it inert. A lozenge dissolves due to its alchemical ingredients, so it typically still works even if you don't have saliva.",
                "links": [
                    {
                        "type": "link",
                        "name": "elixirs",
                        "alt": "elixirs",
                        "game-obj": "Traits",
                        "aonid": 59
                    },
                    {
                        "type": "link",
                        "name": "potions",
                        "alt": "potions",
                        "game-obj": "Traits",
                        "aonid": 130
                    }
                ],
                "classes": [
                    "trait"
                ]
            }
        ],
