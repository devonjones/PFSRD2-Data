    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Made of elemental salts and essences from the Inner Sphere or where such planes leak onto the Universe, *fundamental oil* is anathema to elementals and other creatures with a weakness to elemental damage. A weapon anointed with this oil acts as *bane oil* to elementals, but the damage type is the same as the target\u2019s greatest weakness if the target has weakness to acid, cold, electricity, fire, or sonic damage. If it has none of these, the additional damage is the same type as the weapon\u2019s damage type. These effects last 1 minute.",
        "level": 11,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
