                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "ae3604d98ffc303ee0eb84f9c3281d28",
                "text": "Oils are magical gels, ointments, pastes, or salves that are typically applied to an object and are used up in the process.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            }
