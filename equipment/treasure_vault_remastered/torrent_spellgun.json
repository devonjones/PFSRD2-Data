                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "23c17a4eee189983083f41b20ff9ff92",
                "text": "An ability with this trait involves an attack. For each attack you make beyond the first on your turn, you take a multiple attack penalty.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
                            "alt": "Player Core pg. 454",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 454,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "07336d377bbfcf8d760f34f32f513526",
                "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Spellgun",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Treasure Vault",
                        "link": {
                            "type": "link",
                            "name": "Treasure Vault pg. 221",
                            "alt": "Treasure Vault pg. 221",
                            "game-obj": "Sources",
                            "aonid": 191
                        },
                        "page": 221,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 191
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "890556826496c12df122838e112a1723",
                "text": "The spellgun trait appears on items that can generate a magical effect that flies out like a bullet. You can make either a spell attack roll with a spellgun or a ranged attack roll using your proficiency with simple firearms. Spellguns have a range increment, which applies regardless of which type of attack roll you make. Though you can use your modifier for simple firearms, a spellgun isn't actually a firearm. You don't get the damage of a firearm Strike, nor other benefits like critical specialization. Similarly, you can't load or reload a spellgun, affix talismans to one, make a spellgun Strike as part of an action that lets you make a firearm Strike, and so on.",
                "links": [
                    {
                        "type": "link",
                        "name": "firearms",
                        "alt": "firearms",
                        "game-obj": "WeaponGroups",
                        "aonid": 16
                    },
                    {
                        "type": "link",
                        "name": "critical specialization",
                        "alt": "critical specialization",
                        "game-obj": "Rules",
                        "aonid": 235
                    },
                    {
                        "type": "link",
                        "name": "talismans",
                        "alt": "talismans",
                        "game-obj": "Traits",
                        "aonid": 155
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Water",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 165,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 463",
                            "alt": "Player Core pg. 463",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 463,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "28b3ffaf7df1fef23da1eb1d9c63267d",
                "text": "Effects with the water trait either manipulate or conjure water. Those that manipulate water have no effect in an area without water. Creatures with this trait consist primarily of water or have a connection to magical water.  \n  \nPlanes with this trait are mostly liquid. Visitors who can\u2019t breathe water or reach an air pocket likely drown. The rules for aquatic combat aquatic combat usually apply, including the inability to cast fire spells or use actions with the fire trait. Creatures with a weakness to water take damage equal to double their weakness at the end of each round.",
                "links": [
                    {
                        "type": "link",
                        "name": "aquatic combat",
                        "alt": "aquatic combat",
                        "game-obj": "Rules",
                        "aonid": 2438
                    }
                ],
                "classes": [
                    "trait"
                ]
            }
        ],
