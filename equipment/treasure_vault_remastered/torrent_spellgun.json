    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Carved of seashell, a *torrent spellgun* is damp to the touch, and seaweed wraps around its grip. You Activate the spellgun by aiming it at one creature and making your choice of a spell attack roll or a firearm attack roll against the target's AC. This spellgun has a range increment of 30 feet. The spellgun blasts a powerful jet of water that deals bludgeoning damage based on the spellgun's type, then disintegrates into sand.",
        "level": 3,
        "image": {
            "type": "image",
            "name": "Torrent Spellgun",
            "image": "Torrent_Spellgun.webp"
        },
        "traits": [
