    "craft_requirements": "Supply a casting of a spell of the appropriate rank. The spell must have a casting time of [#] or [##] , and must have a range.",
    "level": 4,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You Cast the Spell. Its range increases by 30 feet. As normal for increasing ranges, if the spell normally has a range of touch, its range extends to 30 feet.",
          "frequency": "once per day, plus overcharge",
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
