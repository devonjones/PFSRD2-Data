    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Opening this vial releases a mighty gust, forming into a fearsome Huge elemental hurricane. The elemental breathes a 30-foot cone of air. Each creature in the cone must succeed at a DC 28 Fortitude save or be knocked away from the elemental. A creature knocked into a solid object stops moving and takes 4d6 bludgeoning damage.",
        "level": 11,
        "traits": [
            {
                "name": "Air",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 5,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 452,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "8ca8a0ac0e16b3c136f09ca48d8578bb",
                "text": "Effects with the air trait either manipulate or conjure air. Those that manipulate air have no effect in a vacuum or an area without air. Creatures with this trait consist primarily of air or have a connection to magical air.   \n  \nPlanes with this trait consist mostly of open spaces and air of various levels of turbulence, though they also contain rare islands of floating stone and other elements and energies. Air planes usually have breathable atmospheres, though they might include clouds of acidic or toxic gas. Earth creatures often find themselves at a disadvantage within air planes, as there\u2019s little solid ground for them to gain their bearings, which tends to at least make them uncomfortable.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 6,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 452",
                            "alt": "Player Core pg. 452",
                            "game-obj": "Sources",
                            "aonid": 216
