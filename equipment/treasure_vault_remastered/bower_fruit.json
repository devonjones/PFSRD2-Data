            "type": "stat_block_section",
            "subtype": "affliction",
            "name": "Bower Fruit",
            "saving_throw": {
                "type": "stat_block_section",
                "subtype": "save_dc",
                "text": "DC 30 Fortitude",
                "dc": 30,
                "save_type": "Fort"
            },
            "stages": [
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 1",
                    "text": "You\u2019re afflicted by hunger as if you hadn\u2019t eaten food in days. You become fatigued and take 1d4 damage each day that can\u2019t be healed until you sate your hunger. No amount of eating food can sate your hunger during the spell\u2019s duration, with one exception\u2014food from the First World sates your hunger and suppresses the effects, but permanently increases the save DC by 1 (to a maximum of DC 35). After the week ends, if your hunger is still not sated, you take damage from starvation. (1 week)"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 2",
                    "text": "As stage 1, plus you\u2019re sickened 1"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 3",
                    "text": "As stage 1, plus you\u2019re drained 1 and sickened 1"
                },
                {
                    "type": "stat_block_section",
                    "subtype": "affliction_stage",
                    "name": "Stage 4",
                    "text": "As stage 1, plus you\u2019re drained 2, sickened 2, and stupefied 2."
                }
            ],
