    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1* *leather lamellar* *armor* incorporates the plates of an ore louse\u2019s hide, woven together with the creature\u2019s own sinew into a functional set of armor. While wearing the *rusting carapace*, you gain a +1 circumstance bonus to AC and saving throws against any effect that would rust you or your items, such as the ore louse\u2019s Strikes that have the rust ability or the *rust cloud* spell.",
        "level": 8,
