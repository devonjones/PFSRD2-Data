      "abilities": [
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "One Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "Through the staff's strange whispering, you gain a glimpse into the mind and desires of one creature you can see within 30 feet. Until the end of your next turn, that creature is flat-footed to you and takes a \u20132 circumstance penalty to saving throws against your spells.",
          "frequency": "once per round",
