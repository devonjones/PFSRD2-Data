    "subtype": "equipment",
    "text": "Warpwobble poison causes hallucinations of space bending and stretching, leading to vertigo and an inability to discern a stable place to move.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 6,
