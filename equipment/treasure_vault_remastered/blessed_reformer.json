    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The Empyreal word for \u201crepent\u201d is etched in golden lettering on the shaft of this *+2 greater striking merciful dawnsilver warhammer*. If you are unholy, you are enfeebled 2 while carrying or wielding this weapon.",
        "level": 14,
        "image": {
            "type": "image",
            "name": "Blessed Reformer",
            "image": "Blessed_Reformer.webp"
        },
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
