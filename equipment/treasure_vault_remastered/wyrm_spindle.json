    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The broken tips of four dragon claws\u2014one of each magical tradition\u2014are set into a silver fitting. They protrude in the shape of a star or compass. \n* **Armor** After you cast a non-cantrip spell by activating the spindle, you gain resistance 5 to fire, force, mental, and spirit for 1 minute.\n* **Weapon** After you cast a non-cantrip spell by activating the spindle, you gain a Dragon Breath activity that takes 2 actions and deals 6d6 damage to all creatures in a 30-foot cone with a DC 28 basic Reflex save. Choose the type of damage when you use Dragon Breath: fire, force, mental, or spirit. You can use this activity once before the end of your next turn.",
        "level": 12,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
