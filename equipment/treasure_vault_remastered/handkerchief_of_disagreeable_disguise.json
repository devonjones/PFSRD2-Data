                            "game-obj": "Traits",
                            "aonid": 645
                        }
                    ],
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "manipulate"
                        }
                    ],
                    "activation_time": "1 minute"
                }
            ]
        },
