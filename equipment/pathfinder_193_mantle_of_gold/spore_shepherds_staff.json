    "craft_requirements": "Supply one casting of all listed levels of all listed spells.",
    "level": 4,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You expend a number of charges from the staff to cast a spell from its list.",
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This staff is constructed from a magically grown amanita mushroom, with a shaft that spreads into a bright red cap speckled in white. While wielding the staff you gain a +2 circumstance bonus to Nature checks to identify fungus.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "uncommon"
        ],
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "9011037bb4a11ca6cf2d16fa8a657bf5",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "summoning",
            "aonid": 154,
            "game-obj": "Traits",
            "name": "summoning",
            "type": "link"
          },
          {
            "alt": "teleportation",
            "aonid": 156,
            "game-obj": "Traits",
            "name": "teleportation",
            "type": "link"
          }
        ],
        "name": "Conjuration",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 630",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 630",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 630,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait are associated with the conjuration school of magic, typically involving summoning, creation, teleportation, or moving things from place to place.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 151,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f6cdd9b53ed4b4a360df284df4503b27",
        "game-obj": "Traits",
        "name": "Staff",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 278",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 278",
              "type": "link"
            },
            "name": "GM Core",
            "page": 278,
            "type": "source"
          }
        ],
        "text": "This magic item holds spells of a particular theme and allows a spellcaster to cast additional spells by preparing the staff.",
        "type": "trait"
      }
    ],
