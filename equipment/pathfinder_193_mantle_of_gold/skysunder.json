    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking clan dagger* bears the face of a stern dwarven god, his beard and features forming part of the blade.   \n  \n**Forming the Bond** The PCs complete the rite of repatriation.  \n **Advancing the Bond** Protect, recover, and restore dwarven culture and people.  \n **Minor Gifts** deadly spark, divine retribution, word of faith; divine retribution Strikes made with Skysunder gain the deadly d4 trait.  \n **Major Gifts** holy light, propelling winds",
        "level": 4,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 161,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
