        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "b767873f1e57f8326b773c8d1e27cc5c",
        "game-obj": "Traits",
        "name": "Electricity",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "Effects with this trait deal electricity damage. A creature with this trait has a connection to magical electricity.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "01bf3e53d6c0fc7f70419341635bfe8f",
        "game-obj": "Traits",
        "name": "Evocation",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 631",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 631",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 631,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait are associated with the evocation school of magic, typically involving energy and elemental forces.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
