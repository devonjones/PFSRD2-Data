    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+2 greater striking astral elven curve blade* was the treasured weapon of the Calistrian witch Silisifex, who played several key roles in reclaiming Kyonin from Tanglebriar when the elves returned to Golarion. Although a witch, her mesmerizing skill with the curved blade rivaled that of many soldiers. Her reasons for leaving Soulcutter behind in Kyonin before her final mission into Tanglebriar in an attempt to purify Deathstalk Tower are unknown.  \n  \nAs long as you carry *Soulcutter*, you gain its potency bonus as an item bonus to all saving throws against mental effects. This bonus increases by 2 against possession effects.",
        "level": 15,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 161,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "a179d6a05b0c814096f81ec4373a54f6",
                "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
