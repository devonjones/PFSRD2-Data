                        {
                            "type": "link",
                            "name": "basic",
                            "alt": "basic",
                            "game-obj": "Rules",
                            "aonid": 2247
                        }
                    ],
                    "effect": "Poison wells up from the armor\u2019s links to seep into the triggering creature\u2019s body, causing it to suffer wracking pains as if it were being stung by thousands of angry wasps. The triggering creature takes 7d6 persistent poison damage (DC 34 basic Fortitude save); this persistent damage cannot be ended as long as the triggering creature continues to grapple you.",
