    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This robe was the favored garment of the legendary Ekujae hero, Iyalirrin. When the draconic god Dahak threatened destruction, Iyalirrin was the primary architect of a powerful ritual to banish him called the anima invocation. Iyalirrin and many others were forced to sacrifice themselves to empower this ritual, but he ensured his *Anima Robe* remained in good hands before he did so. Since then, the Anima Robe has been worn by dozens of elven occultists and bards who have traveled Golarion and beyond. The *Anima Robe* has remained in the care of Queen Telandia for only the past few dozen years.  \n  \nWhile wearing the Anima Robe, you gain a +2 item bonus to Diplomacy checks made to Make an Impression and to all Performance checks. You also gain resistance 10 to to mental damage.",
        "level": 15,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 161,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "a179d6a05b0c814096f81ec4373a54f6",
                "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
