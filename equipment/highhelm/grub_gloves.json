    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Danila Kenn and Depa Stepwell of Common Goods developed these gloves after complaints from an exhausted grindlegrub rancher. Since their development, the gloves have become popular not just among grindlegrub ranchers, but laborers of all kinds in Stonebreach. The thick gloves are designed to help ranchers hold on to the squirming, slimy bodies of grindlegrubs, and help soothe the wear and tear of the day while restoring energy for after-hours pursuits. While wearing the gloves, you gain a +1 item bonus to Athletics checks. The gripping power of the gloves provides you with a +2 circumstance bonus to Reflex saves to Grab an Edge. If you roll a success to Grab an Edge, you get a critical success instead, as the *gripping gloves* allow you to hold on even with just a few fingertips.",
        "level": 6,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
