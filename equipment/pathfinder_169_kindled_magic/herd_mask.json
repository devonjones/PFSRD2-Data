    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "All *herd masks* are linked to at least one other *herd mask* and are usually sold in sets of multiple masks. Linked *herd masks* look like one another, with only the slightest of differences to tell them apart.",
        "level": 6,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
