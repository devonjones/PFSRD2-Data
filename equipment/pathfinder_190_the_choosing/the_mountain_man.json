        ],
        "edition": "remastered",
        "game-id": "19f6eb51879c14d91e272262da89e4b5",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "rare",
            "aonid": 137,
            "game-obj": "Traits",
            "name": "rare",
            "type": "link"
          },
          {
            "alt": "unique",
            "aonid": 161,
            "game-obj": "Traits",
            "name": "unique",
            "type": "link"
          }
        ],
        "name": "Artifact",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 300",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 300",
              "type": "link"
            },
            "name": "GM Core",
            "page": 300,
            "type": "source"
          }
        ],
        "text": "Items with this trait are artifacts. These magic items can't be crafted by normal means, and they can't be damaged by normal means. Artifacts are always rare or unique.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "76ee712c81efc12942289aa115c7a3d7",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "the Harrow Court",
            "aonid": 23,
            "game-obj": "Planes",
            "name": "the Harrow Court",
            "type": "link"
          }
        ],
        "name": "Harrow Court",
        "sources": [
          {
            "link": {
              "alt": "Pathfinder #190: The Choosing pg. 75",
              "aonid": 198,
              "game-obj": "Sources",
              "name": "Pathfinder #190: The Choosing pg. 75",
              "type": "link"
            },
            "name": "Pathfinder #190: The Choosing",
            "page": 75,
            "type": "source"
          }
        ],
        "text": "This trait is associated with the _Deck of Destiny_ and the Harrow Court. It is limited to the Stolen Fate campaign.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 98,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "invest",
            "aonid": 2799,
            "game-obj": "Actions",
            "name": "invest",
            "type": "link"
          }
        ],
        "name": "Invested",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 219",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 219",
              "type": "link"
            },
            "name": "GM Core",
            "page": 219,
            "type": "source"
          }
        ],
        "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "e15261ef9d67eae23579ccf106d27c86",
        "game-obj": "Traits",
        "name": "Transmutation",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 637",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 637",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 637,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait are associated with the transmutation school of magic, typically changing something\u2019s form.",
        "type": "trait"
      }
    ],
    "type": "stat_block"
