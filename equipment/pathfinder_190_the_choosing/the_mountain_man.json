    "subtype": "equipment",
    "text": "*The Mountain Man* represents creatures with incredible physical power. As long as you have *The Mountain Man* invested, it grants you a +2 item bonus to Athletics checks to Force Open, Grapple, Shove, or Trip. This increases to a +3 item bonus if you are at least 17th level.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 161,
          "game-obj": "Traits",
          "type": "alternate_link"
