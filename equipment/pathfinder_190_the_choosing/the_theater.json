        "game-id": "19f6eb51879c14d91e272262da89e4b5",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "rare",
            "aonid": 137,
            "game-obj": "Traits",
            "name": "rare",
            "type": "link"
          },
          {
            "alt": "unique",
            "aonid": 161,
            "game-obj": "Traits",
            "name": "unique",
            "type": "link"
          }
        ],
        "name": "Artifact",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 300",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 300",
              "type": "link"
            },
            "name": "GM Core",
            "page": 300,
            "type": "source"
          }
        ],
        "text": "Items with this trait are artifacts. These magic items can't be crafted by normal means, and they can't be damaged by normal means. Artifacts are always rare or unique.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "dc277f983a39bb74b92ffada679a9c8a",
        "game-obj": "Traits",
        "name": "Divination",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 631",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 631",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 631,
            "type": "source"
          }
        ],
        "text": "The divination school of magic typically involves obtaining or transferring information, or predicting events.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "76ee712c81efc12942289aa115c7a3d7",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "the Harrow Court",
