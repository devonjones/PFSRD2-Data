              "aonid": 371,
              "game-obj": "Rules",
              "name": "counteract",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 76,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "7adeee5fc9bf211a4db10de37045506c",
              "game-obj": "Traits",
              "links": [
                {
                  "alt": "misfortune",
                  "aonid": 110,
                  "game-obj": "Traits",
                  "name": "misfortune",
                  "type": "link"
                }
              ],
              "name": "Fortune",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 401",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 401",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 401,
                  "type": "source"
                }
              ],
              "text": "A fortune effect beneficially alters how you roll your dice. You can never have more than one fortune effect alter a single roll. If multiple fortune effects would apply, you have to pick which to use. If a fortune effect and a misfortune effect would apply to the same roll, the two cancel each other out, and you roll normally.",
              "type": "trait"
            }
          ],
          "trigger": "You are targeted by a misfortune effect",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "carried",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "*The Theater* represents prophecy and how prophets can't change the unfolding pageantry of fate. As long as you have *The Theater* invested and as long as you are not already doomed, when you would gain the doomed condition, attempt a DC 10 flat check. On a success, you do not gain the doomed condition.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 161,
