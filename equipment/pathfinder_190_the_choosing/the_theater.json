          ],
          "effect": "*The Theater* attempts to counter the misfortune effect before it affects you. It has a counteract level equal to your level divided by 2 (rounded up), and a counteract modifier of your Class DC \u2013 10.",
          "frequency": "once per hour",
          "links": [
            {
              "alt": "misfortune",
              "aonid": 110,
              "game-obj": "Traits",
              "name": "misfortune",
              "type": "link"
            },
