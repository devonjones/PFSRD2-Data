              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "command"
            }
          ],
          "effect": "The protective spirit within the gun imposes a vision of redemption in your foe's mind. The foe must choose one of the following options. \n* You're unharmed by the triggering damage.\n* You gain resistance to all damage against the triggering damage equal to 2 + your level. After the damaging effect is applied, the enemy becomes enfeebled 2 until the end of its next turn and takes 4 persistent good damage.",
          "frequency": "once per day",
          "links": [
            {
              "alt": "enfeebled 2",
              "aonid": 13,
              "game-obj": "Conditions",
              "name": "enfeebled 2",
              "type": "link"
            },
            {
              "alt": "persistent good damage",
              "aonid": 29,
              "game-obj": "Conditions",
              "name": "persistent good damage",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "trigger": "An enemy within 30 feet damages you",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This *+2 striking dueling pistol* is fashioned from silvery steel that glistens with a radiant light. You can choose to make a nonlethal attack with the *redeemer's pistol* without taking a \u20132 penalty; if you do so, the attack deals 1d6 additional mental damage. You can also call forth the redemptive spirit within the gun to pass judgment on your foes.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 161,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "unique"
        ],
        "edition": "remastered",
        "game-id": "a179d6a05b0c814096f81ec4373a54f6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Unique",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "fd5735184d8cc7e06debda7ae557fa0d",
        "game-obj": "Traits",
        "name": "Abjuration",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 628",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 628",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 628,
            "type": "source"
          }
        ],
        "text": "Effects and magic items with this trait are associated with the abjuration school of magic, typically involving protection or wards.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "legacy",
        "game-id": "0b69d10c0f742fd54efa8502e91ee56c",
        "game-obj": "Traits",
        "name": "Good",
        "sources": [
          {
            "errata": {
              "alt": "4.0",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "4.0",
              "type": "link"
            },
            "link": {
              "alt": "Core Rulebook pg. 632",
              "aonid": 1,
              "game-obj": "Sources",
              "name": "Core Rulebook pg. 632",
              "type": "link"
            },
            "name": "Core Rulebook",
            "page": 632,
            "type": "source"
          }
        ],
        "text": "Good effects often manipulate energy from good-aligned Outer Planes and are antithetical to evil divine servants or divine servants of evil deities. A creature with this trait is good in alignment.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 106,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "6a1f80610baa3617c1597f49c6406313",
        "game-obj": "Traits",
        "name": "Mental",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
