                "classes": [
                    "unique"
                ]
            },
            {
                "name": "Curse",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 38,
                    "alternate_type": "legacy"
