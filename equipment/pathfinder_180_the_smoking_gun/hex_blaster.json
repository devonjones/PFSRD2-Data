    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+2 striking fearsome arquebus* is composed of warped and twisted wood engraved with eerie runes. When the weapon fires, the blast sometimes sounds like the cackling of a diabolical witch.",
