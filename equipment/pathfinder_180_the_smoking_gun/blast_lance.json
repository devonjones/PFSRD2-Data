                        },
                        {
                            "type": "link",
                            "name": "pushed back",
                            "alt": "pushed back",
                            "game-obj": "Rules",
                            "aonid": 451
                        }
                    ],
                    "success": "The target takes half the fire damage.",
                    "failure": "The target takes the full fire damage and is pushed back 5 feet. You can Stride after it, but you must move the same distance and in the same direction.",
                    "critical_failure": "The target takes double damage and is pushed back 10 feet. You can Stride after it, but you must move the same distance and in the same direction.",
