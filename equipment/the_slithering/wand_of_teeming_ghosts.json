  "stat_block": {
    "bulk": {
      "subtype": "bulk",
      "text": "L",
      "type": "stat_block_section",
      "value": null
    },
    "craft_requirements": "Supply a casting of *false vitality* of the appropriate rank.",
    "level": 6,
    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "activation_types": [
            {
              "subtype": "activation_type",
              "type": "stat_block_section",
              "value": "cast a spell"
            }
          ],
          "effect": "You cast *false vitality* of the indicated rank. During the duration of the spell, wisps that resemble spirits flit around you as long as you have any temporary Hit Points from *false vitality*, and you can use the following action.",
          "frequency": "once per day, plus overcharge",
          "links": [
            {
              "alt": "false vitality",
              "aonid": 1523,
              "game-obj": "Spells",
              "name": "false vitality",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "type": "stat_block_section"
        },
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "Free Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "You end *false vitality* and increase the creature's frightened condition value to 2.",
          "links": [
            {
              "alt": "frightened 1",
              "aonid": 19,
              "game-obj": "Conditions",
              "name": "frightened 1",
              "type": "link"
            }
          ],
          "name": "Activate",
          "requirement": "You have at least 1 temporary Hit Point from *false vitality*",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 32,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "e32d877417a40fe977d27634dc14f99f",
              "game-obj": "Traits",
              "name": "Concentrate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 454",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 454,
                  "type": "source"
                }
              ],
              "text": "An action with this trait requires a degree of mental concentration and discipline.",
              "type": "trait"
            }
          ],
          "trigger": "You successfully impart the frightened 1 condition on a creature",
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This pale wooden wand is carved to resemble a thigh bone with metal caps at each end. Ghostly tendrils seem to swirl around it every so often.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "uncommon"
        ],
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 103,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "15e2d048ce93e7b648064b09972535bc",
        "game-obj": "Traits",
        "name": "Magical",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 458",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 458",
              "type": "link"
            },
            "name": "Player Core",
            "page": 458,
            "type": "source"
          }
        ],
        "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 164,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f7fe46b3a30bfb0e9bfbe655396afc22",
        "game-obj": "Traits",
        "name": "Wand",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 463",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 463",
              "type": "link"
            },
            "name": "Player Core",
            "page": 463,
            "type": "source"
          }
        ],
        "text": "A wand contains a single spell which you can cast once per day.",
        "type": "trait"
      }
