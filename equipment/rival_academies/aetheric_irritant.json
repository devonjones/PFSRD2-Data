                        "name": "Guns & Gears",
                        "link": {
                            "type": "link",
                            "name": "Guns & Gears pg. 233",
                            "alt": "Guns & Gears pg. 233",
                            "game-obj": "Sources",
                            "aonid": 98
                        },
                        "page": 233,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 98
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "984375da91f3d0abd6b27d241acc7b20",
                "text": "Gadgets are consumable technological inventions with innovative uses.",
                "links": [
                    {
                        "type": "link",
                        "name": "consumable",
                        "alt": "consumable",
                        "game-obj": "Traits",
                        "aonid": 36
                    }
