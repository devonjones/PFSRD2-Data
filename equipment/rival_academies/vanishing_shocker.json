            "name": "Guns & Gears",
            "page": 233,
            "type": "source"
          }
        ],
        "text": "Gadgets are consumable technological inventions with innovative uses.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 92,
