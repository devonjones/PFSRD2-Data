                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "held in 1 hand",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "The vanishing shocker is a cube with extruding spikes at each corner. This inscrutable device channels occult energy through the electricity it produces, creating the result of invisible lighting. When activated, the cube floats above your head, creating a field of invisible electricity in a 10-foot emanation that lasts for 1 round. You and creatures within the emanation are concealed. Creatures that enter or start their turn within the area must attempt a DC 22 Reflex save.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "uncommon"
        ],
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 36,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "07336d377bbfcf8d760f34f32f513526",
        "game-obj": "Traits",
        "name": "Consumable",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 454",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 454",
              "type": "link"
            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 56,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "b767873f1e57f8326b773c8d1e27cc5c",
        "game-obj": "Traits",
        "name": "Electricity",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 455",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 455",
              "type": "link"
            },
            "name": "Player Core",
            "page": 455,
            "type": "source"
          }
        ],
        "text": "Effects with this trait deal electricity damage. A creature with this trait has a connection to magical electricity.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "984375da91f3d0abd6b27d241acc7b20",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "consumable",
            "aonid": 36,
            "game-obj": "Traits",
            "name": "consumable",
            "type": "link"
          }
        ],
        "name": "Gadget",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 98,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Guns & Gears pg. 233",
              "aonid": 98,
              "game-obj": "Sources",
              "name": "Guns & Gears pg. 233",
              "type": "link"
