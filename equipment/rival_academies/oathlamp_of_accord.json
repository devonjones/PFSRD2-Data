    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This hooded lantern takes the form of a translucent prism. It functions as a normal hooded lantern, except that it isn\u2019t fueled by oil, but by oaths. While you\u2019re holding the lantern, you gain a +1 item bonus to Diplomacy checks.",
        "level": 3,
        "traits": [
            {
