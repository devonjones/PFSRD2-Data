    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Visitors to the Echo Repository always emerge with one of these silver coins, stamped with the visage of a faceless queen, somewhere on their person. An *echo token* carries a minute shard of the Echo Repository's mission to impart lost information.",
        "level": 1,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e4b0e4f5f4b3d4cad3bea67ec077e297",
                "text": "This rarity indicates that a rules element is very difficult to find in the game world. A rare feat, spell, item or the like is available to players only if the GM decides to include it in the game, typically through discovery during play. Creatures with this trait are rare. They typically can't be summoned. The DC of Recall Knowledge checks related to these creatures is increased by 5.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "classes": [
                    "rare"
                ]
            },
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 36,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 454",
                            "alt": "Player Core pg. 454",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 454,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "07336d377bbfcf8d760f34f32f513526",
                "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            }
        ],
        "price": {
            "type": "stat_block_section",
            "subtype": "price",
            "text": "3 gp",
            "value": 3,
            "currency": "gp"
        },
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "held in 1 hand"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "effect": "When flipped, the coin disintegrates into a glittery mist. You learn and memorize one random fact about a specific type of Lore (such as Architecture Lore, Elf Lore, Astral Plane Lore) that you didn't previously know, chosen by the GM. The next time you attempt a check to Recall Knowledge on this type of Lore within the next year, you gain a +1 status bonus on the check. You can benefit from only one echo token at a time in this way; if you Flip another echo token, the Lore skill changes. However, the memorized fact will remain perfectly in your memory forever unless magically altered or removed.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Lore",
                            "alt": "Lore",
                            "game-obj": "Skills",
                            "aonid": 41
                        },
                        {
                            "type": "link",
                            "name": "Recall Knowledge",
                            "alt": "Recall Knowledge",
                            "game-obj": "Actions",
                            "aonid": 2367
                        }
                    ],
                    "traits": [
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                            "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions."
                        }
                    ],
                    "activation_name": "Flip a Coin"
                }
            ]
        },
