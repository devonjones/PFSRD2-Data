                "game-obj": "Traits",
                "game-id": "984375da91f3d0abd6b27d241acc7b20",
                "text": "Gadgets are consumable technological inventions with innovative uses.",
                "links": [
                    {
                        "type": "link",
                        "name": "consumable",
                        "alt": "consumable",
                        "game-obj": "Traits",
                        "aonid": 36
                    }
