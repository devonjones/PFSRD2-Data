        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 134,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "60a4f011afd1e0fac8211bd01108d104",
        "game-obj": "Traits",
        "name": "Primal",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
