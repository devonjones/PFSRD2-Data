    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This astrolabe is fashioned of magically attuned platinum plates and rings and is inset with carefully measured ruby gems. The astrolabe\u2019s back is engraved with helpful charts, a calendar, and a maker\u2019s mark.   \n  \nAn *astrolabe of falling stars* can be used as a mariner\u2019s astrolabe. In addition, it can produce the following magical effect.",
        "level": 5,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
