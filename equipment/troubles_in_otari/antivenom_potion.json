    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This cloudy, white liquid helps protect against poisons. When you drink an *antivenom potion*, you can immediately attempt a DC 10 flat check to end any persistent poison damage you're taking. In addition, for 1 minute after drinking the potion, you gain a +1 item bonus to Fortitude saving throws to avoid taking persistent poison damage.",
        "level": 2,
        "traits": [
            {
                "name": "Consumable",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
