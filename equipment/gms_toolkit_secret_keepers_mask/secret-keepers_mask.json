                                {
                                    "type": "stat_block_section",
                                    "subtype": "activation_type",
                                    "value": "interact"
                                }
                            ]
                        }
                    ]
                },
                "text": "This mask is made of gray and black tiles sewn together. It has a messy, inky spiral over the mouth.",
