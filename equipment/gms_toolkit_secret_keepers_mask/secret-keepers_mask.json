    "aonid": 914,
    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Each of these full-face masks is made of stitched materials\u2014often including humanoid skin\u2014and has a single, bulbous eye. While wearing the mask, you gain a +1 item bonus to Deception checks to Lie and the mask doesn't impair your vision. The mask can also be activated, with an ability based on its type.",
        "level": 3,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e4b0e4f5f4b3d4cad3bea67ec077e297",
                "text": "This rarity indicates that a rules element is very difficult to find in the game world. A rare feat, spell, item or the like is available to players only if the GM decides to include it in the game, typically through discovery during play. Creatures with this trait are rare. They typically can't be summoned. The DC of Recall Knowledge checks related to these creatures is increased by 5.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "classes": [
                    "rare"
                ]
            },
            {
                "name": "Divination",
                "type": "trait",
                "edition": "legacy",
                "sources": [
                    {
                        "type": "source",
                        "name": "Core Rulebook",
                        "link": {
                            "type": "link",
                            "name": "Core Rulebook pg. 631",
                            "alt": "Core Rulebook pg. 631",
                            "game-obj": "Sources",
                            "aonid": 1
                        },
                        "page": 631,
                        "errata": {
                            "type": "link",
                            "name": "4.0",
                            "alt": "4.0",
                            "game-obj": "Sources",
                            "aonid": 1
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "dc277f983a39bb74b92ffada679a9c8a",
                "text": "The divination school of magic typically involves obtaining or transferring information, or predicting events.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Enchantment",
                "type": "trait",
                "edition": "legacy",
                "sources": [
                    {
                        "type": "source",
                        "name": "Core Rulebook",
                        "link": {
                            "type": "link",
                            "name": "Core Rulebook pg. 631",
                            "alt": "Core Rulebook pg. 631",
                            "game-obj": "Sources",
                            "aonid": 1
                        },
                        "page": 631,
                        "errata": {
                            "type": "link",
                            "name": "4.0",
                            "alt": "4.0",
                            "game-obj": "Sources",
                            "aonid": 1
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "67a22784fdff12403013a5af60fb8621",
                "text": "Effects and magic items with this trait are associated with the enchantment school of magic, typically involving mind control, emotion alteration, and other mental effects.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Invested",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 98,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
                        "link": {
                            "type": "link",
                            "name": "GM Core pg. 219",
                            "alt": "GM Core pg. 219",
                            "game-obj": "Sources",
                            "aonid": 218
                        },
                        "page": 219,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "56b56ea5f9d865dc549f0ed7372ab504",
                "text": "A character can invest only 10 magical items that have the invested trait. None of the magical effects of the item apply if the character hasn\u2019t invested it, nor can it be activated, though the character still gains any normal benefits from wearing the physical item (like a hat keeping rain off their head).",
                "links": [
                    {
                        "type": "link",
                        "name": "invest",
                        "alt": "invest",
                        "game-obj": "Actions",
                        "aonid": 2799
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            }
        ],
