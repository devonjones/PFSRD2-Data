    "aonid": 1636,
    "game-obj": "Equipment",
    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This musical instrument is crafted from the horn of an aoyin\u2014a large, cannibalistic beast whose form resembles an ox with a white body, four horns, and hair as coarse as straw\u2014and carved with fell symbols. If the *horn of the aoyin's* owner doesn't use the instrument's activation on sapient creatures at least once a day, the *horn of the aoyin* activates at some point of its own choosing on the owner, and the owner critically fails with no saving throw.",
        "level": 13,
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e4b0e4f5f4b3d4cad3bea67ec077e297",
                "text": "This rarity indicates that a rules element is very difficult to find in the game world. A rare feat, spell, item or the like is available to players only if the GM decides to include it in the game, typically through discovery during play. Creatures with this trait are rare. They typically can't be summoned. The DC of Recall Knowledge checks related to these creatures is increased by 5.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "classes": [
                    "rare"
                ]
            },
            {
                "name": "Cursed",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 274,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "GM Core",
                        "link": {
                            "type": "link",
                            "name": "GM Core pg. 306",
                            "alt": "GM Core pg. 306",
                            "game-obj": "Sources",
                            "aonid": 218
                        },
                        "page": 306,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 218
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "93177649f9920e9a2a4a80ada85b7ab1",
                "text": "An item with this trait is cursed to cause trouble for its owner. A curse isn\u2019t detected when the item is identified, though a critical success reveals both the presence and exact nature of the curse. Cursed items can\u2019t be discarded once they\u2019ve been triggered or invested the first time. The item can be removed only if the curse is removed.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Enchantment",
                "type": "trait",
                "edition": "legacy",
                "sources": [
                    {
                        "type": "source",
                        "name": "Core Rulebook",
                        "link": {
                            "type": "link",
                            "name": "Core Rulebook pg. 631",
                            "alt": "Core Rulebook pg. 631",
                            "game-obj": "Sources",
                            "aonid": 1
                        },
                        "page": 631,
                        "errata": {
                            "type": "link",
                            "name": "4.0",
                            "alt": "4.0",
                            "game-obj": "Sources",
                            "aonid": 1
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "67a22784fdff12403013a5af60fb8621",
                "text": "Effects and magic items with this trait are associated with the enchantment school of magic, typically involving mind control, emotion alteration, and other mental effects.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            }
        ],
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "held in 2 hands"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per hour",
                    "effect": "You blow the horn, creating a low growling sound. Creatures other than you within 60 feet must attempt a DC 30 Will save. Those who fail become overwhelmed with an animalistic rage and the urge to consume flesh for 1 round, or 1 minute on a critical failure. They indiscriminately attack the nearest target unaffected by the magic of the horn unless there are no such targets, at which point they set on each other. While affected, they gain a jaws unarmed attack that deals 1d8 piercing damage, deal an additional 2 damage with unarmed attacks, and lose the ability to use any weaponry. They also gain a +2 status bonus to saving throws against mental effects and pain, can detect bleeding creatures and open wounds as an imprecise sense with a range of 30 feet, and gain a +10- foot status bonus to their Speed. Lastly, they take a \u20131 penalty to AC and are unable to use concentrate actions other than Seeking. Creatures who critically succeed are temporarily immune for 24 hours.",
                    "links": [
                        {
                            "type": "link",
                            "name": "unarmed",
                            "alt": "unarmed",
                            "game-obj": "Traits",
                            "aonid": 199
                        },
