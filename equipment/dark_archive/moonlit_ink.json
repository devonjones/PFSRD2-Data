    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This alchemical ink is applied to a stamping device, typically a wooden seal or chop commissioned by the secret society and costing 1 sp. When the seal is pressed to paper, the ink briefly shows up before fading into invisibility. The stamp can be revealed by exposing the stamped item to direct moonlight for 1 minute. A character checking a good or document marked by a moonlit ink stamp must succeed at a DC 25 Perception check to spot the stamp without exposure to moonlight. In addition to its use by secret societies for their secret books, papers, and messages, some smugglers use moonlit ink to mark their goods.",
        "level": 2,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
