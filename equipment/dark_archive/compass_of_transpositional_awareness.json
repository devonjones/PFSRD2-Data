                            "alt": "plane shift",
                            "game-obj": "Spells",
                            "aonid": 222
                        }
                    ],
                    "activation_types": [
                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "concentrate"
                        },
                        {
                            "type": "stat_block_section",
