    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "These wooden discs sometimes form spontaneously at the Wood Pile, a secret conrasu location suffused with extraplanar energy. A conrasu coin can be activated to call upon the power of a specific type of aeon.",
        "level": 3,
        "traits": [
            {
