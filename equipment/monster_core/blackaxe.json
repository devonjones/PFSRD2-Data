          }
        ],
        "name": "Artifact",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 300",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 300",
              "type": "link"
            },
            "name": "GM Core",
            "page": 300,
            "type": "source"
          }
        ],
        "text": "Items with this trait are artifacts. These magic items can't be crafted by normal means, and they can't be damaged by normal means. Artifacts are always rare or unique.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 274,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "93177649f9920e9a2a4a80ada85b7ab1",
        "game-obj": "Traits",
        "name": "Cursed",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "GM Core pg. 306",
              "aonid": 218,
              "game-obj": "Sources",
              "name": "GM Core pg. 306",
              "type": "link"
            },
            "name": "GM Core",
            "page": 306,
            "type": "source"
          }
        ],
        "text": "An item with this trait is cursed to cause trouble for its owner. A curse isn\u2019t detected when the item is identified, though a critical success reveals both the presence and exact nature of the curse. Cursed items can\u2019t be discarded once they\u2019ve been triggered or invested the first time. The item can be removed only if the curse is removed.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 134,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "60a4f011afd1e0fac8211bd01108d104",
        "game-obj": "Traits",
        "name": "Primal",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 460",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 460",
              "type": "link"
            },
            "name": "Player Core",
            "page": 460,
            "type": "source"
          }
        ],
        "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "6309897c89780f17449b984cbb6d26cb",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "holy",
            "aonid": 517,
            "game-obj": "Traits",
            "name": "holy",
            "type": "link"
          }
        ],
        "name": "Unholy",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 462",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 462",
              "type": "link"
            },
            "name": "Player Core",
            "page": 462,
            "type": "source"
          }
        ],
        "text": "Effects with the unholy trait are tied to powerful magical forces of cruelty and sin. They often have stronger effects on holy creatures. Creatures with this trait are strongly devoted to unholy causes, and often have weakness to holy. If a creature with weakness to unholy uses an unholy item or effect, it takes damage from its weakness.",
        "type": "trait"
      }
    ],
    "type": "stat_block"
  },
  "type": "equipment"
