              },
              "edition": "remastered",
              "game-id": "74fd4b78b1a679acb12014cc5bd3ccf6",
              "game-obj": "Traits",
              "name": "Death",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
