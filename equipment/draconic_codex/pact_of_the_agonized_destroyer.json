            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "Attempt an Intimidation check against the Will DC of each creature in a 30-foot emanation that you observe and that observes you.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Intimidation",
                            "alt": "Intimidation",
                            "game-obj": "Skills",
                            "aonid": 40
                        },
                        {
                            "type": "link",
                            "name": "emanation",
                            "alt": "emanation",
                            "game-obj": "Rules",
                            "aonid": 2387
                        },
                        {
                            "type": "link",
                            "name": "frightened",
                            "alt": "frightened",
                            "game-obj": "Conditions",
                            "aonid": 76
                        },
                        {
                            "type": "link",
                            "name": "fleeing",
                            "alt": "fleeing",
                            "game-obj": "Conditions",
                            "aonid": 74
                        },
                        {
                            "type": "link",
                            "name": "death",
                            "alt": "death",
                            "game-obj": "Traits",
                            "aonid": 571
                        }
                    ],
                    "critical_success": "The target must attempt a Fortitude save against your Intimidation DC. On a critical failure, it dies in an explosion of hellfire that deals 6d6 fire damage to each creature in a 5-foot emanation. On any other result, the creature becomes frightened 3 and is fleeing for 1 round. The critical failure effect has the death trait.",
                    "success": "The target becomes frightened 3 and takes 4d6 fire damage.",
                    "failure": "The target becomes frightened 2.",
                    "critical_failure": "The target is unaffected.",
                    "traits": [
                        {
                            "name": "Auditory",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 16,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 453",
                                        "alt": "Player Core pg. 453",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 453,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "84c09922ddd30f2144494f2cb6f19412",
                            "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound."
                        },
                        {
                            "name": "Concentrate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 32,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 454",
                                        "alt": "Player Core pg. 454",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 454,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "e32d877417a40fe977d27634dc14f99f",
                            "text": "An action with this trait requires a degree of mental concentration and discipline."
                        },
                        {
                            "name": "Emotion",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 60,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 455",
                                        "alt": "Player Core pg. 455",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 455,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "fb5f8b3d849b073e1514a6a025810470",
                            "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects."
                        },
                        {
                            "name": "Fear",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 68,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 456",
                                        "alt": "Player Core pg. 456",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 456,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "9a5cea6bfb849deb16206c68f8d113a5",
                            "text": "Fear effects evoke the emotion of fear. Effects with this trait always have the mental and emotion traits as well."
                        },
                        {
                            "name": "Incapacitation",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 93,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 457",
                                        "alt": "Player Core pg. 457",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 457,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "b26076555c07646f046dd58e7d5b3885",
                            "text": "An ability with this trait can take a character completely out of the fight or even kill them, and it\u2019s harder to use on a more powerful character. If a spell has the incapacitation trait, any creature of more than twice the spell\u2019s rank treats the result of their check to prevent being incapacitated by the spell as one degree of success better, or the result of any check the spellcaster made to incapacitate them as one degree of success worse. If any other effect has the incapacitation trait, a creature of higher level than the item, creature, or hazard generating the effect gains the same benefits."
                        },
                        {
                            "name": "Mental",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 106,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a1f80610baa3617c1597f49c6406313",
                            "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature."
                        },
                        {
                            "name": "Unholy",
                            "type": "trait",
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 462",
                                        "alt": "Player Core pg. 462",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 462,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6309897c89780f17449b984cbb6d26cb",
                            "text": "Effects with the unholy trait are tied to powerful magical forces of cruelty and sin. They often have stronger effects on holy creatures. Creatures with this trait are strongly devoted to unholy causes, and often have weakness to holy. If a creature with weakness to unholy uses an unholy item or effect, it takes damage from its weakness.",
                            "links": [
                                {
                                    "type": "link",
                                    "name": "holy",
                                    "alt": "holy",
                                    "game-obj": "Traits",
                                    "aonid": 517
                                }
                            ]
                        }
                    ],
                    "activation_name": "Scream of Unending Destruction"
                }
            ]
        },
