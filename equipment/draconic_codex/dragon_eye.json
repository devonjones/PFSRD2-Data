    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Even in death, a dragon\u2019s gaze is terrible to behold. When used to cast *breathe fire* at 3rd rank or higher, an eye from a dragon causes the spell to manifest some of the creature\u2019s fearsome aura and inspire terror. Creatures in the spell\u2019s area must attempt a basic Will save instead of a basic Reflex save, and in addition to taking the spell\u2019s normal damage on a failure, they\u2019re frightened 1. This adds the emotion, fear, and mental traits to the spell.",
        "level": 5,
        "image": {
            "type": "image",
            "name": "Dragon Eye",
            "image": "Dragon_Eye.webp"
        },
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
