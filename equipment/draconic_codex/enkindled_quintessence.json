                ],
                "game-obj": "Traits",
                "game-id": "9b1412649bade212276b4bc5db25d991",
                "text": "A contract is a type of item that magically establishes an agreement between multiple parties and typically grants magical benefits.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Invested",
