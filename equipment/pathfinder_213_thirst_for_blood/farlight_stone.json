    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "*Farlight stones* are common in libraries, monasteries, labs, and other places where simple but silent communication is important. *Farlight stones* always come in linked pairs, and each of the fist-sized stones can be Activated independently.",
        "level": 2,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
