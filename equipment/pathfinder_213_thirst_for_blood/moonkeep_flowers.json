        "variants": [
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Moonkeep Lily",
                "level": 5,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "30 gp",
                    "value": 30,
                    "currency": "gp"
                },
                "text": "This thin, white lily has stamens that end in small, round portions resembling the moon. When you eat the flower, you gain the flower\u2019s protection for 1 week. During this time, your curse of the werecreature becomes partially inert. Your jaws Strike doesn\u2019t inflict the curse of the werecreature during this time.",
                "links": [
                    {
                        "type": "link",
                        "name": "Strike",
                        "alt": "Strike",
                        "game-obj": "Actions",
                        "aonid": 2306
                    }
                ],
                "sources": [
                    {
                        "type": "source",
                        "name": "Pathfinder #213: Thirst for Blood",
                        "link": {
                            "type": "link",
                            "name": "Pathfinder #213: Thirst for Blood pg. 82",
                            "alt": "Pathfinder #213: Thirst for Blood pg. 82",
                            "game-obj": "Sources",
                            "aonid": 257
                        },
                        "page": 82
                    }
                ]
            },
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Moonkeep Orchid",
                "level": 5,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "30 gp",
                    "value": 30,
                    "currency": "gp"
                },
                "text": "This pale orchid glows nearly white when exposed to moonlight. When you eat the flower, you gain its protection for 3 days. During this time, your curse of the werecreature and moon frenzy don\u2019t cause you to automatically transform during a full moon, and you retain full control of your faculties during a full moon.",
                "sources": [
                    {
                        "type": "source",
                        "name": "Pathfinder #213: Thirst for Blood",
                        "link": {
                            "type": "link",
                            "name": "Pathfinder #213: Thirst for Blood pg. 82",
                            "alt": "Pathfinder #213: Thirst for Blood pg. 82",
                            "game-obj": "Sources",
                            "aonid": 257
                        },
                        "page": 82
                    }
                ]
            },
            {
                "type": "stat_block",
                "subtype": "equipment",
                "name": "Moonkeep Hyacinth",
                "level": 12,
                "price": {
                    "type": "stat_block_section",
                    "subtype": "price",
                    "text": "400 gp",
                    "value": 400,
                    "currency": "gp"
                },
                "text": "This long hyacinth features round buds that bloom into brilliant white petals. When you eat the flower, you immediately become cured of the curse of the werecreature.",
                "sources": [
                    {
                        "type": "source",
                        "name": "Pathfinder #213: Thirst for Blood",
