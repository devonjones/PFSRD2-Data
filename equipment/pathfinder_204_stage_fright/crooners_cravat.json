                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "abcdb0d656f37cebdbee9dca267ef899",
                            "text": "A visual effect can affect only creatures that can see it. This applies only to visible parts of the effect, as determined by the GM."
                        }
