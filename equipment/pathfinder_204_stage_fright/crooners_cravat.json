    "statistics": {
      "abilities": [
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "Two Actions",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "activation_name": "Adjust Cravat",
          "effect": "You make adjustments to the *crooner\u2019s cravat*, transforming it into any type of stylish chosen neckwear; as you do so, you cast a 1st\u2011rank *illusory disguise* on yourself.",
          "frequency": "once per hour",
          "links": [
            {
              "alt": "illusory disguise",
              "aonid": 1568,
              "game-obj": "Spells",
              "name": "illusory disguise",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 92,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "7a03232791db31528747d8a9f9463fd9",
              "game-obj": "Traits",
              "name": "Illusion",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 457",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 457",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 457,
                  "type": "source"
                }
              ],
              "text": "Effects and magic items with this trait involve false sensory stimuli.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 163,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "abcdb0d656f37cebdbee9dca267ef899",
              "game-obj": "Traits",
              "name": "Visual",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 463",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 463",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 463,
                  "type": "source"
                }
              ],
              "text": "A visual effect can affect only creatures that can see it. This applies only to visible parts of the effect, as determined by the GM.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        },
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "Two Actions",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "activation_name": "Influential Croon",
          "effect": "You pour emotion into your vocal performance, projecting an empathetic bond that fascinates listeners. You cast *enthrall* (DC 30 Will save). When you first activate Influential Croon, you can also cast *subconscious suggestion* on one creature within 30 feet (DC 30 Will save).",
          "frequency": "once per hour",
          "links": [
            {
              "alt": "enthrall",
              "aonid": 1516,
              "game-obj": "Spells",
              "name": "enthrall",
              "type": "link"
            },
            {
              "alt": "subconscious suggestion",
              "aonid": 1692,
              "game-obj": "Spells",
              "name": "subconscious suggestion",
              "type": "link"
            }
          ],
          "name": "Activate",
          "subtype": "activation",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 16,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "84c09922ddd30f2144494f2cb6f19412",
              "game-obj": "Traits",
              "name": "Auditory",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 60,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "fb5f8b3d849b073e1514a6a025810470",
              "game-obj": "Traits",
              "name": "Emotion",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 101,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
              "game-obj": "Traits",
              "name": "Linguistic",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "An effect with this trait depends on language comprehension. A linguistic effect that targets a creature works only if the target understands the language you are using.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "worn necklace",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "This long, silky neckcloth has the ability to be tied into a convincing semblance of an elegant evening scarf, a worker\u2019s neck kerchief, an elaborate cravat, or any other neckwear. It also provides a boost to vocal performances, enhancing both projection and the emotive qualities of a performance. In its natural state, this item appears as a long, white silk scarf. A *crooner\u2019s cravat* grants a +1 item bonus to all Performance checks, but this increases to a +2 item bonus for Performance checks to sing.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 161,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "unique"
        ],
        "edition": "remastered",
        "game-id": "a179d6a05b0c814096f81ec4373a54f6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
