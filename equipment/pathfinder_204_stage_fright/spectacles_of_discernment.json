    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Designed for a frequent sponsor of theatrical productions who liked to stay informed of all the off-stage drama, these silver opera glasses are affixed to a slender redwood handle. They can\u2019t be worn on the face but must be raised to the eyes and held there, at which point the spectacles of discernment grant a +2 item bonus to Perception checks to notice details at a distance.",
        "level": 13,
        "traits": [
            {
                "name": "Unique",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 161,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
