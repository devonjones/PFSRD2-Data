    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "These bombs have been mixed with sticky algae that glow and emit poison. Attacks with this bomb don't take the normal penalties and restrictions for being used in water or underwater. A sticky algae bomb deals the listed poison damage. Many types grant an item bonus to attack rolls. In addition, the target is tagged by the bioluminescent substance and leaves a highly visible trail for the next hour. The DC to Track a creature using this trail is 19, but the trail appears only in water.",
        "level": 1,
        "traits": [
            {
                "name": "Alchemical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
