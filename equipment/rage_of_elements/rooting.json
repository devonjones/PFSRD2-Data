    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Small roots grow along the surface of the weapon, clinging tightly to its contours. On a critical hit with the weapon, roots grow from the target. It's immobilized for 1 round (Escape DC 23) and clumsy 1 for as long as the immobilization lasts.",
        "level": 7,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
