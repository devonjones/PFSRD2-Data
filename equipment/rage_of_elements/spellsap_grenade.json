    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The mixture of reagents, liquid djezet, and solid metal shrapnel inside this grenade explodes on contact with air. A spellsap grenade deals the listed slashing damage and splash damage. On a hit against a prepared or spontaneous spellcaster, the target must succeed at a Will saving throw with the listed DC or lose one prepared spell or one spontaneous spell slot. The spell is randomly selected from among the caster's highest three spell ranks (and then from among the spells prepared in that rank, for a prepared spellcaster). The grenade grant an item bonus to attack rolls.",
        "level": 12,
        "image": {
            "type": "image",
            "name": "Spellsap Grenade",
            "image": "SpellsapGrenade.png"
        },
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 11",
                            "alt": "Player Core pg. 11",
