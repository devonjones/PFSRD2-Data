    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *singing stone* looks like a drinking cup made of polished rock, and it always faintly hums or keens. Anyone who carries the cup for some time senses that it changes its tune depending on the types of rock nearby and that it grows quiet in areas with little stone. A *singing stone* is a planar key for *interplanar teleport* and similar magic. When it's used this way, you're more likely to arrive where you intend to be, appearing 1d6\u00d725 miles from your intended destination instead of 1d10\u00d725 miles away.",
        "level": 13,
        "image": {
            "type": "image",
            "name": "Singing Stone",
            "image": "SingingStone.png"
        },
        "traits": [
            {
