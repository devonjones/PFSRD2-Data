    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This ornate fan's carving depicts a particular tableau from the Plane of Wood, often of the site where the fan was created. Fanning it through the air creates a sandalwood-scented breeze and a crackling of magic. A *sandalwood fan* is a planar key for *interplanar teleport* and similar magic. The *sandalwood fan* makes it more likely for you to arrive where you intended, appearing 1d6\u00d725 miles from your intended destination instead of the usual error range. This distance is further reduced to 1d4\u00d725 miles if your destination is the scenery depicted on the fan.",
        "level": 12,
        "image": {
            "type": "image",
            "name": "Sandalwood Fan",
            "image": "SandalwoodFan.png"
        },
        "traits": [
            {
