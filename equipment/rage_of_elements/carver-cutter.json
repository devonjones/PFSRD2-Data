    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Many of the experienced woodcarvers of the Plane of Wood learn to fight as well, the better to travel into hazardous areas in search of rare and beautiful types of wood for their craft. A *carver-cutter* serves a dual role as a weapon and a tool for felling trees and engraving wood. The *+2 striking battle axe* looks like an exquisitely made woodcutting axe.",
        "level": 11,
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Wood",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 463",
                            "alt": "Player Core pg. 463",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 463,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "7c548a9e0a2647c082989720b3de0a87",
                "text": "Effects with the wood trait conjure or manipulate wood. Those that manipulate wood have no effect in an area without wood. Creatures with this trait consist primarily of wood or have a connection to magical wood.  \n  \nThese planes consist of trees and other flora latticed in organic patterns. Wood planes are often perfectly constructed to match their desired purpose or environment but aren\u2019t usually outright hostile to visitors.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            }
        ],
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "held in 1 hand"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "One Action"
                    },
                    "effect": "You pull free a woodworking chisel stored in the knob of the axe. It can have any standard chisel shape you imagine as you activate this ability. You get a +2 item bonus to Crafting checks for woodworking if you use chisels from the  *carver-cutter* . The chisel also functions as a main-gauche . All runes on the axe are replicated on the chisel, but only while both items are on the same person. You can Interact to reinsert the chisel.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Crafting",
                            "alt": "Crafting",
                            "game-obj": "Skills",
                            "aonid": 4
                        },
                        {
                            "type": "link",
                            "name": "main-gauche",
                            "alt": "main-gauche",
                            "game-obj": "Weapons",
                            "aonid": 32
                        }
                    ],
                    "traits": [
                        {
                            "name": "Concentrate",
