    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Noble faydhaan shuyookhs serve coffee brewed in ornate dallahs such as this one to welcome guests in their courts. Most nobles have their kitchen staff import the beans at great expense from other planes then roast the beans with local ingredients gathered on the Plane of Water to create a brew unique to their locale. A faydhaan's dallah has the name of a specific faydhaan shuyookh engraved on the bottom and typically comes with six drinking cups, a platter, and a selection of coffee beans.",
        "level": 14,
        "image": {
            "type": "image",
            "name": "Faydhaan's Dallah",
            "image": "FaydhaansDallah.png"
        },
        "traits": [
            {
                "name": "Magical",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 103,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 458",
                            "alt": "Player Core pg. 458",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 458,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Water",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 165,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 463",
                            "alt": "Player Core pg. 463",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 463,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "28b3ffaf7df1fef23da1eb1d9c63267d",
                "text": "Effects with the water trait either manipulate or conjure water. Those that manipulate water have no effect in an area without water. Creatures with this trait consist primarily of water or have a connection to magical water.  \n  \nPlanes with this trait are mostly liquid. Visitors who can\u2019t breathe water or reach an air pocket likely drown. The rules for aquatic combat aquatic combat usually apply, including the inability to cast fire spells or use actions with the fire trait. Creatures with a weakness to water take damage equal to double their weakness at the end of each round.",
                "links": [
                    {
                        "type": "link",
                        "name": "aquatic combat",
                        "alt": "aquatic combat",
                        "game-obj": "Rules",
                        "aonid": 2438
                    }
                ],
                "classes": [
                    "trait"
                ]
            }
        ],
        "price": {
            "type": "stat_block_section",
            "subtype": "price",
            "text": "4,250 gp",
            "value": 4250,
            "currency": "gp"
        },
        "statistics": {
            "type": "stat_block_section",
            "subtype": "statistics",
            "usage": {
                "type": "stat_block_section",
                "subtype": "usage",
                "text": "held in 1 hand"
            },
            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    },
                    "effect": "You place a handful of beans in the dallah, and it immediately grinds the beans, fills with water, and brews six cups' worth of coffee. Pouring a cupful of coffee into a vessel takes an Interact action, as does drinking a cup. A creature that drinks a cup can breathe underwater and is protected from mild or severe temperatures of underwater environments for 8 hours. The coffee can later be transmuted using the dallah's other activation, but this latent magic ends if the dallah is used to brew coffee again. Coffee poured from the dallah stays in its vessel until someone drinks it or deliberately pours it out, even if the vessel is in an environment where the coffee would normally escape, such as underwater.",
                    "links": [
                        {
                            "type": "link",
                            "name": "mild or severe temperatures",
                            "alt": "mild or severe temperatures",
                            "game-obj": "Rules",
                            "aonid": 642
                        }
                    ],
