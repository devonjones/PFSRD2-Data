            "abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per day",
                    "effect": "You extend the weapon and call out the zuhra's name. They channel their magic through the gloves to assist you with their choice of offense or defense (as determined by the GM). The zuhra makes any choices for the spell, and any save DC is 30. \n* **Offense** The metal of the gloves wraps around your weapon and channels the zuhra's magic to cast a 6th-rank *weapon storm* spell, replicating the metal weapon.\n* **Defense** The metal flows off your arms, creating a *wall of metal*. The wall's surface has the same pattern as the gloves. You lose the gloves' item bonus until the barrier ends, at which point the metal returns to your hands and forearms. You can Dismiss the activation.",
                    "links": [
                        {
                            "type": "link",
                            "name": "weapon storm",
                            "alt": "weapon storm",
                            "game-obj": "Spells",
                            "aonid": 373
                        },
                        {
                            "type": "link",
                            "name": "wall of metal",
                            "alt": "wall of metal",
                            "game-obj": "Spells",
                            "aonid": 1379
                        }
                    ],
                    "requirement": "You're wielding a weapon made primarily of metal",
                    "traits": [
                        {
                            "name": "Concentrate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 32,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 454",
                                        "alt": "Player Core pg. 454",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 454,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "e32d877417a40fe977d27634dc14f99f",
                            "text": "An action with this trait requires a degree of mental concentration and discipline."
                        },
                        {
                            "name": "Manipulate",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 104,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
