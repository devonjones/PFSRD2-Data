    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Exuviae powder comes from cast-off shells of cicada-like insects native to the Plane of Earth, crushed to dust. You sprinkle this powder over your body, leaving an iridescent layer reminiscent of insect chitin. After you do so, for 8 hours, you double the time you can hold your breath. During this time, you also have access to the shed chitin activation.",
        "level": 14,
        "image": {
            "type": "image",
            "name": "Exuviae Powder",
            "image": "ExuviaePowder.png"
        },
        "traits": [
            {
                "name": "Rare",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 137,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
