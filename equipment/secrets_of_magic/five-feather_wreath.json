    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Identical feathers radiate from the center of this spellheart, held in place by woven straw. The spell attack roll of any spell cast by Activating this item is +8, and the spell DC is 18. \n* **Armor** You gain a +1 item bonus to Acrobatics checks and resistance 2 to falling damage.\n* **Weapon** After you cast an air spell by Activating the wreath, you can Fly 5 feet as a single action, or you can Fly 10 feet as a free action if the spell you cast wasn't a cantrip. This must be your next action, and if you don't have a fly Speed, you must end the flight on solid ground or fall.",
        "level": 4,
        "traits": [
            {
                "name": "Air",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 5,
                    "alternate_type": "legacy"
                },
