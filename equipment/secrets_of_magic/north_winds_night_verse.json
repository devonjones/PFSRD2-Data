    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "This *+1 striking frost katana* is always cool to the touch, nearly uncomfortably so. Unadorned and with no tsuba, its honed blade is carved from a single tusk of dragon-turtle ivory and wrapped in strips of winter wolf hide. Strikes with the katana gain a +2 status bonus to damage rolls against creatures that have a status penalty to their Speed or are slowed. The status bonus increases to +3 if the weapon has a *greater striking rune* and +4 for *major striking*.",
        "level": 10,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
