    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The blade of this *+2 striking returning dagger* shines the color of twilight, with a triangular lattice design on the hilt. A thin string of darkness connects your shadow to that of the blade, even once it leaves your hand.",
        "level": 11,
        "traits": [
            {
                "name": "Conjuration",
                "type": "trait",
                "edition": "legacy",
