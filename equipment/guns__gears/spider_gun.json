    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "A *spider gun* is a *+1 striking weapon*. It's a distinct type of martial firearm made from the fangs and spinneret of a Large spider. It deals 1d10 poison damage with a range increment of 30 feet and reload 1. On a critical hit, the venom clings to the target and they take persistent poison damage equal to 1d4 + the number of weapon damage dice. A spider gun does not add critical specialization effects. The gun can be activated to fire webbing that hampers other creatures.",
        "level": 6,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
