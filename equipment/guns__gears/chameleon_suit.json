                        "page": 364
                    }
                ],
                "game-obj": "Traits",
                "game-id": "4abdb1bc8002ecad825f0a1a3e55ac58",
                "text": "Clockworks are intricate, complex constructs that can be programmed to perform specific functions. A clockwork creature must be wound regularly to function.",
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            },
            {
