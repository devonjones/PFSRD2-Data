                        "name": "resistance",
                        "alt": "resistance",
                        "game-obj": "Rules",
                        "aonid": 2318
                    },
                    {
                        "type": "link",
                        "name": "weakness",
                        "alt": "weakness",
                        "game-obj": "Rules",
                        "aonid": 2317
                    }
                ],
                "schema_version": 1.1,
                "classes": [
                    "trait"
                ]
            }
        ],
