    "level": 1,
    "statistics": {
      "access": {
        "subtype": "access",
        "text": "Due to the use of technology, all gadgets are uncommon or rare, though inventors and regions with access to inventors have access to uncommon gadgets.",
        "type": "stat_block_section"
      },
      "subtype": "statistics",
      "type": "stat_block_section",
      "usage": {
        "subtype": "usage",
        "text": "attached to armor or traveler's clothing",
        "type": "stat_block_section"
      }
    },
    "subtype": "equipment",
    "text": "Ablative armor plating is additional plating, combined with springs, clever clockwork, and improvised padding, to absorb damage by knocking the additional pieces free. The pieces slowly come apart on their own with time and movement. The process of attaching the plating takes 10 minutes and grants the wearer of the armor the listed temporary Hit Points for the stated duration or until lost. Removing the plating early destroys it.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "uncommon"
        ],
        "edition": "remastered",
        "game-id": "f31704572455b8d77a8bd97c0045fde6",
        "game-obj": "Traits",
        "links": [
          {
            "alt": "Recall Knowledge",
            "aonid": 26,
            "game-obj": "Actions",
            "name": "Recall Knowledge",
            "type": "link"
          }
        ],
        "name": "Uncommon",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 11",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 11",
              "type": "link"
            },
            "name": "Player Core",
            "page": 11,
            "type": "source"
          }
        ],
        "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 36,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "07336d377bbfcf8d760f34f32f513526",
        "game-obj": "Traits",
        "name": "Consumable",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 454",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 454",
              "type": "link"
            },
            "name": "Player Core",
            "page": 454,
            "type": "source"
          }
        ],
        "text": "An item with this trait can be used only once. Unless stated otherwise, it\u2019s destroyed after activation. Consumable items include alchemical items and magical consumables such as scrolls and talismans. A character can Craft consumable items in batches of four.",
        "type": "trait"
      },
      {
        "classes": [
          "trait"
