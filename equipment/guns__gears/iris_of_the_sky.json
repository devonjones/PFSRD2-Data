                        {
                            "type": "stat_block_section",
                            "subtype": "activation_type",
                            "value": "concentrate"
                        }
                    ],
                    "links": [
                        {
                            "type": "link",
                            "name": "concentrate",
                            "alt": "concentrate",
                            "game-obj": "Traits",
                            "aonid": 561
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "activation",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Two Actions"
                    },
                    "frequency": "once per minute",
                    "effect": "You make a wish into the  *iris of the sky* , yearning for it to strike true, and then fire. Strike against a foe with the iris, rolling the attack roll twice and taking the better result. If the attack is a failure, you take 5 persistent fire damage.",
                    "traits": [
                        {
                            "name": "Fortune",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 76,
                                "alternate_type": "legacy"
                            },
