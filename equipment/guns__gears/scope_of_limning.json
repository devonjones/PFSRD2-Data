    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The dwarven gunsmiths of Dongun Hold originally created these scopes to help them clear out vermin in underground areas. This scope captures the sound that echoes off a creature hit by the firearm and transforms it into light, illuminating the target for all to see.",
        "level": 10,
