    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Built from the spiked tail of a manticore, a *spike launcher* is designed to launch large, spear-like projectiles. A spike launcher is a *+1 striking weapon*. It's a distinct type of martial firearm that deals 1d8 piercing damage. It has the backstabber, fatal aim d12, and kickback traits with a range increment of 120 feet and reload 2. It uses the critical specialization of the bow weapon group, rather than the firearm critical specialization.",
        "level": 6,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
