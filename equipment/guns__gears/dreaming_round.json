    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "The night sky seems contained in this glass projectile. When an activated *dreaming round* damages a creature, it induces drowsiness. The creature must attempt a DC 30 Fortitude save.",
        "level": 14,
        "traits": [
            {
