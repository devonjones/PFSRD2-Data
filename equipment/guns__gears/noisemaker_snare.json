    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "When a creature enters this snare's square, it triggers an extremely loud clockwork device, which explodes with a bang that can be heard from 200 feet away and deals 1d8 fire damage. The creature must attempt a DC 18 Reflex save.",
