    "stat_block": {
        "type": "stat_block",
        "subtype": "equipment",
        "text": "Built from the larynx of a terror shrike or similar animal that possesses a frightening screech or similar special ability, a *screech shooter* is a special *+1 striking harmona gun* designed to fire terrifying blasts of sound. A screech shooter deals sonic damage but can otherwise be used like a normal harmona gun.",
        "level": 9,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
