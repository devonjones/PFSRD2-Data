                    "universal_monster_ability": {
                        "name": "Light Blindness",
                        "type": "ability",
                        "text": "When first exposed to bright light, the monster is blinded until the end of its next turn. After this exposure, light doesn\u2019t blind the monster again until after it spends 1 hour in darkness. However, as long as the monster is in an area of bright light, it\u2019s dazzled.",
                        "ability_type": "universal_monster_ability",
                        "aonid": 22,
                        "game-obj": "MonsterAbilities",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Bestiary",
                                "link": {
