  "schema_version": 1.4,
  "sections": [
    {
      "name": "Thrailorn",
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #202: Severed at the Root pg. 86",
            "aonid": 242,
            "game-obj": "Sources",
            "name": "Pathfinder #202: Severed at the Root pg. 86",
            "type": "link"
          },
          "name": "Pathfinder #202: Severed at the Root",
          "page": 86,
          "type": "source"
        }
      ],
      "text": "When a gnome, halfling, pixie, goblin, or other Small creature is transformed into a woodwarp, they become a thrailorn. Sometimes called a \u201cthornback\u201d by members of the Rootweft Lodge, thrailorns are nimble and strong with a muscular, compact body. Their torso is coiled in thorny branches and growths that sprout long, barbed thorns. These thorns cause deep puncture wounds and can become embedded in the flesh of any creature who gets too close. A thrailorn's head is obscured within their thorny hide, with only their slavering maw and needle-like teeth visible. Though they have poor vision, they have a keen sense of smell.",
      "type": "section"
    }
  ],
  "sources": [
    {
