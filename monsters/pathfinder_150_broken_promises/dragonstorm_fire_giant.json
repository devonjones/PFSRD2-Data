                "name": "Magical",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 633",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 633",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 633,
                    "type": "source"
                  }
                ],
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. A magical item radiates a magic aura infused with its dominant school of magic.  \n  \n Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 684,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "32947e519673126a260ca0b27b0cf276",
                "game-obj": "Traits",
                "name": "Reach",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 283",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 283",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "Natural attacks with this trait can be used to attack creatures up to the listed distance away instead of only adjacent creatures. Weapons with this trait are long and can be used to attack creatures up to 10 feet away instead of only adjacent creatures. For creatures that already have reach with the limb or limbs that wield the weapon, the weapon increases their reach by 5 feet.",
                "type": "trait",
                "value": "15 feet"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 724,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "8a67f6d106646aef38a1ba89b9f50d14",
                "game-obj": "Traits",
                "name": "Versatile",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
