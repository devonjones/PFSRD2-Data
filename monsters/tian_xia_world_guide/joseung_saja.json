          "name": "Monitor",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "Creatures that hail from or have a strong connection to Axis, the Boneyard, or the Maelstrom are called monitors. Monitors can survive the basic environmental effects of planes in the Outer Sphere.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 232,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "c84997e1fc09bd9ed282476a53f59c6d",
          "game-obj": "Traits",
          "name": "Psychopomp",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 218,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "GM Core pg. 333",
                "aonid": 218,
                "game-obj": "Sources",
                "name": "GM Core pg. 333",
                "type": "link"
              },
              "name": "GM Core",
              "page": 333,
              "type": "source"
            }
          ],
          "text": "A family of monitors spawned within the Boneyard to convey souls to the Outer Planes, most psychopomps are true neutral. They typically have darkvision, lifesense, and spirit touch, and they\u2019re immune to death effects.",
          "type": "trait"
        }
      ],
