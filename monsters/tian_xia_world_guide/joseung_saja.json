        "name": "Psychopomp",
        "sections": [
          {
            "links": [
              {
                "alt": "celestials",
                "aonid": 551,
                "game-obj": "Traits",
                "name": "celestials",
                "type": "link"
              },
              {
                "alt": "fiends",
                "aonid": 600,
                "game-obj": "Traits",
