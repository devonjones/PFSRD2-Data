                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 454",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 454",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 454,
                    "type": "source"
                  }
                ],
                "text": "Effects with this trait deal cold damage. Creatures with this trait have a connection to magical cold.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 134,
