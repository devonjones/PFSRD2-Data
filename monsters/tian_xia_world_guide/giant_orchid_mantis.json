  "name": "Giant Orchid Mantis",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Giant Orchid Mantis",
      "sources": [
        {
          "link": {
            "alt": "Tian Xia World Guide pg. 292",
            "aonid": 223,
            "game-obj": "Sources",
            "name": "Tian Xia World Guide pg. 292",
            "type": "link"
          },
          "name": "Tian Xia World Guide",
          "page": 292,
          "type": "source"
        }
      ],
      "text": "These mantises have grown to an unusual size, which makes their camouflage less effective in most environments. As such, they're usually found in areas where a blossom the size of an adult human could pass as normal, in the lushest rainforests, or in lands where rare medicinal herbs are cultivated. Tame giant orchid mantises can also be found protecting those rich enough to afford such decorative guards.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Tian Xia World Guide pg. 292",
        "aonid": 223,
        "game-obj": "Sources",
        "name": "Tian Xia World Guide pg. 292",
        "type": "link"
      },
      "name": "Tian Xia World Guide",
      "page": 292,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Animal"
      ],
      "family": {
        "aonid": 356,
        "edition": "remastered",
