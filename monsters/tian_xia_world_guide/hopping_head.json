  "name": "Hopping Head",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Hopping Head",
      "sources": [
        {
          "link": {
            "alt": "Tian Xia World Guide pg. 286",
            "aonid": 223,
            "game-obj": "Sources",
            "name": "Tian Xia World Guide pg. 286",
            "type": "link"
          },
          "name": "Tian Xia World Guide",
          "page": 286,
          "type": "source"
        }
      ],
      "text": "A hopping head is shaped like a humanoid head, sometimes with elaborate facial features, other times with a crude toylike visage. Below the head is a spring-loaded column that allows the hopping head to move itself around.",
      "type": "section"
    }
  ],
  "sources": [
