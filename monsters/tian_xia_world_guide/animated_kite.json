  "schema_version": 1.4,
  "sections": [
    {
      "name": "Animated Kite",
      "sources": [
        {
          "link": {
            "alt": "Tian Xia World Guide pg. 278",
            "aonid": 223,
            "game-obj": "Sources",
            "name": "Tian Xia World Guide pg. 278",
            "type": "link"
          },
          "name": "Tian Xia World Guide",
          "page": 278,
          "type": "source"
        }
      ],
      "text": "An animated kite is perfect for spying, allowing observation from a great distance, although many are treated more like pets. The kite itself is a simple handcraft, easily created and destroyed, made of enchanted paper stretched over a fine bamboo frame. More advanced kites can be decorated with a variety of runes that allow the enchanter to see or hear from a distance.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Tian Xia World Guide pg. 278",
        "aonid": 223,
        "game-obj": "Sources",
        "name": "Tian Xia World Guide pg. 278",
        "type": "link"
      },
      "name": "Tian Xia World Guide",
      "page": 278,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
