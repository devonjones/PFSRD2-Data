        },
        {
          "classes": [
            "size"
          ],
          "edition": "legacy",
          "game-id": "448cf113826665b98a61ca5d9d068bee",
          "game-obj": "Traits",
          "name": "Large",
          "sources": [
            {
              "errata": {
