            },
            "area": [
              {
                "shape": "line",
                "size": 60,
                "subtype": "area",
                "text": "60-foot line",
                "type": "stat_block_section",
                "unit": "feet"
              }
            ],
            "damage": [
              {
                "damage_type": "bludgeoning",
                "formula": "4d6",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "name": "Floodwaters",
            "saving_throw": [
              {
                "basic": true,
                "dc": 25,
                "save_type": "Ref",
                "subtype": "save_dc",
                "text": "DC 25 basic Reflex save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "Waters rush forth in a 60-foot line, dealing 4d6 bludgeoning damage (DC 25 basic Reflex save). Creatures that fail the save and aren't grabbed by the imugi are pushed 10 feet away.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 134,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "60a4f011afd1e0fac8211bd01108d104",
                "game-obj": "Traits",
                "name": "Primal",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 460",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 460",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 460,
                    "type": "source"
                  }
                ],
                "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 165,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "28b3ffaf7df1fef23da1eb1d9c63267d",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "aquatic combat",
                    "aonid": 2438,
                    "game-obj": "Rules",
                    "name": "aquatic combat",
                    "type": "link"
                  }
                ],
                "name": "Water",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 463",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 463",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 463,
                    "type": "source"
                  }
                ],
                "text": "Effects with the water trait either manipulate or conjure water. Those that manipulate water have no effect in an area without water. Creatures with this trait consist primarily of water or have a connection to magical water.  \n  \nPlanes with this trait are mostly liquid. Visitors who can\u2019t breathe water or reach an air pocket likely drown. The rules for aquatic combat aquatic combat usually apply, including the inability to cast fire spells or use actions with the fire trait. Creatures with a weakness to water take damage equal to double their weakness at the end of each round.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
          "name": "Floodwaters",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
