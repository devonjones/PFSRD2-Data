        {
          "ability": {
            "ability_type": "offensive",
            "name": "Separated Body",
            "subtype": "ability",
            "text": "A manananggal typically resembles a living humanoid. They don't appear as an aberration at first glance and receive a +4 status bonus to their Deception DC when Impersonating a humanoid. At any time, but especially at night, a manananggal can, as a 3-action activity with the manipulate trait, rip their upper torso from their bottom half, leaving the lower torso limp and helpless but allowing the upper torso to fly free. A manananggal can separate their body at any time, but they risk further damage if they do so during the day. The manananggal's upper and lower halves share the same pool of HP. If its lower half is damaged, the manananggal is immediately aware of the attack. Each minute a manananggal remains separated after sunrise and before sunset, it takes 2d6 points of damage until it reattaches its upper and lower torsos or is destroyed, whichever comes first.",
            "type": "stat_block_section"
          },
          "name": "Separated Body",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "damage": [
              {
                "formula": "4d6",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "effect": "The manananggal drives their tongue into the grabbed creature to drink its blood. This deals 4d6 damage, and the manananggal gains temporary Hit Points equal to the damage dealt. A creature whose blood is drained by a manananggal is drained 1 until it receives healing (of any kind or amount).",
            "links": [
              {
                "alt": "drained",
                "aonid": 68,
                "game-obj": "Conditions",
                "name": "drained",
                "type": "link"
              }
            ],
            "name": "Blood Drain",
            "requirement": "The manananggal has a creature grabbed",
            "subtype": "ability",
            "type": "stat_block_section"
          },
          "name": "Blood Drain",
