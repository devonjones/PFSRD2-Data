  "name": "Animated Wine Vessel",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Animated Wine Vessel",
      "sources": [
        {
          "link": {
            "alt": "Tian Xia World Guide pg. 279",
            "aonid": 223,
            "game-obj": "Sources",
            "name": "Tian Xia World Guide pg. 279",
            "type": "link"
          },
          "name": "Tian Xia World Guide",
          "page": 279,
          "type": "source"
        }
      ],
      "text": "A beautiful wine vessel presents a mark of status among drinkers, to say nothing of an animated one that pours the wine on its own. Although normally harmless servants, these vessels will just as quickly follow instructions to swallow intruders and drown them in strong wine.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Tian Xia World Guide pg. 279",
        "aonid": 223,
        "game-obj": "Sources",
        "name": "Tian Xia World Guide pg. 279",
        "type": "link"
      },
      "name": "Tian Xia World Guide",
      "page": 279,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Construct",
        "Mindless"
