                    "name": "Player Core",
                    "page": 454,
                    "type": "source"
                  }
                ],
                "text": "An action with this trait requires a degree of mental concentration and discipline.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 127,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "69f30c8801710f12f6fbd5a2c7c0d91d",
