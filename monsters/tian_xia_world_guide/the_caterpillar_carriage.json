  "schema_version": 1.4,
  "sections": [
    {
      "name": "The Caterpillar Carriage",
      "sources": [
        {
          "link": {
            "alt": "Tian Xia World Guide pg. 286",
            "aonid": 223,
            "game-obj": "Sources",
            "name": "Tian Xia World Guide pg. 286",
            "type": "link"
          },
          "name": "Tian Xia World Guide",
          "page": 286,
          "type": "source"
        }
      ],
      "text": "The haunted construct known as the caterpillar carriage is composed of armored segments that flow over one another as the carriage inches forward. It has two forelegs that dig grooves into the ground, making way for the many wheels situated along its underside.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
