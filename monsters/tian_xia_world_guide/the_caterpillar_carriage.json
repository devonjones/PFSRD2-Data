        "monster_family": {
          "name": "Haunted Clockwork",
          "subtype": "monster_family",
          "type": "stat_block_section"
        },
        "name": "Haunted Clockwork",
        "sections": [
          {
            "name": "Eerie Adornment",
            "sources": [
              {
                "link": {
                  "alt": "Tian Xia World Guide pg. 286",
                  "aonid": 223,
                  "game-obj": "Sources",
                  "name": "Tian Xia World Guide pg. 286",
                  "type": "link"
                },
                "name": "Tian Xia World Guide",
                "page": 286,
                "type": "source"
              }
            ],
            "text": "All haunted constructs yearn to embellish their frames. They prize unique materials, delicate or skillful constructions, and ornaments. In addition to decorating their current body, they use these materials to build a new body as the haunted construct becomes larger and more powerful.",
            "type": "section"
          }
        ],
        "sources": [
          {
            "link": {
              "alt": "Tian Xia World Guide pg. 286",
              "aonid": 223,
              "game-obj": "Sources",
              "name": "Tian Xia World Guide pg. 286",
              "type": "link"
            },
            "name": "Tian Xia World Guide",
            "page": 286,
            "type": "source"
          }
        ],
        "text": "The constructs of the Clicking Caverns all have similar designs, being made of clockwork. The most unusual feature of them is that they\u2019re self-replicating, or perhaps self-reincarnating, since the animation of a haunted construct requires a soul.",
        "type": "monster_family"
      },
