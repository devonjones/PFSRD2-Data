  "sections": [
    {
      "name": "Great Ironbill",
      "sections": [
        {
          "image": {
            "image": "Sidebar_1_AdviceAndRules.png",
            "name": "Advice and Rules",
            "type": "image"
          },
          "name": "Living Alarm",
          "sidebar_heading": "Advice and Rules",
          "sidebar_type": "advice_and_rules",
          "sources": [
            {
              "link": {
                "alt": "Pathfinder #209: Destroyer's Doom pg. 86",
                "aonid": 251,
                "game-obj": "Sources",
                "name": "Pathfinder #209: Destroyer's Doom pg. 86",
                "type": "link"
              },
              "name": "Pathfinder #209: Destroyer's Doom",
              "page": 86,
              "type": "source"
            }
          ],
          "subtype": "sidebar",
          "text": "The great ironbill tends to remain eerily still, making it hard to spot when it stands amongst trees or shadows. Combined with their deafeningly loud calls, properly trained ironbills make excellent guards.",
          "type": "section"
        }
      ],
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #209: Destroyer's Doom pg. 86",
            "aonid": 251,
            "game-obj": "Sources",
            "name": "Pathfinder #209: Destroyer's Doom pg. 86",
            "type": "link"
          },
          "name": "Pathfinder #209: Destroyer's Doom",
          "page": 86,
          "type": "source"
        }
      ],
      "text": "The great ironbill, a stork-like creature native to Dirt Sea shores, is known for clapping its fearsome beak to create incredibly loud and unnerving sounds.",
      "type": "section"
    }
  ],
