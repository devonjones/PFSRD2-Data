  "sections": [
    {
      "name": "Warcat of Rull",
      "sections": [
        {
          "image": {
            "image": "Sidebar_4_RelatedCreatures.png",
            "name": "Related Creatures",
            "type": "image"
          },
          "name": "Apex Predator",
          "sidebar_heading": "Related Creatures",
          "sidebar_type": "related_creatures",
          "sources": [
            {
              "link": {
                "alt": "Pathfinder #209: Destroyer's Doom pg. 87",
                "aonid": 251,
                "game-obj": "Sources",
                "name": "Pathfinder #209: Destroyer's Doom pg. 87",
                "type": "link"
              },
              "name": "Pathfinder #209: Destroyer's Doom",
              "page": 87,
              "type": "source"
            }
          ],
          "subtype": "sidebar",
          "text": "The warcat of Rull is a stealthy predator that roams a large territory, hunting alone or with a mate. Even when nursing cubs, warcats hunt for themselves and teach their cubs to be self-sufficient. Warcats fear no challenge, preying on megafauna, giants, and even young dragons.",
          "type": "section"
        }
      ],
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #209: Destroyer's Doom pg. 87",
            "aonid": 251,
            "game-obj": "Sources",
            "name": "Pathfinder #209: Destroyer's Doom pg. 87",
            "type": "link"
          },
          "name": "Pathfinder #209: Destroyer's Doom",
          "page": 87,
          "type": "source"
        }
      ],
      "text": "These fierce hippo-sized cats with scaly, armored skin can only be bred and trained by the most skilled handlers.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Pathfinder #209: Destroyer's Doom pg. 87",
