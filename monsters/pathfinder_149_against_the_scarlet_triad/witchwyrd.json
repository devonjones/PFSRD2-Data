          "links": [
            {
              "alt": "force barrage",
              "aonid": 1536,
              "game-obj": "Spells",
              "name": "force barrage",
              "type": "link"
            }
          ],
          "name": "Absorb Force",
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 11,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a30ff50ed821ab5b9699b2f3d68c0d6",
              "game-obj": "Traits",
              "name": "Arcane",
              "sources": [
                {
