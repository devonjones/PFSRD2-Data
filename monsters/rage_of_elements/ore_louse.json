          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "d3bfc0df6c75fa3d188816919a7c6bf5",
          "game-obj": "Traits",
          "name": "Amphibious",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
