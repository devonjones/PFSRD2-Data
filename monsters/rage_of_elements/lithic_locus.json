          "edition": "remastered",
          "game-id": "ee36f249251dca4d6fd0a126bc920850",
          "game-obj": "Traits",
          "name": "Construct",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
