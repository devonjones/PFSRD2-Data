  "schema_version": 1.4,
  "sections": [
    {
      "name": "Metal Wisp",
      "sources": [
        {
          "errata": {
            "alt": "2.0",
            "aonid": 205,
            "game-obj": "Sources",
            "name": "2.0",
            "type": "link"
          },
          "link": {
            "alt": "Rage of Elements pg. 152",
            "aonid": 205,
            "game-obj": "Sources",
            "name": "Rage of Elements pg. 152",
            "type": "link"
          },
          "name": "Rage of Elements",
          "page": 152,
          "type": "source"
        }
      ],
      "text": "A metal wisp is a roiling sphere of rust particles and sharp metal fragments, all furiously orbiting a liquid metal core that resembles the skull of a mortal creature\u2014usually a humanoid, but animal and even more fantastical skulls are not uncommon. They don't form attachments as easily as wisps from other elemental planes, which tend to view metal wisps as too morose, although they retain a certain curiosity since their return from the planar severance.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "2.0",
        "aonid": 205,
