          ],
          "name": "Fire-fueled Rage",
          "subtype": "ability",
          "text": "When a nightwood guardian takes fire damage, they become enraged. The guardian gains 15 temporary Hit Points, deals 2 additional damage with melee Strikes, and has a \u20131 penalty to AC. They can't Raise their Shield or use actions with the concentrate trait except for Seek. This effect ends when the nightwood guardian no longer observes any fire for 1 round or when they fall unconscious, whichever comes first.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "stunned",
              "aonid": 36,
              "game-obj": "Conditions",
              "name": "stunned",
              "type": "link"
            },
            {
              "alt": "regeneration",
              "aonid": 26,
              "game-obj": "MonsterAbilities",
              "name": "regeneration",
              "type": "link"
            }
          ],
          "name": "Flesh of Wood",
          "subtype": "ability",
          "text": "Wounds inflicted on a nightwood guardian turn their flesh to wood. When the guardian is reduced to 40 HP or fewer, their body becomes solid wood. They are stunned, have resistance 10 to all damage, and have regeneration 40 (deactivated by fire). This ends once the guardian has 100 HP or more, though they can choose to stay in this form indefinitely.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 134,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "60a4f011afd1e0fac8211bd01108d104",
              "game-obj": "Traits",
              "name": "Primal",
              "sources": [
                {
                  "errata": {
