                  "alternate_link": {
                    "alternate_type": "legacy",
                    "aonid": 106,
                    "game-obj": "Traits",
                    "type": "alternate_link"
                  },
                  "edition": "remastered",
                  "game-id": "6a1f80610baa3617c1597f49c6406313",
                  "game-obj": "Traits",
                  "name": "Mental",
                  "sources": [
