      "ac": {
        "subtype": "armor_class",
        "type": "stat_block_section",
        "value": 30
      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "stupefied 1",
              "aonid": 37,
              "game-obj": "Conditions",
