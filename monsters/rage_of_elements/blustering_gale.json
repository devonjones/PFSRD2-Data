            "subtype": "ability",
            "text": "The blustering gale exhales as a unit, creating a powerful windstorm. This windstorm is a 10-foot burst within 100 feet that deals 3d8+10 bludgeoning damage (DC 30 basic Reflex save). Creatures that fail their saving throw are pushed 10 feet in any direction (plus knocked prone on a critical failure). When the troop is reduced to 8 or fewer squares, this area decreases to a 5-foot burst and the distance pushed decreases to 5 feet.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 5,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "8ca8a0ac0e16b3c136f09ca48d8578bb",
                "game-obj": "Traits",
                "name": "Air",
                "sources": [
                  {
                    "errata": {
