          {
            "alt": "Track",
            "aonid": 2408,
            "game-obj": "Actions",
            "name": "Track",
            "type": "link"
          }
        ],
        "name": "Snow Walker",
        "subtype": "ability",
        "text": "The Ilverani sentry ignores the effects of difficult terrain from snowy environments. When moving through snow, an Ilverani sentry minimizes traces left behind and makes it harder for others to find them. The DC of checks to Track an Ilverani sentry through snowy terrain gains a +4 status bonus.",
        "type": "stat_block_section"
      }
    ],
