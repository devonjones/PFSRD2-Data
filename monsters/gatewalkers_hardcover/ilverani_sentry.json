        ],
        "name": "Arctic Forager",
        "subtype": "ability",
        "text": "While using Survival to Subsist in arctic environments, if the Ilverani sentry rolls a failure or a critical failure, they get a success instead. If the sentry rolls a success, they can provide food for 4 additional creatures that eat about as much as a human, or for 8 creatures on a critical success.",
        "type": "stat_block_section"
      },
      {
        "ability_type": "interaction",
        "links": [
          {
            "alt": "difficult terrain",
            "aonid": 2367,
