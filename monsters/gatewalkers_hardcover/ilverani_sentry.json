            ],
            "name": "Ranged",
            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 174,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c0d76f25881949145ec6769d79ad49b5",
                "game-obj": "Traits",
                "name": "Deadly",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "On a critical hit, the weapon adds a weapon damage die of the listed size. Roll this after doubling the weapon\u2019s damage. This increases to two dice if the weapon has a _greater striking rune_ and three dice if the weapon has a _major striking rune_. For instance, a rapier with a _greater striking rune_ deals 2d8 extra piercing damage on a critical hit. An ability that changes the size of the weapon\u2019s normal damage dice doesn\u2019t change the size of its deadly die.",
                "type": "trait",
                "value": "d10"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 103,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "game-obj": "Traits",
                "name": "Magical",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 191,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "75d7a94811530a56c9e064166c98e78d",
                "game-obj": "Traits",
                "name": "Propulsive",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You add half your Strength modifier (if positive) to damage rolls with a propulsive ranged weapon. If you have a negative Strength modifier, you add your full Strength modifier instead.",
                "type": "trait"
              },
              {
                "edition": "legacy",
                "game-id": "104d6fc2d1d7f97108e1e9b4be5089b1",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "range increments",
                    "aonid": 227,
                    "game-obj": "Rules",
                    "name": "range increments",
                    "type": "link"
                  }
                ],
                "name": "Range",
                "sources": [
                  {
