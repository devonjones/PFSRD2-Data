              "name": "Player Core",
              "page": 11,
              "type": "source"
            }
          ],
          "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
          "type": "trait"
        },
        {
          "classes": [
            "size"
          ],
          "edition": "legacy",
          "game-id": "448cf113826665b98a61ca5d9d068bee",
          "game-obj": "Traits",
          "name": "Large",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Core Rulebook pg. 474",
                "href": "https://paizo.com/products/btq01y0k?Pathfinder-Core-Rulebook",
                "name": "Core Rulebook pg. 474",
                "type": "link"
              },
              "name": "Core Rulebook",
              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* 10 feet, *Reach (Tall):* 10 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 108,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "1debc9c19f9ffadf57ee0ebf1bc785cb",
          "game-obj": "Traits",
          "name": "Mindless",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "A mindless creature has either programmed or rudimentary mental attributes. Most, if not all, of their mental attribute modifiers are \u20135. They are immune to all mental effects.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 160,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "20f6f5f93a453f3006eb194c6d712042",
          "game-obj": "Traits",
          "name": "Undead",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 462",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 462",
                "type": "link"
              },
              "name": "Player Core",
              "page": 462,
              "type": "source"
            }
          ],
          "text": "Once living, these creatures were infused after death with void energy and soul-corrupting unholy magic. When reduced to 0 Hit Points, an undead creature is destroyed. Undead creatures are damaged by vitality energy and are healed by void energy, and don\u2019t benefit from healing vitality effects.",
          "type": "trait"
        },
        {
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "6309897c89780f17449b984cbb6d26cb",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "holy",
              "aonid": 517,
              "game-obj": "Traits",
              "name": "holy",
              "type": "link"
            }
          ],
          "name": "Unholy",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 462",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 462",
                "type": "link"
              },
              "name": "Player Core",
              "page": 462,
              "type": "source"
            }
          ],
          "text": "Effects with the unholy trait are tied to powerful magical forces of cruelty and sin. They often have stronger effects on holy creatures. Creatures with this trait are strongly devoted to unholy causes, and often have weakness to holy. If a creature with weakness to unholy uses an unholy item or effect, it takes damage from its weakness.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
