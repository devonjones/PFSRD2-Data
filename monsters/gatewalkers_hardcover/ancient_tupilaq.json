            "automatic_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "ability_type": "automatic",
                    "name": "Construct Armor",
                    "text": "Like normal objects, an ancient tupilaq has Hardness. This Hardness reduces any damage it takes by an amount equal to the Hardness. Once an ancient tupilaq is reduced to less to 72 Hit Points or fewer, or immediately upon being damaged by a critical hit, its construct armor breaks, it loses its Hardness, and its Armor Class is reduced to 28."
                }
            ]
