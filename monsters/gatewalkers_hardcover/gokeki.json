{
    "name": "Gokeki",
    "type": "creature",
    "sections": [
        {
            "name": "Gokeki",
            "type": "section",
            "sections": [
                {
                    "name": "Harvested Treasures",
                    "type": "section",
                    "text": "While gokekis aren't intelligent enough to gather treasure of their own, many natives of Castrovel consider their bodies a valuable resource. If harvested with a successful DC 17 Nature or Survival check, the gokeki's filament gland can be used as 25 gp worth of raw materials for potent glues such as everlasting adhesive. The filament itself is identical to a 60-foot length of rope. Finally, the creature's harpoon can be used as a javelin.",
                    "sources": [
                        {
                            "type": "source",
                            "name": "Gatewalkers (Hardcover)",
                            "link": {
                                "type": "link",
                                "name": "Gatewalkers (Hardcover) pg. 259",
                                "alt": "Gatewalkers (Hardcover) pg. 259",
                                "game-obj": "Sources",
                                "aonid": 290
                            },
                            "page": 259
                        }
                    ],
                    "subtype": "sidebar",
                    "sidebar_type": "additional_lore",
                    "sidebar_heading": "Additional Lore",
                    "image": {
                        "type": "image",
                        "name": "Additional Lore",
                        "image": "Sidebar_2_AdditionalLore.png"
                    },
                    "links": [
                        {
                            "type": "link",
                            "name": "Nature",
                            "alt": "Nature",
                            "game-obj": "Skills",
                            "aonid": 43
                        },
                        {
                            "type": "link",
                            "name": "Survival",
                            "alt": "Survival",
                            "game-obj": "Skills",
                            "aonid": 49
                        },
                        {
                            "type": "link",
