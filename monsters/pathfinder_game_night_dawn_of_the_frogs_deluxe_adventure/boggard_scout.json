            },
            "saving_throw": [
              {
                "dc": 17,
                "save_type": "Will",
                "subtype": "save_dc",
                "text": "DC 17 Will save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "The boggard scout unleashes a terrifying croak. Any non-boggard within 30 feet becomes frightened 1 unless they succeed at a DC 17 Will save. Those who critically succeed are temporarily immune for 1 minute.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
