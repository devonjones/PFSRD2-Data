  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Animal",
        "Dinosaur"
      ],
      "family": {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 32,
          "game-obj": "MonsterFamilies",
