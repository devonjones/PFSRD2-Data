  "sections": [
    {
      "name": "Electric Eel",
      "sections": [
        {
          "image": {
            "image": "Sidebar_5_TreasureAndRewards.png",
            "name": "Treasure and Rewards",
            "type": "image"
          },
          "name": "Electric Eel Hide",
          "sidebar_heading": "Treasure and Rewards",
          "sidebar_type": "treasure_and_rewards",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Monster Core pg. 138",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 138",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 138,
              "type": "source"
            }
          ],
          "subtype": "sidebar",
          "text": "Hide harvested from electric eels can be used to create armor or items that provide protection from electricity.",
          "type": "section"
        }
      ],
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 138",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 138",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 138,
          "type": "source"
        }
      ],
      "text": "Usually found in freshwater rivers and lakes, an electric eel is not particularly aggressive, but its ability to stun predators and prey alike can be dangerous to larger creatures searching for their next meal. Electric eels are more closely related to catfish than to other eels.",
      "type": "section"
    }
  ],
