          ],
          "name": "Berserk",
          "saving_throw": [
            {
              "dc": 5,
              "save_type": "Flat Check",
              "subtype": "save_dc",
              "text": "DC 5 flat check",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "A severely damaged charnel creation has a chance of going berserk. If it has 40 or fewer HP at the start of its turn, the creation must succeed at a DC 5 flat check or go berserk. A berserk creation wildly attacks the nearest living creature, or the nearest object if no creatures are nearby. A creation loses its immunity to mental effects while berserk.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "electricity",
              "aonid": 586,
              "game-obj": "Traits",
              "name": "electricity",
              "type": "link"
            },
            {
              "alt": "slowed",
              "aonid": 92,
              "game-obj": "Conditions",
              "name": "slowed",
              "type": "link"
            }
          ],
          "name": "Electric Healing",
          "subtype": "ability",
          "text": "Any time a charnel creation would be affected by an effect with the electricity trait, it loses any slowed condition it has and gains HP equal to half the damage the spell would have dealt. If the creation starts its turn in an area that deals electricity damage, it gains 2d4 HP.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "damage": [
            {
              "damage_type": "electricity",
              "formula": "3d6",
              "subtype": "attack_damage",
              "type": "stat_block_section"
            },
            {
              "damage_type": "electricity",
              "formula": "6d6",
              "subtype": "attack_damage",
              "type": "stat_block_section"
            }
          ],
          "effect": "The creation lashes out and tries to grab a nearby creature. The creation attempts an Athletics check to Grapple a creature within reach. The creature also takes 3d6 electricity damage on a success, or 6d6 electricity damage on a critical success.",
          "links": [
            {
              "alt": "electricity",
