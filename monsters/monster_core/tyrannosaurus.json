  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Animal",
        "Dinosaur"
      ],
      "family": {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 32,
          "game-obj": "MonsterFamilies",
          "type": "alternate_link"
        },
        "aonid": 391,
        "edition": "remastered",
        "game-id": "90e4afe4014aaae28a569bd754af4616",
        "game-obj": "MonsterFamilies",
        "link": {
          "alt": "Dinosaur",
          "aonid": 391,
          "game-obj": "MonsterFamilies",
