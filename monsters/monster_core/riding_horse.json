                    "universal_monster_ability": {
                        "name": "Buck",
                        "type": "ability",
                        "text": "Most monsters that serve as mounts can attempt to buck off unwanted or annoying riders, but most mounts will not use this reaction against a trusted creature unless the mounts are spooked or mistreated.",
