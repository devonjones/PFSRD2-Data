  "schema_version": 1.4,
  "sections": [
    {
      "name": "Quetzalcoatlus",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 278",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 278",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 278,
          "type": "source"
        }
      ],
      "text": "Quetzalcoatlus are the largest flying members of the pterosaur family and are often mistaken for dragons due to their immense size and 40-foot wingspans. Using the joints of their massive wings as forelimbs, they are also quite capable of moving on land, snatching smaller prey from the ground or out of streams.  \n  \n Quetzalcoatlus are carnivorous, feeding on a variety of reptiles, mammals, large fish, amphibians, and other vertebrates. They are not inherently aggressive creatures and are happy to scavenge for food, but when presented with live prey they readily attack almost any creature smaller than themselves.",
      "type": "section"
    }
  ],
  "sources": [
    {
