                "game-id": "062d349c50c70477d316b8620025454e",
                "game-obj": "Traits",
                "name": "Sonic",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 461",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 461",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 461,
                    "type": "source"
                  }
                ],
                "text": "An effect with the sonic trait functions only if it makes sound, meaning it has no effect in an area of silence or in a vacuum. This is different from an auditory spell, which is effective only if the target can hear it. A sonic effect might deal sonic damage.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
          "name": "Staccato Strike",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Two Actions",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "area": [
              {
                "shape": "emanation",
                "size": 120,
                "subtype": "area",
                "text": "120-foot emanation",
                "type": "stat_block_section",
                "unit": "feet"
              }
            ],
            "critical_failure": "The target is confused for 1 round and immediately attacks itself (in the normal fashion for attacking oneself while confused). This Strike doesn't give the creature a flat check to recover from the confusion.",
            "critical_success": "The target is unaffected and is temporarily immune for 1 minute.",
            "failure": "The target is confused for 1 round.",
            "links": [
              {
                "alt": "confused",
                "aonid": 63,
                "game-obj": "Conditions",
                "name": "confused",
                "type": "link"
              }
            ],
            "name": "Warbling Song",
            "saving_throw": [
              {
                "dc": 32,
                "save_type": "Will",
                "subtype": "save_dc",
                "text": "DC 32 Will save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "success": "The target is unaffected.",
            "text": "The cauthooj gives a strange, ululating cry that causes nearby creatures to lash out violently and without control. Each creature within a 120-foot emanation that can hear the cauthooj must attempt a DC 32 Will save to resist the effect.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 93,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "b26076555c07646f046dd58e7d5b3885",
                "game-obj": "Traits",
                "name": "Incapacitation",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 457",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 457",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 457,
                    "type": "source"
                  }
                ],
                "text": "An ability with this trait can take a character completely out of the fight or even kill them, and it\u2019s harder to use on a more powerful character. If a spell has the incapacitation trait, any creature of more than twice the spell\u2019s rank treats the result of their check to prevent being incapacitated by the spell as one degree of success better, or the result of any check the spellcaster made to incapacitate them as one degree of success worse. If any other effect has the incapacitation trait, a creature of higher level than the item, creature, or hazard generating the effect gains the same benefits.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 106,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "game-obj": "Traits",
                "name": "Mental",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 134,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "60a4f011afd1e0fac8211bd01108d104",
                "game-obj": "Traits",
                "name": "Primal",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 460",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 460",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 460,
                    "type": "source"
                  }
                ],
                "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
