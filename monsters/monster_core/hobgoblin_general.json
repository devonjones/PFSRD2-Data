                "value": "d8"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 180,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "18975df1ca2f4e961748576c9d842330",
