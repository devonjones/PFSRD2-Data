                },
                "edition": "remastered",
                "game-id": "c0d76f25881949145ec6769d79ad49b5",
                "game-obj": "Traits",
                "name": "Deadly",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
