  "schema_version": 1.4,
  "sections": [
    {
      "name": "Kholo Sergeant",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 209",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 209",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 209,
          "type": "source"
        }
      ],
      "text": "When kholos band together to form mercenary bands or raiding parties, the strongest or most respected among them is often designated the hunt leader or sergeant. These kholo are responsible for the safety and success of their packmates and train extensively in the art of war. Their skill at arms makes them powerful adversaries. A kholo sergeant might also serve as a mercenary group's leader in other affairs, such as sorting out domestic disputes or negotiating with rival kholo bands.",
      "type": "section"
    }
  ],
  "sources": [
