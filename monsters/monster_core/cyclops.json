          },
          "effect": "The cyclops peers into an occluded spectrum of possible futures. They get a success (but not a critical success) on the roll instead of rolling.",
          "frequency": "once per day",
          "name": "Flash of Insight",
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
