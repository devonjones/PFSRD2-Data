          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 11,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a30ff50ed821ab5b9699b2f3d68c0d6",
              "game-obj": "Traits",
              "name": "Arcane",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 452",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 452",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 452,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the arcane tradition, which is built on logic and rationality. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to arcane magic.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 206,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "5315505cfd3f3ba2685e9747898193b2",
              "game-obj": "Traits",
              "name": "Aura",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 163,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "abcdb0d656f37cebdbee9dca267ef899",
              "game-obj": "Traits",
              "name": "Visual",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 463",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 463",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 463,
                  "type": "source"
                }
              ],
              "text": "A visual effect can affect only creatures that can see it. This applies only to visible parts of the effect, as determined by the GM.",
              "type": "trait"
            }
          ],
          "trigger": "A creature within 30 feet that the basilisk can see starts its turn",
