          "edition": "remastered",
          "game-id": "00eec53f8ff824a5080c3d092eecd593",
          "game-obj": "Traits",
          "name": "Aberration",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
