          "edition": "remastered",
          "game-id": "56f1257037b862f01182b562f44329a8",
          "game-obj": "Traits",
          "name": "Dragon",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 455",
