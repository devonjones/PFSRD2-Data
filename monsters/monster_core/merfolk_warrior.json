              "link": {
                "alt": "Monster Core pg. 363",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 363",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 363,
              "type": "source"
            }
          ],
          "text": "These aquatic humanoids have an upper body similar to a human and a lower body similar to a fish.",
          "type": "trait"
        }
