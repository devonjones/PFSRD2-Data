  "schema_version": 1.4,
  "sections": [
    {
      "links": [
        {
          "alt": "Haagenti",
          "aonid": 260,
          "game-obj": "Deities",
          "name": "Haagenti",
          "type": "link"
        }
      ],
      "name": "Grothlut",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 152",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 152",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 152,
          "type": "source"
        }
      ],
      "text": "Sluglike abominations, grothluts are grotesque dregs of the fleshwarping process. While their head and torso are vaguely humanoid, their arms are rubbery and move awkwardly at their sides. Wretched creatures, they moan piteously when other creatures are near, perhaps as the last remnants of their mind pleads to be free from their horrid warped form.  \n  \n Many fleshwarpers consider the grothlut to be a failure of a creation, as the transformation all but stamps out consciousness. Others disagree, arguing that warping the creature's mind makes it all the more useful, since it becomes pliable and easy to herd. Cultists of Haagenti typically use grothluts as guardians that slowly patrol the edges of their enclaves. Once in position, grothluts can be used as crude shock troops, unleashed to soften enemy forces before more valuable warriors wade in and cut down the enemies who have been nauseated by the grothluts' exploded organs and flesh.",
      "type": "section"
    }
  ],
  "sources": [
