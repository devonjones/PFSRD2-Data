      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Head Regrowth",
          "subtype": "ability",
          "text": "A hydra ordinarily has five heads. A creature can attempt to sever one of the hydra's heads by specifically targeting it and dealing damage equal to the head's Hit Points. A head that is not completely severed returns to full Hit Points at the end of any creature's turn.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "splash",
              "aonid": 699,
              "game-obj": "Traits",
              "name": "splash",
              "type": "link"
            },
            {
              "alt": "regeneration",
              "aonid": 72,
              "game-obj": "MonsterAbilities",
              "name": "regeneration",
              "type": "link"
            }
          ],
          "name": "Hydra Regeneration",
          "saving_throw": [
            {
              "dc": 25,
              "save_type": "Fort",
              "subtype": "save_dc",
              "text": "DC 25 Fortitude save",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "A hydra can regrow a severed head using hydra regeneration. A creature can prevent this regrowth by dealing acid or fire damage to the stump, cauterizing it. Single-target acid or fire effects need to be targeted at a specific stump, but effects that deal splash damage or affect areas covering the hydra's whole space cauterize all stumps if they deal acid or fire damage. If the attack that severs a head deals any acid or fire damage, the stump is cauterized instantly. If all five heads are cauterized, the hydra dies.The hydra has regeneration equal to 3 \u00d7 the number of heads it has. If a hydra's body is missing any heads and the remaining stumps have not been cauterized, the hydra attempts a DC 25 Fortitude save after it regains Hit Points from regeneration. On a success, one uncauterized stump regrows two heads; on a critical success, two uncauterized stumps regrow into two heads each. The hydra can never grow more than double the number of heads it ordinarily has. The hydra's regeneration only fully deactivates if all its heads are severed and all stumps are cauterized, at which point it dies.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "name": "Reactive Heads",
          "subtype": "ability",
          "text": "A hydra gains an extra reaction per round for each of its heads beyond the first, which it can use only to make Reactive Strikes. It can't use more than 1 reaction on the same triggering action, even if a creature leaves several squares within its reach, and the hydra must use a different head for each Reactive Strike it makes. Whenever one of the hydra's heads is severed, the hydra loses 1 of its extra reactions per round.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "links": [
            {
              "alt": "Reactive Strike",
              "aonid": 48,
              "game-obj": "MonsterAbilities",
              "name": "Reactive Strike",
              "type": "link"
            }
          ],
          "name": "Reactive Strike",
          "subtype": "ability",
          "text": "(see reactive heads)",
          "type": "stat_block_section",
          "universal_monster_ability": {
            "ability_type": "universal_monster_ability",
            "action_type": {
              "name": "Reaction",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "aonid": 48,
            "edition": "remastered",
            "effect": "The monster attempts a melee Strike against the triggering creature. If the attack is a critical hit and the trigger was a manipulate action, the monster disrupts that action. This Strike doesn't count toward the monster's multiple attack penalty, and its multiple attack penalty doesn't apply to this Strike.",
            "game-id": "b9713edb3863029c09b5709dff24cd40",
            "game-obj": "MonsterAbilities",
            "links": [
              {
                "alt": "manipulate",
                "aonid": 104,
                "game-obj": "Traits",
                "name": "manipulate",
                "type": "link"
              },
              {
                "alt": "move",
                "aonid": 114,
                "game-obj": "Traits",
