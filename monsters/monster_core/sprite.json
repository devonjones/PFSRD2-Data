        "name": "Sprite",
        "sections": [
          {
            "name": "Sprite Pranks",
            "sources": [
              {
                "errata": {
                  "alt": "1.1",
                  "aonid": 221,
                  "game-obj": "Sources",
                  "name": "1.1",
                  "type": "link"
                },
                "link": {
                  "alt": "Monster Core pg. 322",
                  "aonid": 221,
                  "game-obj": "Sources",
                  "name": "Monster Core pg. 322",
                  "type": "link"
                },
                "name": "Monster Core",
                "page": 322,
                "type": "source"
              }
            ],
            "text": "Sprite pranks tend to be kind-hearted in nature; they might use their abilities to embarrass a braggart or to trick them into a convoluted scheme to help someone notice an admirer who has been there for them all along. Their plans are often half-baked; sprites' mercurial nature means they can easily become distracted by something new before following through on a previous plan.",
            "type": "section"
          }
        ],
        "sources": [
          {
            "errata": {
              "alt": "1.1",
              "aonid": 221,
              "game-obj": "Sources",
              "name": "1.1",
              "type": "link"
            },
            "link": {
              "alt": "Monster Core pg. 322",
              "aonid": 221,
              "game-obj": "Sources",
              "name": "Monster Core pg. 322",
              "type": "link"
            },
            "name": "Monster Core",
            "page": 322,
            "type": "source"
          }
        ],
        "text": "Elusive, flighty, and ebullient, sprites are what many villagers first imagine when they hear the terms \u201cfey\u201d or \u201cfairy.\u201d While their dispositions vary, all sprites share a connection to magic and a diminutive size. This family of fey shares its name with its slightest and most populous member, the common sprite.",
        "type": "monster_family"
      },
      "knowledge": [
        {
          "dc": 13,
          "link": {
            "alt": "Recall Knowledge - Fey",
            "aonid": 2638,
            "game-obj": "Rules",
            "name": "Recall Knowledge - Fey",
            "type": "link"
          },
          "name": "Fey",
          "skills": [
            {
              "link": {
                "alt": "Nature",
                "aonid": 43,
                "game-obj": "Skills",
                "name": "Nature",
                "type": "link"
              },
              "name": "Nature",
              "subtype": "knowledge_skill",
              "type": "stat_block_section"
            }
          ],
          "subtype": "knowledge",
          "type": "stat_block_section"
        }
      ],
      "level": -1,
      "name": "creature_type",
      "rarity": "Common",
      "size": "Tiny",
      "subtype": "creature_type",
      "traits": [
        {
          "classes": [
            "size"
          ],
          "edition": "legacy",
          "game-id": "bb6959f434e4e1dc9ae2c02ca9015792",
          "game-obj": "Traits",
          "name": "Tiny",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Core Rulebook pg. 474",
                "href": "https://paizo.com/products/btq01y0k?Pathfinder-Core-Rulebook",
                "name": "Core Rulebook pg. 474",
                "type": "link"
              },
              "name": "Core Rulebook",
              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* Less than 5 feet, *Reach (Tall):* 0 feet, *Reach (Long):* 0 feet.  Multiple Tiny creatures can occupy the same square.  At least four can fit in a single square, though the GM might determine that even more can fit.  Tiny creatures can occupy a space larger creature as well, and if their reach is 0 feet, they must do so in order to attack.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 69,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "68e0931a4aa46e583f2efa3182902f5b",
          "game-obj": "Traits",
          "name": "Fey",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 456",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 456",
                "type": "link"
              },
              "name": "Player Core",
              "page": 456,
              "type": "source"
            }
          ],
          "text": "Creatures of the First World are called the fey",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 238,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "c0482886162ecbc56fbaf7ae58ae301d",
          "game-obj": "Traits",
          "name": "Sprite",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Monster Core pg. 363",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 363",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 363,
              "type": "source"
            }
          ],
          "text": "A family of diminutive winged fey with a strong connection to primal magic.",
          "type": "trait"
        }
      ],
