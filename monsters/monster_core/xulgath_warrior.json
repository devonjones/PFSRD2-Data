  "schema_version": 1.4,
  "sections": [
    {
      "name": "Xulgath Warrior",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 352",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 352",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 352,
          "type": "source"
        }
      ],
      "text": "Xulgath warriors strike with fury and eager cruelty, always ready for the next fight. The taking of prizes from battle\u2014including weapons and items stolen from defeated foes along with grislier trophies harvested from fallen victims' flesh\u2014is a popular pursuit among these vicious reptiles, and those whose armor and scales are most adorned are awarded the greatest respect (and perhaps fear) from their kin.",
      "type": "section"
    }
  ],
