  "name": "Arbiter",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Arbiter",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 8",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 8",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 8,
          "type": "source"
        }
      ],
      "text": "These spherical aeons are scouts and diplomats. Found throughout the multiverse, they have traditionally kept watch over chaos and its agents. With the announcement of the Convergence, many arbiters now serve as go-betweens among the aeon alliance and its mortal associates.",
      "type": "section"
    }
  ],
  "sources": [
