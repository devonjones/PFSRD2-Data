  "sections": [
    {
      "name": "Larval Ofalth",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 249",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 249",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 249,
          "type": "source"
        }
      ],
      "text": "Ofalths reproduce asexually. When they first hatch from their leathery eggs, larval ofalths resemble a tendril of flesh supported by spindly legs, but they soon cocoon themselves in trash, to serve as both armor and camouflage.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
