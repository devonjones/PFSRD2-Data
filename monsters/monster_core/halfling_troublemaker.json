  "schema_version": 1.4,
  "sections": [
    {
      "name": "Halfling Troublemaker",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 192",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 192",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 192,
          "type": "source"
        }
      ],
      "text": "A halfling's bravado can sometimes lead them into trouble. These tricksters often roam in groups trying to one-up each other's last prank. While troublemakers rarely intend to kill, occasionally their pranks get out of hand.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "1.1",
        "aonid": 221,
        "game-obj": "Sources",
        "name": "1.1",
        "type": "link"
      },
      "link": {
        "alt": "Monster Core pg. 192",
        "aonid": 221,
        "game-obj": "Sources",
        "name": "Monster Core pg. 192",
        "type": "link"
      },
      "name": "Monster Core",
      "page": 192,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Humanoid"
      ],
      "family": {
        "aonid": 426,
        "edition": "remastered",
        "game-id": "6c86a2ee2af3f945cff0335b31d57a94",
        "game-obj": "MonsterFamilies",
        "link": {
          "alt": "Halfling",
          "aonid": 426,
          "game-obj": "MonsterFamilies",
