    {
      "name": "Homunculus",
      "sections": [
        {
          "image": {
            "image": "Sidebar_1_AdviceAndRules.png",
            "name": "Advice and Rules",
            "type": "image"
          },
          "links": [
            {
              "alt": "soulbound doll",
              "aonid": 383,
              "game-obj": "Monsters",
              "name": "soulbound doll",
              "type": "link"
            },
            {
              "alt": "soulbound",
              "aonid": 773,
