                "alt": "subtle",
                "aonid": 522,
                "game-obj": "Traits",
                "name": "subtle",
                "type": "link"
              }
            ],
            "name": "Tooth Tug",
            "requirement": "The tooth fairy's last action was a successful pliers Strike against a creature with teeth",
            "saving_throw": [
