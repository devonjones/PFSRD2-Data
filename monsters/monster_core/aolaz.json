        ],
        "name": "Flawless Hearing",
        "subtype": "ability",
        "text": "An aolaz has an incredible sense of hearing. It can hear any sound made within 1,000 feet as though it were only 5 feet away from the source of the sound, and any sound within 1 mile as though it were only 30 feet away from the source of the sound. An aolaz's hearing is a precise sense.",
        "type": "stat_block_section"
      }
