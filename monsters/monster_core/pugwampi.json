                "edition": "remastered",
                "game-id": "ca5b7a642aef726cc9055981ca84f89d",
                "game-obj": "Traits",
                "name": "Versatile",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
