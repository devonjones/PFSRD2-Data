            "name": "Tinker",
            "range": {
              "range": 60,
              "subtype": "range",
              "text": "range of 60 feet",
              "type": "stat_block_section",
              "unit": "feet"
            },
            "saving_throw": [
              {
                "dc": 5,
                "save_type": "Flat Check",
                "subtype": "save_dc",
                "text": "DC 5 flat check",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "A group of six jinkins can work together for an hour to imbue an item with a curse at a range of 60 feet. While this process is lengthy, it's also unobtrusive and can be performed while Hiding. Jinkins prefer to use this ability on magic items. The curse makes the item unreliable (DC 5 flat check or waste any action to Interact with or Activate the item), adds a bizarre requirement to use the item, or imparts some other curse of a similar caliber.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 38,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "d108d452587889359960cb6377f62982",
                "game-obj": "Traits",
                "name": "Curse",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 454",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 454",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 454,
                    "type": "source"
                  }
                ],
                "text": "A curse is an effect that places some long-term affliction on a creature. Curses are always magical and are typically the result of a spell or trap. Effects with this trait can be removed only by effects that specifically target curses.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 134,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
