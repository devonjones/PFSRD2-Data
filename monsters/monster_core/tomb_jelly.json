  "sections": [
    {
      "name": "Tomb Jelly",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 257",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 257",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 257,
          "type": "source"
        }
      ],
      "text": "Tomb jellies are animate masses of protoplasm with a sickly combination of yellow, gray, and black hues. Their acidic bodies dissolve flesh but leave other materials, including a victim's gear and bones, intact. Some ancient cultures entombed bodies in stone sarcophagi with tomb jellies to allow the ooze to break down the flesh and clean and polish the bones.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "1.1",
        "aonid": 221,
        "game-obj": "Sources",
        "name": "1.1",
        "type": "link"
      },
      "link": {
        "alt": "Monster Core pg. 257",
        "aonid": 221,
        "game-obj": "Sources",
        "name": "Monster Core pg. 257",
        "type": "link"
      },
      "name": "Monster Core",
      "page": 257,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
