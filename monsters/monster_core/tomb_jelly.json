            "name": "Bound in Death",
            "subtype": "ability",
            "text": "The tomb jelly splatters some of its substance on a willing undead creature within its reach. The target regains 5 HP and its melee Strikes get the benefits of tomb curse until the end of its next turn.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 89,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "46d51374c2ada72347818dbac1edd7a3",
                "game-obj": "Traits",
                "name": "Healing",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 457",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 457",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 457,
                    "type": "source"
                  }
                ],
                "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 118,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "3272a04f38d00c2316cbc6fe1eb1cda1",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "undead",
                    "aonid": 160,
                    "game-obj": "Traits",
                    "name": "undead",
                    "type": "link"
                  }
                ],
                "name": "Void",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 463",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 463",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 463,
                    "type": "source"
                  }
                ],
                "text": "Effects with this trait heal undead creatures with void energy, deal void damage to living creatures, or manipulate void energy.  \n  \nPlanes with this trait are vast, empty reaches that suck the life from the living. They tend to be lonely, haunted planes, drained of color and filled with winds carrying the moans of the dead At the end of each round, a living creature takes at least minor void environmental damage. In the strongest areas of a void plane, they could take moderate or even major void damage at the end of each round. This damage has the death trait, and if a living creature is reduced to 0 Hit Points by this void damage and killed, it crumbles into ash and can become a wraith (see Monster Core).",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
