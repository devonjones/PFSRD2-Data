  "sections": [
    {
      "name": "Megalodon",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 307",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 307",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 307,
          "type": "source"
        }
      ],
      "text": "Prehistoric sharks of incredible size, strength, and ferocity, megalodons scour waters deep and shallow to sate their considerable hunger. The presence of a megalodon undeniably affects the local aquatic ecosystem.",
      "type": "section"
    }
  ],
  "sources": [
