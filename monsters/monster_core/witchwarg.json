  "sections": [
    {
      "name": "Witchwarg",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 341",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 341",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 341,
          "type": "source"
        }
      ],
      "text": "Witchwargs are related to wargs, but are larger, smarter, and far more dangerous. They are capable of exhaling plumes of freezing breath. When they deign to serve others, they usually reserve this privilege for more dangerous creatures, such as the winter witches of Irrisen.",
      "type": "section"
    }
  ],
