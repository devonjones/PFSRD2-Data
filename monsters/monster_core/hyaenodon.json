  "sections": [
    {
      "name": "Hyaenodon",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 205",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 205",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 205,
          "type": "source"
        }
      ],
      "text": "Hyaenodons are ferocious primeval creatures that resemble hyenas. Looming, shaggy-furred animals nearly the size of a horse, hyaenodons are truly formidable predators to be reckoned with, due both to their size and to their flesh-shearing jaws. Hyaenodons prey on small horses, camels, and even young rhinoceroses. Kholo clans find these creatures particularly useful as mounts and guardians.",
      "type": "section"
    }
  ],
