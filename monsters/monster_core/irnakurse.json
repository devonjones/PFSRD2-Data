                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
