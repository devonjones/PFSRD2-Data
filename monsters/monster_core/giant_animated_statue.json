  "name": "Giant Animated Statue",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Giant Animated Statue",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 19",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 19",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 19,
          "type": "source"
        }
      ],
      "text": "Giant animated statues' increased size and power make them most useful in large vaults, spacious chambers, or outdoor locations. Tasks beyond their capabilities typically require a more advanced construct, not an animated object.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "1.1",
        "aonid": 221,
        "game-obj": "Sources",
