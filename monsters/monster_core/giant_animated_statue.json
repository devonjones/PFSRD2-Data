          "edition": "remastered",
          "game-id": "ee36f249251dca4d6fd0a126bc920850",
          "game-obj": "Traits",
          "name": "Construct",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 454",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 454",
                "type": "link"
              },
              "name": "Player Core",
              "page": 454,
              "type": "source"
            }
          ],
          "text": "A construct is an artificial creature empowered by a force other than vitality or void.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 108,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "1debc9c19f9ffadf57ee0ebf1bc785cb",
          "game-obj": "Traits",
          "name": "Mindless",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "A mindless creature has either programmed or rudimentary mental attributes. Most, if not all, of their mental attribute modifiers are \u20135. They are immune to all mental effects.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
