                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "You can throw this weapon as a ranged attack; it is a ranged weapon when thrown. You add your Strength modifier to damage as you would for a melee weapon. When this trait appears on a melee weapon, it also includes the range increment. Ranged weapons with this trait use the range increment in the weapon\u2019s Range entry.",
                "type": "trait",
                "value": "30 feet"
              }
            ],
            "type": "stat_block_section",
            "weapon": "javelin"
          },
          "name": "Ranged",
          "offensive_action_type": "attack",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "links": [
              {
                "alt": "quickened",
                "aonid": 89,
                "game-obj": "Conditions",
                "name": "quickened",
                "type": "link"
              }
            ],
            "name": "Bellowing Command",
            "subtype": "ability",
            "text": "The ogre boss issues a command to hasten their fellows. Each ogre ally who hears and understands this command becomes quickened until the end of that ally's next turn but can use the extra action only to Step or Stride.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 60,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "fb5f8b3d849b073e1514a6a025810470",
                "game-obj": "Traits",
                "name": "Emotion",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 455",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 455",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 455,
                    "type": "source"
                  }
                ],
                "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 68,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "9a5cea6bfb849deb16206c68f8d113a5",
                "game-obj": "Traits",
                "name": "Fear",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 456",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 456",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 456,
                    "type": "source"
                  }
                ],
                "text": "Fear effects evoke the emotion of fear. Effects with this trait always have the mental and emotion traits as well.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 101,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
                "game-obj": "Traits",
                "name": "Linguistic",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "An effect with this trait depends on language comprehension. A linguistic effect that targets a creature works only if the target understands the language you are using.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 106,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "game-obj": "Traits",
                "name": "Mental",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
