            "name": "Encircling Command",
            "range": {
              "range": 30,
              "subtype": "range",
              "text": "within 30 feet",
              "type": "stat_block_section",
              "unit": "feet"
            },
            "subtype": "ability",
            "text": "Each caligni skulker within 30 feet of the hunter can Step. Each skulker can benefit from Encircling Command only once per round.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
