        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 228,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "1c81f167df78a49c05e2f95171fb6797",
          "game-obj": "Traits",
          "name": "Mummy",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Monster Core pg. 363",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 363",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 363,
              "type": "source"
            }
          ],
          "text": "A mummy is an undead creature created from a preserved corpse.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 160,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "20f6f5f93a453f3006eb194c6d712042",
          "game-obj": "Traits",
          "name": "Undead",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 462",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 462",
                "type": "link"
              },
              "name": "Player Core",
              "page": 462,
              "type": "source"
            }
          ],
          "text": "Once living, these creatures were infused after death with void energy and soul-corrupting unholy magic. When reduced to 0 Hit Points, an undead creature is destroyed. Undead creatures are damaged by vitality energy and are healed by void energy, and don\u2019t benefit from healing vitality effects.",
          "type": "trait"
        },
        {
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "6309897c89780f17449b984cbb6d26cb",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "holy",
              "aonid": 517,
              "game-obj": "Traits",
              "name": "holy",
              "type": "link"
            }
          ],
          "name": "Unholy",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 462",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 462",
                "type": "link"
              },
              "name": "Player Core",
              "page": 462,
              "type": "source"
            }
          ],
          "text": "Effects with the unholy trait are tied to powerful magical forces of cruelty and sin. They often have stronger effects on holy creatures. Creatures with this trait are strongly devoted to unholy causes, and often have weakness to holy. If a creature with weakness to unholy uses an unholy item or effect, it takes damage from its weakness.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
