          ],
          "name": "Blighted Consumption",
          "range": {
            "range": 30,
            "subtype": "range",
            "text": "within 30 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "saving_throw": [
            {
              "dc": 24,
              "save_type": "Fort",
              "subtype": "save_dc",
              "text": "DC 24 Fortitude save",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 38,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "d108d452587889359960cb6377f62982",
              "game-obj": "Traits",
              "name": "Curse",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 454",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 454,
                  "type": "source"
                }
              ],
              "text": "A curse is an effect that places some long-term affliction on a creature. Curses are always magical and are typically the result of a spell or trap. Effects with this trait can be removed only by effects that specifically target curses.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 48,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
              "game-obj": "Traits",
              "name": "Divine",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 126,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "31b1fcebcaa04711c9f0d282aa02bfee",
              "game-obj": "Traits",
              "name": "Poison",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 459",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 459",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 459,
                  "type": "source"
                }
              ],
              "text": "An effect with this trait delivers a poison or deals poison damage. An item with this trait is poisonous and might cause an affliction.",
              "type": "trait"
            }
          ],
          "trigger": "A creature within 30 feet eats or drinks (including an alchemical item or potion)",
          "type": "stat_block_section"
        }
      ],
