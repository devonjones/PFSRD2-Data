    "name": "Animated Armor",
    "offense": {
      "offensive_actions": [
        {
          "attack": {
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "attack_type": "melee",
            "bonus": {
              "bonuses": [
                10,
                5,
                0
              ],
              "link": {
                "alt": "+5/+0",
                "aonid": 322,
                "game-obj": "Rules",
                "name": "+5/+0",
                "type": "link"
              },
              "subtype": "attack_bonus",
              "type": "stat_block_section"
            },
            "damage": [
              {
                "damage_type": "slashing",
                "formula": "1d8+4",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "name": "Melee",
            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 174,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c0d76f25881949145ec6769d79ad49b5",
                "game-obj": "Traits",
                "name": "Deadly",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "On a critical hit, the weapon adds a weapon damage die of the listed size. Roll this after doubling the weapon\u2019s damage. This increases to two dice if the weapon has a _greater striking rune_ and three dice if the weapon has a _major striking rune_. For instance, a rapier with a _greater striking rune_ deals 2d8 extra piercing damage on a critical hit. An ability that changes the size of the weapon\u2019s normal damage dice doesn\u2019t change the size of its deadly die.",
                "type": "trait",
                "value": "d8"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 180,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "18975df1ca2f4e961748576c9d842330",
                "game-obj": "Traits",
                "name": "Forceful",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "This weapon becomes more dangerous as you build momentum. When you attack with it more than once on your turn, the second attack gains a circumstance bonus to damage equal to the number of weapon damage dice, and each later attack gains a circumstance bonus to damage equal to double the number of damage dice.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 103,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
