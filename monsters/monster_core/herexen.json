      "subtype": "creature_type",
      "traits": [
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 159,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "uncommon"
