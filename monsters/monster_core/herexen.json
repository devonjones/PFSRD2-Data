              "effects": [
                {
                  "operation": "select",
                  "selection": {
                    "action": "replace",
                    "description": "- Swap out the herexen's domain spell for a 1st-rank focus spell from a domain associated with that deity.",
                    "type": "select"
                  },
                  "target": "$.offense.offensive_actions[*].spells"
                }
              ],
              "subtype": "change",
              "text": "- Swap out the herexen's domain spell for a 1st-rank focus spell from a domain associated with that deity.",
              "type": "stat_block_section"
            },
            {
              "change_category": "spells",
              "effects": [
                {
                  "operation": "select",
                  "selection": {
                    "action": "replace",
                    "description": "- Swap the defiled religious symbol for the correct deity. For example, an ex-Sarenite herexen carries a scimitar and a defiled religious symbol of Sarenrae, and can cast *fire ray* (attack +12) as a focus spell.",
                    "type": "select"
                  },
                  "target": "$.offense.offensive_actions[*].spells"
                }
              ],
              "links": [
                {
