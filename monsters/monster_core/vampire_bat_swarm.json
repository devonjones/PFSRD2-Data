  "schema_version": 1.4,
  "sections": [
    {
      "name": "Vampire Bat Swarm",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 40",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 40",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 40,
          "type": "source"
        }
      ],
      "text": "Although the typical vampire bat has a wingspan of 7 inches and doesn't pose a significant threat to larger prey alone (and indeed, these blood-drinkers can feed without their sleeping victims ever noticing), some unusually aggressive species of these bats hunt in deadly swarms. A churning cloud of vampire bats is much more dangerous than the sum of its individual parts and is capable of inflicting an overwhelming number of bleeding wounds in a frighteningly short span of time.",
      "type": "section"
    }
  ],
  "sources": [
