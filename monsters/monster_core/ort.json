          "game-id": "f4bfadf0db13af1b3cde6e4663b082db",
          "game-obj": "Traits",
          "name": "Fiend",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 456",
