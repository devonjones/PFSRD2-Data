        "edition": "remastered",
        "game-id": "8991327092c9edf1c04be83b746130fd",
        "game-obj": "MonsterFamilies",
        "link": {
          "alt": "Drake",
          "aonid": 404,
          "game-obj": "MonsterFamilies",
          "name": "Drake",
