              "type": "link"
            }
          ],
          "name": "Hydration",
          "subtype": "ability",
          "text": "Azarketi must regularly submerge themselves in water to rehydrate their water-acclimated skin. After the first 24 hours outside of water, they gain a \u20131 status penalty to Fortitude saves as their skin cracks and their gills become painful. After 48 hours, they begin to suffocate until returned to water.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "The azarketi crab catcher gains a +2 circumstance bonus to AC against the triggering attack. After the attack, they Swim 5 feet.",
          "name": "Swim Away",
          "requirement": "The azarketi crab catcher is swimming",
          "subtype": "ability",
          "trigger": "The azarketi crab catcher is targeted with an attack and can see the attacker",
          "type": "stat_block_section"
        }
      ],
