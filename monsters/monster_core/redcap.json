      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "critical_success": "The redcap is unaffected.",
          "failure": "The redcap gains the fleeing condition for 1 round and is frightened 4.",
          "links": [
            {
              "alt": "frightened 2",
              "aonid": 76,
              "game-obj": "Conditions",
              "name": "frightened 2",
              "type": "link"
