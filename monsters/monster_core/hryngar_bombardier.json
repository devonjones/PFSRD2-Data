                "name": "Player Core pg. 455",
                "type": "link"
              },
              "name": "Player Core",
              "page": 455,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the dwarf ancestry. Dwarves are stout folk who often live underground and typically have darkvision. An ability with this trait can be used or selected only by dwarves. An item with this trait is created and used by dwarves.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 53,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "554facb0a5044011c1891ad449cf9c89",
          "game-obj": "Traits",
          "name": "Hryngar",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Subterranean kin of the dwarves, hryngars typically have darkvision, resist poison, and recoil from bright light.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
