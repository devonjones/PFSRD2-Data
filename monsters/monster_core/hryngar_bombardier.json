  "schema_version": 1.4,
  "sections": [
    {
      "name": "Hryngar Bombardier",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 202",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 202",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 202,
          "type": "source"
        }
      ],
      "text": "Hryngar chemists have a knack for creating alchemical grenades. Their traditions often motivate them to constantly experiment and innovate, though the hostile nature of their environs tends to focus these innovations on weapons or other tools of war. Hryngar bombardiers eagerly steal notes and secrets from their underlings, pushing their students to cut corners to produce results while gleefully pillaging the credit and profits. For those hryngar bombardiers who find themselves pressed into combat service, each thrown grenade represents a new opportunity to observe the  suffering they inflict, before eagerly incorporating that data into their next experiment or innovation to create an even more terrible tool of torment.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "1.1",
