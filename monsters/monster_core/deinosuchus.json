  "sections": [
    {
      "name": "Deinosuchus",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 69",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 69",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 69,
          "type": "source"
        }
      ],
      "text": "The deinosuchus is a primeval relative of the crocodile, and is an enormous predator capable of catching and eating dinosaurs that wander too close to its domain! Much longer lived than other crocodiles, it can grow to around 30 feet long.",
      "type": "section"
    }
  ],
  "sources": [
