                },
                "edition": "remastered",
                "game-id": "b46c08b2d190882823c18fba71cc1d81",
                "game-obj": "Traits",
                "name": "Backswing",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You can use the momentum from a missed attack with this weapon to lead into your next attack. After missing with this weapon on your turn, you gain a +1 circumstance bonus to your next attack with this weapon before the end of your turn.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 193,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6cd7af0b11cadecab9bad5582f02196b",
                "game-obj": "Traits",
                "name": "Shove",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "You can use this weapon to Shove with the Athletics skill even if you don\u2019t have a free hand. This uses the weapon\u2019s reach (if different from your own) and adds the weapon\u2019s item bonus to attack rolls as an item bonus to the Athletics check. If you critically fail a check to Shove using the weapon, you can drop the weapon to take the effects of a failure instead of a critical failure.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section",
            "weapon": "greatclub"
