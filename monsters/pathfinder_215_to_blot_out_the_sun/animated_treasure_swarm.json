          "game-id": "1debc9c19f9ffadf57ee0ebf1bc785cb",
          "game-obj": "Traits",
          "name": "Mindless",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
