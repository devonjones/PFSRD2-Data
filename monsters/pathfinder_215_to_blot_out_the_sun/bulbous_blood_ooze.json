    "sections": [
        {
            "name": "Bulbous Blood Ooze",
            "type": "section",
            "text": "*Nethys Note: No description has been provided for this creature.*",
            "sources": [
                {
                    "type": "source",
                    "name": "Pathfinder #215: To Blot Out the Sun",
                    "link": {
                        "type": "link",
                        "name": "Pathfinder #215: To Blot Out the Sun pg. 55",
                        "alt": "Pathfinder #215: To Blot Out the Sun pg. 55",
