              "subtype": "area",
              "text": "15-foot burst",
              "type": "stat_block_section",
              "unit": "feet"
            }
          ],
          "effect": "The dust bunnies stir, kicking up a cloud in a 15-foot burst centered on the swarm that lasts for 1 minute. Creatures who enter or start their turn in this cloud must attempt a DC 16 Fortitude save or take a \u20131 circumstance penalty to skill checks that have the concentration trait and all Perception checks as their sensory organs become impaired.",
          "links": [
            {
              "alt": "concentration",
              "aonid": 561,
              "game-obj": "Traits",
              "name": "concentration",
              "type": "link"
            }
          ],
          "name": "Cloud of Allergens",
          "saving_throw": [
            {
              "dc": 16,
              "save_type": "Fort",
              "subtype": "save_dc",
              "text": "DC 16 Fortitude save",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "trigger": "The swarm rolls initiative",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "name": "Dust to Dust",
          "subtype": "ability",
          "text": "When a dust bunny swarm is destroyed, it re-forms after 2d4 days in the area in which it was destroyed unless the location has been significantly cleaned of all dust and debris.",
          "type": "stat_block_section"
        }
      ],
