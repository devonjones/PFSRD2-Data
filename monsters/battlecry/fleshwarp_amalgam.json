            "automatic_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "ability_type": "automatic",
                    "name": "Brutal Retaliation",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Reaction"
                    },
                    "trigger": "The fleshwarp amalgam loses a segment due to passing a Hit Point threshold",
                    "links": [
                        {
                            "type": "link",
                            "name": "emanation",
                            "alt": "emanation",
                            "game-obj": "Rules",
                            "aonid": 2387
                        },
                        {
                            "type": "link",
