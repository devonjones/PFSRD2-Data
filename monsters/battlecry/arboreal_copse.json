              "type": "source"
            }
          ],
          "text": "*Space:* 20 feet or more, *Reach (Tall):* 20 feet, *Reach (Long):* 15 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 125,
