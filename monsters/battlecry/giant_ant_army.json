{
    "name": "Giant Ant Army",
    "type": "creature",
    "sections": [
        {
            "name": "Giant Ant Army",
            "type": "section",
            "text": "Like their tiny counterparts, colonies of giant ants often form vast armies that launch regular campaigns into the lands surrounding their nests to forage for food and expand their territory. Though their primary targets are usually rival colonies, a giant ant army that happens upon a humanoid settlement will not hesitate to overrun and strip it of resources to bring back to their queen, taking a particular interest in the settlement's former inhabitants.",
            "sources": [
                {
                    "type": "source",
                    "name": "Battlecry!",
                    "link": {
                        "type": "link",
                        "name": "Battlecry! pg. 181",
                        "alt": "Battlecry! pg. 181",
                        "game-obj": "Sources",
                        "aonid": 268
                    },
                    "page": 181
                }
            ]
        }
    ],
