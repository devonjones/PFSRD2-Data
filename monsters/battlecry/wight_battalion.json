      ],
      "name": "Wight Battalion",
      "sources": [
        {
          "link": {
            "alt": "Battlecry! pg. 194",
            "aonid": 268,
            "game-obj": "Sources",
            "name": "Battlecry! pg. 194",
            "type": "link"
          },
          "name": "Battlecry!",
          "page": 194,
          "type": "source"
        }
      ],
      "text": "Wights are malevolent undead, bent on desecrating the holy and determined to cause suffering to all living creatures. A lone wight is dangerous enough, but when compelled to act together, they are a force to be reckoned with. A wight battalion has the potential to curse entire armies, increasing their numbers until they become an unholy tide.",
      "type": "section"
    }
  ],
  "sources": [
    {
