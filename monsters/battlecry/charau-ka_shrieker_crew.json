      "name": "Charau-Ka Shrieker Crew",
      "sources": [
        {
          "link": {
            "alt": "Battlecry! pg. 175",
            "aonid": 268,
            "game-obj": "Sources",
            "name": "Battlecry! pg. 175",
            "type": "link"
