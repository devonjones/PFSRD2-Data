            "name": "Shrieking Charge",
            "saving_throw": [
              {
                "basic": true,
                "dc": 23,
                "save_type": "Ref",
                "subtype": "save_dc",
                "text": "DC 23 basic   Reflex save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "With raucous shrieks, the shrieker crew charges forward. The troop Strides twice. If they move at least 10 feet, the crew deals 3d6+13 slashing damage (DC 23 basic   Reflex save) to each enemy in a 5-foot emanation at the end of the crew's movement. Each target who fails this save is also deafened for 1 round.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
          "name": "Shrieking Charge",
