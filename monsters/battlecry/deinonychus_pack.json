      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Animal",
        "Dinosaur",
        "Troop"
      ],
      "family": {
        "alternate_link": {
          "alternate_type": "legacy",
