              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Humanoid creatures reason and act much like humans. They typically stand upright and have two arms and two legs.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 367,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "2d407154112121f24c49d97c89d90b55",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "troop defenses",
              "aonid": 86,
              "game-obj": "MonsterAbilities",
              "name": "troop defenses",
              "type": "link"
            },
            {
              "alt": "troop movement",
              "aonid": 85,
              "game-obj": "MonsterAbilities",
              "name": "troop movement",
              "type": "link"
            }
          ],
          "name": "Troop",
          "sources": [
            {
              "link": {
                "alt": "NPC Core pg. 238",
                "aonid": 236,
                "game-obj": "Sources",
                "name": "NPC Core pg. 238",
                "type": "link"
              },
              "name": "NPC Core",
              "page": 238,
              "type": "source"
            }
          ],
          "text": "A troop is an organized collection of component creatures, typically Small or Medium in size, working as a cohesive whole. Over the course of enough attacks and downed comrades, troops shrink in size. A troop typically has the troop defenses and troop movement abilities, and most troops have weaknesses to area damage and splash damage. Because they consist of multiple discrete creatures, they can't be summoned.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
    "defense": {
      "ac": {
        "subtype": "armor_class",
        "type": "stat_block_section",
        "value": 35
      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Troop Defenses",
          "subtype": "ability",
          "type": "stat_block_section",
          "universal_monster_ability": {
            "ability_type": "universal_monster_ability",
            "aonid": 86,
            "edition": "remastered",
            "game-id": "80c36d6067f5b5aa7530731a70f98a00",
            "game-obj": "MonsterAbilities",
            "links": [
              {
                "alt": "Troops",
                "aonid": 849,
                "game-obj": "Traits",
                "name": "Troops",
                "type": "link"
              },
              {
                "alt": "charm",
