  "sections": [
    {
      "name": "Clockwork Infantry",
      "sources": [
        {
          "link": {
            "alt": "Battlecry! pg. 176",
            "aonid": 268,
            "game-obj": "Sources",
            "name": "Battlecry! pg. 176",
            "type": "link"
          },
          "name": "Battlecry!",
          "page": 176,
          "type": "source"
        }
      ],
      "text": "With each unit being 500 pounds of metal and magic, a clockwork infantry is a force to be reckoned with on the battlefield. Needing no food, shelter, or rest and feeling no pain, clockwork infantry can advance where living units have great trouble. With no morale that can be broken or minds that can be beguiled, they patrol without stopping and show no mercy. The only drawback is the need to wind them more often than simpler clockwork mechanics.",
      "type": "section"
    }
  ],
  "sources": [
