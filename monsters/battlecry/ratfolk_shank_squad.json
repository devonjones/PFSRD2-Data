                "sections": [
                    {
                        "name": "Vast Warrens and Hidden Homes",
                        "type": "section",
                        "text": "On Golarion, ysoki are most numerous in the Darklands below the continent of Tian Xia, where they rule a vast empire, but they can be found in the Inner Sea region as well\u2014particularly in the badlands and hills of Numeria, where they eagerly scavenge and collect strange technological wonders and weapons.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Monster Core",
                                "link": {
