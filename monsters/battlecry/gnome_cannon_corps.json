      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Troop Defenses",
          "subtype": "ability",
          "type": "stat_block_section",
          "universal_monster_ability": {
            "ability_type": "universal_monster_ability",
            "aonid": 86,
            "edition": "remastered",
            "game-id": "80c36d6067f5b5aa7530731a70f98a00",
            "game-obj": "MonsterAbilities",
            "links": [
              {
                "alt": "Troops",
