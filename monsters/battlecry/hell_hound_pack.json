          ],
          "edition": "remastered",
          "game-id": "28f1c378d01673d4b58ae0b8c7d35631",
          "game-obj": "Traits",
          "name": "Beast",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
