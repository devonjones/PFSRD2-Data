                        ],
                        "effect": "Using blades attached to their crossbows, the dwarven longshots engages in a coordinated melee attack against enemies in a 5-foot emanation, with a DC 26 basic Reflex save. The damage depends on the number of actions.  \n [#] 1d8+2 piercing damage   \n [##] 2d8+11 piercing damage   \n [###] 3d8+13",
                        "text": "piercing damage"
                    }
                },
                {
                    "name": "Bolts from the Blue",
                    "type": "stat_block_section",
                    "subtype": "offensive_action",
                    "offensive_action_type": "ability",
                    "ability": {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "ability_type": "offensive",
                        "name": "Bolts from the Blue",
                        "action_type": {
