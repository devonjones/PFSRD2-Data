          "game-id": "2d407154112121f24c49d97c89d90b55",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "troop defenses",
              "aonid": 86,
              "game-obj": "MonsterAbilities",
              "name": "troop defenses",
              "type": "link"
            },
            {
              "alt": "troop movement",
