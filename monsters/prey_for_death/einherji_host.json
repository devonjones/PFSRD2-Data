                "name": "Monster Core 2 pg. 363",
                "type": "link"
              },
              "name": "Monster Core 2",
              "page": 363,
              "type": "source"
            }
          ],
          "text": "Aesir are often-bellicose monitors, honing their skill in battle and preparing for a final confrontation at the end of the multiverse.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 111,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "58c3de8b2876f9ef1cfb8035500d22e6",
          "game-obj": "Traits",
          "name": "Monitor",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "Creatures that hail from or have a strong connection to Axis, the Boneyard, or the Maelstrom are called monitors. Monitors can survive the basic environmental effects of planes in the Outer Sphere.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 367,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "2d407154112121f24c49d97c89d90b55",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "troop defenses",
              "aonid": 86,
              "game-obj": "MonsterAbilities",
              "name": "troop defenses",
              "type": "link"
            },
            {
              "alt": "troop movement",
              "aonid": 85,
              "game-obj": "MonsterAbilities",
              "name": "troop movement",
              "type": "link"
            }
          ],
          "name": "Troop",
          "sources": [
            {
              "link": {
                "alt": "NPC Core pg. 238",
                "aonid": 236,
                "game-obj": "Sources",
                "name": "NPC Core pg. 238",
                "type": "link"
              },
              "name": "NPC Core",
              "page": 238,
              "type": "source"
            }
          ],
          "text": "A troop is an organized collection of component creatures, typically Small or Medium in size, working as a cohesive whole. Over the course of enough attacks and downed comrades, troops shrink in size. A troop typically has the troop defenses and troop movement abilities, and most troops have weaknesses to area damage and splash damage. Because they consist of multiple discrete creatures, they can't be summoned.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
