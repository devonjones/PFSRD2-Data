    "defense": {
      "ac": {
        "subtype": "armor_class",
        "type": "stat_block_section",
        "value": 38
      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Battle Arrogance",
          "subtype": "ability",
          "text": "Ordulf hasn't met a significant combat challenge in ages, and even when facing deadly foes like the PCs his arrogance can be used against him. If a PC successfully disarms, feints, frightens, or trips Ordulf, his arrogance gets the better of him and he grows sloppy in his tactics, reducing his AC to 34 until the start of his next turn. A PC can also attempt to issue a more debilitating insult to Ordulf, as detailed in Insulting Ordulf.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "doomed",
              "aonid": 67,
              "game-obj": "Conditions",
              "name": "doomed",
              "type": "link"
            }
          ],
          "name": "Gorum's Major Boon",
          "subtype": "ability",
          "text": "When Ordulf is reduced to 0 Hit Points, Gorum feeds him the zeal of his Aesir, allowing Ordulf to draw upon his own life force to fight on and on without falling. He is healed to 150 Hit Points and becomes doomed 1 (or increases his doomed condition by 1), causing his features to look progressively more gaunt and scarred. Once he reaches doomed 4, he dies.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 89,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "46d51374c2ada72347818dbac1edd7a3",
              "game-obj": "Traits",
              "name": "Healing",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 457",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 457",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 457,
                  "type": "source"
                }
              ],
              "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
