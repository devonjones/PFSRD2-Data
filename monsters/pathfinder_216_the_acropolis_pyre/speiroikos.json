            "automatic_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "ability_type": "automatic",
                    "name": "Diverted Fury",
                    "text": "The speiroikos' aggression can be redirected against their own numbers. A creature within 30 feet of the speiroikos can take an action to throw a small object such as a rock among the troop, attempting a DC 17 Deception check; this action has the manipulate trait. On a success, the troop deals its two- action Dory Strike damage to itself on its next round, taking no other actions.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Deception",
                            "alt": "Deception",
                            "game-obj": "Skills",
                            "aonid": 38
                        },
                        {
