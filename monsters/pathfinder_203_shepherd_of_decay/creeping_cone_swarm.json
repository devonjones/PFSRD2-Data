  "schema_version": 1.4,
  "sections": [
    {
      "links": [
        {
          "alt": "Ayrzul's Blight",
          "aonid": 41,
          "game-obj": "Diseases",
          "name": "Ayrzul's Blight",
          "type": "link"
        }
      ],
      "name": "Creeping Cones",
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #203 Shepherd of Decay pg. 80",
            "aonid": 243,
            "game-obj": "Sources",
            "name": "Pathfinder #203 Shepherd of Decay pg. 80",
            "type": "link"
          },
          "name": "Pathfinder #203 Shepherd of Decay",
          "page": 80,
          "type": "source"
        }
      ],
      "text": "Caustic fluid seeps out from the scales of these sluglike cones, which spawn in unsuspecting hosts until they're mature enough to seek a place to root. Moving in writhing swarms that seek a habitat flush with prey, creeping cones spread Ayrzul's Blight when destroyed, but leaving them to grow unchecked poses a great risk to other creatures.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Pathfinder #203 Shepherd of Decay pg. 80",
        "aonid": 243,
        "game-obj": "Sources",
