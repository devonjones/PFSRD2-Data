        "name": "Blight Bonded",
        "sections": [
          {
            "name": "Other Blight Bonds",
            "sources": [
              {
                "link": {
                  "alt": "Pathfinder #203 Shepherd of Decay pg. 80",
                  "aonid": 243,
                  "game-obj": "Sources",
                  "name": "Pathfinder #203 Shepherd of Decay pg. 80",
                  "type": "link"
