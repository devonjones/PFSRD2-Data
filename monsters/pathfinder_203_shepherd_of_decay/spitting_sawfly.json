  "sections": [
    {
      "name": "Spitting Sawfly",
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #203 Shepherd of Decay pg. 80",
            "aonid": 243,
            "game-obj": "Sources",
            "name": "Pathfinder #203 Shepherd of Decay pg. 80",
            "type": "link"
          },
          "name": "Pathfinder #203 Shepherd of Decay",
          "page": 80,
          "type": "source"
        }
      ],
      "text": "Spitting sawflies are enormous, bloated insects covered in tumor-like knots of spores. These ravenous pests sow disease and spores wherever they go, heralding the infestation of creeping cones.",
      "type": "section"
    }
  ],
  "sources": [
