    "interaction_abilities": [
      {
        "ability_type": "interaction",
        "name": "Luminous Fire",
        "subtype": "ability",
        "text": "A sprite naturally sheds light like a torch. The sprite can extinguish, rekindle, or change the color of this light using a single action, which has the concentrate trait. While this light is extinguished, the sprite\u2019s Strikes don\u2019t deal fire damage and they can\u2019t use their luminous spark Strike.",
        "traits": [
          {
            "edition": "legacy",
            "game-id": "01bf3e53d6c0fc7f70419341635bfe8f",
            "game-obj": "Traits",
            "name": "Evocation",
            "sources": [
              {
                "errata": {
                  "alt": "4.0",
                  "aonid": 1,
                  "game-obj": "Sources",
                  "name": "4.0",
                  "type": "link"
                },
                "link": {
                  "alt": "Core Rulebook pg. 631",
                  "aonid": 1,
                  "game-obj": "Sources",
                  "name": "Core Rulebook pg. 631",
                  "type": "link"
                },
                "name": "Core Rulebook",
                "page": 631,
                "type": "source"
              }
            ],
            "text": "Effects and magic items with this trait are associated with the evocation school of magic, typically involving energy and elemental forces.",
            "type": "trait"
          },
          {
            "alternate_link": {
              "alternate_type": "remastered",
              "aonid": 640,
              "game-obj": "Traits",
              "type": "alternate_link"
            },
            "edition": "legacy",
            "game-id": "69fd6e4c82f250de73bff8d657c357d1",
            "game-obj": "Traits",
            "links": [
              {
                "alt": "counteract",
                "aonid": 371,
                "game-obj": "Rules",
                "name": "counteract",
                "type": "link"
              },
              {
                "alt": "darkness",
                "aonid": 39,
                "game-obj": "Traits",
                "name": "darkness",
                "type": "link"
              }
            ],
            "name": "Light",
            "sources": [
              {
                "errata": {
                  "alt": "4.0",
                  "aonid": 1,
                  "game-obj": "Sources",
                  "name": "4.0",
                  "type": "link"
                },
                "link": {
                  "alt": "Core Rulebook pg. 633",
                  "aonid": 1,
                  "game-obj": "Sources",
                  "name": "Core Rulebook pg. 633",
                  "type": "link"
                },
                "name": "Core Rulebook",
                "page": 633,
                "type": "source"
              }
            ],
            "text": "Light effects overcome non-magical darkness in the area, and can counteract magical darkness. You must usually target darkness magic with your light magic directly to counteract the darkness, but some light spells automatically attempt to counteract darkness.",
            "type": "trait"
          },
          {
            "alternate_link": {
              "alternate_type": "remastered",
              "aonid": 676,
              "game-obj": "Traits",
              "type": "alternate_link"
            },
            "edition": "legacy",
            "game-id": "e96c6783f38a842d8fbd4231a853c319",
            "game-obj": "Traits",
            "links": [
              {
                "alt": "magical",
                "aonid": 103,
                "game-obj": "Traits",
                "name": "magical",
                "type": "link"
              }
            ],
            "name": "Primal",
            "sources": [
              {
                "errata": {
                  "alt": "4.0",
                  "aonid": 1,
                  "game-obj": "Sources",
                  "name": "4.0",
                  "type": "link"
                },
                "link": {
                  "alt": "Core Rulebook pg. 635",
                  "aonid": 1,
                  "game-obj": "Sources",
                  "name": "Core Rulebook pg. 635",
                  "type": "link"
                },
                "name": "Core Rulebook",
                "page": 635,
                "type": "source"
              }
            ],
            "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.",
            "type": "trait"
          }
        ],
