                    "type": "source"
                  }
                ],
                "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.",
                "type": "trait"
              },
              {
                "edition": "legacy",
                "game-id": "01bf3e53d6c0fc7f70419341635bfe8f",
