        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Three Actions",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "name": "Gulp or Grab",
            "subtype": "ability",
            "text": "The Azarpal swallows a single meal or alchemical food and stores it in one of six stomachs. Therein, the food doesn't spoil (drinks must be swallowed in closed containers, or they spill and affect the azarpal normally). The azarpal can use this activity to reach into its mouth and retrieve a stored item as well. Any item that remains stored in an azarpal's stomach for at least 24 hours becomes laced with azarpal poison.",
