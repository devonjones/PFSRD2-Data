    "offense": {
      "offensive_actions": [
        {
          "attack": {
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "attack_type": "melee",
            "bonus": {
              "bonuses": [
                20,
                15,
                10
              ],
              "link": {
                "alt": "+15/+10",
                "aonid": 322,
                "game-obj": "Rules",
                "name": "+15/+10",
                "type": "link"
              },
              "subtype": "attack_bonus",
              "type": "stat_block_section"
            },
            "damage": [
              {
                "damage_type": "piercing",
                "formula": "2d4+8",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "name": "Melee",
            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 175,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "131678d51da8c778d796e57057176286",
                "game-obj": "Traits",
                "name": "Disarm",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You can use this weapon to Disarm with the Athletics skill even if you don\u2019t have a free hand. This uses the weapon\u2019s reach (if different from your own) and adds the weapon\u2019s item bonus to attack rolls (if any) as an item bonus to the Athletics check. If you critically fail a check to Disarm using the weapon, you can drop the weapon to take the effects of a failure instead of a critical failure. On a critical success, you still need a free hand if you want to take the item.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 179,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a57956799f3d30121d529e48f12904c",
                "game-obj": "Traits",
                "name": "Finesse",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You can use your Dexterity modifier instead of your Strength modifier on attack rolls using this melee weapon. You still calculate damage using Strength.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 103,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "15e2d048ce93e7b648064b09972535bc",
                "game-obj": "Traits",
                "name": "Magical",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 194,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "435cbfa8d6a3da2e6b53b01082b49f7d",
                "game-obj": "Traits",
                "name": "Sweep",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "This weapon makes wide swinging attacks. When you attack with this weapon, you gain a +1 circumstance bonus to your attack roll if you already attempted to attack a different target this turn using this weapon.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 252,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "93ab405e7b3b5a2c09d54871ceacfe40",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "Interact",
                    "aonid": 2297,
                    "game-obj": "Actions",
                    "name": "Interact",
                    "type": "link"
                  },
                  {
                    "alt": "disarmed",
                    "aonid": 2383,
                    "game-obj": "Actions",
                    "name": "disarmed",
                    "type": "link"
                  }
                ],
                "name": "Tethered",
                "sources": [
                  {
                    "errata": {
                      "alt": "1.1",
                      "aonid": 227,
                      "game-obj": "Sources",
                      "name": "1.1",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core 2 pg. 274",
                      "aonid": 227,
                      "game-obj": "Sources",
                      "name": "Player Core 2 pg. 274",
                      "type": "link"
                    },
                    "name": "Player Core 2",
                    "page": 274,
                    "type": "source"
                  }
                ],
                "text": "This weapon is attached to a length of rope or chain that allows you to retrieve it after it has left your hand. If you have a free hand (including if you've just thrown a two-handed tethered weapon and have a hand holding nothing but the weapon's tether), you can use an Interact action to pull the weapon back into your grasp after you have thrown it as a ranged attack or after it has been disarmed (unless it's being held by another creature).",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 196,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "a49ec55650ed4dafa9fa0c699bfd7e42",
                "game-obj": "Traits",
                "name": "Trip",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "You can use this weapon to Trip with the Athletics skill even if you don\u2019t have a free hand. This uses the weapon\u2019s reach (if different from your own) and adds the weapon\u2019s item bonus to attack rolls as an item bonus to the Athletics check. If you critically fail a check to Trip using the weapon, you can drop the weapon to take the effects of a failure instead of a critical failure.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section",
            "weapon": "rope dart"
