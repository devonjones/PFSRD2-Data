                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "ability_type": "automatic",
                    "name": "Construct Armor",
                    "text": "Like normal objects, a painted griffon has Hardness. This Hardness reduces any damage it takes by an amount equal to the Hardness. Once a painted griffon is reduced to less than half its Hit Points, or immediately upon being damaged by a critical hit, its construct armor breaks, removing the Hardness and reducing its Armor Class to 19."
                }
            ]
