  "sections": [
    {
      "name": "Painted Landscape",
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #218: Titanbane pg. 87",
            "aonid": 274,
            "game-obj": "Sources",
            "name": "Pathfinder #218: Titanbane pg. 87",
            "type": "link"
          },
          "name": "Pathfinder #218: Titanbane",
          "page": 87,
          "type": "source"
        }
      ],
      "text": "Resembling a large mural, a painted landscape attacks by animating the very landscape it depicts: trees, castles, or even snow-capped mountains.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Pathfinder #218: Titanbane pg. 87",
