                "name": "Core Rulebook pg. 474",
                "type": "link"
              },
              "name": "Core Rulebook",
              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* 10 feet, *Reach (Tall):* 10 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 20,
            "game-obj": "Traits",
