                        "aonid": 222,
                        "alternate_type": "legacy"
                    },
                    "edition": "remastered",
                    "sources": [
                        {
                            "type": "source",
                            "name": "GM Core",
                            "link": {
                                "type": "link",
                                "name": "GM Core pg. 330",
                                "alt": "GM Core pg. 330",
                                "game-obj": "Sources",
                                "aonid": 218
                            },
                            "page": 330,
                            "errata": {
                                "type": "link",
