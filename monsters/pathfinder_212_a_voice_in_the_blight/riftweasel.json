              {
                "alt": "Demoralize",
                "aonid": 2395,
                "game-obj": "Actions",
                "name": "Demoralize",
                "type": "link"
              },
              {
                "alt": "sickened 1",
                "aonid": 91,
                "game-obj": "Conditions",
                "name": "sickened 1",
                "type": "link"
              }
            ],
            "name": "Burst from the Dead",
            "requirement": "The riftweasel is inside of a carcass",
            "subtype": "ability",
