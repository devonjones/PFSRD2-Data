              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* 10 feet, *Reach (Tall):* 10 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
