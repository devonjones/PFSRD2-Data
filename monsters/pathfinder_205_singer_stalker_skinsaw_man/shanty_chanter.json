                "type": "link"
              }
            ],
            "name": "Shanty Call",
            "range": {
              "range": 60,
              "subtype": "range",
              "text": "within 60 feet",
              "type": "stat_block_section",
              "unit": "feet"
            },
            "subtype": "ability",
            "traits": [
              {
                "alternate_link": {
