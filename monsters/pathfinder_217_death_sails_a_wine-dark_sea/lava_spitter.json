                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "The lava spitter expels a 15-foot cone of lava, dealing 5d6 fire damage to every creature within the cone (DC 20 basic Reflex save). This area becomes hazardous terrain for 1 minute. A creature takes 2 fire damage each time it moves into one of these squares. The lava spitter then can't Spew Lava for 1d4 rounds.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 72,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "974c2ceb862b6781b4ebac590bd83913",
                "game-obj": "Traits",
                "name": "Fire",
                "sources": [
                  {
                    "errata": {
