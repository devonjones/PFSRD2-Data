      "name": "Gigantic Bee Guard",
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #217: Death Sails a Wine-Dark Sea pg. 88",
            "aonid": 273,
            "game-obj": "Sources",
            "name": "Pathfinder #217: Death Sails a Wine-Dark Sea pg. 88",
            "type": "link"
          },
          "name": "Pathfinder #217: Death Sails a Wine-Dark Sea",
          "page": 88,
          "type": "source"
        }
      ],
      "text": "These specialized worker bees investigate danger, protect the hive, and attack intruders. They're particularly sensitive to the pheromones of their colony and respond quickly to threats.",
      "type": "section"
    }
  ],
