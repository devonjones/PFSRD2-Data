            "family": {
                "name": "Stygian Guardian",
                "type": "monster_family",
                "sections": [
                    {
                        "name": "Other Stygian Guardians",
                        "type": "section",
                        "text": "While keribos and eumenids are the most frequently encountered stygian guardians, they\u2019re far from the only ones. Amnerion also created multi-armed giants called thalisons to carry out jobs requiring great strength and serve as protectors of their palace, although these giants spend most of their time melded into the cavern walls. Within Bothrios, horrid half-mantis, half-scorpion creatures called scynoxthis mete out punishments to the wicked.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Pathfinder #217: Death Sails a Wine-Dark Sea",
                                "link": {
                                    "type": "link",
                                    "name": "Pathfinder #217: Death Sails a Wine-Dark Sea pg. 86",
                                    "alt": "Pathfinder #217: Death Sails a Wine-Dark Sea pg. 86",
                                    "game-obj": "Sources",
                                    "aonid": 273
                                },
                                "page": 86
                            }
                        ]
                    }
                ],
                "sources": [
                    {
                        "type": "source",
                        "name": "Pathfinder #217: Death Sails a Wine-Dark Sea",
                        "link": {
                            "type": "link",
                            "name": "Pathfinder #217: Death Sails a Wine-Dark Sea pg. 86",
                            "alt": "Pathfinder #217: Death Sails a Wine-Dark Sea pg. 86",
