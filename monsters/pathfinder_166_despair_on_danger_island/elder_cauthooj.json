              }
            ],
            "subtype": "ability",
            "success": "The target is unaffected. ",
            "text": "The cauthooj gives a strange, ululating cry that causes nearby creatures to lash out violently and without control. Each creature within 120-foot emanation that can hear the cauthooj must attempt a DC 34 Will save to resist the effect.",
            "traits": [
              {
                "alternate_link": {
