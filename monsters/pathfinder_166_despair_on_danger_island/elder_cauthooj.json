                      "name": "Core Rulebook pg. 282",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "The multiple attack penalty you take with this weapon on the second attack on your turn is \u20134 instead of \u20135, and \u20138 instead of \u201310 on the third and subsequent attacks in the turn.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 570,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "4399b21e9ad18be0621c73d34aadd240",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "rapier",
                    "aonid": 36,
                    "game-obj": "Weapons",
                    "name": "rapier",
                    "type": "link"
                  }
                ],
                "name": "Deadly",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 282",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 282",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "On a critical hit, the weapon adds a weapon damage die of the listed size. Roll this after doubling the weapon's damage. This increases to two dice if the weapon has a _greater striking rune_ and three dice if the weapon has a _major striking rune_. For instance, a rapier with a _greater striking rune_ deals 2d8 extra piercing damage on a critical hit. An ability that changes the size of the weapon's normal damage dice doesn't change the size of its deadly die.",
                "type": "trait",
                "value": "d12"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 684,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "32947e519673126a260ca0b27b0cf276",
                "game-obj": "Traits",
                "name": "Reach",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 283",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 283",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "Natural attacks with this trait can be used to attack creatures up to the listed distance away instead of only adjacent creatures. Weapons with this trait are long and can be used to attack creatures up to 10 feet away instead of only adjacent creatures. For creatures that already have reach with the limb or limbs that wield the weapon, the weapon increases their reach by 5 feet.",
                "type": "trait",
                "value": "10 feet"
              }
            ],
