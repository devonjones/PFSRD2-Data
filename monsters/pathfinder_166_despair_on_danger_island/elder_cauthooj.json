                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 634",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 634,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target's mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              },
              {
                "alternate_link": {
