            "name": "Troop Defenses",
            "sources": [
              {
                "link": {
                  "alt": "NPC Core pg. 231",
                  "aonid": 236,
                  "game-obj": "Sources",
                  "name": "NPC Core pg. 231",
                  "type": "link"
