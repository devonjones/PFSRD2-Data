  "schema_version": 1.4,
  "sections": [
    {
      "name": "Arboreal Shepherd",
      "sections": [
        {
          "image": {
            "image": "Sidebar_2_AdditionalLore.png",
            "name": "Additional Lore",
            "type": "image"
          },
          "name": "Occult Nutrients",
          "sidebar_heading": "Additional Lore",
          "sidebar_type": "additional_lore",
          "sources": [
            {
              "link": {
                "alt": "Pathfinder #201: Pactbreaker pg. 82",
                "aonid": 241,
                "game-obj": "Sources",
                "name": "Pathfinder #201: Pactbreaker pg. 82",
                "type": "link"
              },
              "name": "Pathfinder #201: Pactbreaker",
              "page": 82,
              "type": "source"
            }
          ],
          "subtype": "sidebar",
          "text": "While drawing water, nutrients, and trace primal energy from the soil, an arboreal sometimes absorbs psychic impressions that shape its growth. Taking root in haunted landscapes or abandoned fairgrounds can result in truly sinister or frolicsome arboreals.",
          "type": "section"
        }
      ],
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #201: Pactbreaker pg. 82",
            "aonid": 241,
            "game-obj": "Sources",
            "name": "Pathfinder #201: Pactbreaker pg. 82",
            "type": "link"
          },
          "name": "Pathfinder #201: Pactbreaker",
          "page": 82,
          "type": "source"
        }
      ],
      "text": "Shepherds develop an eccentric fascination with local fauna. These shepherds eagerly bear fruit to feed their friends, provide roosts for bats, and invite beasts to gnaw nesting niches directly into their trunks.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Pathfinder #201: Pactbreaker pg. 82",
        "aonid": 241,
