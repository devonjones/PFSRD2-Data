                    "page": 454,
                    "type": "source"
                  }
                ],
                "text": "An action with this trait requires a degree of mental concentration and discipline.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 104,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
                "game-obj": "Traits",
                "name": "Manipulate",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
