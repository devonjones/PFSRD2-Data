                "name": "Player Core pg. 11",
                "type": "link"
              },
              "name": "Player Core",
              "page": 11,
              "type": "source"
            }
          ],
          "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
          "type": "trait"
        },
        {
          "classes": [
            "size"
          ],
          "edition": "legacy",
          "game-id": "bb6959f434e4e1dc9ae2c02ca9015792",
          "game-obj": "Traits",
          "name": "Tiny",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Core Rulebook pg. 474",
                "href": "https://paizo.com/products/btq01y0k?Pathfinder-Core-Rulebook",
                "name": "Core Rulebook pg. 474",
                "type": "link"
              },
              "name": "Core Rulebook",
              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* Less than 5 feet, *Reach (Tall):* 0 feet, *Reach (Long):* 0 feet.  Multiple Tiny creatures can occupy the same square.  At least four can fit in a single square, though the GM might determine that even more can fit.  Tiny creatures can occupy a space larger creature as well, and if their reach is 0 feet, they must do so in order to attack.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 69,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "68e0931a4aa46e583f2efa3182902f5b",
          "game-obj": "Traits",
          "name": "Fey",
          "sources": [
