        {
          "ability": {
            "ability_type": "offensive",
            "name": "Powerful Fist",
            "subtype": "ability",
            "text": "Vinn doesn't take the normal \u20132 circumstance penalty when making a lethal attack with his unarmed attacks.",
            "type": "stat_block_section"
          },
          "name": "Powerful Fist",
          "offensive_action_type": "ability",
