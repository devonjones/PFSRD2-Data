            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 147,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "062d349c50c70477d316b8620025454e",
                "game-obj": "Traits",
                "name": "Sonic",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 461",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 461",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 461,
                    "type": "source"
                  }
                ],
                "text": "An effect with the sonic trait functions only if it makes sound, meaning it has no effect in an area of silence or in a vacuum. This is different from an auditory spell, which is effective only if the target can hear it. A sonic effect might deal sonic damage.",
                "type": "trait"
              },
              {
                "edition": "legacy",
                "game-id": "104d6fc2d1d7f97108e1e9b4be5089b1",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "range increments",
                    "aonid": 227,
                    "game-obj": "Rules",
