            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 149",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 149",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 149,
          "type": "source"
        }
      ],
      "text": "A single bite from this creature's signature fangs can cause death by blood loss within minutes; what's worse, the giant fangtooth is willing to attack creatures far larger than itself.",
      "type": "section"
    }
  ],
