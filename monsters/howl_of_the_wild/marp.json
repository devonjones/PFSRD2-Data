            "critical_failure": "As failure, but 40 gp",
            "critical_success": "The target can refuse the request, though they can also choose to willingly hand over any amount of gold. If they do so, they gain a +1 status bonus to the next saving throw they attempt within 1 minute, and they're temporarily immune to Scampering Theft for 1 minute.",
            "failure": "The target must drop coins, gold jewelry, or other objects worth 20 gp.",
            "name": "Gold?",
            "saving_throw": [
              {
                "dc": 22,
                "save_type": "Will",
                "subtype": "save_dc",
                "text": "DC 22 Will save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "success": "The target can refuse the request.",
            "text": "The marp asks for gold from all creatures in a 30-foot emanation. Each target must attempt a DC 22 Will save or retrieve and drop gold valuables as a free action.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 60,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "fb5f8b3d849b073e1514a6a025810470",
                "game-obj": "Traits",
                "name": "Emotion",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 455",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 455",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 455,
                    "type": "source"
                  }
                ],
                "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 101,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
                "game-obj": "Traits",
                "name": "Linguistic",
                "sources": [
                  {
