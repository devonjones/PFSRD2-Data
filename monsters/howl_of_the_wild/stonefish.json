  "sections": [
    {
      "name": "Stonefish",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 148",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 148",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 148,
          "type": "source"
        }
      ],
      "text": "Stonefish use their superior camouflage to lie in wait and devour small prey, becoming indistinguishable from the reefs they call home. Larger creatures are also at risk, although mostly through accidental contact with the stonefish's spines and their agonizing venom.",
      "type": "section"
    }
  ],
