  "schema_version": 1.4,
  "sections": [
    {
      "name": "Titanosaur",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 138",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 138",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 138,
          "type": "source"
        }
      ],
      "text": "Titanosaurs are some of the largest land animals ever to walk the surface of Golarion, massive sauropods that can reach over 100 feet in length and weigh more than 80 tons. While typically content to focus on consuming vast quantities of vegetation and ignore the presence of smaller creatures, titanosaurs that feel threatened can unleash destruction rivaling natural disasters.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
