                },
                "game-id": "24190e6414a71e17d8ee078ed9cec4a3",
                "text": "Sharks of all shapes and sizes have stalked the oceans, largely unchanged, since primordial times. They are efficient, ruthless predators with multiple rows of razor-sharp teeth capable of rending prey in an instant. Their uncanny ability to smell blood in the water means sharks might show up at any scene of aquatic carnage.",
                "edition": "remastered",
                "link": {
                    "type": "link",
                    "name": "Shark",
                    "alt": "Shark",
                    "game-obj": "MonsterFamilies",
                    "aonid": 470
                }
