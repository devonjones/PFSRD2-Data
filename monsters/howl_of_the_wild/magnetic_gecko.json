          {
            "alt": "electricity",
            "aonid": 586,
            "game-obj": "Traits",
            "name": "electricity",
            "type": "link"
          }
        ],
        "name": "Greater Electrolocation",
        "range": {
          "range": 20,
          "subtype": "range",
          "text": "range of 20 feet",
          "type": "stat_block_section",
          "unit": "feet"
        },
        "subtype": "ability",
        "text": "A magnetic gecko can sense minute electrical charges in living creatures, which it can use as a precise sense at a range of 20 feet. This distance increases to 100 feet against any creature that has used an electricity effect within the last minute.",
        "type": "stat_block_section"
      },
      {
        "ability_type": "interaction",
        "links": [
          {
            "alt": "Athletics",
            "aonid": 36,
            "game-obj": "Skills",
            "name": "Athletics",
            "type": "link"
          },
          {
            "alt": "Climb",
            "aonid": 2374,
            "game-obj": "Actions",
            "name": "Climb",
            "type": "link"
          }
        ],
        "name": "Uncanny Climber",
        "subtype": "ability",
        "text": "A magnetic gecko's feet allow it to climb virtually any surface, no matter how slick or sheer. If a gecko attempts an Athletics check to Climb and critically fails, it gets a failure instead.",
        "type": "stat_block_section"
      }
    ],
