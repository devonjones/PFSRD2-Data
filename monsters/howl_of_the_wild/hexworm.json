                "type": "link"
              }
            ],
            "name": "Arcane Consumption",
            "subtype": "ability",
            "text": "The hexworm attempts to consume the magic of an adjacent magical effect or unattended magic item. It attempts a counteract check against the target with a +11 modifier. On a success, the magical effect ends. A magic item instead becomes a mundane item for 1 round. The hexworm gains 2d8 Hit Points.",
            "type": "stat_block_section"
          },
          "name": "Arcane Consumption",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Free Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "effect": "The hexworm Strides up to its Speed toward the nearest source of magic it can detect.",
            "name": "Arcanotaxis",
            "requirement": "The hexworm has detected a source of magic with its arcanosense",
            "subtype": "ability",
            "trigger": "The hexworm's turn begins",
            "type": "stat_block_section"
          },
