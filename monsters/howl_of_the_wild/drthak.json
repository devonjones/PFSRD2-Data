  "sections": [
    {
      "name": "Drthak",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 140",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 140",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 140,
          "type": "source"
        }
      ],
      "text": "Drthaks are aquatic predators with long trailing fins that are rarely seen, clinging to coasts and estuaries where the high silt content makes them practically invisible to predators and prey alike. Some have been known to come inland, tracking their prey miles upriver before striking. The underwater environment alters the typical dischoran hunting behavior, with drthaks creating bubbles that implode to stun prey.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
