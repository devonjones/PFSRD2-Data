  "schema_version": 1.4,
  "sections": [
    {
      "name": "Majungasaurus",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 137",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 137",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 137,
          "type": "source"
        }
      ],
      "text": "The majungasaurus prowls in a crouched posture, carrying its bulk so low to the ground it is eye-to-eye with its prey. Unlike most carnivorous dinosaurs, the majungasaurus is primarily an ambush predator, patiently lying in wait for quarry to come within reach before bursting from cover with a signature cry to attack.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "2.1",
