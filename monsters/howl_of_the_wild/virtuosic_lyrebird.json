            "aonid": 20,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "28f1c378d01673d4b58ae0b8c7d35631",
          "game-obj": "Traits",
          "name": "Beast",
          "sources": [
            {
