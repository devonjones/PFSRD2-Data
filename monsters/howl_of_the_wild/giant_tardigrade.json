          "text": "*Space:* 15 feet, *Reach (Tall):* 15 feet, *Reach (Long):* 10 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 207,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
