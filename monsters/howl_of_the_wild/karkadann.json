  "sections": [
    {
      "name": "Karkadann",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 190",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 190",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 190,
          "type": "source"
        }
      ],
      "text": "Karkadanns are a distant relation to unicorns, favoring more open terrain than their woodland kin. With the build of a buffalo, karkadanns have gray, scaly bodies, thicker hooves, and no mane. Despite their territoriality and harsh temperament, many karkadanns can be befriended by those who truly hold respect for nature in their hearts.",
      "type": "section"
    }
  ],
