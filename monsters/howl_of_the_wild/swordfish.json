  "sections": [
    {
      "name": "Swordfish",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 149",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 149",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 149,
          "type": "source"
        }
      ],
      "text": "Contrary to popular belief, the bill of the swordfish is not used for impaling its prey, but to stun or slash. Specialized organs help keep it warm in the coldest waters, increasing its already considerable speed and reflexes.",
      "type": "section"
    }
  ],
