    {
      "name": "Swift Guide",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 183",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 183",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 183,
          "type": "source"
        }
      ],
      "text": "Swift guides are often among the first spirit guides to respond to threats, and they're said to move with such incredible speed that it's impossible to tell whether they're one or many until the battle is resolved.",
      "type": "section"
    }
  ],
