  "sections": [
    {
      "name": "Goblin Shark",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 179",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 179",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 179,
          "type": "source"
        }
      ],
      "text": "Goblin sharks are deep-sea hunters, dwelling near the ocean floor. They make up for their slow swimming speed with stealthy ambushes, allowing prey to get within reach before lashing out with their extending jaws.",
      "type": "section"
    }
  ],
  "sources": [
