  "sections": [
    {
      "name": "Lightning Turtle",
      "sources": [
        {
          "errata": {
            "alt": "2.1",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "2.1",
            "type": "link"
          },
          "link": {
            "alt": "Howl of the Wild pg. 153",
            "aonid": 226,
            "game-obj": "Sources",
            "name": "Howl of the Wild pg. 153",
            "type": "link"
          },
          "name": "Howl of the Wild",
          "page": 153,
          "type": "source"
        }
      ],
      "text": "Lightning turtles have a reputation as kind protectors of those lost or injured at sea. Their unique ability to promote healing by stimulating the body's natural bioelectricity has led to many attempts over the year to domesticate the creatures, but none have been successful.",
      "type": "section"
    }
  ],
