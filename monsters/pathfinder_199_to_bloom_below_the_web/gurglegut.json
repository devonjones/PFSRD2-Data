        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "effect": "Gurglegut barks out a command to a single onidoshi in area D1. That onidoshi can use a reaction to attempt a melee Strike against an adjacent foe.",
            "frequency": "once per round",
            "name": "Command Onidoshi",
            "subtype": "ability",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 541,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "7d678190de7a644e0a6b04dbf091b032",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "sonic",
                    "aonid": 147,
                    "game-obj": "Traits",
                    "name": "sonic",
                    "type": "link"
                  },
                  {
                    "alt": "deaf",
                    "aonid": 8,
                    "game-obj": "Conditions",
                    "name": "deaf",
                    "type": "link"
                  }
                ],
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 629",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 629",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 629,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can't hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 642,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "6edda404b944cad315573cc3d5d011c6",
                "game-obj": "Traits",
                "name": "Linguistic",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 633",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 633",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 633,
                    "type": "source"
                  }
                ],
                "text": "An effect with this trait depends on language comprehension. A linguistic effect that targets a creature works only if the target understands the language you are using.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
          "name": "Command Onidoshi",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
