            ],
            "effect": "The Oaksteward's hands transform into wild claws for 1 minute. The Oaksteward gains the following Strike.  \n Melee [#] claw +7 (agile, finesse), Damage 1d6+2 slashing",
            "frequency": "once per day",
            "name": "Wild Shape",
            "subtype": "ability",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 657,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "66440f274ec71243e3ffd3572646d43e",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "counteract",
