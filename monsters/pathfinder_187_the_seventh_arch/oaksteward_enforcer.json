                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "The multiple attack penalty you take with this weapon on the second attack on your turn is \u20134 instead of \u20135, and \u20138 instead of \u201310 on the third and subsequent attacks in the turn.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 602,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "9205dbb5fc7a16fe38ebed77c30d1a29",
                "game-obj": "Traits",
                "name": "Finesse",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 282",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 282",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You can use your Dexterity modifier instead of your Strength modifier on attack rolls using this melee weapon. You still use your Strength modifier when calculating damage.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 711,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "6babc6b6f8a46e05d54c2f58fd24db30",
                "game-obj": "Traits",
                "name": "Thrown",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 283",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 283",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "You can throw this weapon as a ranged attack, and it is a ranged weapon when thrown. A thrown weapon adds your Strength modifier to damage just like a melee weapon does. When this trait appears on a melee weapon, it also includes the range increment. Ranged weapons with this trait use the range increment specified in the weapon\u2019s Range entry.",
                "type": "trait",
                "value": "10 feet"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 724,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "legacy",
                "game-id": "8a67f6d106646aef38a1ba89b9f50d14",
                "game-obj": "Traits",
                "name": "Versatile",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 283",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 283",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "A versatile weapon can be used to deal a different type of damage than that listed in the Damage entry. This trait indicates the alternate damage type. For instance, a piercing weapon that is versatile S can be used to deal piercing or slashing damage. You choose the damage type each time you make an attack.",
                "type": "trait",
                "value": "S"
              }
            ],
