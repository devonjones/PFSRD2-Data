                    "game-obj": "Traits",
                    "name": "magical",
                    "type": "link"
                  }
                ],
                "name": "Primal",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 635",
