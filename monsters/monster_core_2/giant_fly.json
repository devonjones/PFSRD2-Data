{
    "name": "Giant Fly",
    "type": "creature",
    "sections": [
        {
            "name": "Giant Fly",
            "type": "section",
            "text": "This massive fly's twitching limbs seem to never stop moving as it constantly cleans itself and scoops anything edible into its mouthparts. While primarily carrion eaters, giant flies sometimes prey on livestock or other animals too slow to get away. They are not particularly dangerous, and are mostly reviled due to their obnoxious droning and habit of spreading disease.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 157",
                        "alt": "Monster Core 2 pg. 157",
                        "game-obj": "Sources",
                        "aonid": 276
                    },
                    "page": 157
                }
            ]
        }
    ],
