          "game-id": "978beb291b7b1c2b3bd65e46fa769e12",
          "game-obj": "Traits",
          "name": "Aquatic",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
