  "schema_version": 1.4,
  "sections": [
    {
      "name": "Trilobite Swarm",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 326",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 326",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 326,
          "type": "source"
        }
      ],
      "text": "Trilobites typically live in close proximity to others of their kind. On rare occasions, particularly when the most common prey around is larger than what a single trilobite can take down, they form swarms that seem to actively cooperate with each other. These swarms latch onto their prey, and the combined efforts of so many trilobites at once make escape difficult.",
      "type": "section"
    }
  ],
  "sources": [
