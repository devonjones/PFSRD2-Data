  "schema_version": 1.4,
  "sections": [
    {
      "name": "Giant Chameleon",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 216",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 216",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 216,
          "type": "source"
        }
      ],
      "text": "Giant chameleons are legendary for their ability to change their skin color in response to their surroundings. Their eyes are capable of peering in different directions independently, making them almost as difficult to sneak up on as they are to notice in the first place.",
      "type": "section"
    }
  ],
  "sources": [
    {
