            },
            {
              "alt": "manipulate",
              "aonid": 645,
              "game-obj": "Traits",
              "name": "manipulate",
              "type": "link"
            },
            {
              "alt": "Athletics",
              "aonid": 36,
              "game-obj": "Skills",
              "name": "Athletics",
              "type": "link"
            }
          ],
          "name": "If a kappa is",
          "subtype": "ability",
          "text": "grappled, restrained, or stunned, another creature can attempt to spill the water from their bowl by spending a single action, which has the attack and manipulate traits, to attempt an Athletics check against the kappa's Fortitude DC. On a success, the creature spills the kappa's water.",
          "type": "stat_block_section"
        }
