{
    "name": "Giant Maggot",
    "type": "creature",
    "sections": [
        {
            "name": "Giant Maggot",
            "type": "section",
            "text": "Giant flies lay their eggs on the bodies of larger monsters or livestock. When they hatch, these eggs release squirming maggots the size of humans, ravenous young who voraciously consume any flesh in the immediate vicinity\u2014typically starting with the body upon which they were born.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 157",
                        "alt": "Monster Core 2 pg. 157",
