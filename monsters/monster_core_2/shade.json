      "name": "Shade",
      "sections": [
        {
          "image": {
            "image": "Sidebar_2_AdditionalLore.png",
            "name": "Additional Lore",
            "type": "image"
          },
          "links": [
            {
              "alt": "First World",
              "aonid": 35,
              "game-obj": "Planes",
              "name": "First World",
              "type": "link"
            },
            {
              "alt": "fey",
              "aonid": 599,
