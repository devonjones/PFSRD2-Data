  "name": "Animated Silverware Swarm",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Animated Silverware Swarm",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 32",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 32",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 32,
          "type": "source"
        }
      ],
      "text": "Nobles are known to pay great amounts to animate their silverware, both for ease in cleaning and to serve as novelties during dinner parties.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
