              "name": "Monster Core",
              "page": 363,
              "type": "source"
            }
          ],
          "text": "Trolls are giant, brutish creatures and are well known for transforming into inanimate materials.",
          "type": "trait"
        },
        {
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "7c548a9e0a2647c082989720b3de0a87",
          "game-obj": "Traits",
          "name": "Wood",
          "sources": [
