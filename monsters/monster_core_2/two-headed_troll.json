                "type": "link"
              },
              "name": "Player Core",
              "page": 456,
              "type": "source"
            }
          ],
          "text": "Giants are massive humanoid creatures.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
