{
    "name": "Ogre Spider",
    "type": "creature",
    "sections": [
        {
            "name": "Ogre Spider",
            "type": "section",
            "text": "These terrifying creatures grow as large as elephants. The placement of their eyes above their wide mandibles evokes the grimacing visage of an ogre's leer. Ogres find ogre spider faces simultaneously amusing and adorable, but in most cases, ogres' attempts to keep these spiders as pets result in dead ogres and well-fed spiders.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 302",
                        "alt": "Monster Core 2 pg. 302",
                        "game-obj": "Sources",
                        "aonid": 276
                    },
                    "page": 302
                }
            ]
        }
    ],
