{
    "name": "Giant Leech",
    "type": "creature",
    "sections": [
        {
            "name": "Giant Leech",
            "type": "section",
            "text": "Capable of growing to lengths of nearly 5 feet, giant leeches have circular maws filled with hook-like teeth. They prefer to dwell in stagnant or slowmoving shallow water or in damp, moist undergrowth. Horses and larger animals are their favorite prey, but they won't balk at a chance to latch onto a human- or halfling-sized meal.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 212",
                        "alt": "Monster Core 2 pg. 212",
                        "game-obj": "Sources",
                        "aonid": 276
                    },
                    "page": 212
                }
            ],
            "links": [
