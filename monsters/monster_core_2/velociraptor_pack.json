              "page": 452,
              "type": "source"
            }
          ],
          "text": "An animal is a creature with a relatively low intelligence. It typically doesn\u2019t have an Intelligence attribute modifier over \u20134, can\u2019t speak languages, and can\u2019t be trained in Intelligence-based skills.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 45,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "b9b19eb20658dddf3015914e684dd8ce",
          "game-obj": "Traits",
          "name": "Dinosaur",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
