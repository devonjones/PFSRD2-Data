              "name": "Player Core",
              "page": 455,
              "type": "source"
            }
          ],
          "text": "These reptiles have survived from prehistoric times.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 367,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
