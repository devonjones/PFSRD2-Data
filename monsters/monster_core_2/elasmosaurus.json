                        "links": [
                            {
                                "type": "link",
                                "name": "Swims",
                                "alt": "Swims",
                                "game-obj": "Actions",
                                "aonid": 2381
                            }
                        ],
                        "text": "A swimming elasmosaurus thrashes the area around it as it attempts to flee. It makes two paddle Strikes, each of which must be against separate targets, and each of which takes the normal multiple attack penalty. It then Swims up to its swim Speed. This Swim does not trigger reactions based on movement."
                    }
                },
                {
                    "name": "Other Aquatic Reptiles",
                    "type": "stat_block_section",
                    "subtype": "offensive_action",
                    "offensive_action_type": "ability",
                    "ability": {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "ability_type": "offensive",
                        "name": "Other Aquatic Reptiles",
                        "text": "The elasmosaurus is but one of many types of aquatic reptiles found in primeval oceans or lost worlds. Some, like the ichthyosaurus, are almost fishlike in appearance. Others, such as the mosasaurus, are truly massive beasts capable of killing and eating whales."
                    }
                }
