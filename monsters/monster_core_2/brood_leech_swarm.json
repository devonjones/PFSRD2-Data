  "schema_version": 1.4,
  "sections": [
    {
      "name": "Brood Leech Swarm",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 212",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 212",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 212,
          "type": "source"
        }
      ],
      "text": "Most smaller species of leeches don't tend to swarm, but brood leeches are prone to gathering in seething, undulant masses of squirming gluttony. When they collect in sufficient numbers to swarm, they eschew the stealth of a lone leech's feeding methods in favor of swift and merciless feeding. In these situations, their mild venom can affect much larger creatures than their usual prey.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Monster Core 2 pg. 212",
        "aonid": 276,
        "game-obj": "Sources",
        "name": "Monster Core 2 pg. 212",
        "type": "link"
      },
      "name": "Monster Core 2",
      "page": 212,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
