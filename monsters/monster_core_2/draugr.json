          ],
          "subtype": "ability",
          "text": "A creature that slays a draugr is subjected to a mariner's curse spell with a DC of 17. The curse ends if the draugr is buried in a calm sea or after 1 week passes.",
          "traits": [
            {
              "alternate_link": {
