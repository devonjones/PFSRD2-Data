          ],
          "name": "Easy to Influence",
          "subtype": "ability",
          "text": "Any mental spell can affect a carbuncle, regardless of creature type limitations. Against a *suggestion* spell, a carbuncle always gets an outcome one degree of success worse than it rolled on its saving throw.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "The carbuncle feigns death by teleporting away and leaving a replica of its corpse behind, creating a colorful flash of light and a croaking sound. The real carbuncle transports to a clear space within 30 feet that it can see and leaves a hollow shell behind. The fake body appears solid until it is touched, at which point it crumbles to dust.",
          "name": "Fatal Faker",
          "range": {
            "range": 30,
            "subtype": "range",
            "text": "within 30 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 11,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a30ff50ed821ab5b9699b2f3d68c0d6",
              "game-obj": "Traits",
              "name": "Arcane",
              "sources": [
                {
