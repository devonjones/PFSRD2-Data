      "name": "Tikbalang",
      "sections": [
        {
          "image": {
            "image": "Sidebar_5_TreasureAndRewards.png",
            "name": "Treasure and Rewards",
            "type": "image"
          },
          "links": [
            {
              "alt": "Grabs",
              "aonid": 45,
              "game-obj": "MonsterAbilities",
              "name": "Grabs",
              "type": "link"
            },
            {
              "alt": "Seek",
