              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "links": [
              {
                "alt": "persistent cold damage",
                "aonid": 86,
                "game-obj": "Conditions",
                "name": "persistent cold damage",
                "type": "link"
              },
              {
                "alt": "light blindness",
