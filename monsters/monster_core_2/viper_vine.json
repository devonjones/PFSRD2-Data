  "sections": [
    {
      "name": "Viper Vine",
      "sections": [
        {
          "image": {
            "image": "Sidebar_5_TreasureAndRewards.png",
            "name": "Treasure and Rewards",
            "type": "image"
          },
          "links": [
            {
              "alt": "Crafting",
              "aonid": 37,
