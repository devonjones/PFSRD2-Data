              "text": "within 60 feet",
              "type": "stat_block_section",
              "unit": "feet"
            },
            "saving_throw": [
              {
                "dc": 23,
                "save_type": "Will",
                "subtype": "save_dc",
                "text": "DC 23 Will",
                "type": "stat_block_section"
