  "sections": [
    {
      "name": "Spear Frog",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 158",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 158",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 158,
          "type": "source"
        }
      ],
      "text": "The spear frog is named for its toxin, which is traditionally used to envenom thrown projectiles like spears and daggers.",
      "type": "section"
    }
  ],
