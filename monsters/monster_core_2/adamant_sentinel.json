              },
              "name": "Core Rulebook",
              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* 15 feet, *Reach (Tall):* 15 feet, *Reach (Long):* 10 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
