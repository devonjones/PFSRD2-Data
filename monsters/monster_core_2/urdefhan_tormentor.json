        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Two Actions",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "effect": "The urdefhan lets out a battle cry, sending themself and their allies into a fanatical frenzy. The tormentor and each ally that hears the call gains a +1 status bonus to attack rolls, damage rolls, and saving throws, and takes a \u20131 status penalty to AC. Affected creatures must use at least one of their actions to Strike each round, if they're able (even if it means attacking an ally, object, or thin air). This lasts for 2d4 rounds.",
            "frequency": "once per day",
            "name": "Stoke the Fervent",
            "subtype": "ability",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 48,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
                "game-obj": "Traits",
                "name": "Divine",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 455",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 455",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 455,
                    "type": "source"
                  }
                ],
                "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 60,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "fb5f8b3d849b073e1514a6a025810470",
                "game-obj": "Traits",
                "name": "Emotion",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 455",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 455",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 455,
                    "type": "source"
                  }
                ],
                "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 106,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "game-obj": "Traits",
                "name": "Mental",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
          "name": "Stoke the Fervent",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "effect": "The urdefhan maintains contact, turning the creature's flesh translucent around the site of the injury. The target must succeed at a DC 22 Fortitude save or be affected by drain blood or drain vitality (the urdefhan's choice). If the jaws Strike was a critical hit, the creature is affected by both effects, using the same save result for both. \n* **Drain Blood** The urdefhan drinks some of the creature's blood. On a failed save, the creature is drained 1 and the urdefhan regains 5 HP (or, on a critical failure, it's drained 2 and the urdefhan regains 10 HP).\n* **Drain Vitality** The urdefhan draws out some of the creature's vital essence. The creature becomes enfeebled 1 for 1 hour on a failed save (or enfeebled 2 for 1 hour on a critical failure).",
            "links": [
              {
                "alt": "drained",
                "aonid": 68,
                "game-obj": "Conditions",
                "name": "drained",
                "type": "link"
              },
              {
                "alt": "enfeebled",
                "aonid": 71,
                "game-obj": "Conditions",
                "name": "enfeebled",
                "type": "link"
              }
            ],
            "name": "Wicked Bite",
            "requirement": "The urdefhan damaged a creature with a jaws Strike on their last action",
            "saving_throw": [
              {
                "dc": 22,
                "save_type": "Fort",
                "subtype": "save_dc",
                "text": "DC 22 Fortitude save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "type": "stat_block_section"
          },
          "name": "Wicked Bite",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        }
