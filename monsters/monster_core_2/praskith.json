      "name": "Praskith",
      "sections": [
        {
          "image": {
            "image": "Sidebar_5_TreasureAndRewards.png",
            "name": "Treasure and Rewards",
            "type": "image"
          },
          "links": [
            {
              "alt": "Alchemical Crafting",
              "aonid": 5117,
              "game-obj": "Feats",
              "name": "Alchemical Crafting",
              "type": "link"
