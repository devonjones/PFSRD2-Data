                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 200,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "ca5b7a642aef726cc9055981ca84f89d",
                "game-obj": "Traits",
                "name": "Versatile",
