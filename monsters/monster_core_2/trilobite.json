              },
              "link": {
                "alt": "Core Rulebook pg. 474",
                "href": "https://paizo.com/products/btq01y0k?Pathfinder-Core-Rulebook",
                "name": "Core Rulebook pg. 474",
                "type": "link"
              },
              "name": "Core Rulebook",
              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* Less than 5 feet, *Reach (Tall):* 0 feet, *Reach (Long):* 0 feet.  Multiple Tiny creatures can occupy the same square.  At least four can fit in a single square, though the GM might determine that even more can fit.  Tiny creatures can occupy a space larger creature as well, and if their reach is 0 feet, they must do so in order to attack.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 9,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "24a5a0d7db8088ac55fd5dc902b7ad1c",
          "game-obj": "Traits",
          "name": "Animal",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "An animal is a creature with a relatively low intelligence. It typically doesn\u2019t have an Intelligence attribute modifier over \u20134, can\u2019t speak languages, and can\u2019t be trained in Intelligence-based skills.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 168,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "978beb291b7b1c2b3bd65e46fa769e12",
          "game-obj": "Traits",
          "name": "Aquatic",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "Aquatic creatures are at home underwater. Their bludgeoning and slashing unarmed Strikes don\u2019t take the usual \u20132 penalty for being underwater. Aquatic creatures can breathe water but not air.",
          "type": "trait"
        }
      ],
