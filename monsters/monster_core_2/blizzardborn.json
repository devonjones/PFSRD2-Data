  "name": "Blizzardborn",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Blizzardborn",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 151",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 151",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 151,
          "type": "source"
        }
      ],
      "text": "Freezing and thawing in a near-constant loop, blizzardborn resemble humanoid forms composed of a mixture of partially melted snow and sleet. These elementals move with crunching strides, their bodies constantly sloshing and sloughing off shards of ice. Because of their ability to refreeze, blizzardborn can travel into warmer environments safely, though they tend to look more like slush in these areas.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
