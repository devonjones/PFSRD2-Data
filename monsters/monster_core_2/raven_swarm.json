            "offensive_actions": [
                {
                    "name": "Enraged Cunning",
                    "type": "stat_block_section",
                    "subtype": "offensive_action",
                    "offensive_action_type": "ability",
                    "ability": {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "ability_type": "offensive",
                        "name": "Enraged Cunning",
                        "links": [
                            {
                                "type": "link",
                                "name": "Thievery",
                                "alt": "Thievery",
                                "game-obj": "Skills",
                                "aonid": 50
                            }
                        ],
                        "text": "There are few things as dangerously persistent in the natural world as an angry unkindness of ravens. A raven swarm can hound its prey through most barriers. Simple latches, unsecured chimney flues, loosely shuttered windows, and similar obstacles rarely keep an unkindness away. A raven swarm attempts a Thievery check to bypass many of these simple obstructions, typically against DC 20."
                    }
                },
                {
                    "name": "Swarming Beaks",
                    "type": "stat_block_section",
                    "subtype": "offensive_action",
                    "offensive_action_type": "ability",
                    "ability": {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "ability_type": "offensive",
                        "name": "Swarming Beaks",
                        "action_type": {
                            "type": "stat_block_section",
                            "subtype": "action_type",
                            "name": "One Action"
                        },
                        "links": [
                            {
                                "type": "link",
                                "name": "basic",
                                "alt": "basic",
                                "game-obj": "Rules",
                                "aonid": 2297
                            },
                            {
                                "type": "link",
                                "name": "blinded",
                                "alt": "blinded",
                                "game-obj": "Conditions",
                                "aonid": 59
                            }
                        ],
                        "text": "The ravens' angry pecking deals 2d8 piercing damage to each enemy in the swarm's space (DC 20 basic Reflex save). A creature that critically fails its save is blinded for 1d4 rounds as the ravens focus their attacks on the target's vulnerable face.",
