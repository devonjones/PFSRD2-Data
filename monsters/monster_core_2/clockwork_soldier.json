  "sections": [
    {
      "name": "Clockwork Soldier",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 71",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 71",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 71,
          "type": "source"
        }
      ],
      "text": "These diligent machines guard their assigned posts tirelessly. A typical clockwork soldier stands 6 feet tall and consists of 500 pounds of metal and magic.",
      "type": "section"
    }
  ],
