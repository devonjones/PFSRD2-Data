  "name": "Attic Whisperer",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Attic Whisperer",
      "sections": [
        {
          "image": {
            "image": "Sidebar_2_AdditionalLore.png",
            "name": "Additional Lore",
            "type": "image"
          },
          "name": "Varisian Nursery Rhyme",
          "sidebar_heading": "Additional Lore",
          "sidebar_type": "additional_lore",
          "sources": [
            {
              "link": {
                "alt": "Monster Core 2 pg. 47",
                "aonid": 276,
                "game-obj": "Sources",
                "name": "Monster Core 2 pg. 47",
                "type": "link"
              },
              "name": "Monster Core 2",
              "page": 47,
              "type": "source"
            }
          ],
          "subtype": "sidebar",
          "text": "*Is the attic whispering?  \n Are we safe below?  \n Do you think he's listening?  \n Is that his shadow?  \n  \n Do you hear him waking,  \n Up above the stairs?  \n Do you hear him weeping?  \n Is he really there?  \n  \n Can you say \u201cI'm speaking?\u201d  \n Are you saying naught?  \n Is it you who's weeping?  \n Is it you he's caught?*",
          "type": "section"
        }
      ],
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 47",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 47",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 47,
          "type": "source"
        }
      ],
      "text": "Beware the haunting sobs of the attic whisperer, for they carry the pained wrath of an abandoned child who perished due to the neglect or absence of their caretakers. Animated by loneliness, the embittered spirit binds itself to the material world in a body made of bits and oddments of a lost childhood. To give themselves the semblance of a head, they top their patchwork bodies with a small animal's skull.  \n  \n Attic whisperers most frequently lurk in old infirmaries, orphanages, and other such institutions where children were forgotten, and they lay dormant for decades in hopes they might one day find a playmate to ease their eternal loneliness. When they sense the living, attic whisperers attempt to lure them into their clutches by calling out to them using the voice of a small child. Though attic whisperers intend only to play with those they encounter, they drain the breath and voice from living creatures as their worst impulses take over.",
      "type": "section"
    }
  ],
  "sources": [
    {
