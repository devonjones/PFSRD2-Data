            "family": {
                "name": "Goblin Snake",
                "type": "monster_family",
                "sections": [
                    {
                        "name": "Indolent Overlords",
                        "type": "section",
                        "text": "The exact nature of the relationship between goblins and goblin snakes is a matter of some contention, with some goblins viewing the creatures as minor demigods or the ascended souls of fallen heroes, and others viewing them as abominations to be destroyed on sight. A goblin snake fortunate enough to find a goblin community of the former sort usually treats its adoring followers as inferiors, if not outright servants, and expects them to ply it with regular offerings of food and valuables.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Monster Core 2",
                                "link": {
                                    "type": "link",
                                    "name": "Monster Core 2 pg. 168",
                                    "alt": "Monster Core 2 pg. 168",
                                    "game-obj": "Sources",
                                    "aonid": 276
                                },
                                "page": 168
                            }
                        ],
                        "links": [
                            {
