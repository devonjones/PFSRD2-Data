  "sections": [
    {
      "name": "Platecarpus",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 227",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 227",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 227,
          "type": "source"
        }
      ],
      "text": "The mid-sized platecarpuses are the most common type of mosasaur. They're typically 15 feet long, but larger specimens can grow up to 20 feet. The larger varieties sometimes eat humans and humanoids of similar size, but most stick to smaller fare.",
      "type": "section"
    }
  ],
