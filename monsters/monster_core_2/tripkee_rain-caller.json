            "family": {
                "name": "Tripkee",
                "type": "monster_family",
                "sections": [
                    {
                        "name": "A History of Neutrality",
                        "type": "section",
                        "text": "Tripkee villages rarely get involved in the conflicts of other communities despite various trade-based alliances, preferring to focus on maintaining relative peace within their own small societies. Legends explain this attitude with a tale of a tripkee champion who dragged his people into a war between humans and charau-ka. The stories differ as to which side the tripkees took, but every version ends with the bloody deaths of the hero and his family. Since that time, village elders claim, tripkees have done their best to remain far from the conflicts of others.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "NPC Core",
                                "link": {
                                    "type": "link",
                                    "name": "NPC Core pg. 214",
                                    "alt": "NPC Core pg. 214",
                                    "game-obj": "Sources",
                                    "aonid": 236
                                },
                                "page": 214
                            }
                        ]
                    }
                ],
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "MonsterFamilies",
                    "aonid": 110,
                    "alternate_type": "legacy"
                },
                "sources": [
                    {
                        "type": "source",
                        "name": "NPC Core",
                        "link": {
                            "type": "link",
                            "name": "NPC Core pg. 214",
