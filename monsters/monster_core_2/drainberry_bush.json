              {
                "alt": "grabbed",
                "aonid": 77,
                "game-obj": "Conditions",
                "name": "grabbed",
                "type": "link"
              },
              {
                "alt": "drained",
                "aonid": 68,
                "game-obj": "Conditions",
                "name": "drained",
                "type": "link"
              }
            ],
            "name": "Drain Blood",
            "requirement": "The drainberry bush has at least one living creature grabbed with one of its vines",
            "saving_throw": [
              {
                "dc": 25,
                "save_type": "Fort",
                "subtype": "save_dc",
                "text": "DC 25 Fortitude save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
