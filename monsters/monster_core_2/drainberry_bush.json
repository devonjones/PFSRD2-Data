          },
          "name": "Drain Blood",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Two Actions",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "name": "Storm of Vines",
            "subtype": "ability",
            "text": "The drainberry bush makes up to four vine Strikes, each against a different target. These attacks count toward the bush's multiple attack penalty, but the multiple attack penalty doesn't increase until after the bush makes all these attacks.",
            "type": "stat_block_section"
          },
