      ],
      "name": "Deep One Hybrid",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 88",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 88",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 88,
          "type": "source"
        }
      ],
      "text": "Whether from their devout faith to Dagon or their own biological lineage, some humans display physical indicators of their connection to deep ones.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Monster Core 2 pg. 88",
