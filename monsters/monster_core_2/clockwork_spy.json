  "name": "Clockwork Spy",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "links": [
        {
          "alt": "wizards",
          "aonid": 39,
          "game-obj": "Classes",
