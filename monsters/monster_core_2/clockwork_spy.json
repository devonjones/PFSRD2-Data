    "interaction_abilities": [
      {
        "ability_type": "interaction",
        "action_type": {
          "name": "One Action",
          "subtype": "action_type",
          "type": "stat_block_section"
        },
        "name": "Record Audio  [one-action]",
        "range": {
          "range": 25,
          "subtype": "range",
          "text": "within 25 feet",
          "type": "stat_block_section",
          "unit": "feet"
        },
        "subtype": "ability",
        "text": "The clockwork spy records all sounds within 25 feet onto a small gemstone worth 1 gp embedded in its body. The clockwork spy can record up to 1 hour of sound on a single gemstone. Once it begins recording, it can't cease recording early, nor can it record onto a gemstone that already contains a recording. Some clockwork spies contain multiple gemstones to allow for a series of recordings. Since clockwork spies are not intelligent, they must be given simple commands regarding when to start recording sounds. A clockwork spy can differentiate between different kinds of creatures but not between specific individuals.",
        "type": "stat_block_section"
      },
      {
        "ability_type": "interaction",
        "links": [
          {
            "alt": "Wind-Up",
            "aonid": 575,
            "game-obj": "MonsterFamilies",
            "name": "Wind-Up",
            "type": "link"
          },
          {
            "alt": "Thievery",
            "aonid": 50,
            "game-obj": "Skills",
            "name": "Thievery",
            "type": "link"
          },
          {
            "alt": "Disable a Device",
            "aonid": 2411,
            "game-obj": "Actions",
            "name": "Disable a Device",
            "type": "link"
          }
        ],
        "name": "Wind-Up",
        "saving_throw": [
          {
            "dc": 14,
            "subtype": "save_dc",
            "text": "DC 14",
            "type": "stat_block_section"
          }
        ],
        "subtype": "ability",
        "text": "The spy can start or stop playback of recorded sound by spending a single action. Removing a gemstone from or installing a gemstone into a clockwork spy requires a successful DC 14 Thievery check to Disable a Device; on a failure, the gemstone is undamaged, but any recorded sounds are erased and the gemstone still can't be used to make another recording. 24 hours, DC 14, standby",
        "type": "stat_block_section"
      }
    ],
