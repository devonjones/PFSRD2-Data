            "automatic_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "ability_type": "automatic",
                    "name": "Construct Armor",
                    "text": "Like normal objects, a tupilaq has Hardness. This Hardness reduces any damage it takes by an amount equal to the Hardness. Once a tupilaq is reduced to less than half its Hit Points, or immediately upon being damaged by a critical hit, its construct armor breaks, it loses its Hardness, and its Armor Class is reduced to 22."
                }
            ]
