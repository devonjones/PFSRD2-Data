  "sections": [
    {
      "name": "Earth Wisp",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 152",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 152",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 152,
          "type": "source"
        }
      ],
      "text": "Earth wisps are rolling spheres of rock, mud, and leaves, perpetually humming with low, rumbling energy. They're timid and aloof but fiercely loyal to those they know and trust.",
      "type": "section"
    }
  ],
