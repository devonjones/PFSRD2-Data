          "edition": "remastered",
          "game-id": "d3bfc0df6c75fa3d188816919a7c6bf5",
          "game-obj": "Traits",
          "name": "Amphibious",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "An amphibious creature can breathe in water and in air, even outside of its preferred environment, usually indefinitely but at least for hours. These creatures often have a swim Speed. Their bludgeoning and slashing unarmed Strikes don\u2019t take the usual \u20132 penalty for being underwater.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Humanoid creatures reason and act much like humans. They typically stand upright and have two arms and two legs.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
