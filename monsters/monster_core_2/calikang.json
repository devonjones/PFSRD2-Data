      "name": "Calikang",
      "sections": [
        {
          "image": {
            "image": "Sidebar_2_AdditionalLore.png",
            "name": "Additional Lore",
            "type": "image"
          },
          "links": [
            {
              "alt": "asuras",
              "aonid": 571,
