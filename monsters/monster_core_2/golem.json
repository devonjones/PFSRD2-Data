      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "sleep",
              "aonid": 696,
              "game-obj": "Traits",
              "name": "sleep",
              "type": "link"
            }
          ],
          "name": "Day of Rest",
          "subtype": "ability",
          "text": "A golem needs 1 day of rest per week or it becomes uncontrollable. An uncontrollable golem is unable to cast spells, and it takes a \u20132 circumstance penalty to checks made using Wisdom, including Will saves. While uncontrollable, the golem loses its immunity to sleep. The golem is uncontrollable until it takes a day of rest.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "name": "Faithful",
          "subtype": "ability",
          "text": "A golem faithfully serves its creator as long as it's not in an uncontrollable state (see above). While the golem is faithful, it follows the commands of its creator, even to its own detriment. While the golem remains faithful to its creator, the golem can't be confused or controlled by any creature other than its creator.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "encumbered",
              "aonid": 70,
              "game-obj": "Conditions",
              "name": "encumbered",
              "type": "link"
            }
          ],
          "name": "Hefty Helper",
          "subtype": "ability",
          "text": "The golem can carry 13 Bulk before becoming encumbered and can carry a maximum Bulk of 18.",
          "type": "stat_block_section"
        }
      ],
