{
    "name": "Giant Crab",
    "type": "creature",
    "sections": [
        {
            "name": "Giant Crab",
            "type": "section",
            "text": "These skittering creatures are prized for their delicious meat, but their size makes them dangerous targets for harvesting. The statistics presented here represent giant crabs that live close to the water's surface. Crabs that live deeper underwater often exhibit more extreme adaptations to their environment. For example, crabs living in the depths where little light reaches them gain darkvision and cold resistance, and those adapted to the most hostile reaches of the deep sea can detect nearby creatures through subtle shifts in ocean currents.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 77",
                        "alt": "Monster Core 2 pg. 77",
                        "game-obj": "Sources",
                        "aonid": 276
                    },
                    "page": 77
                }
            ]
        }
