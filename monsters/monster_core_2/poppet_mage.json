  "schema_version": 1.4,
  "sections": [
    {
      "name": "Poppet Mage",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 256",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 256",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 256,
          "type": "source"
        }
      ],
      "text": "With extra time, care, and patience, poppets can be woven with magic, making them talented little spellcasters.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Monster Core 2 pg. 256",
        "aonid": 276,
