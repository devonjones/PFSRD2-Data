  "sections": [
    {
      "name": "Fire Wisp",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 153",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 153",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 153,
          "type": "source"
        }
      ],
      "text": "Fire wisps are sizzling spheres of flame and ash, perpetually crackling and shimmering with heat. They're carefree, boisterous, and quick to action\u2014 sometimes recklessly so.",
      "type": "section"
    }
  ],
