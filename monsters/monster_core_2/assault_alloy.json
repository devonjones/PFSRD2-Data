          ],
          "text": "*Space:* 5 feet, *Reach (Tall):* 5 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 57,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "5d5faedc073c06d1e992a384f32591bb",
          "game-obj": "Traits",
          "name": "Elemental",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 455",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 455",
                "type": "link"
              },
              "name": "Player Core",
              "page": 455,
              "type": "source"
            }
          ],
          "text": "Elementals are creatures directly tied to an element and native to the elemental planes. Elementals don\u2019t need to breathe.",
          "type": "trait"
        },
        {
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "180279e4a2e6fa2992daac7a77cb9a69",
          "game-obj": "Traits",
          "name": "Metal",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "Effects with the metal trait conjure or manipulate metal. Those that manipulate metal have no effect in an area without metal. Creatures with this trait consist primarily of metal or have a connection to magical metal.  \n  \nThese planes consist of chaotic and shifting structures and oceans of metal. Metal planes tend to exist in a state of change and decay, leaving plentiful pockets of air for visitors to breathe or move within. Creatures unlucky enough to be entombed in the plane\u2019s substance risk suffocation if they can\u2019t phase through metal. Wood creatures find the lack of stability and soil on a metal plane disconcerting and often fail to thrive in such environments.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
    "defense": {
      "ac": {
        "subtype": "armor_class",
        "type": "stat_block_section",
        "value": 31
      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Metal Manipulation",
          "range": {
            "range": 30,
            "subtype": "range",
            "text": "30 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "subtype": "ability",
          "text": "An assault alloy has control over all unattended metal within the emanation and can use any of this metal as the origin point for their metal needle ranged Strikes.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 206,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "5315505cfd3f3ba2685e9747898193b2",
              "game-obj": "Traits",
              "name": "Aura",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item.",
              "type": "trait"
            },
            {
              "edition": "remastered",
              "game-id": "180279e4a2e6fa2992daac7a77cb9a69",
              "game-obj": "Traits",
              "name": "Metal",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "Effects with the metal trait conjure or manipulate metal. Those that manipulate metal have no effect in an area without metal. Creatures with this trait consist primarily of metal or have a connection to magical metal.  \n  \nThese planes consist of chaotic and shifting structures and oceans of metal. Metal planes tend to exist in a state of change and decay, leaving plentiful pockets of air for visitors to breathe or move within. Creatures unlucky enough to be entombed in the plane\u2019s substance risk suffocation if they can\u2019t phase through metal. Wood creatures find the lack of stability and soil on a metal plane disconcerting and often fail to thrive in such environments.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "The physical damage from the triggering weapon, spell, or effect instead restores the assault alloy's Hit Points as they seamlessly incorporate some of the metal used into their body. If already at full Hit Points, the assault alloy gains temporary Hit Points that last for 1 round instead. If a metal weapon triggers this, the weapon's die size decreases by one step to a minimum die size of d4 for 1 minute, and that weapon can't trigger Instinctive Alloy again during this time.",
          "links": [
            {
              "alt": "temporary Hit Points",
              "aonid": 2321,
              "game-obj": "Rules",
              "name": "temporary Hit Points",
              "type": "link"
            }
          ],
          "name": "Instinctive Alloy",
          "subtype": "ability",
          "trigger": "The assault alloy is hit by an attack with a metal weapon or metal spell or effect",
          "type": "stat_block_section"
        }
      ],
