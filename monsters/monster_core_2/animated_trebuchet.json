              "name": "Player Core",
              "page": 454,
              "type": "source"
            }
          ],
          "text": "A construct is an artificial creature empowered by a force other than vitality or void.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 108,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
