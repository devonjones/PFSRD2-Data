                        "name": "Camel Spit",
                        "links": [
                            {
                                "type": "link",
                                "name": "dazzled",
                                "alt": "dazzled",
                                "game-obj": "Conditions",
                                "aonid": 65
                            },
                            {
                                "type": "link",
                                "name": "sickened",
                                "alt": "sickened",
                                "game-obj": "Conditions",
                                "aonid": 91
                            }
                        ],
                        "text": "To drive away enemies, the camel spits the partially digested contents of its stomach at a creature within 10 feet. On a hit, the target is dazzled for 1 round and must succeed at a DC 17 Fortitude save or become sickened 1. The camel can't use its camel spit Strike again for 1d4 rounds."
                    }
                },
                {
                    "name": "Sand Stride",
                    "type": "stat_block_section",
                    "subtype": "offensive_action",
                    "offensive_action_type": "ability",
                    "ability": {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "ability_type": "offensive",
                        "name": "Sand Stride",
                        "action_type": {
                            "type": "stat_block_section",
                            "subtype": "action_type",
                            "name": "Two Actions"
                        },
                        "links": [
                            {
                                "type": "link",
                                "name": "Strides",
                                "alt": "Strides",
                                "game-obj": "Actions",
                                "aonid": 2305
                            }
                        ],
                        "text": "The camel Strides twice. It has a +5-foot circumstance bonus to its Speed during these Strides, ignoring difficult terrain caused by rubble, sand, and uneven ground made of earth and stone."
                    }
