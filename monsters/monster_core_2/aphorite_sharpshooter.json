                ],
                "name": "Range",
                "sources": [
                  {
                    "link": {
                      "alt": "Bestiary pg. 17",
                      "aonid": 2,
                      "game-obj": "Sources",
                      "name": "Bestiary pg. 17",
                      "type": "link"
