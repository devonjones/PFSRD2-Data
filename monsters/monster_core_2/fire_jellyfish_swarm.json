          "edition": "remastered",
          "game-id": "24a5a0d7db8088ac55fd5dc902b7ad1c",
          "game-obj": "Traits",
          "name": "Animal",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "An animal is a creature with a relatively low intelligence. It typically doesn\u2019t have an Intelligence attribute modifier over \u20134, can\u2019t speak languages, and can\u2019t be trained in Intelligence-based skills.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 168,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "978beb291b7b1c2b3bd65e46fa769e12",
          "game-obj": "Traits",
          "name": "Aquatic",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "Aquatic creatures are at home underwater. Their bludgeoning and slashing unarmed Strikes don\u2019t take the usual \u20132 penalty for being underwater. Aquatic creatures can breathe water but not air.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 108,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "1debc9c19f9ffadf57ee0ebf1bc785cb",
          "game-obj": "Traits",
          "name": "Mindless",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "A mindless creature has either programmed or rudimentary mental attributes. Most, if not all, of their mental attribute modifiers are \u20135. They are immune to all mental effects.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 239,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
