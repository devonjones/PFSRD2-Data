            "family": {
                "name": "Jellyfish",
                "type": "monster_family",
                "sections": [
                    {
                        "name": "Jellyfish Species",
                        "type": "section",
                        "text": "A large number of types of monstrous jellyfish dwell in the world\u2019s oceans, each with their own unusual specialty in hunting. The immense vampire jellyfish is a blood-drinking monster that often attacks sailors aboard ships. Among the largest are the dreaded whaler jellyfish, colossal creatures that feed on whales or even krakens.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Monster Core 2",
                                "link": {
                                    "type": "link",
                                    "name": "Monster Core 2 pg. 200",
                                    "alt": "Monster Core 2 pg. 200",
                                    "game-obj": "Sources",
                                    "aonid": 276
                                },
                                "page": 200
                            }
                        ],
                        "links": [
                            {
                                "type": "link",
                                "name": "krakens",
                                "alt": "krakens",
