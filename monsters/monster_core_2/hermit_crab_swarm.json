{
    "name": "Hermit Crab Swarm",
    "type": "creature",
    "sections": [
        {
            "name": "Hermit Crab Swarm",
            "type": "section",
            "text": "When hermit crabs find a shell that's too large, they lie in wait for others to arrive and move into the shell, abandoning a possible replacement. This can form a large chain of queuing crabs waiting to upgrade their shells. Interruptions can aggravate the crabs, resulting in attacks against the unfortunate source of disruption.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 77",
                        "alt": "Monster Core 2 pg. 77",
                        "game-obj": "Sources",
                        "aonid": 276
                    },
                    "page": 77
                }
            ]
        }
    ],
