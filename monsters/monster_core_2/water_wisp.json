      "name": "Water Wisp",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 153",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 153",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 153,
          "type": "source"
        }
      ],
      "text": "Water wisps are swimming spheres of foam and water, perpetually humming with a wash of soft sounds. They're gentle, nurturing, and quick to help anyone in need.",
      "type": "section"
    }
  ],
