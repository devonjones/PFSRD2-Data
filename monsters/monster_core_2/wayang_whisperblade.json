                  "aonid": 179,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a57956799f3d30121d529e48f12904c",
                "game-obj": "Traits",
                "name": "Finesse",
                "sources": [
                  {
