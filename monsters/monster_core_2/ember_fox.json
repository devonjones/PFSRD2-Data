                "aonid": 409,
                "game-obj": "MonsterFamilies",
                "name": "Elemental, Earth",
                "type": "link"
              },
              {
                "alt": "Elemental, Fire",
                "aonid": 43,
                "game-obj": "MonsterFamilies",
                "name": "Elemental, Fire",
                "type": "link"
              },
              {
                "alt": "Elemental, Mephit",
                "aonid": 44,
                "game-obj": "MonsterFamilies",
                "name": "Elemental, Mephit",
                "type": "link"
              },
              {
                "alt": "Elemental, Metal",
                "aonid": 343,
                "game-obj": "MonsterFamilies",
                "name": "Elemental, Metal",
                "type": "link"
              },
              {
                "alt": "Elemental, Scamp",
                "aonid": 411,
