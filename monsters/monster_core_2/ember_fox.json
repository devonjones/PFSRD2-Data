      ],
      "name": "Ember Fox",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 148",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 148",
            "type": "link"
