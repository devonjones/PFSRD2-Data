                            },
                            {
                                "type": "link",
                                "name": "fatal d12",
                                "alt": "fatal d12",
                                "game-obj": "Traits",
                                "aonid": 597
                            }
                        ],
                        "text": "The bison surges forward at its foe, horns lowered. It Strides twice. If the bison ends its movement within melee range of an enemy, it makes a horn Strike against that enemy. This Strike gains the fatal d12 trait."
                    }
                },
                {
                    "name": "Rolling Thunder",
                    "type": "stat_block_section",
                    "subtype": "offensive_action",
                    "offensive_action_type": "ability",
                    "ability": {
                        "type": "stat_block_section",
                        "subtype": "ability",
