              "type": "source"
            }
          ],
          "text": "*Space:* 5 feet, *Reach (Tall):* 5 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 108,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "1debc9c19f9ffadf57ee0ebf1bc785cb",
          "game-obj": "Traits",
          "name": "Mindless",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "A mindless creature has either programmed or rudimentary mental attributes. Most, if not all, of their mental attribute modifiers are \u20135. They are immune to all mental effects.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 122,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "59778327f4f1f550ee82536a9e4742eb",
          "game-obj": "Traits",
          "name": "Ooze",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 459",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 459",
                "type": "link"
              },
              "name": "Player Core",
              "page": 459,
              "type": "source"
            }
          ],
          "text": "Oozes are creatures with simple anatomies. They tend to have low mental attribute modifiers and immunity to mental effects and precision damage.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
    "defense": {
      "ac": {
        "subtype": "armor_class",
        "type": "stat_block_section",
        "value": 12
      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Corrosive Surface",
          "subtype": "ability",
          "text": "A creature that hits a verdurous ooze with a metal weapon or unarmed attack must attempt a DC 21 Reflex save. On a failure, the weapon or creature takes 2d4 acid damage (after dealing damage to the ooze as normal). Thrown weapons take this damage automatically with no save.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "emanation",
              "aonid": 2387,
              "game-obj": "Rules",
              "name": "emanation",
              "type": "link"
            },
            {
              "alt": "difficult terrain",
              "aonid": 2366,
              "game-obj": "Rules",
              "name": "difficult terrain",
              "type": "link"
            }
          ],
          "name": "Enliven Foliage",
          "range": {
            "range": 20,
            "subtype": "range",
            "text": "20 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "saving_throw": [
            {
              "dc": 21,
              "save_type": "Ref",
              "subtype": "save_dc",
              "text": "DC 21 Reflex save",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "The verdurous ooze constantly emits supernatural vapors that cause nearby plants to grow rapidly and writhe and grasp at anything and everything within the emanation. This area becomes difficult terrain for non\u2013verdurous ooze creatures. When a creature starts its turn in this aura, it must succeed at a DC 21 Reflex save or take a \u201310-foot circumstance penalty to its Speeds until it leaves the emanation.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 206,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "5315505cfd3f3ba2685e9747898193b2",
              "game-obj": "Traits",
              "name": "Aura",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 134,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "60a4f011afd1e0fac8211bd01108d104",
              "game-obj": "Traits",
              "name": "Primal",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 460",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 460",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 460,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "name": "Split",
          "subtype": "ability",
          "text": "When a verdurous ooze that has 10 or more HP is hit by an attack that would deal piercing or slashing damage, it splits into two identical oozes, each with half the original's HP. One ooze is in the same space as the original, and the other is in an adjacent, unoccupied space. If no adjacent space is unoccupied, it automatically pushes creatures and objects out of the way to fill a space (the GM decides if an object or creature is too big or heavy to push).",
          "type": "stat_block_section"
        }
      ],
