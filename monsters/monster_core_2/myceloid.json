              }
            ],
            "name": "Darkvision",
            "sources": [
              {
                "errata": {
                  "alt": "1.1",
                  "aonid": 221,
                  "game-obj": "Sources",
                  "name": "1.1",
                  "type": "link"
                },
                "link": {
                  "alt": "Monster Core pg. 359",
