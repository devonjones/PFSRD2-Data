{
    "name": "Khravgodon",
    "type": "creature",
    "sections": [
        {
            "name": "Khravgodon",
            "type": "section",
            "sections": [
                {
                    "name": "Tail Tales",
                    "type": "section",
                    "text": "A Kellid legend holds that the khravgodon once had a beautiful tail covered with bright, thick fur. One night, the khravgodon fell asleep in the open, having danced all night showing off its beautiful tail. When it awoke, ankhravs had chewed all the hair off khravgodon's tail, leaving it with the bald appendage we see today. Khravgodons have been taking revenge on ankhravs ever since.",
                    "sources": [
                        {
                            "type": "source",
                            "name": "Monster Core 2",
                            "link": {
                                "type": "link",
                                "name": "Monster Core 2 pg. 244",
                                "alt": "Monster Core 2 pg. 244",
                                "game-obj": "Sources",
                                "aonid": 276
                            },
                            "page": 244
                        }
                    ],
                    "subtype": "sidebar",
                    "sidebar_type": "additional_lore",
                    "sidebar_heading": "Additional Lore",
                    "image": {
                        "type": "image",
                        "name": "Additional Lore",
                        "image": "Sidebar_2_AdditionalLore.png"
                    },
                    "links": [
                        {
                            "type": "link",
                            "name": "ankhravs",
                            "alt": "ankhravs",
                            "game-obj": "MonsterFamilies",
                            "aonid": 361
                        }
                    ]
                }
            ],
            "text": "Few creatures can shrug off an ankhrav's acid and crunch its chitin like a khravgodon.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core 2",
                    "link": {
                        "type": "link",
                        "name": "Monster Core 2 pg. 244",
                        "alt": "Monster Core 2 pg. 244",
                        "game-obj": "Sources",
                        "aonid": 276
                    },
                    "page": 244
                }
            ]
        }
    ],
