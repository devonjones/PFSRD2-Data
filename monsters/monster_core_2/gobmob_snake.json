            {
              "dc": 20,
              "subtype": "save_dc",
              "text": "DC 20",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "Whenever a gobmob snake critically fails at an attack roll or skill check, it must succeed at a DC 5 flat check or become slowed 1 as its heads argue over which of them is to blame. An enemy can provoke an argument by attempting a DC 20 Deception check as a single action with the auditory, concentrate, linguistic, and mental traits.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
