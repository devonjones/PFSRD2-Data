                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 456",
                "type": "link"
              },
              "name": "Player Core",
              "page": 456,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a small, frantic goblinoid. Goblins tend to have darkvision. An ability with this trait can be used or chosen only by goblins. A weapon with this trait is created and used by goblins.",
