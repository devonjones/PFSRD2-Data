              "name": "Recall Knowledge",
              "type": "link"
            },
            {
              "alt": "Step",
              "aonid": 2304,
              "game-obj": "Actions",
              "name": "Step",
              "type": "link"
            }
          ],
          "name": "All This Has Happened Before",
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 120,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "a9126c150baeaac5ec247ce82c9b8ce2",
              "game-obj": "Traits",
              "name": "Occult",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
