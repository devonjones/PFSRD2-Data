                                "name": "Primal",
                                "type": "trait",
                                "alternate_link": {
                                    "type": "alternate_link",
                                    "game-obj": "Traits",
                                    "aonid": 134,
                                    "alternate_type": "legacy"
                                },
                                "edition": "remastered",
                                "sources": [
                                    {
                                        "type": "source",
                                        "name": "Player Core",
                                        "link": {
                                            "type": "link",
                                            "name": "Player Core pg. 460",
                                            "alt": "Player Core pg. 460",
                                            "game-obj": "Sources",
                                            "aonid": 216
