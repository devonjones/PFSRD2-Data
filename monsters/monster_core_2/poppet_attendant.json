          "subtype": "monster_family",
          "type": "stat_block_section"
        },
        "name": "Poppet",
        "sections": [
          {
            "name": "Poppet Assistants",
            "sources": [
              {
                "link": {
                  "alt": "Monster Core 2 pg. 256",
                  "aonid": 276,
                  "game-obj": "Sources",
                  "name": "Monster Core 2 pg. 256",
                  "type": "link"
                },
                "name": "Monster Core 2",
                "page": 256,
                "type": "source"
              }
            ],
            "text": "Poppets are often crafted to be assistants within specific trades, making each one unique and specially designed for their tasks. For instance, a blacksmith's assistant may be crafted from sturdier materials than most poppets and lack their usual weakness to fire, while a poppet crafted to help out in an alchemical laboratory may be waterproofed and have articulated fingers for carefully measuring out different ingredients.",
            "type": "section"
          }
        ],
        "sources": [
          {
            "link": {
              "alt": "Monster Core 2 pg. 256",
              "aonid": 276,
              "game-obj": "Sources",
              "name": "Monster Core 2 pg. 256",
              "type": "link"
            },
            "name": "Monster Core 2",
            "page": 256,
            "type": "source"
          }
        ],
        "text": "Poppets are simple constructs made to assist their creators with basic tasks.",
        "type": "monster_family"
      },
