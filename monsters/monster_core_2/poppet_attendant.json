  "schema_version": 1.4,
  "sections": [
    {
      "name": "Poppet Attendant",
      "sources": [
        {
          "link": {
            "alt": "Monster Core 2 pg. 256",
            "aonid": 276,
            "game-obj": "Sources",
            "name": "Monster Core 2 pg. 256",
            "type": "link"
          },
          "name": "Monster Core 2",
          "page": 256,
          "type": "source"
        }
      ],
      "text": "Poppet attendants are among the most common form of poppets. Most attendants can be found in creative trades, especially among tailors and cobblers.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "Monster Core 2 pg. 256",
        "aonid": 276,
        "game-obj": "Sources",
        "name": "Monster Core 2 pg. 256",
        "type": "link"
      },
      "name": "Monster Core 2",
      "page": 256,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Construct",
        "Humanoid"
      ],
      "family": {
        "aonid": 615,
