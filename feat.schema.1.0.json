{
	"$schema": "http://json-schema.org/draft-07/schema#",

	"definitions": {
		"pfs": {
			"type": "object",
			"properties": {
				"type": {"enum": ["stat_block_section"]},
				"subtype": {"enum": ["pfs"]},
				"availability": {"enum": ["Standard", "Limited", "Restricted"]},
				"note": {"type": "string"}
			},
			"required": ["type", "subtype", "availability"],
			"additionalProperties": false
		},
		"alternate_link": {
			"type": "object",
			"properties": {
				"type": {"enum": ["alternate_link"]},
				"game-obj": {"enum": [
					"Actions", "Ancestries", "Archetypes", "Armor",
					"Classes", "Conditions", "Deities", "Diseases",
					"Domains", "Equipment", "Feats", "Heritages",
					"Languages", "MonsterAbilities", "MonsterFamilies",
					"Monsters", "NPCs", "Planes", "Rituals", "Rules",
					"Shields", "SiegeWeapons", "Skills", "Sources",
					"Spells", "Traits", "WeaponGroups", "Weapons"
				]},
				"game-id": {"type": "string"},
				"alternate_type": {"enum": ["legacy", "remastered"]},
				"aonid": {"type": "integer"}
			},
			"required": ["game-obj", "aonid"],
			"additionalProperties": false
		},
		"image": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["image"]},
				"game-obj": {"type": "string"},
				"image": {"type": "string"}
			},
			"required": ["name", "type", "image"],
			"additionalProperties": false
		},
		"link": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["link"]},
				"alt": {"type": "string"},
				"href": {"type": "string"},
				"game-obj": {"enum": [
					"Actions", "Ancestries", "AnimalCompanions", "ArcaneSchools",
					"ArcaneThesis", "Archetypes", "Armor", "ArmorGroups",
					"Backgrounds", "Bloodlines",
					"Causes", "Classes", "Conditions", "Curses",
					"Deities", "DeityCategories", "Diseases", "Doctrines",
					"Domains", "DruidicOrders", "Elements", "Epithets",
					"Equipment", "Familiars", "Feats",
					"Followers", "Hazards", "Heritages",
					"HuntersEdge", "HybridStudies", "Innovations", "Instincts",
					"Languages", "Lessons", "Methodologies",
					"MonsterAbilities", "MonsterFamilies",
					"MonsterTemplates", "Monsters", "Muses", "Mysteries",
					"MythicCallings", "NPCs", "Patrons", "Planes", "Practices",
					"Rackets", "Relics", "ResearchFields", "Rituals",
					"Rules", "Shields", "Skills", "Sources", "SpellLists",
					"Spells", "Styles", "SubconsciousMinds",
					"Tenets", "Traits", "Ways",
					"WeaponGroups", "Weapons"
				]},
				"aonid": {"type": "integer"}
			},
			"required": ["name", "type", "alt"],
			"additionalProperties": false
		},
		"links": {
			"type": "array",
			"items": {"$ref": "#/definitions/link"},
			"additionalItems": false
		},
		"license": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["section"]},
				"subtype": {"enum": ["license"]},
				"license": {"enum": [
					"OPEN GAME LICENSE Version 1.0a",
					"Open RPG Creative license"]},
				"text": {"type": "string"},
				"sections": {"$ref": "#/definitions/sections"}
			},
			"additionalProperties": false
		},
		"source": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["source"]},
				"link": {"$ref": "#/definitions/link"},
				"note": {"$ref": "#/definitions/link"},
				"page": {"type": "integer"},
				"errata": {"$ref": "#/definitions/link"}
			},
			"required": ["name", "type", "link"],
			"additionalProperties": false
		},
		"sources": {
			"type": "array",
			"items": {"$ref": "#/definitions/source"},
			"additionalItems": false
		},
		"section": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["section"]},
				"text": {"type": "string"},
				"sections": {"$ref": "#/definitions/sections"},
				"sources": {"$ref": "#/definitions/sources"},
				"subtype": {"enum": ["sidebar", "index"]},
				"sidebar_type": {"enum": [
					"treasure_and_rewards", "related_creatures", "locations",
					"additional_lore", "advice_and_rules", "geb"
				]},
				"sidebar_heading": {"type": "string"},
				"image": {"$ref": "#/definitions/image"},
				"links": {"$ref": "#/definitions/links"},
				"abilities": {
					"type": "array",
					"items": {"$ref": "#/definitions/called_ability"},
					"additionalItems": false
				}
			},
			"additionalProperties": false
		},
		"sections": {
			"type": "array",
			"items": {"$ref": "#/definitions/section"},
			"additionalItems": false
		},
		"action_type": {
			"type": "object",
			"properties": {
				"type": {"enum": ["stat_block_section"]},
				"subtype": {"enum": ["action_type"]},
				"name": {"enum": [
					"Reaction", "Free Action", "One Action",
					"Two Actions", "Three Actions"
				]}
			},
			"required": ["type", "subtype", "name"],
			"additionalProperties": false
		},
		"trait": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["trait"]},
				"game-id": {"type": "string"},
				"game-obj": {"enum": ["Traits"]},
				"value": {"type": "string"},
				"text": {"type": "string"},
				"classes": {
					"type": "array",
					"items": {"type": "string"},
					"additionalItems": false
				},
				"sources": {"$ref": "#/definitions/sources"},
				"sections": {"$ref": "#/definitions/sections"},
				"links": {"$ref": "#/definitions/links"},
				"alternate_link": {"$ref": "#/definitions/alternate_link"},
				"edition": {"enum": ["legacy", "remastered"]}
			},
			"required": ["name", "type", "game-id", "game-obj", "sources", "edition"],
			"additionalProperties": false
		},
		"feat_archetype": {
			"type": "object",
			"properties": {
				"name": {"type": "string"},
				"type": {"enum": ["feat_archetype"]},
				"link": {"$ref": "#/definitions/link"},
				"note": {"type": "string"},
				"links": {"$ref": "#/definitions/links"}
			},
			"required": ["name", "type"],
			"additionalProperties": false
		},
		"called_ability": {
			"type": "object",
			"properties": {
				"type": {"enum": ["stat_block_section"]},
				"subtype": {"enum": ["ability"]},
				"ability_type": {"enum": ["called"]},
				"name": {"type": "string"},
				"sections": {"$ref": "#/definitions/sections"},
				"link": {"$ref": "#/definitions/link"},
				"traits": {
					"type": "array",
					"items": {"$ref": "#/definitions/trait"},
					"additionalItems": false
				},
				"sources": {"$ref": "#/definitions/sources"},
				"text": {"type": "string"},
				"links": {"$ref": "#/definitions/links"},
				"trigger": {"type": "string"},
				"requirement": {"type": "string"},
				"frequency": {"type": "string"},
				"prerequisite": {"type": "string"},
				"effect": {"type": "string"},
				"cost": {"type": "string"},
				"duration": {"type": "string"},
				"access": {"type": "string"},
				"special": {"type": "string"},
				"archetype": {
					"type": "array",
					"items": {"$ref": "#/definitions/feat_archetype"},
					"additionalItems": false
				},
				"critical_success": {"type": "string"},
				"success": {"type": "string"},
				"failure": {"type": "string"},
				"critical_failure": {"type": "string"}
			},
			"required": ["type", "subtype", "ability_type", "name"],
			"additionalProperties": false
		},
		"feat": {
			"type": "object",
			"properties": {
				"type": {"enum": ["stat_block_section"]},
				"subtype": {"enum": ["feat"]},
				"name": {"type": "string"},
				"level": {"type": "integer"},
				"text": {"type": "string"},
				"action_type": {"$ref": "#/definitions/action_type"},
				"traits": {
					"type": "array",
					"items": {"$ref": "#/definitions/trait"},
					"additionalItems": false
				},
				"prerequisite": {"type": "string"},
				"requirement": {"type": "string"},
				"trigger": {"type": "string"},
				"frequency": {"type": "string"},
				"access": {"type": "string"},
				"archetype": {
					"type": "array",
					"items": {"$ref": "#/definitions/feat_archetype"},
					"additionalItems": false
				},
				"archetype_level": {"type": "integer"},
				"special": {"type": "string"},
				"effect": {"type": "string"},
				"cost": {"type": "string"},
				"duration": {"type": "string"},
				"critical_success": {"type": "string"},
				"success": {"type": "string"},
				"failure": {"type": "string"},
				"critical_failure": {"type": "string"},
				"abilities": {
					"type": "array",
					"items": {"$ref": "#/definitions/called_ability"},
					"additionalItems": false
				},
				"links": {"$ref": "#/definitions/links"}
			},
			"required": ["type", "subtype", "name", "level", "text"],
			"additionalProperties": false
		}
	},
	"type": "object",
	"properties": {
		"name": {"type": "string"},
		"type": {"enum": ["feat"]},
		"aonid": {"type": "integer"},
		"game-obj": {"enum": ["Feats"]},
		"game-id": {"type": "string"},
		"feat": {"$ref": "#/definitions/feat"},
		"sources": {"$ref": "#/definitions/sources"},
		"sections": {"$ref": "#/definitions/sections"},
		"alternate_link": {"oneOf": [
			{"$ref": "#/definitions/alternate_link"},
			{"type": "array", "items": {"$ref": "#/definitions/alternate_link"}, "additionalItems": false}
		]},
		"alternate_links": {
			"type": "array",
			"items": {"$ref": "#/definitions/alternate_link"},
			"additionalItems": false
		},
		"edition": {"enum": ["legacy", "remastered"]},
		"pfs": {"$ref": "#/definitions/pfs"},
		"schema_version": {"enum": [1.0]},
		"license": {"$ref": "#/definitions/license"}
	},
	"required": ["name", "type", "aonid", "game-obj", "game-id", "feat", "sources", "edition", "pfs", "schema_version", "license"],
	"additionalProperties": false
}
