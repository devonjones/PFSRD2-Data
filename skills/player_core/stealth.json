            {
                "name": "Hide",
                "type": "stat_block_section",
                "text": "You huddle behind cover or greater cover or deeper into concealment to become hidden, rather than observed. The GM  rolls your Stealth check in secret and compares the result to the Perception DC of each creature you're observed by but that you have cover or greater cover against or are concealed from. You get a +2 circumstance bonus to your check if you have standard cover (or +4 from greater cover).",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 244",
                            "alt": "Player Core pg. 244",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 244,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "action_type": {
                    "type": "stat_block_section",
                    "subtype": "action_type",
                    "name": "One Action"
                },
                "traits": [
                    {
                        "type": "stat_block_section",
                        "subtype": "trait",
                        "name": "Secret",
                        "link": {
                            "type": "link",
                            "name": "Secret",
                            "alt": "Secret",
                            "game-obj": "Traits",
                            "aonid": 142
                        }
                    }
                ],
                "source": {
