    "game-obj": "Skills",
    "skill": {
        "name": "Intimidation",
        "type": "stat_block_section",
        "text": "You bend others to your will using threats. Unlike Deception or Diplomacy, Intimidation is typically a blunt instrument with little room for nuance or care.",
        "subtype": "skill",
        "key_ability": "cha",
        "skill_type": "character_skill",
        "actions": [
            {
                "name": "Coerce",
                "type": "stat_block_section",
                "sections": [
                    {
                        "name": "Changing Attitudes",
                        "type": "section",
                        "text": "Your influence on NPCs is measured with a set of attitudes that reflect how they view your character. These are only a brief summary of a creature's disposition. The GM will supply additional nuance based on the history and beliefs of the characters you're interacting with, and their attitudes can change in accordance with the story. The attitudes are detailed in the Conditions Appendix and are summarized here. \n* **Helpful**: Willing to help you and responds favorably to your requests.\n* **Friendly**: Has a good attitude toward you, but won't necessarily stick their neck out to help you.\n* **Indifferent**: Doesn't care about you either way. (Most NPCs start out indifferent.)\n* **Unfriendly**: Dislikes you and doesn't want to help you.\n* **Hostile**: Actively works against you\u2014and might attack you just because of their dislike.\n No one can ever change the attitude of a player character with these skills. You can roleplay interactions with player characters, and even use Diplomacy results if the player wants a mechanical sense of how convincing or charming a character is, but players make the ultimate decisions about how their characters respond.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Player Core",
                                "link": {
                                    "type": "link",
                                    "name": "Player Core pg. 240",
                                    "alt": "Player Core pg. 240",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                },
                                "page": 240,
                                "errata": {
                                    "type": "link",
                                    "name": "2.0",
                                    "alt": "2.0",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                }
                            }
                        ],
                        "links": [
                            {
                                "type": "link",
                                "name": "Conditions Appendix",
                                "alt": "Conditions Appendix",
                                "game-obj": "Rules",
                                "aonid": 2455
                            },
                            {
                                "type": "link",
                                "name": "Helpful",
                                "alt": "Helpful",
                                "game-obj": "Conditions",
                                "aonid": 21
                            },
                            {
                                "type": "link",
                                "name": "Friendly",
                                "alt": "Friendly",
                                "game-obj": "Conditions",
                                "aonid": 18
                            },
                            {
                                "type": "link",
                                "name": "Indifferent",
                                "alt": "Indifferent",
                                "game-obj": "Conditions",
                                "aonid": 25
                            },
                            {
                                "type": "link",
                                "name": "Unfriendly",
                                "alt": "Unfriendly",
                                "game-obj": "Conditions",
                                "aonid": 40
                            },
                            {
                                "type": "link",
                                "name": "Hostile",
                                "alt": "Hostile",
                                "game-obj": "Conditions",
                                "aonid": 23
                            },
                            {
                                "type": "link",
                                "name": "Diplomacy",
                                "alt": "Diplomacy",
                                "game-obj": "Skills",
                                "aonid": 6
                            }
                        ]
                    }
                ],
                "text": "With threats either veiled or overt, you attempt to bully a creature into doing what you want. You must spend at least 1 minute of conversation with the creature. At the end of the conversation, attempt an Intimidation check against the target's Will DC, modified by any circumstances the GM determines. (The attitudes referenced in the effects below are summarized in the Changing Attitudes sidebar and described in full in the Conditions Appendix.)",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 240",
                            "alt": "Player Core pg. 240",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 240,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "traits": [
                    {
