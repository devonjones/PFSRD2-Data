    "skill": {
        "name": "Survival",
        "type": "stat_block_section",
        "text": "You are adept at living in the wilderness, foraging for food and building shelter, and with training you discover the secrets of tracking and hiding your trail.\n* ***Subsist*** in the wild by foraging for food and building shelter.",
        "subtype": "skill",
        "key_ability": "wis",
        "skill_type": "character_skill",
        "actions": [
            {
                "name": "Sense Direction",
                "type": "stat_block_section",
                "text": "Using the stars, the position of the sun, traits of the geography or flora, or the behavior of fauna, you can stay oriented in the wild. Typically, you attempt a Survival check only once per day, but some environments or changes might necessitate rolling more often. The GM determines the DC and how long this activity takes (usually just a minute or so). More unusual locales or those you're unfamiliar with might require you to have a minimum proficiency rank to Sense Direction. Without a compass, you take a \u20132 item penalty to checks to Sense Direction.",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 246",
                            "alt": "Player Core pg. 246",
                            "game-obj": "Sources",
                            "aonid": 216
