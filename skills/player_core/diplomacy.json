                                "name": "Friendly",
                                "alt": "Friendly",
                                "game-obj": "Conditions",
                                "aonid": 18
                            },
                            {
                                "type": "link",
                                "name": "Indifferent",
                                "alt": "Indifferent",
                                "game-obj": "Conditions",
                                "aonid": 25
                            },
                            {
                                "type": "link",
                                "name": "Unfriendly",
                                "alt": "Unfriendly",
                                "game-obj": "Conditions",
                                "aonid": 40
                            },
                            {
