            {
                "name": "Make an Impression",
                "type": "stat_block_section",
                "sections": [
                    {
                        "name": "Changing Attitudes",
                        "type": "section",
                        "text": "Your influence on NPCs is measured with a set of attitudes that reflect how they view your character. These are only a brief summary of a creature's disposition. The GM will supply additional nuance based on the history and beliefs of the characters you're interacting with, and their attitudes can change in accordance with the story. The attitudes are detailed in the Conditions Appendix and are summarized here. \n* **Helpful**: Willing to help you and responds favorably to your requests.\n* **Friendly**: Has a good attitude toward you, but won't necessarily stick their neck out to help you.\n* **Indifferent**: Doesn't care about you either way. (Most NPCs start out indifferent.)\n* **Unfriendly**: Dislikes you and doesn't want to help you.\n* **Hostile**: Actively works against you\u2014and might attack you just because of their dislike.\n No one can ever change the attitude of a player character with these skills. You can roleplay interactions with player characters, and even use Diplomacy results if the player wants a mechanical sense of how convincing or charming a character is, but players make the ultimate decisions about how their characters respond.",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Player Core",
                                "link": {
                                    "type": "link",
                                    "name": "Player Core pg. 239",
                                    "alt": "Player Core pg. 239",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                },
                                "page": 239,
                                "errata": {
                                    "type": "link",
                                    "name": "2.0",
                                    "alt": "2.0",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                }
                            }
                        ],
                        "links": [
                            {
                                "type": "link",
                                "name": "Conditions Appendix",
                                "alt": "Conditions Appendix",
                                "game-obj": "Rules",
                                "aonid": 2455
                            },
                            {
                                "type": "link",
                                "name": "Helpful",
                                "alt": "Helpful",
                                "game-obj": "Conditions",
                                "aonid": 21
                            },
