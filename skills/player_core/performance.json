    "skill": {
        "name": "Performance",
        "type": "stat_block_section",
        "text": "You are skilled at a form of performance, using your talents to impress a crowd or make a living.",
        "subtype": "skill",
        "key_ability": "cha",
        "skill_type": "character_skill",
        "actions": [
            {
                "name": "Perform",
                "type": "stat_block_section",
                "text": "When making a brief performance\u2014one song, a quick dance, or a few jokes\u2014you use the Perform action. This action is most useful when you want to prove your capability or impress someone quickly. Performing rarely has an impact on its own, but it might influence the DCs of subsequent Diplomacy checks against the observers, or even change their attitudes if the GM sees fit.",
                "sources": [
