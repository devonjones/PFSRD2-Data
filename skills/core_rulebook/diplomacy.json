{
    "name": "Diplomacy",
    "type": "skill",
    "sections": [
        {
            "name": "Changing Attitudes",
            "type": "section",
            "sections": [
                {
                    "name": "Related Feats",
                    "type": "section",
                    "text": "To see a list of Feats related to Diplomacy, *click here*.",
                    "sources": [
                        {
