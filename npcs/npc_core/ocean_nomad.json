  "sections": [
    {
      "name": "Ocean Nomad",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 150",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 150",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 150,
          "type": "source"
        }
      ],
      "text": "For some, the ocean is not merely a means of getting from port to port, but a home in and of itself.",
      "type": "section"
    }
  ],
  "sources": [
