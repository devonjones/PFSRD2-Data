  "name": "Harbormaster",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Harbormaster",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 111",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 111",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 111,
          "type": "source"
        }
      ],
      "text": "A port must sustain itself on different types of flows: the seaward and coastal flows, marked by the rising and falling of the tides, and the constant flow of trade. A harbormaster is expected to know the former reflexively and encourage the latter within the jurisdictional rules of law.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 111",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 111",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 111,
      "type": "source"
    }
  ],
