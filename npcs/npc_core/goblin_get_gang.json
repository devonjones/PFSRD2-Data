  "schema_version": 1.4,
  "sections": [
    {
      "name": "Goblin Get Gang",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 187",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 187",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 187,
          "type": "source"
        }
      ],
      "text": "There is little more terrifying than a goblin raiding party out to take from its neighbors. A swarming mix of commandos, pyros, and war chanters armed with dogslicers, horsechoppers, burning torches, and sharp teeth, this troop enjoys pillaging unprepared communities. Their song is an unsettling counterpart to the screams of their victims.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
