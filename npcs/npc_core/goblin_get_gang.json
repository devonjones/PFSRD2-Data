            }
          ],
          "name": "Goblins Chant and Goblins Sing!",
          "range": {
            "range": 30,
            "subtype": "range",
            "text": "30 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "saving_throw": [
            {
              "dc": 19,
              "save_type": "Will",
              "subtype": "save_dc",
              "text": "DC 19 Will",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "The goblin get gang's disharmonious chorus of disturbing lyrics makes it difficult to concentrate. Any creature performing a concentrate action in the area must succeed at a DC 19 Will save or the action is lost. On a critical success, the creature is temporarily immune for 1 minute.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 16,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "84c09922ddd30f2144494f2cb6f19412",
              "game-obj": "Traits",
              "name": "Auditory",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 206,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "5315505cfd3f3ba2685e9747898193b2",
              "game-obj": "Traits",
              "name": "Aura",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
