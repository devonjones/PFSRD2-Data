              "name": "Player Core",
              "page": 456,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a small, frantic goblinoid. Goblins tend to have darkvision. An ability with this trait can be used or chosen only by goblins. A weapon with this trait is created and used by goblins.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
