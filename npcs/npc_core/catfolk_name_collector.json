  "sections": [
    {
      "name": "Catfolk Name Collector",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 172",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 172",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 172,
          "type": "source"
        }
      ],
      "text": "Name collectors are esteemed touchstones of catfolk culture. They record the adventures of catfolk heroes, speak to spirits, and tell legends about strange and faraway places.",
      "type": "section"
    }
  ],
