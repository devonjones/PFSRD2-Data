  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Human",
        "Humanoid"
      ],
      "family": {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 182,
          "game-obj": "MonsterFamilies",
