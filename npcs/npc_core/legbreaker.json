  "sections": [
    {
      "name": "Legbreaker",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 21",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 21",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 21,
          "type": "source"
        }
      ],
      "text": "Criminal organizations are always happy to loan out money at exorbitant rates, and their legbreakers are always happy to collect.",
      "type": "section"
    }
  ],
  "sources": [
    {
