  "schema_version": 1.4,
  "sections": [
    {
      "name": "Gravedigger",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 69",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 69",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 69,
          "type": "source"
        }
      ],
      "text": "An often-overlooked group of laborers, gravediggers have a reputation for being as quiet and grim as their workplace. They're usually strong and tough from their long hours of backbreaking labor, and they tend to have a unique perspective on life and death.",
      "type": "section"
    }
  ],
