  "schema_version": 1.4,
  "sections": [
    {
      "name": "Innkeeper",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 69",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 69",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 69,
          "type": "source"
        }
      ],
      "text": "The sight of an inn is a welcome one to any weary traveler. Innkeepers can often be found cleaning the common room, overseeing the evening meal, or settling in new lodgers. Innkeepers keep an eye on their neighbors' doings and are often excellent sources of information.",
      "type": "section"
    }
  ],
