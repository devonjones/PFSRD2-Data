                  }
                ],
                "name": "Nonlethal",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "Attacks with this weapon are nonlethal, and are used to knock creatures unconscious instead of kill them. You can use a nonlethal weapon to make a lethal attack with a \u20132 circumstance penalty.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 199,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "b33cff5f3243a6681e903029455f779a",
                "game-obj": "Traits",
                "name": "Unarmed",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "An unarmed attack uses your body rather than a manufactured weapon. An unarmed attack isn\u2019t a weapon, though has a weapon group and might have weapon traits. An unarmed attack can\u2019t be Disarmed. It also doesn\u2019t take up a hand, though a fist or other grasping appendage generally works like a free-hand weapon.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section",
            "weapon": "fist"
          },
          "name": "Melee",
          "offensive_action_type": "attack",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "attack": {
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "attack_type": "ranged",
            "bonus": {
              "bonuses": [
                5,
                0,
                -5
              ],
              "link": {
                "alt": "+0/-5",
                "aonid": 322,
                "game-obj": "Rules",
                "name": "+0/-5",
                "type": "link"
              },
              "subtype": "attack_bonus",
              "type": "stat_block_section"
            },
            "damage": [
              {
                "damage_type": "bludgeoning",
                "formula": "1d4+2",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "name": "Ranged",
            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 195,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c42503980965022311443a6e1e55ab57",
                "game-obj": "Traits",
                "name": "Thrown",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "You can throw this weapon as a ranged attack; it is a ranged weapon when thrown. You add your Strength modifier to damage as you would for a melee weapon. When this trait appears on a melee weapon, it also includes the range increment. Ranged weapons with this trait use the range increment in the weapon\u2019s Range entry.",
                "type": "trait",
                "value": "10 feet"
              }
            ],
            "type": "stat_block_section",
            "weapon": "pewter mug"
          },
          "name": "Ranged",
          "offensive_action_type": "attack",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "damage": [
              {
                "formula": "1d4",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "links": [
              {
                "alt": "nonlethal",
                "aonid": 661,
                "game-obj": "Traits",
                "name": "nonlethal",
                "type": "link"
              }
            ],
            "name": "Home Base Brawler",
            "subtype": "ability",
            "text": "The innkeeper knows how to settle fights that break out. When the innkeeper is fighting in their establishment, their Strikes gain a +1 circumstance bonus to the attack roll, deal an additional 1d4 damage, and gain the nonlethal trait if they don't already have it. The innkeeper can choose not to gain this benefit.",
            "type": "stat_block_section"
          },
          "name": "Home Base Brawler",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Three Actions",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "effect": "The innkeeper gives some pertinent advice to a single creature other than themself. For 24 hours, when that creature fails a skill check or saving throw, they can recall this advice and reroll the check, using the second result instead. Once that creature uses this ability, its effect ends. A creature that receives the Innkeeper's Advice is temporarily immune to the ability for 1 month.",
            "frequency": "once per day",
            "name": "Innkeeper's Advice",
            "subtype": "ability",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 76,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "7adeee5fc9bf211a4db10de37045506c",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "misfortune",
                    "aonid": 110,
                    "game-obj": "Traits",
                    "name": "misfortune",
                    "type": "link"
                  }
                ],
                "name": "Fortune",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 401",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 401",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 401,
                    "type": "source"
                  }
                ],
                "text": "A fortune effect beneficially alters how you roll your dice. You can never have more than one fortune effect alter a single roll. If multiple fortune effects would apply, you have to pick which to use. If a fortune effect and a misfortune effect would apply to the same roll, the two cancel each other out, and you roll normally.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 101,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
                "game-obj": "Traits",
                "name": "Linguistic",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "An effect with this trait depends on language comprehension. A linguistic effect that targets a creature works only if the target understands the language you are using.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 106,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "game-obj": "Traits",
                "name": "Mental",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
          "name": "Innkeeper's Advice",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        }
      ],
