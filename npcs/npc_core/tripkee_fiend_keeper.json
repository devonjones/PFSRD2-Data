                "name": "difficult terrain",
                "type": "link"
              }
            ],
            "name": "Forest Passage",
            "subtype": "ability",
            "text": "The tripkee ignores difficult terrain caused by plants, such as bushes, vines, and undergrowth.",
            "type": "stat_block_section"
          },
          "name": "Forest Passage",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "effect": "The tripkee fiend keeper allows a portion of the fiendish power they have absorbed to flow through their body. For the next minute, the tripkee fiend keeper's Strikes deal an additional die of damage and gain the unholy trait. The tripkee fiend keeper also gains 10 temporary Hit Points, a +5- foot status bonus to Speed for the duration, and weakness 5 to holy. At the end of the duration, the tripkee fiend keeper is stupefied 1 for 1 hour.",
            "links": [
              {
                "alt": "stupefied",
                "aonid": 94,
                "game-obj": "Conditions",
                "name": "stupefied",
                "type": "link"
