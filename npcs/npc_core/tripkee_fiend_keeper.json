  "sections": [
    {
      "name": "Tripkee Fiend Keeper",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 215",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 215",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 215,
          "type": "source"
        }
      ],
      "text": "Tripkees have a technique for dealing with unholy threats that has been passed down through the generations. A fiend keeper can absorb unholy spirits into their body before those entities can cause trouble for their kin. Though they can tap into this power when necessary, tripkee fiend keepers try to cleanse themselves of its evil influence by undertaking good deeds.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 215",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 215",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 215,
      "type": "source"
    }
  ],
