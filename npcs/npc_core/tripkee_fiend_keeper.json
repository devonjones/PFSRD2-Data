                    "name": "Player Core",
                    "page": 454,
                    "type": "source"
                  }
                ],
                "text": "An action with this trait requires a degree of mental concentration and discipline.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 48,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
                "game-obj": "Traits",
                "name": "Divine",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
