  "schema_version": 1.4,
  "sections": [
    {
      "name": "Surgeon",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 61",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 61",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 61,
          "type": "source"
        }
      ],
      "text": "The surgeon specializes in the physical alteration of the body to prevent the spread of disease, removing necrotic and decaying flesh to help the whole to survive. Few healers know the science of anatomy and physiology better.",
      "type": "section"
    }
  ],
  "sources": [
