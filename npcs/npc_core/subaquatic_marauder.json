  "name": "Subaquatic Marauder",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Subaquatic Marauder",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 149",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 149",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 149,
          "type": "source"
        }
      ],
      "text": "A new breed of pirate, these raiders strike at unsuspecting ships from beneath the cover of the waves. The bulky, reinforced diving suits they wear also serve as armor and clockwork mechanisms augment their strength.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 149",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 149",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 149,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Human",
        "Humanoid"
      ],
      "family": {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 196,
          "game-obj": "MonsterFamilies",
          "type": "alternate_link"
