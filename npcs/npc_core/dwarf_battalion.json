  "schema_version": 1.4,
  "sections": [
    {
      "name": "Dwarf Battalion",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 175",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 175",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 175,
          "type": "source"
        }
      ],
      "text": "Dwarven soldiers make formidable units, capable of holding their own against most enemies. In combat, a dwarf battalion is a well-oiled machine, unleashing coordinated attacks against foes.",
      "type": "section"
    }
  ],
  "sources": [
    {
