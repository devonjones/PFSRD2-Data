  "sections": [
    {
      "name": "Deluded Mob",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 155",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 155",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 155,
          "type": "source"
        }
      ],
      "text": "Pulled astray by lies, bribes, and propaganda, these desperate people are convinced to fight on their behalf of utter villains. Conspiracists, propagandists, masterminds, despots, and more take advantage of these mobs.",
      "type": "section"
    }
  ],
