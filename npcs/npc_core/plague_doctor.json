  "name": "Plague Doctor",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Plague Doctor",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 62",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 62",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 62,
          "type": "source"
        }
      ],
      "text": "These healers, often seen wearing distinctive masks and burning powders to defend against airborne plagues, are as much feared as they are respected. To see a plague doctor signals that disease has infested the land\u2014and that it might have already taken hold.",
      "type": "section"
    }
  ],
  "sources": [
