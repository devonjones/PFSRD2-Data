  "schema_version": 1.4,
  "sections": [
    {
      "name": "Forlorn Artist",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 178",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 178",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 178,
          "type": "source"
        }
      ],
      "text": "Forlorn elves, who spend their lives among shorter-lived peoples, often grow morose from constant loss. Some channel this melancholy into their art.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 178",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 178",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 178,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
