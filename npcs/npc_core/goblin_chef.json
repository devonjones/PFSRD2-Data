  "schema_version": 1.4,
  "sections": [
    {
      "name": "Goblin Chef",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 186",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 186",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 186,
          "type": "source"
        }
      ],
      "text": "Goblins eat almost anything. Though they'll survive on raw or little-cooked meat, some prefer searing or frying their food first\u2014or better yet, pickling it! A goblin chef can make anything edible (at least to a goblin).",
      "type": "section"
    }
  ],
