  "schema_version": 1.4,
  "sections": [
    {
      "name": "Kobold Trapper",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 198",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 198",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 198,
          "type": "source"
        }
      ],
      "text": "Kobolds are skillful artisans, always inventing new traps and snares to defend their territory and ambush enemies. Kobold trappers enjoy showing off their crafting prowess on the battlefield.",
      "type": "section"
    }
  ],
