  "sections": [
    {
      "name": "Construction Worker",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 70",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 70",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 70,
          "type": "source"
        }
      ],
      "text": "A brilliant architect can contemplate wondrous structural marvels, but someone must pick up a hammer and make these dreams real. Construction workers are the backbone of any city's infrastructure.",
      "type": "section"
    }
  ],
