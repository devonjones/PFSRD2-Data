  "schema_version": 1.4,
  "sections": [
    {
      "name": "Envoy",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 12",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 12",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 12,
          "type": "source"
        }
      ],
      "text": "Envoys are guests of a given court, representing the interests of another court or organization. Some envoys stay in one place so long they're practically considered locals, though those with whom they parley are swiftly reminded where their loyalty lies.",
      "type": "section"
    }
  ],
