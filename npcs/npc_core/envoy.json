                "game-obj": "Rules",
                "name": "+1/-3",
                "type": "link"
              },
              "subtype": "attack_bonus",
              "type": "stat_block_section"
            },
            "damage": [
              {
                "damage_type": "piercing",
                "formula": "1d4+2",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "name": "Ranged",
            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 170,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "52e96f4918ed43308370f4576b59947c",
                "game-obj": "Traits",
                "name": "Agile",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "The multiple attack penalty you take with this weapon on the second attack on your turn is \u20134 instead of \u20135, and \u20138 instead of \u201310 on the third and subsequent attacks in the turn.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 195,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c42503980965022311443a6e1e55ab57",
                "game-obj": "Traits",
                "name": "Thrown",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "You can throw this weapon as a ranged attack; it is a ranged weapon when thrown. You add your Strength modifier to damage as you would for a melee weapon. When this trait appears on a melee weapon, it also includes the range increment. Ranged weapons with this trait use the range increment in the weapon\u2019s Range entry.",
                "type": "trait",
                "value": "10 feet"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 200,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "ca5b7a642aef726cc9055981ca84f89d",
                "game-obj": "Traits",
                "name": "Versatile",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "A versatile weapon can be used to deal a different type of damage than its listed type. This trait indicates the alternate damage type. For instance, a piercing weapon with versatile S can deal piercing or slashing damage. You choose the damage type each time you attack.",
                "type": "trait",
                "value": "S"
              }
            ],
            "type": "stat_block_section",
            "weapon": "dagger"
          },
          "name": "Ranged",
          "offensive_action_type": "attack",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "frequency": "1 hour",
            "links": [
              {
                "alt": "disrupted",
                "aonid": 2342,
                "game-obj": "Rules",
                "name": "disrupted",
                "type": "link"
              },
              {
                "alt": "hostile action",
                "aonid": 300,
                "game-obj": "Rules",
                "name": "hostile action",
                "type": "link"
              }
            ],
            "name": "Diplomatic Immunity",
            "saving_throw": [
              {
                "dc": 15,
                "save_type": "Will",
                "subtype": "save_dc",
                "text": "DC 15 Will save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "The envoy invokes their diplomatic status. Until the end of the envoy's next turn, any creature that attempts to attack them must succeed at a DC 15 Will save or have their attack disrupted. The attacker gains weakness 2 to all damage from the envoy's allies while Diplomatic Immunity lasts, whether their attack was disrupted or not.  \nThe envoy can Sustain this ability. If the envoy takes a hostile action, Diplomatic Immunity ends and can't be used again for 1 hour.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 32,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "e32d877417a40fe977d27634dc14f99f",
                "game-obj": "Traits",
                "name": "Concentrate",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 454",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 454",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 454,
                    "type": "source"
                  }
                ],
                "text": "An action with this trait requires a degree of mental concentration and discipline.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 60,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "fb5f8b3d849b073e1514a6a025810470",
                "game-obj": "Traits",
                "name": "Emotion",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 455",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 455",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 455,
                    "type": "source"
                  }
                ],
                "text": "This effect alters a creature\u2019s emotions. Effects with this trait always have the mental trait as well. Creatures with special training or that have mechanical or artificial intelligence are immune to emotion effects.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 101,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
                "game-obj": "Traits",
                "name": "Linguistic",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "An effect with this trait depends on language comprehension. A linguistic effect that targets a creature works only if the target understands the language you are using.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 106,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "game-obj": "Traits",
                "name": "Mental",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section"
          },
