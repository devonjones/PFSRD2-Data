  "schema_version": 1.4,
  "sections": [
    {
      "name": "Druid Initiate",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 547",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 547",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 547,
          "type": "source"
        }
      ],
      "text": "A neophyte druid learns basic techniques and spellcasting soon after being initiated into their druidic order. The druid initiate has already learned much from their mentors\u2014elders among the order\u2014but hasn't had a chance to develop their own identity.",
      "type": "section"
    }
  ],
