  "sections": [
    {
      "name": "Local Herbalist",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 60",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 60",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 60,
          "type": "source"
        }
      ],
      "text": "Local herbalists use their understanding of the natural world to heal and restore balance. Most join a secret lodge that teaches these ancient arts.",
      "type": "section"
    }
  ],
  "sources": [
    {
