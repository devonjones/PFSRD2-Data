  "schema_version": 1.4,
  "sections": [
    {
      "name": "Obsessive Researcher",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 138",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 138",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 138,
          "type": "source"
        }
      ],
      "text": "Academia rewards specialization, and so the universities and athenaeums of the Inner Sea are full to the brim of sunlight-deprived scholars who are the world experts in such obscure topics such as the migratory habits of bogwids or the folklore of pre-Choral Brevoy.",
      "type": "section"
    }
  ],
  "sources": [
