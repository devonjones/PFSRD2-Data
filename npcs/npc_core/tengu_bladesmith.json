              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 198,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "0e8ed4994b70627221d17c355028e53f",
                "game-obj": "Traits",
                "name": "Two-Hand",
                "sources": [
                  {
