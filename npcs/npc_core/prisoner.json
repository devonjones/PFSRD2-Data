            ],
            "name": "Braving The Mob",
            "sources": [
              {
                "link": {
                  "alt": "NPC Core pg. 40",
                  "aonid": 236,
                  "game-obj": "Sources",
                  "name": "NPC Core pg. 40",
                  "type": "link"
                },
                "name": "NPC Core",
                "page": 40,
                "type": "source"
              }
            ],
            "text": "A mob is a violent crowd that works as greater difficult terrain and hazardous terrain, dealing 1d4 damage for each square entered. A creature can spend a single action to attempt a DC 16 Intimidation check, clearing the mob from all squares adjacent to them on a success (or all squares within 10 feet on a critical success). This action has the concentrate, emotion, manipulate, and mental traits. If the mob is meant to be a combat encounter, you can instead use the deluded mob.",
            "type": "section"
          }
        ],
        "sources": [
          {
            "link": {
              "alt": "NPC Core pg. 40",
              "aonid": 236,
              "game-obj": "Sources",
              "name": "NPC Core pg. 40",
              "type": "link"
            },
            "name": "NPC Core",
            "page": 40,
            "type": "source"
          }
        ],
        "text": "Unfortunately, every society has people living on its fringes.",
        "type": "monster_family"
