          "game-id": "d2f0b049794167d52146f46a7264e39f",
          "game-obj": "Traits",
          "name": "Human",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
