  "schema_version": 1.4,
  "sections": [
    {
      "name": "Bandit Gang",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 22",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 22",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 22,
          "type": "source"
        }
      ],
      "text": "Cutthroat crews of criminals form gangs to take out larger scores and intimidate their victims. Bandit gangs are often accompanied by a gang leader.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 22",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 22",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 22,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Human",
        "Humanoid",
        "Troop"
      ],
      "family": {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 182,
          "game-obj": "MonsterFamilies",
