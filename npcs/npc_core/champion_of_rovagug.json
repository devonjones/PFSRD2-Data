          "name": "Champion's Aura",
          "range": {
            "range": 15,
            "subtype": "range",
            "text": "15 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "subtype": "ability",
          "text": "Any follower of Rovagug in the aura knows the champion is a champion of Rovagug. Enemies in the aura take a \u20131 circumstance penalty to saves against fear, and an enemy that ends its turn in the aura can't reduce the value of its frightened condition below 1. The aura can be suppressed or resumed with a single action, which has the concentrate trait, and ends if the champion falls unconscious.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 206,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "5315505cfd3f3ba2685e9747898193b2",
              "game-obj": "Traits",
              "name": "Aura",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
