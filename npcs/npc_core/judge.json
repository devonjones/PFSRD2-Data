  "schema_version": 1.4,
  "sections": [
    {
      "name": "Judge",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 108",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 108",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 108,
          "type": "source"
        }
      ],
      "text": "Properly exercised, the duties of a judge include strict adherence to the law regardless of station, with minimal sentimentality. Yet for every unbiased justice, there's one who is zealously confident in their own agenda.",
      "type": "section"
    }
  ],
  "sources": [
