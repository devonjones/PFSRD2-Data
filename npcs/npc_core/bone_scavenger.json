  "sections": [
    {
      "name": "Bone Scavenger",
      "sections": [
        {
          "image": {
            "image": "Sidebar_1_AdviceAndRules.png",
            "name": "Advice and Rules",
            "type": "image"
          },
          "name": "Ant Kholos",
          "sidebar_heading": "Advice and Rules",
          "sidebar_type": "advice_and_rules",
          "sources": [
            {
              "link": {
                "alt": "NPC Core pg. 196",
                "aonid": 236,
                "game-obj": "Sources",
                "name": "NPC Core pg. 196",
                "type": "link"
              },
              "name": "NPC Core",
              "page": 196,
              "type": "source"
            }
          ],
          "subtype": "sidebar",
          "text": "The bone scavenger belongs to the ant kholo heritage, smaller and with larger ears than other kholos. You can change this NPC to a different kholo heritage by making it Medium, and you can conversely change a different kholo NPC to an ant kholo by making their size Small.",
          "type": "section"
        }
      ],
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 196",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 196",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 196,
          "type": "source"
        }
      ],
      "text": "Kholos have a strong connection to their ancestors, often using their bones as art and weapons to further honor them. Bone scavengers are sent to the fields after a battle to collect the bones of their fellow allies. They often eschew the pack hunting techniques of other kholos, spreading out among their foes when encountered in groups.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 196",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 196",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 196,
      "type": "source"
    }
  ],
