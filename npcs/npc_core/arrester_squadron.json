  "schema_version": 1.4,
  "sections": [
    {
      "name": "Arrester Squadron",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 118",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 118",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 118,
          "type": "source"
        }
      ],
      "text": "These guards have been extensively trained to perform complex maneuvers together. They are sent to capture accused criminals believed to be especially dangerous (whether due to their own abilities or due to their allies).",
      "type": "section"
    }
  ],
  "sources": [
