          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "6849416011c8c26de22cca22c8c970e8",
          "game-obj": "Traits",
          "name": "Leshy",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 458",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 458",
                "type": "link"
              },
              "name": "Player Core",
              "page": 458,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the leshy ancestry. These small plant or fungus creatures are humanoid in form. An ability with this trait can be used or selected only by leshies. A weapon with this trait is created and used by leshies.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 125,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "651e06f09e5aea780d7c70a36ce5b1f2",
          "game-obj": "Traits",
          "name": "Plant",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 459",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 459",
                "type": "link"
              },
              "name": "Player Core",
              "page": 459,
              "type": "source"
            }
          ],
          "text": "Vegetable creatures have the plant trait. They are distinct from normal plants. Magical effects with this trait manipulate or conjure plants or plant matter in some way. Effects that manipulate plants have no effect in an area with no plants.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 367,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "2d407154112121f24c49d97c89d90b55",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "troop defenses",
              "aonid": 86,
              "game-obj": "MonsterAbilities",
              "name": "troop defenses",
              "type": "link"
            },
            {
              "alt": "troop movement",
              "aonid": 85,
              "game-obj": "MonsterAbilities",
              "name": "troop movement",
              "type": "link"
            }
          ],
          "name": "Troop",
          "sources": [
            {
              "link": {
                "alt": "NPC Core pg. 238",
                "aonid": 236,
                "game-obj": "Sources",
                "name": "NPC Core pg. 238",
                "type": "link"
              },
              "name": "NPC Core",
              "page": 238,
              "type": "source"
            }
          ],
          "text": "A troop is an organized collection of component creatures, typically Small or Medium in size, working as a cohesive whole. Over the course of enough attacks and downed comrades, troops shrink in size. A troop typically has the troop defenses and troop movement abilities, and most troops have weaknesses to area damage and splash damage. Because they consist of multiple discrete creatures, they can't be summoned.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
    "defense": {
      "ac": {
        "subtype": "armor_class",
        "type": "stat_block_section",
        "value": 21
      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Encircling Maze",
          "subtype": "ability",
          "text": "A corn leshy throng is arranged in rows of stalks to envelop foes, stretching upward to block their vision. It can move into other creatures' spaces, and other creatures can move into its squares.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "Troop Defenses",
              "aonid": 44,
              "game-obj": "MonsterAbilities",
              "name": "Troop Defenses",
              "type": "link"
            },
            {
              "alt": "Survival",
              "aonid": 49,
              "game-obj": "Skills",
              "name": "Survival",
              "type": "link"
            },
            {
              "alt": "greater difficult terrain",
              "aonid": 453,
              "game-obj": "Rules",
              "name": "greater difficult terrain",
              "type": "link"
            }
          ],
          "name": "Troop Defenses",
          "saving_throw": [
            {
              "dc": 20,
              "subtype": "save_dc",
              "text": "DC 20",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "When a Medium or smaller creature attempts to enter any of the corn leshy throng's spaces, it must attempt a DC 20 Survival check. If the creature fails, it gets turned around\u2014all the throng's squares are greater difficult terrain for it until the end of this turn. A creature needs to attempt this check only the first time in a round it attempts to enter one of the throng's squares.",
          "type": "stat_block_section",
          "universal_monster_ability": {
            "ability_type": "universal_monster_ability",
            "aonid": 86,
            "edition": "remastered",
            "game-id": "80c36d6067f5b5aa7530731a70f98a00",
            "game-obj": "MonsterAbilities",
            "links": [
              {
                "alt": "Troops",
                "aonid": 849,
                "game-obj": "Traits",
                "name": "Troops",
                "type": "link"
              },
              {
                "alt": "charm",
                "aonid": 1463,
                "game-obj": "Spells",
                "name": "charm",
                "type": "link"
              },
              {
                "alt": "Demoralize",
                "aonid": 2395,
                "game-obj": "Actions",
                "name": "Demoralize",
                "type": "link"
              }
            ],
            "name": "Troop Defenses",
            "sources": [
              {
                "link": {
                  "alt": "NPC Core pg. 231",
                  "aonid": 236,
                  "game-obj": "Sources",
                  "name": "NPC Core pg. 231",
                  "type": "link"
                },
                "name": "NPC Core",
                "page": 231,
                "type": "source"
              }
            ],
            "text": "Troops are composed of many individuals, represented by four \u201csegments\u201d on a battle grid. Each segment is 10 feet on each side and as tall as the individual members of the troop. Segments must remain contiguous. Each one has to share at least 5 feet of one of its edges with another segment\u2014 being adjacent on a diagonal isn't sufficient! You can measure flanking, cover, and the like using the center of any segment.  \n  \n A troop has two Hit Point thresholds in its HP entry and loses segments as it crosses thresholds. Typically, the higher threshold is at 2/3 of the troop's maximum Hit Points and the lower is at 1/3 of its maximum. Once the troop drops below the higher threshold, it loses one segment, leaving three segments (12 squares) remaining and setting the first threshold as the troop's new maximum Hit Points. This repeats when the troop drops below the lower threshold, leaving two segments (8 squares). At 0 Hit Points, the troop disperses entirely, with the few remaining members surrendering, fleeing, or easily dispatched, as determined by the GM. Typically the creature who caused the troop to lose a segment decides which to remove, or the GM decides when a specific creature wasn't responsible. To restore lost segments and maximum Hit Points, a troop needs to spend downtime to use long-term treatment on casualties or recruit new members to replace the fallen.  \n  \n Troops are typically immune to non-damaging effects that target a single creature, such as a *charm* spell or the Demoralize action. An ability that can target 5 or more creatures can target an entire segment, increasing to two segments if it can target 10 or more creatures and to the entire troop if it can target 20 or more creatures. An ability that affects all creatures in a certain range affects all segments in range (make any checks or saves separately for each segment). As examples, an 8th- rank charm spell (with 10 targets) can affect two segments, and an ability that Demoralizes all creatures within 30 feet of you would affect all segments that are fully within that range. A non-damaging ability that would prevent a segment from acting, cause them to flee, or otherwise make them unable to function as part of the troop for a round or more removes the segment entirely. The troop loses a number of HP required to bring it to the next threshold. If an ability both deals damage and has a non-damaging effect, apply the damage then the rest of the effect.",
            "type": "ability"
          }
        },
        {
          "ability_type": "automatic",
          "area": [
            {
              "shape": "emanation",
              "size": 30,
              "subtype": "area",
              "text": "30-foot emanation",
              "type": "stat_block_section",
              "unit": "feet"
            }
          ],
          "links": [
            {
              "alt": "difficult terrain",
              "aonid": 453,
              "game-obj": "Rules",
              "name": "difficult terrain",
              "type": "link"
            }
          ],
          "name": "Verdant Burst",
          "subtype": "ability",
          "text": "When the corn leshy throng dies, a burst of primal energy explodes from their body, restoring 3d8 Hit Points to each plant creature in a 30-foot emanation. This area immediately fills with stalks of corn, becoming difficult terrain. If the terrain is not a viable environment for these plants, they wither after 24 hours.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 89,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "46d51374c2ada72347818dbac1edd7a3",
              "game-obj": "Traits",
              "name": "Healing",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 457",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 457",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 457,
                  "type": "source"
                }
              ],
              "text": "A healing effect restores a creature\u2019s body, typically by restoring Hit Points, but sometimes by removing diseases or other debilitating effects.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 134,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "60a4f011afd1e0fac8211bd01108d104",
              "game-obj": "Traits",
              "name": "Primal",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 460",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 460",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 460,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the primal tradition, connecting to the natural world and instinct. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to primal magic.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 128,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6571a8a0a7aae945b34252db53de1861",
              "game-obj": "Traits",
              "links": [
                {
                  "alt": "undead",
                  "aonid": 160,
                  "game-obj": "Traits",
                  "name": "undead",
                  "type": "link"
                }
              ],
              "name": "Vitality",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 463",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 463",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 463,
                  "type": "source"
                }
              ],
              "text": "Effects with this trait heal living creatures with energy from the Forge of Creation, deal vitality energy damage to undead, or manipulate vitality energy.  \n  \nThese planes are awash with life energy. Colors are brighter, fires are hotter, noises are louder, and sensations are more intense. At the end of each round, an undead creature takes at least minor vitality environmental damage. In the strongest areas of a vitality plane, they could take moderate or even major vitality damage instead. While this might seem safe for living creatures, vitality planes present a different danger. Living creatures regain an amount of HP each round equal to the environmental damage undead take in the same area. If this would bring the living creature above their maximum HP, any excess becomes temporary HP. Unlike normal, these temporary HP combine with each other, and they last until the creature leaves the plane. If a creature\u2019s temporary HP from a vitality plane ever exceeds its maximum HP, it explodes in a burst of overloaded vitality energy, spreading across the area to birth new souls.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
