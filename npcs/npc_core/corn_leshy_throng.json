  "name": "Corn Leshy Throng",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Corn Leshy Throng",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 201",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 201",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 201,
          "type": "source"
        }
      ],
      "text": "A thick forest or flourishing farm sometimes sees an explosion of primal magic leading to the creation of a multitude of leshies. When still young, these spirits might band together with their crop-mates for protection or to achieve a mutual goal. Used to growing in rows, many corn leshies can form a sizable legion.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 201",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 201",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 201,
      "type": "source"
    }
  ],
  "stat_block": {
    "creature_type": {
      "creature_types": [
        "Leshy",
        "Plant",
        "Troop"
      ],
