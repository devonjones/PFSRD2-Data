    "name": "Political Upstart",
    "offense": {
      "offensive_actions": [
        {
          "attack": {
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "attack_type": "melee",
            "bonus": {
              "bonuses": [
                5,
                1,
                -3
              ],
              "link": {
                "alt": "+1/-3",
                "aonid": 322,
                "game-obj": "Rules",
                "name": "+1/-3",
                "type": "link"
              },
              "subtype": "attack_bonus",
              "type": "stat_block_section"
            },
            "damage": [
              {
                "damage_type": "bludgeoning",
                "formula": "1d4",
                "subtype": "attack_damage",
                "type": "stat_block_section"
              }
            ],
            "name": "Melee",
            "subtype": "attack",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 170,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "52e96f4918ed43308370f4576b59947c",
                "game-obj": "Traits",
                "name": "Agile",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "The multiple attack penalty you take with this weapon on the second attack on your turn is \u20134 instead of \u20135, and \u20138 instead of \u201310 on the third and subsequent attacks in the turn.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 179,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a57956799f3d30121d529e48f12904c",
                "game-obj": "Traits",
                "name": "Finesse",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You can use your Dexterity modifier instead of your Strength modifier on attack rolls using this melee weapon. You still calculate damage using Strength.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 188,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "312297acabb98ff0cdf19025756472d7",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "nonlethal",
                    "aonid": 2311,
                    "game-obj": "Rules",
                    "name": "nonlethal",
                    "type": "link"
                  }
                ],
                "name": "Nonlethal",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "Attacks with this weapon are nonlethal, and are used to knock creatures unconscious instead of kill them. You can use a nonlethal weapon to make a lethal attack with a \u20132 circumstance penalty.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 199,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "b33cff5f3243a6681e903029455f779a",
                "game-obj": "Traits",
                "name": "Unarmed",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "An unarmed attack uses your body rather than a manufactured weapon. An unarmed attack isn\u2019t a weapon, though has a weapon group and might have weapon traits. An unarmed attack can\u2019t be Disarmed. It also doesn\u2019t take up a hand, though a fist or other grasping appendage generally works like a free-hand weapon.",
                "type": "trait"
              }
            ],
            "type": "stat_block_section",
            "weapon": "fist"
          },
          "name": "Melee",
          "offensive_action_type": "attack",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "One Action",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "name": "Fiery Rhetoric",
            "range": {
              "range": 30,
              "subtype": "range",
              "text": "within 30 feet",
              "type": "stat_block_section",
              "unit": "feet"
            },
            "subtype": "ability",
            "text": "The upstart rattles off talking points at an enemy within 30 feet. The target takes a \u20132 status penalty to Perception and Will saves for 1 minute.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
