  "schema_version": 1.4,
  "sections": [
    {
      "name": "Jinx Eater",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 212",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 212",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 212,
          "type": "source"
        }
      ],
      "text": "Whether kidnapped, conscripted, or having entered voluntary service, a tengu in the role of jinx eater on a ship's crew is tasked with keeping the crew free of misfortune. Those with the necessary skill to do so often achieve a respected and privileged position on board.",
      "type": "section"
    }
  ],
  "sources": [
