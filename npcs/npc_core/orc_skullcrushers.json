  "schema_version": 1.4,
  "sections": [
    {
      "name": "Orc Skullcrushers",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 207",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 207",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 207,
          "type": "source"
        }
      ],
      "text": "Orc warriors search for more effective weapons and tactics\u2014most physical, but some magical. As they fought back against the undead on their borders, they formed bands of skullcrushers to crush hordes of skeletons.",
      "type": "section"
    }
  ],
  "sources": [
    {
