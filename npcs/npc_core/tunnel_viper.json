  "schema_version": 1.4,
  "sections": [
    {
      "name": "Tunnel Viper",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 210",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 210",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 210,
          "type": "source"
        }
      ],
      "text": "There is no better way for a ysoki to distinguish themself than to defend the warren, with many proving themselves by venturing out and challenging monsters they come across. Those who return triumphant from such tests find themselves among the ranks of ysoki warriors, able to wear their accomplishments as a badge of pride. They often venture out again once established and experienced to attain more notoriety as warriors.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 210",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 210",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 210,
      "type": "source"
    }
  ],
