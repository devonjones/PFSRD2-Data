  "schema_version": 1.4,
  "sections": [
    {
      "name": "Goblin Scavenger",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 186",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 186",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 186,
          "type": "source"
        }
      ],
      "text": "Many goblins scavenge materials, shiny objects, and anything else they can get their hands on, but a goblin scavenger is the best at finding such useful items. More importantly, they're great at making use of them without killing themselves. Most of the time.",
      "type": "section"
    }
  ],
  "sources": [
