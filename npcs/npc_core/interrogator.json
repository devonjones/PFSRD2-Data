                },
                "edition": "remastered",
                "game-id": "36bd7375ee334ca30404dac02062c504",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "off-guard",
                    "aonid": 58,
                    "game-obj": "Conditions",
                    "name": "off-guard",
                    "type": "link"
                  }
                ],
                "name": "Backstabber",
                "sources": [
                  {
