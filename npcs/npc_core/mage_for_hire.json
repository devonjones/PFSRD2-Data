  "schema_version": 1.4,
  "sections": [
    {
      "name": "Mage For Hire",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 82",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 82",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 82,
          "type": "source"
        }
      ],
      "text": "Some mercenaries sell magical talents to earn a living. While there are many types of mages for hire, some of the sneakiest are specialized in scrying, using their skills for infiltration and sabotage.",
      "type": "section"
    }
  ],
