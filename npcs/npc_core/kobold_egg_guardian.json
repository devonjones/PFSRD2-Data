            ],
            "name": "Immobilizing Thrust",
            "saving_throw": [
              {
                "dc": 20,
                "save_type": "Ref",
                "subtype": "save_dc",
                "text": "DC 20 Reflex save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "The kobold egg guardian makes a longspear Strike. If the Strike hits, the target must attempt a DC 20 Reflex save. On a failure, the creature is immobilized until the kobold egg guardian moves, attacks with the longspear, or is no longer wielding the longspear.",
            "type": "stat_block_section"
          },
          "name": "Immobilizing Thrust",
          "offensive_action_type": "ability",
          "subtype": "offensive_action",
          "type": "stat_block_section"
        },
        {
          "ability": {
            "ability_type": "offensive",
            "action_type": {
              "name": "Two Actions",
              "subtype": "action_type",
              "type": "stat_block_section"
            },
            "links": [
              {
                "alt": "fascinated",
                "aonid": 72,
                "game-obj": "Conditions",
                "name": "fascinated",
                "type": "link"
              }
            ],
            "name": "Luring Retreat",
            "saving_throw": [
              {
                "dc": 17,
                "save_type": "Will",
                "subtype": "save_dc",
                "text": "DC 17 Will save",
                "type": "stat_block_section"
              }
            ],
            "subtype": "ability",
            "text": "The kobold egg guardian screams and Strides up to their Speed. Each enemy who sees or hears the kobold egg guardian must succeed at a DC 17 Will save or be fascinated by the egg guardian for 1 round. On the creature's turn, it must use at least 1 action (or 2 actions on a critical failure) to move closer to the kobold egg guardian (while avoiding obvious dangers). Regardless of the result of the save, targets are then immune to Luring Retreat for 24 hours.",
            "traits": [
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 16,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "84c09922ddd30f2144494f2cb6f19412",
                "game-obj": "Traits",
                "name": "Auditory",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 453",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 453",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 453,
                    "type": "source"
                  }
                ],
                "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 106,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a1f80610baa3617c1597f49c6406313",
                "game-obj": "Traits",
                "name": "Mental",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 163,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
