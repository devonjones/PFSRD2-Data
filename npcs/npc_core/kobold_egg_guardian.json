  "schema_version": 1.4,
  "sections": [
    {
      "name": "Kobold Egg Guardian",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 198",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 198",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 198,
          "type": "source"
        }
      ],
      "text": "Kobold egg guardians are some of the best warriors in a tribe, tasked with protecting the next generation. They pledge to give their lives to protect the tribe's eggs, though not before exhausting all their tricks.",
      "type": "section"
    }
  ],
