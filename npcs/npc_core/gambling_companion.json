  "schema_version": 1.4,
  "sections": [
    {
      "name": "Gambling Companion",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 212",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 212",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 212,
          "type": "source"
        }
      ],
      "text": "A reputation for protecting against bad luck, combined with skill and knowledge, establish these tengu as ideal gambling companions. Their role includes providing local knowledge of establishments as well as the various games available. Refined skills of observation and an ability to read other players increases the value of their services. The example provided is for a companion who frequents the finer establishments. For some areas, a patron would look for a companion with greater fighting skills to also fill the role of bodyguard.",
      "type": "section"
    }
  ],
  "sources": [
