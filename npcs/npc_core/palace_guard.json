  "name": "Palace Guard",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Palace Guard",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 14",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 14",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 14,
          "type": "source"
        }
      ],
      "text": "Often the younger offspring of minor nobility or those from long lines of trusted staff, palace guards are in charge of defending the royal family and their inner stronghold. Their days consist of guarding doorways, escorting nobles, and keeping those in their charge as safe as possible.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "link": {
        "alt": "NPC Core pg. 14",
        "aonid": 236,
        "game-obj": "Sources",
        "name": "NPC Core pg. 14",
        "type": "link"
      },
      "name": "NPC Core",
      "page": 14,
      "type": "source"
    }
  ],
