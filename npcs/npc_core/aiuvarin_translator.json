      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "The translator attempts a Performance check with a +5 circumstance bonus against the Will DC of the creature. On a success, the creature is unaffected by the linguistic effect, and the translator can choose to make the creature confused until the end of the creature's next turn.",
          "links": [
            {
              "alt": "linguistic",
              "aonid": 642,
              "game-obj": "Traits",
              "name": "linguistic",
              "type": "link"
            },
            {
              "alt": "Performance",
              "aonid": 45,
              "game-obj": "Skills",
              "name": "Performance",
              "type": "link"
            },
            {
              "alt": "confused",
              "aonid": 63,
              "game-obj": "Conditions",
              "name": "confused",
              "type": "link"
            }
          ],
          "name": "Crosstalk",
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 16,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "84c09922ddd30f2144494f2cb6f19412",
              "game-obj": "Traits",
              "name": "Auditory",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "Auditory actions and effects rely on sound. An action with the auditory trait can be successfully performed only if the creature using the action can speak or otherwise produce the required sounds. A spell or effect with the auditory trait has its effect only if the target can hear it. This applies only to sound-based parts of the effect, as determined by the GM. This is different from a sonic effect, which still affects targets who can\u2019t hear it (such as deaf targets) as long as the effect itself makes sound.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 32,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "e32d877417a40fe977d27634dc14f99f",
              "game-obj": "Traits",
              "name": "Concentrate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 454",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 454,
                  "type": "source"
                }
              ],
              "text": "An action with this trait requires a degree of mental concentration and discipline.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 101,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "c1c0a189dd3d1a3d7c5daf9a6bafba49",
              "game-obj": "Traits",
              "name": "Linguistic",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "An effect with this trait depends on language comprehension. A linguistic effect that targets a creature works only if the target understands the language you are using.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 106,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a1f80610baa3617c1597f49c6406313",
              "game-obj": "Traits",
              "name": "Mental",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature.",
              "type": "trait"
            }
          ],
          "trigger": "A creature within 20 feet of the translator would be targeted by or in the area of an ability with the linguistic trait",
          "type": "stat_block_section"
        }
      ],
