  "schema_version": 1.4,
  "sections": [
    {
      "name": "Aiuvarin Translator",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 178",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 178",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 178,
          "type": "source"
        }
      ],
      "text": "Many societies recognize aiuvarins' skills as adept translators.",
      "type": "section"
    }
  ],
