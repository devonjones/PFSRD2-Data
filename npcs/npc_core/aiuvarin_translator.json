          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "ae6472f1355dd22f5c4debf05ec1d209",
          "game-obj": "Traits",
          "name": "Aiuvarin",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "A creature with this trait has the aiuvarin versatile heritage. Aiuvarins are of mixed ancestry, including elves or other aiuvarins. An ability with this trait can be used or selected only by aiuvarins.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 58,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "a023c0f7b7ead52667c69b7b4184b996",
          "game-obj": "Traits",
          "name": "Elf",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 455",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 455",
                "type": "link"
              },
              "name": "Player Core",
              "page": 455,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the elf ancestry. Elves are mysterious people with rich traditions of magic and scholarship who typically have low-light vision. An ability with this trait can be used or selected only by elves. A weapon with this trait is created and used by elves.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 90,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "d2f0b049794167d52146f46a7264e39f",
          "game-obj": "Traits",
          "name": "Human",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the human ancestry. Humans are a diverse array of people known for their adaptability. An ability with this trait can be used or selected only by humans.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Humanoid creatures reason and act much like humans. They typically stand upright and have two arms and two legs.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
    "defense": {
