  "sections": [
    {
      "name": "Departmental Chair",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 141",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 141",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 141,
          "type": "source"
        }
      ],
      "text": "All the departmental chair really wants is a chance to quietly do their research. Instead, they've been roped into dealing with every emergency\u2014political, supernatural, or emotional\u2014in the university. They are not thrilled about this.",
      "type": "section"
    }
  ],
