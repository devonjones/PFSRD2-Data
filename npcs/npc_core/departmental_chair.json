                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You can use your Dexterity modifier instead of your Strength modifier on attack rolls using this melee weapon. You still calculate damage using Strength.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 188,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "312297acabb98ff0cdf19025756472d7",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "nonlethal",
                    "aonid": 2311,
                    "game-obj": "Rules",
                    "name": "nonlethal",
                    "type": "link"
                  }
                ],
                "name": "Nonlethal",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "Attacks with this weapon are nonlethal, and are used to knock creatures unconscious instead of kill them. You can use a nonlethal weapon to make a lethal attack with a \u20132 circumstance penalty.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 199,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "b33cff5f3243a6681e903029455f779a",
                "game-obj": "Traits",
                "name": "Unarmed",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "An unarmed attack uses your body rather than a manufactured weapon. An unarmed attack isn\u2019t a weapon, though has a weapon group and might have weapon traits. An unarmed attack can\u2019t be Disarmed. It also doesn\u2019t take up a hand, though a fist or other grasping appendage generally works like a free-hand weapon.",
                "type": "trait"
              }
            ],
