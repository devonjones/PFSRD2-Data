                  "aonid": 199,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "b33cff5f3243a6681e903029455f779a",
                "game-obj": "Traits",
                "name": "Unarmed",
                "sources": [
                  {
