  "name": "Kobold Earth Diver",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Kobold Earth Diver",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 199",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 199",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 199,
          "type": "source"
        }
      ],
      "text": "Kobold earth divers study the geology of the areas near their communities. The mystical influence of their community's patron or years of extensive training at digging or earth magic allow them to swiftly burrow through the ground and to feel movements in the ground beneath their feet.",
      "type": "section"
    }
  ],
