                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "6a57956799f3d30121d529e48f12904c",
                "game-obj": "Traits",
                "name": "Finesse",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
