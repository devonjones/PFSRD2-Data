  "schema_version": 1.4,
  "sections": [
    {
      "name": "Forager",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 52",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 52",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 52,
          "type": "source"
        }
      ],
      "text": "Foragers know the areas they live and work in like no other. They can tell you exactly where to find a rare medicinal fern, when to harvest it, and how to use it; just don't expect them to be up-to-date on the latest town gossip. They spend as much time in the wilderness as they can, filling their baskets with a variety of useful plants.",
      "type": "section"
    }
  ],
  "sources": [
    {
