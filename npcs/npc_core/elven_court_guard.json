  "schema_version": 1.4,
  "sections": [
    {
      "name": "Elven Court Guard",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 180",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 180",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 180,
          "type": "source"
        }
      ],
      "text": "In the tangled web of lineages, rivalries, and shifting alliances that is an elven noble court, aristocratic families employ bodyguards loyal to them alone.",
      "type": "section"
    }
  ],
  "sources": [
    {
