                "links": [
                  {
                    "alt": "nonlethal",
                    "aonid": 2311,
                    "game-obj": "Rules",
                    "name": "nonlethal",
                    "type": "link"
                  }
                ],
                "name": "Nonlethal",
                "sources": [
                  {
