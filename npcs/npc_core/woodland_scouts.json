          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "a023c0f7b7ead52667c69b7b4184b996",
          "game-obj": "Traits",
          "name": "Elf",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 455",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 455",
                "type": "link"
              },
              "name": "Player Core",
              "page": 455,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the elf ancestry. Elves are mysterious people with rich traditions of magic and scholarship who typically have low-light vision. An ability with this trait can be used or selected only by elves. A weapon with this trait is created and used by elves.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Humanoid creatures reason and act much like humans. They typically stand upright and have two arms and two legs.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 367,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "2d407154112121f24c49d97c89d90b55",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "troop defenses",
              "aonid": 86,
              "game-obj": "MonsterAbilities",
              "name": "troop defenses",
              "type": "link"
            },
            {
              "alt": "troop movement",
              "aonid": 85,
              "game-obj": "MonsterAbilities",
              "name": "troop movement",
              "type": "link"
            }
          ],
          "name": "Troop",
          "sources": [
            {
              "link": {
                "alt": "NPC Core pg. 238",
                "aonid": 236,
                "game-obj": "Sources",
                "name": "NPC Core pg. 238",
                "type": "link"
              },
              "name": "NPC Core",
              "page": 238,
              "type": "source"
            }
          ],
          "text": "A troop is an organized collection of component creatures, typically Small or Medium in size, working as a cohesive whole. Over the course of enough attacks and downed comrades, troops shrink in size. A troop typically has the troop defenses and troop movement abilities, and most troops have weaknesses to area damage and splash damage. Because they consist of multiple discrete creatures, they can't be summoned.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
