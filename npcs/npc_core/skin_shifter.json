  "schema_version": 1.4,
  "sections": [
    {
      "name": "Skin Shifter",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 134",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 134",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 134,
          "type": "source"
        }
      ],
      "text": "Skin shifters are defenders of nature, blessed by the spirits of the wild with the ability to shape shift into powerful animal forms. Prowling as beasts or charging across the field, they protect the balance of nature and punish those who would upset it.",
      "type": "section"
    }
  ],
