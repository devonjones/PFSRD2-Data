  "schema_version": 1.4,
  "sections": [
    {
      "name": "Bodyguard",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 82",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 82",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 82,
          "type": "source"
        }
      ],
      "text": "Hired to protect someone famous or powerful, bodyguards use intimidation, quick wits, and martial skill to keep their charges safe. Such mercenaries might be auxiliaries to a noble's personal guards, but with special directives to safeguard their patrons.",
      "type": "section"
    }
  ],
