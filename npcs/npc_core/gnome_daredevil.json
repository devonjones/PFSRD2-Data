                        }
                      ],
                      "name": "Unflappable",
                      "subtype": "ability",
                      "text": "When the bleachling gnome rolls a critical failure on a check with the emotion trait, they get a failure instead.",
                      "type": "stat_block_section"
                    }
                  ],
                  "change_category": "abilities",
                  "effects": [
