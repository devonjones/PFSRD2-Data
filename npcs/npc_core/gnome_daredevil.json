  "name": "Gnome Daredevil",
  "pfs": {
    "availability": "Standard",
    "subtype": "pfs",
    "type": "stat_block_section"
  },
  "schema_version": 1.4,
  "sections": [
    {
      "name": "Gnome Daredevil",
      "sources": [
        {
          "link": {
            "alt": "NPC Core pg. 183",
            "aonid": 236,
            "game-obj": "Sources",
            "name": "NPC Core pg. 183",
            "type": "link"
          },
          "name": "NPC Core",
          "page": 183,
          "type": "source"
        }
      ],
      "text": "These nimble warriors capitalize on their slight stature and dexterous movements to evade and overtake their foes on the battlefield. Their unmatched skill with the gnome flickmace allows a daredevil to strike from a short distance and twirl away unscathed, sometimes hitting hard enough to topple their foes.",
      "type": "section"
    }
  ],
  "sources": [
    {
