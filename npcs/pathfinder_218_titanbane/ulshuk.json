      },
      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "name": "Aura of the All-Seeing Eye",
          "range": {
            "range": 10,
            "subtype": "range",
            "text": "10 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "subtype": "ability",
          "text": "Ulshuk and his allies within the aura gain a +1 status bonus to saving throws against spells.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 206,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "5315505cfd3f3ba2685e9747898193b2",
              "game-obj": "Traits",
              "name": "Aura",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 453",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 453",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 453,
                  "type": "source"
                }
              ],
              "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 48,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "243cd4d729d5eddd1e2c4635b7985fb9",
              "game-obj": "Traits",
              "name": "Divine",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 455",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 455",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 455,
                  "type": "source"
                }
              ],
              "text": "This magic comes from the divine tradition, drawing power from deities or similar sources. Anything with this trait is magical.  \n  \nA creature with this trait is primarily constituted of or has a strong connection to divine magic.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        }
      ],
