              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* 5 feet, *Reach (Tall):* 5 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 90,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "d2f0b049794167d52146f46a7264e39f",
          "game-obj": "Traits",
          "name": "Human",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the human ancestry. Humans are a diverse array of people known for their adaptability. An ability with this trait can be used or selected only by humans.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 226,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "fb818a4accf5634080e895b421bedf8c",
          "game-obj": "Traits",
          "links": [
            {
              "alt": "lizardfolk",
              "aonid": 81,
              "game-obj": "Ancestries",
              "name": "lizardfolk",
              "type": "link"
            }
          ],
          "name": "Lizardfolk",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 227,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Player Core 2 pg. 317",
                "aonid": 227,
                "game-obj": "Sources",
                "name": "Player Core 2 pg. 317",
                "type": "link"
              },
              "name": "Player Core 2",
              "page": 317,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the lizardfolk ancestry, a family of reptilian humanoids. An ability with this trait can be used or selected only by lizardfolk.",
          "type": "trait"
        },
        {
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "40b5d9c5e49dbe2aea5d7ecf38d950f3",
          "game-obj": "Traits",
          "name": "Mythic",
          "sources": [
            {
              "link": {
                "alt": "War of Immortals pg. 69",
                "aonid": 232,
                "game-obj": "Sources",
                "name": "War of Immortals pg. 69",
                "type": "link"
              },
              "name": "War of Immortals",
              "page": 69,
              "type": "source"
            }
          ],
          "text": "Options with this trait grant or utilize mythic power. Feats with the mythic trait can only be taken by mythic characters, who are typically characters with a mythic Calling.  \n  \n Monsters with the mythic trait have access to a pool of Mythic Points and are particularly strong for creatures of their level. Many mythic monsters are either resistant or entirely immune to attacks from non-mythic creatures and weapons.  \n  \n Spells with the mythic trait require the expenditure of a Mythic Point in order to be cast, and items with the mythic trait require the expenditure of a Mythic Point in order to use their activated abilities.  \n  \n Weapons with the mythic trait overcome the resistances and immunities of mythic monsters.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Humanoid creatures reason and act much like humans. They typically stand upright and have two arms and two legs.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
    "defense": {
      "ac": {
