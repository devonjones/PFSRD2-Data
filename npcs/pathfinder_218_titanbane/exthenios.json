              "type": "source"
            }
          ],
          "text": "*Space:* 5 feet, *Reach (Tall):* 5 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "40b5d9c5e49dbe2aea5d7ecf38d950f3",
          "game-obj": "Traits",
          "name": "Mythic",
          "sources": [
            {
              "link": {
                "alt": "War of Immortals pg. 69",
                "aonid": 232,
                "game-obj": "Sources",
                "name": "War of Immortals pg. 69",
                "type": "link"
              },
              "name": "War of Immortals",
              "page": 69,
              "type": "source"
            }
          ],
          "text": "Options with this trait grant or utilize mythic power. Feats with the mythic trait can only be taken by mythic characters, who are typically characters with a mythic Calling.  \n  \n Monsters with the mythic trait have access to a pool of Mythic Points and are particularly strong for creatures of their level. Many mythic monsters are either resistant or entirely immune to attacks from non-mythic creatures and weapons.  \n  \n Spells with the mythic trait require the expenditure of a Mythic Point in order to be cast, and items with the mythic trait require the expenditure of a Mythic Point in order to use their activated abilities.  \n  \n Weapons with the mythic trait overcome the resistances and immunities of mythic monsters.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 236,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "3fa972aba0f2ddd5e5418c0c918d951e",
          "game-obj": "Traits",
          "name": "Skeleton",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Monster Core pg. 363",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 363",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 363,
              "type": "source"
            }
          ],
          "text": "This undead is made by animating a dead creature's skeleton with void energy.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 160,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "20f6f5f93a453f3006eb194c6d712042",
          "game-obj": "Traits",
          "name": "Undead",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 462",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 462",
                "type": "link"
              },
              "name": "Player Core",
              "page": 462,
              "type": "source"
            }
          ],
          "text": "Once living, these creatures were infused after death with void energy and soul-corrupting unholy magic. When reduced to 0 Hit Points, an undead creature is destroyed. Undead creatures are damaged by vitality energy and are healed by void energy, and don\u2019t benefit from healing vitality effects.",
          "type": "trait"
        }
      ],
      "type": "stat_block_section"
    },
