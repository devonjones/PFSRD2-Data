          ],
          "name": "Death Grip",
          "subtype": "ability",
          "text": "Exthenios clutches Aerekostes with a literal death grip. Attempts to Disarm him of the weapon are treated as one degree of success lower.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Reaction",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "effect": "Exthenios makes a melee Strike against the triggering creature, or a void bolt Strike if the creature isn't within his reach. If the Strike is a success, the creature must attempt a DC 7 flat check (or a DC 12 flat check if Exthenios's Strike was a critical success). On a failure, the triggering action is disrupted.",
          "links": [
            {
              "alt": "flat check",
              "aonid": 333,
              "game-obj": "Rules",
              "name": "flat check",
              "type": "link"
            }
          ],
          "name": "My Fight!",
          "requirement": "Exthenios has a creature under the effects of Engaging Duel",
          "saving_throw": [
            {
              "dc": 7,
              "modifiers": [
                {
                  "name": "or a DC 12 flat check if Exthenios's Strike was a critical success",
                  "subtype": "modifier",
                  "type": "stat_block_section"
                }
              ],
              "save_type": "Flat Check",
              "subtype": "save_dc",
              "text": "DC 7 flat check",
              "type": "stat_block_section"
            },
            {
              "dc": 12,
              "save_type": "Flat Check",
              "subtype": "save_dc",
              "text": "DC 12 flat check",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "trigger": "A creature other than the target of Engaging Duel takes a hostile action against Exthenios or uses a spell or ability that affects the target of Engaging Duel",
          "type": "stat_block_section"
        },
