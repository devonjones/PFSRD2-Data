  "sections": [
    {
      "name": "Orc Raider",
      "sources": [
        {
          "link": {
            "alt": "Pathfinder #209: Destroyer's Doom pg. 88",
            "aonid": 251,
            "game-obj": "Sources",
            "name": "Pathfinder #209: Destroyer's Doom pg. 88",
            "type": "link"
          },
          "name": "Pathfinder #209: Destroyer's Doom",
          "page": 88,
          "type": "source"
        }
      ],
      "text": "Highly trained and dangerous, orc raiders are masters of channeling their rage in battle. This orc raider draws upon the powers of the elements for their rage, but other raiders could gain strength from different instincts.",
      "type": "section"
    }
  ],
