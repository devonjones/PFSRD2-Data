                    "aonid": 192,
                    "game-obj": "Traits",
                    "name": "reach",
                    "type": "link"
                  }
                ],
                "name": "Disarm",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 282",
