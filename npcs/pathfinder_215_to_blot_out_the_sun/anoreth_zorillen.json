              "game-obj": "Actions",
              "name": "Strike",
              "type": "link"
            }
          ],
          "name": "Scrap Ward",
          "subtype": "ability",
          "trigger": "A construct within 60 feet of Anoreth is damaged",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "flat check",
              "aonid": 333,
              "game-obj": "Rules",
              "name": "flat check",
              "type": "link"
            }
          ],
          "name": "Steady Spellcasting",
          "saving_throw": [
            {
              "dc": 15,
              "save_type": "Flat Check",
              "subtype": "save_dc",
              "text": "DC 15 flat check",
              "type": "stat_block_section"
            }
          ],
          "subtype": "ability",
          "text": "If a reaction would disrupt Anoreth's spellcasting action, they attempt a DC 15 flat check; if they succeed, their action isn't disrupted.",
          "type": "stat_block_section"
        }
