              "name": "Core Rulebook",
              "page": 637,
              "type": "source"
            }
          ],
          "text": "A rules element with this trait is one-of-a-kind. The DC of Recall Knowledge checks related to creatures with this trait is increased by 10.",
          "type": "trait"
        },
        {
          "classes": [
            "alignment"
          ],
          "edition": "legacy",
          "game-id": "213a025fa0c9f9beb3271a265a7d05e8",
          "game-obj": "Traits",
          "name": "Chaotic",
          "sources": [
            {
              "errata": {
                "alt": "4.0",
                "aonid": 1,
                "game-obj": "Sources",
                "name": "4.0",
                "type": "link"
              },
              "link": {
                "alt": "Core Rulebook pg. 629",
                "aonid": 1,
                "game-obj": "Sources",
                "name": "Core Rulebook pg. 629",
                "type": "link"
              },
              "name": "Core Rulebook",
              "page": 629,
              "type": "source"
            }
          ],
          "text": "Chaotic effects often manipulate energy from chaos-aligned Outer Planes and are anathema to lawful divine servants or divine servants of lawful deities. A creature with this trait is chaotic in alignment.",
          "type": "trait"
        },
        {
          "classes": [
            "alignment"
          ],
          "edition": "legacy",
          "game-id": "0b69d10c0f742fd54efa8502e91ee56c",
          "game-obj": "Traits",
          "name": "Good",
          "sources": [
            {
              "errata": {
