                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 283",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 283",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "An effect with this trait is not inherently deadly. Damage from a nonlethal effect knocks a creature out rather than killing it. You can use a nonlethal weapon to make a lethal attack with a \u20132 circumstance penalty.",
                "type": "trait"
              },
              {
                "alternate_link": {
