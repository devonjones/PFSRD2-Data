                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 630",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 630",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 630,
                    "type": "source"
                  }
                ],
                "text": "An action with this trait requires a degree of mental concentration and discipline.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "remastered",
                  "aonid": 590,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
