      "automatic_abilities": [
        {
          "ability_type": "automatic",
          "links": [
            {
              "alt": "Pharasma",
              "aonid": 14,
              "game-obj": "Deities",
              "name": "Pharasma",
              "type": "link"
            }
          ],
          "name": "False Faith",
          "subtype": "ability",
          "text": "Abridan is an ex-cleric. While he's lost the magical abilities that come from his connection to Pharasma, he can still use the *major staff of healing* or any of his scrolls by tricking the item. Since he can't cast spells, he can't recharge his staff, and uses its remaining charges only as a last resort.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "automatic",
          "action_type": {
            "name": "Free Action",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "damage": [
            {
              "damage_type": "negative",
              "formula": "11d6",
              "subtype": "attack_damage",
              "type": "stat_block_section"
            }
          ],
          "effect": "Urgathoa watched Abridan's fall from grace, and if he dies before he finishes his conversion, her disappointment causes his body to decay as if he had been dead for a week. This process also causes all living creatures within 30 feet to take 11d6 negative damage (DC 33 basic Fortitude save). If steps are not thereafter taken to prevent his soul from returning (such as by casting *gentle repose* on the partially decayed corpse), Abridan rises as a dybbuk on the site of his death a minute after the next sundown and seeks revenge on the PCs for killing him.",
          "links": [
            {
              "alt": "Urgathoa",
              "aonid": 19,
              "game-obj": "Deities",
              "name": "Urgathoa",
              "type": "link"
            },
            {
              "alt": "basic",
              "aonid": 329,
              "game-obj": "Rules",
              "name": "basic",
              "type": "link"
            },
            {
              "alt": "gentle repose",
              "aonid": 131,
              "game-obj": "Spells",
              "name": "gentle repose",
              "type": "link"
            },
            {
              "alt": "dybbuk",
              "aonid": 1140,
              "game-obj": "Monsters",
              "name": "dybbuk",
              "type": "link"
            }
          ],
          "name": "Marked by Urgathoa",
          "range": {
            "range": 30,
            "subtype": "range",
            "text": "within 30 feet",
            "type": "stat_block_section",
            "unit": "feet"
          },
          "saving_throw": [
