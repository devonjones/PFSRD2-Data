  "schema_version": 1.4,
  "sections": [
    {
      "name": "Dwarf Warrior",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 135",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 135",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 135,
          "type": "source"
        }
      ],
      "text": "Between their finely crafted equipment and natural bravery, a dwarf warrior can hold their ground against mighty foes. If respected, these warriors can become life-long allies; if slighted, they can become a thorn in one's side for the remainder of one's life.",
      "type": "section"
    }
  ],
