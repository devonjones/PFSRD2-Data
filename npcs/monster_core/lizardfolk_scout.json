  "schema_version": 1.4,
  "sections": [
    {
      "name": "Lizardfolk Scout",
      "sections": [
        {
          "name": "Terrain Advantage Non-lizardfolk creatures that are in difficult terrain or are in water and lack a swim Speed are off-guard to the lizardfolk scout.",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Monster Core pg. 227",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 227",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 227,
              "type": "source"
            }
          ],
          "type": "section"
        }
      ],
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 227",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 227",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 227,
          "type": "source"
        }
      ],
      "text": "Iruxi scouts are the lizardfolk most often encountered by adventurers, for these unsentimental  explorers and hunters spend most of their lives on the move, constantly patrolling the territories held by their enclave. If intruders are driven off, it is the responsibility of iruxi scouts to track them, observe them, and learn their ways and weaknesses so as to report back to the community and aid in the defense against potential reprisals.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
        "alt": "1.1",
        "aonid": 221,
        "game-obj": "Sources",
