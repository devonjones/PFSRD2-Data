  "schema_version": 1.4,
  "sections": [
    {
      "name": "Goblin War Chanter",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 175",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 175",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 175,
          "type": "source"
        }
      ],
      "text": "While all goblins enjoy singing, goblin war chanters pride themselves on mastering the art of vocal performance. Their ballads and jingles are undeniably catchy, and serve their purpose in battle well, inspiring goblins and distracting foes. Whether they are actually enjoyable is entirely subjective.",
      "type": "section"
    }
  ],
