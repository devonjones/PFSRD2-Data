                "edition": "remastered",
                "game-id": "131678d51da8c778d796e57057176286",
                "game-obj": "Traits",
                "name": "Disarm",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
