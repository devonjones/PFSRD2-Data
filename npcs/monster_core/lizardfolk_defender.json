  "schema_version": 1.4,
  "sections": [
    {
      "name": "Lizardfolk Defender",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 226",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 226",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 226,
          "type": "source"
        }
      ],
      "text": "A lizardfolk defender serves as a protector of the young, guardian of the settlement, and when no other options are available, a soldier in times of war. They eagerly rise to the defense of their kin but do not revel in battle. An iruxi defender would rather turn back intruders and allow them to flee with the knowledge they were beaten, in hopes that such word prevents further invasions, but they are not naive. Iruxis understand the need for revenge, and when they allow a foe to escape, they do not forget.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
