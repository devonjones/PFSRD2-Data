                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "75d7a94811530a56c9e064166c98e78d",
                "game-obj": "Traits",
                "name": "Propulsive",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
