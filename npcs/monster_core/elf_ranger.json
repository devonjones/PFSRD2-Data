  "sections": [
    {
      "name": "Elf Ranger",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 151",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 151",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 151,
          "type": "source"
        }
      ],
      "text": "Many elves learn the bow before even picking up their first blade. Because of this, many elves act as rangers at some point in their long lives.",
      "type": "section"
    }
  ],
  "sources": [
