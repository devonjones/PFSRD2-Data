  "schema_version": 1.4,
  "sections": [
    {
      "name": "Orc Scrapper",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 258",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 258",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 258,
          "type": "source"
        }
      ],
      "text": "Acting as the most common orc combat unit, orc scrappers are ferocious fighters who rely on unrelenting strength, rather than combat experience, to prove their mettle and attempt to rise in the hold's standing.",
      "type": "section"
    }
  ],
