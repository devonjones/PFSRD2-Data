  "sections": [
    {
      "name": "Aiuvarin Elementalist",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 151",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 151",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 151,
          "type": "source"
        }
      ],
      "text": "Commonly referred to as half-elves, aiuvarins often have trouble fitting into society. This can lead to many aiuvarins diverting their full attention towards their own personal pursuits, such as studying spellcasting.",
      "type": "section"
    }
  ],
  "sources": [
