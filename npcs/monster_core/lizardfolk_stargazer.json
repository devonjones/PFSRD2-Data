  "schema_version": 1.4,
  "sections": [
    {
      "name": "Lizardfolk Stargazer",
      "sources": [
        {
          "errata": {
            "alt": "1.1",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "1.1",
            "type": "link"
          },
          "link": {
            "alt": "Monster Core pg. 227",
            "aonid": 221,
            "game-obj": "Sources",
            "name": "Monster Core pg. 227",
            "type": "link"
          },
          "name": "Monster Core",
          "page": 227,
          "type": "source"
        }
      ],
      "text": "The tradition of astrology and looking to the stars for both navigation and prognostication is well-established in iruxi society, and their wise and observant stargazers are among the people's most respected members. Even the lowliest stargazer, as presented here, has a number of useful primal spells to aid their kin; in larger iruxi settlements, stargazers wield even greater powers.",
      "type": "section"
    }
  ],
  "sources": [
    {
      "errata": {
