                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 458",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 458",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 458,
                    "type": "source"
                  }
                ],
                "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 191,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "75d7a94811530a56c9e064166c98e78d",
                "game-obj": "Traits",
                "name": "Propulsive",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 282",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 282",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 282,
                    "type": "source"
                  }
                ],
                "text": "You add half your Strength modifier (if positive) to damage rolls with a propulsive ranged weapon. If you have a negative Strength modifier, you add your full Strength modifier instead.",
                "type": "trait"
              },
              {
                "edition": "legacy",
                "game-id": "104d6fc2d1d7f97108e1e9b4be5089b1",
                "game-obj": "Traits",
                "links": [
                  {
                    "alt": "range increments",
                    "aonid": 227,
                    "game-obj": "Rules",
                    "name": "range increments",
                    "type": "link"
                  }
                ],
                "name": "Range",
                "sources": [
                  {
                    "link": {
                      "alt": "Bestiary pg. 17",
                      "aonid": 2,
                      "game-obj": "Sources",
                      "name": "Bestiary pg. 17",
                      "type": "link"
                    },
                    "name": "Bestiary",
                    "page": 17,
                    "type": "source"
                  }
                ],
                "text": "These attacks will either list a finite range or a range increment, which follows the normal rules for range increments.",
                "type": "trait",
                "value": "increment 100 feet"
              },
              {
                "edition": "legacy",
                "game-id": "15577d9931e0c744a9e12be2d087a290",
                "game-obj": "Traits",
                "name": "Reload",
                "sources": [
                  {
                    "errata": {
                      "alt": "4.0",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "4.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Core Rulebook pg. 279",
                      "aonid": 1,
                      "game-obj": "Sources",
                      "name": "Core Rulebook pg. 279",
                      "type": "link"
                    },
                    "name": "Core Rulebook",
                    "page": 279,
                    "type": "source"
                  }
                ],
                "text": "While all weapons need some amount of time to get into position, many ranged weapons also need to be loaded and reloaded. This entry indicates how many Interact actions it takes to reload such weapons. This can be 0 if drawing ammunition and firing the weapon are part of the same action. If an item takes 2 or more actions to reload, the GM determines whether they must be performed together as an activity, or you can spend some of those actions during one turn and the rest during your next turn.  \n  \nAn item with an entry of \u201c\u2014\u201d must be drawn to be thrown, which usually takes an Interact action just like drawing any other weapon. Reloading a ranged weapon and drawing a thrown weapon both require a free hand. Switching your grip to free a hand and then to place your hands in the grip necessary to wield the weapon are both included in the actions you spend to reload a weapon.",
                "type": "trait",
                "value": "0"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 201,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "ea2a97c7c225653dc2f8c20abc1815aa",
                "game-obj": "Traits",
                "name": "Volley",
                "sources": [
                  {
                    "errata": {
                      "alt": "2.0",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "2.0",
                      "type": "link"
                    },
                    "link": {
                      "alt": "Player Core pg. 283",
                      "aonid": 216,
                      "game-obj": "Sources",
                      "name": "Player Core pg. 283",
                      "type": "link"
                    },
                    "name": "Player Core",
                    "page": 283,
                    "type": "source"
                  }
                ],
                "text": "This ranged weapon is less effective at close distances. Your attacks against targets that are at a distance within the range listed take a \u20132 penalty.",
                "type": "trait",
                "value": "30 feet"
              }
            ],
