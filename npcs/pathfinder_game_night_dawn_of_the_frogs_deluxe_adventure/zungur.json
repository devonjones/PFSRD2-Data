          "game-id": "d3bfc0df6c75fa3d188816919a7c6bf5",
          "game-obj": "Traits",
          "name": "Amphibious",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 452",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 452",
                "type": "link"
              },
              "name": "Player Core",
              "page": 452,
              "type": "source"
            }
          ],
          "text": "An amphibious creature can breathe in water and in air, even outside of its preferred environment, usually indefinitely but at least for hours. These creatures often have a swim Speed. Their bludgeoning and slashing unarmed Strikes don\u2019t take the usual \u20132 penalty for being underwater.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 209,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "2387b5c43b3c8abad01269ab652fc9db",
          "game-obj": "Traits",
          "name": "Boggard",
          "sources": [
            {
              "errata": {
                "alt": "1.1",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "1.1",
                "type": "link"
              },
              "link": {
                "alt": "Monster Core pg. 361",
                "aonid": 221,
                "game-obj": "Sources",
                "name": "Monster Core pg. 361",
                "type": "link"
              },
              "name": "Monster Core",
              "page": 361,
              "type": "source"
            }
          ],
          "text": "Boggards are frog-like humanoids. They typically have darkvision.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
