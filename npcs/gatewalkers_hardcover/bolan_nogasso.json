      ],
      "name": "Bolan Nogasso, Rebel Oaksteward",
      "sections": [
        {
          "links": [
            {
              "alt": "Shadewither Key",
              "aonid": 1818,
              "game-obj": "Equipment",
              "name": "Shadewither Key",
              "type": "link"
            },
            {
              "alt": "Recall Knowledge - Humanoid",
              "aonid": 2638,
              "game-obj": "Rules",
              "name": "Recall Knowledge - Humanoid",
              "type": "link"
            },
            {
              "alt": "Society",
              "aonid": 47,
              "game-obj": "Skills",
              "name": "Society",
              "type": "link"
            },
            {
              "alt": "Unspecific Lore",
              "aonid": 2638,
              "game-obj": "Rules",
