                "name": "Chart a Course",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "traits": [
                    {
                        "name": "Concentrate",
                        "type": "trait",
                        "alternate_link": {
                            "type": "alternate_link",
                            "game-obj": "Traits",
                            "aonid": 32,
                            "alternate_type": "legacy"
                        },
                        "edition": "remastered",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Player Core",
                                "link": {
                                    "type": "link",
                                    "name": "Player Core pg. 454",
