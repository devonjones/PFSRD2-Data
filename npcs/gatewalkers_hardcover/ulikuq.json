                                "page": 454,
                                "errata": {
                                    "type": "link",
                                    "name": "2.0",
                                    "alt": "2.0",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                }
                            }
                        ],
                        "game-obj": "Traits",
                        "game-id": "e32d877417a40fe977d27634dc14f99f",
                        "text": "An action with this trait requires a degree of mental concentration and discipline.",
                        "schema_version": 1.1,
                        "classes": []
                    }
                ],
                "text": "Ulikuq spends 10 minutes to plot a course and attempts a DC 20 Sailing Lore or Survival check. This check is reduced to DC 15 in an arctic environment such as the Crown of the World. On a success, the severity of environmental conditions during the journey is reduced by one step for 24 hours (two steps on a critical success). This changes moderate damage to minor damage, winds that create greater difficult terrain cause only difficult terrain, and so on.",
                "links": [
                    {
                        "type": "link",
                        "name": "Sailing Lore",
                        "alt": "Sailing Lore",
                        "game-obj": "Skills",
                        "aonid": 41
                    },
                    {
                        "type": "link",
                        "name": "Survival",
                        "alt": "Survival",
                        "game-obj": "Skills",
                        "aonid": 49
                    },
                    {
                        "type": "link",
                        "name": "greater difficult terrain",
                        "alt": "greater difficult terrain",
                        "game-obj": "Rules",
                        "aonid": 2586
                    }
                ]
            }
