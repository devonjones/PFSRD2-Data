        ],
        "name": "Predict Weather",
        "requirement": "Innumma is outdoors",
        "saving_throw": [
          {
            "dc": 20,
            "subtype": "save_dc",
            "text": "DC 20",
            "type": "stat_block_section"
          },
          {
            "dc": 15,
            "subtype": "save_dc",
            "text": "DC 15",
            "type": "stat_block_section"
          }
        ],
        "subtype": "ability",
        "success": "As critical success, but Innumma gains only a +1 circumstance bonus to Survival checks made to prepare for any weather event that might occur.",
