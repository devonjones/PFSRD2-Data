    "interaction_abilities": [
      {
        "ability_type": "interaction",
        "critical_failure": "Innumma misinterprets the environment's indicators, predicting a weather event as if he had earned a critical success but which will not occur that day.",
        "critical_success": "Innumma accurately predicts the day's weather. He learns if a weather event will occur in the region within the next 24 hours, and if so, what the event is and approximately when it will occur. He gains a +2 circumstance bonus to Survival checks made to prepare for this weather event.",
        "effect": "Innumma spends 10 minutes observing the environment, trying to predict the day's weather. He attempts a DC 20 Survival or Weather Lore check. This check is reduced to DC 15 in an arctic environment such as the Crown of the World.",
        "failure": "Innumma can't determine anything about the day's weather.",
        "frequency": "once per day",
        "links": [
          {
            "alt": "Survival",
            "aonid": 49,
            "game-obj": "Skills",
            "name": "Survival",
            "type": "link"
          },
          {
            "alt": "Weather Lore",
