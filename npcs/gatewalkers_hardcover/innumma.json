        "interaction_abilities": [
            {
                "name": "Predict Weather",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "traits": [
                    {
                        "name": "Concentrate",
                        "type": "trait",
                        "alternate_link": {
                            "type": "alternate_link",
                            "game-obj": "Traits",
                            "aonid": 32,
                            "alternate_type": "legacy"
                        },
                        "edition": "remastered",
                        "sources": [
                            {
                                "type": "source",
                                "name": "Player Core",
                                "link": {
                                    "type": "link",
                                    "name": "Player Core pg. 454",
                                    "alt": "Player Core pg. 454",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                },
                                "page": 454,
                                "errata": {
                                    "type": "link",
                                    "name": "2.0",
                                    "alt": "2.0",
                                    "game-obj": "Sources",
                                    "aonid": 216
                                }
                            }
                        ],
                        "game-obj": "Traits",
                        "game-id": "e32d877417a40fe977d27634dc14f99f",
                        "text": "An action with this trait requires a degree of mental concentration and discipline.",
                        "schema_version": 1.1,
                        "classes": []
                    }
                ]
            },
            {
                "name": "Requirements",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "Innumma is outdoors;"
            },
            {
                "name": "Frequency",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "once per day;"
            },
            {
                "name": "Effect",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "Innumma spends 10 minutes observing the environment, trying to predict the day's weather. He attempts a DC 20 Survival or Weather Lore check. This check is reduced to DC 15 in an arctic environment such as the Crown of the World.",
                "links": [
                    {
                        "type": "link",
                        "name": "Survival",
                        "alt": "Survival",
                        "game-obj": "Skills",
                        "aonid": 49
                    },
                    {
                        "type": "link",
                        "name": "Weather Lore",
                        "alt": "Weather Lore",
                        "game-obj": "Skills",
                        "aonid": 41
                    }
                ]
            },
            {
                "name": "Critical Success",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "Innumma accurately predicts the day's weather. He learns if a weather event will occur in the region within the next 24 hours, and if so, what the event is and approximately when it will occur. He gains a +2 circumstance bonus to Survival checks made to prepare for this weather event."
            },
            {
                "name": "Success",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "As critical success, but Innumma gains only a +1 circumstance bonus to Survival checks made to prepare for any weather event that might occur."
            },
            {
                "name": "Failure",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "Innumma can't determine anything about the day's weather."
            },
            {
                "name": "Critical Failure",
                "type": "stat_block_section",
                "subtype": "ability",
                "ability_type": "interaction",
                "text": "Innumma misinterprets the environment's indicators, predicting a weather event as if he had earned a critical success but which will not occur that day."
            }
        ],
