                    "page": 457,
                    "type": "source"
                  }
                ],
                "text": "Effects and magic items with this trait involve false sensory stimuli.",
                "type": "trait"
              },
              {
                "alternate_link": {
                  "alternate_type": "legacy",
                  "aonid": 120,
                  "game-obj": "Traits",
                  "type": "alternate_link"
                },
                "edition": "remastered",
                "game-id": "a9126c150baeaac5ec247ce82c9b8ce2",
                "game-obj": "Traits",
                "name": "Occult",
                "sources": [
                  {
                    "errata": {
