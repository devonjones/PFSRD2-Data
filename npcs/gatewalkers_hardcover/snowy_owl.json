              "page": 474,
              "type": "source"
            }
          ],
          "text": "*Space:* 5 feet, *Reach (Tall):* 5 feet, *Reach (Long):* 5 feet",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 90,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "monsters"
          ],
          "edition": "remastered",
          "game-id": "d2f0b049794167d52146f46a7264e39f",
          "game-obj": "Traits",
          "name": "Human",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "A creature with this trait is a member of the human ancestry. Humans are a diverse array of people known for their adaptability. An ability with this trait can be used or selected only by humans.",
          "type": "trait"
        },
        {
          "alternate_link": {
            "alternate_type": "legacy",
            "aonid": 91,
            "game-obj": "Traits",
            "type": "alternate_link"
          },
          "classes": [
            "creature_type"
          ],
          "edition": "remastered",
          "game-id": "0c7ddd2d1aff745e1b670b9eb846114e",
          "game-obj": "Traits",
          "name": "Humanoid",
          "sources": [
            {
              "errata": {
                "alt": "2.0",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "2.0",
                "type": "link"
              },
              "link": {
                "alt": "Player Core pg. 457",
                "aonid": 216,
                "game-obj": "Sources",
                "name": "Player Core pg. 457",
                "type": "link"
              },
              "name": "Player Core",
              "page": 457,
              "type": "source"
            }
          ],
          "text": "Humanoid creatures reason and act much like humans. They typically stand upright and have two arms and two legs.",
          "type": "trait"
        }
