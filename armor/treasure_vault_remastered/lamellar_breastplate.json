    "stat_block": {
        "type": "stat_block",
        "subtype": "armor",
        "text": "Slats of lacquered steel or other metal held together with cord, whether leather or silk, make up most lamellar breastplates. The lacquering prevents the metal from corroding.",
        "level": 0,
        "traits": [
            {
                "name": "Hindering",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Treasure Vault",
                        "link": {
                            "type": "link",
                            "name": "Treasure Vault pg. 219",
