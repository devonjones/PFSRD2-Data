    "stat_block": {
        "type": "stat_block",
        "subtype": "armor",
        "text": "Absalom style once led famous adventurers to wear clothing with an unusual number of buckles, pouches, and straps. This fashion birthed a trend that led to \u201cbuckle armor,\u201d a colloquial name for chic armor with spacious tool storage. Buckle armor comes with the storage armor adjustment.",
        "level": 0,
        "traits": [
            {
                "name": "Adjusted",
                "type": "trait",
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
