                "game-obj": "Traits",
                "game-id": "538d80d59310d72e7bdd375d3b3bf3f1",
                "text": "This armor is loud and likely to alert others to your presence. The armor\u2019s check penalty applies to Stealth checks even if you have the required Strength modifier.",
                "classes": [
                    "trait"
                ]
            }
