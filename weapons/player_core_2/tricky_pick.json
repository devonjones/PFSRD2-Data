    "subtype": "weapon",
    "text": "This ingenious kobold pick conceals several hidden traps that the wielder can activate to trick and befuddle foes with a variety of damaging blades and bludgeoning surfaces.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 159,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
