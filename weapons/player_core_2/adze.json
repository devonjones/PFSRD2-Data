    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "A common cutting tool, an adze resembles an axe\u2014but the cutting edge is horizontal, rather than vertical. The adze\u2019s shape makes it popular among woodworkers, and tripkee builders often use them to construct their treetop homes. The tool also serves as an effective weapon, due in part to the immense strength required to swing it.",
        "level": 0,
        "traits": [
            {
                "name": "Forceful",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 180,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
