    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "This handheld weapon\u2019s three parallel blades extend between the fingers to resemble the natural claws of the amurruns who created them, providing a way for those catfolk without suitable natural claws to share the fighting customs of their kin.",
        "level": 0,
        "image": {
