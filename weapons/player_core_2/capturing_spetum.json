            "game-obj": "Rules",
            "name": "darkvision",
            "type": "link"
          }
        ],
        "name": "Hobgoblin",
        "sources": [
          {
            "errata": {
              "alt": "1.1",
              "aonid": 227,
              "game-obj": "Sources",
              "name": "1.1",
              "type": "link"
            },
            "link": {
              "alt": "Player Core 2 pg. 316",
              "aonid": 227,
              "game-obj": "Sources",
              "name": "Player Core 2 pg. 316",
              "type": "link"
            },
            "name": "Player Core 2",
            "page": 316,
            "type": "source"
          }
        ],
        "text": "A creature with this trait is a tall, militaristic goblinoid. Hobgoblins tend to have darkvision. An ability with this trait can be used or selected only by hobgoblins. An item with this trait is created and used by hobgoblins.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 192,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "1d6143e399ba5d4085ca236a97cf860c",
        "game-obj": "Traits",
        "name": "Reach",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 283",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 283",
              "type": "link"
            },
            "name": "Player Core",
            "page": 283,
            "type": "source"
          }
        ],
        "text": "This weapon can be used to attack enemies up to 10 feet away instead of only adjacent enemies. For creatures with reach, the weapon increases their reach by 5 feet.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 196,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "a49ec55650ed4dafa9fa0c699bfd7e42",
        "game-obj": "Traits",
        "name": "Trip",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 283",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 283",
              "type": "link"
            },
            "name": "Player Core",
            "page": 283,
            "type": "source"
          }
        ],
        "text": "You can use this weapon to Trip with the Athletics skill even if you don\u2019t have a free hand. This uses the weapon\u2019s reach (if different from your own) and adds the weapon\u2019s item bonus to attack rolls as an item bonus to the Athletics check. If you critically fail a check to Trip using the weapon, you can drop the weapon to take the effects of a failure instead of a critical failure.",
        "type": "trait"
      }
    ],
