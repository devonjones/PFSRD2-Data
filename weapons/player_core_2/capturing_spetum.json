          },
          {
            "alt": "move",
            "aonid": 658,
            "game-obj": "Traits",
            "name": "move",
            "type": "link"
          }
        ],
        "name": "Hampering",
        "sources": [
          {
            "errata": {
              "alt": "1.1",
              "aonid": 227,
              "game-obj": "Sources",
              "name": "1.1",
              "type": "link"
            },
            "link": {
              "alt": "Player Core 2 pg. 274",
              "aonid": 227,
              "game-obj": "Sources",
              "name": "Player Core 2 pg. 274",
              "type": "link"
            },
            "name": "Player Core 2",
            "page": 274,
            "type": "source"
          }
        ],
        "text": "A weapon with the hampering trait includes a disruptive limb or flange. After you hit with the weapon, you can use an Interact action to give the target a \u201310-foot circumstance penalty to all Speeds. The penalty ends after the target takes a move action, at the start of your next turn, if you attack with the weapon, or if you move out of reach of the target, whichever comes first.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 268,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "f98c4e0d86cb282388ecb3f6c20b3000",
