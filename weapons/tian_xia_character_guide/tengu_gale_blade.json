    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "This fan-shaped sword designed by tengu smiths has five broad blades that join at its hilt. Tengu sailors use them as makeshift weather vanes, for the sword spins in the wind\u2019s direction when loosely held aloft.",
        "level": 0,
