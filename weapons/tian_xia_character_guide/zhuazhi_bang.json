    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "This niche close-combat weapon resembles a flail with articulated talons used to hook onto an opponent\u2019s clothing or armor.",
        "level": 0,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
