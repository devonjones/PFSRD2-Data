    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "The shuan ji is a polearm featuring a long spear point on one end and two crescent-shaped blades that allow the wielder to strike with either side of the weapon.",
        "level": 0,
        "traits": [
            {
                "name": "Uncommon",
