        "type": "stat_block",
        "subtype": "weapon",
        "text": "A reinforced stock is a weighted crossbow, firearm haft, or grip customized for striking in melee. An attached reinforced stock requires the same number of hands as the weapon it's attached to.",
        "level": 0,
        "traits": [
            {
                "name": "Attached",
