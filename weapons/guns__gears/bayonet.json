    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "This blade or spike can be attached to a crossbow or firearm but, unlike other attached weapons, can be wielded in one hand as its own weapon. When used as a separate weapon, it can't benefit from any runes or abilities that function only for attached weapons. An attached bayonet requires the same number of hands as the weapon it's attached to. A detached bayonet requires one hand.",
        "level": 0,
        "traits": [
            {
                "name": "Agile",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
