                            "aonid": 216
                        },
                        "page": 456,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "4f7b46a2044aea5ae844a7fc8b3bbbaa",
                "text": "A creature with this trait is a small, frantic goblinoid. Goblins tend to have darkvision. An ability with this trait can be used or chosen only by goblins. A weapon with this trait is created and used by goblins.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Scatter",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 413,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "NPC Core",
                        "link": {
                            "type": "link",
                            "name": "NPC Core pg. 50",
                            "alt": "NPC Core pg. 50",
                            "game-obj": "Sources",
                            "aonid": 236
                        },
                        "page": 50
                    }
                ],
                "game-obj": "Traits",
                "game-id": "078ebaefcfbeb6e50d1317aa9be6ee75",
                "text": "This weapon fires a cluster of pellets in a wide spray. Scatter always has an area listed with it, indicating the radius of the spray. On a hit, the primary target of attacks with a scatter weapon take the listed damage, and the target and all other creatures within the listed radius around it take 1 point of splash damage per weapon damage die, of the same type as the initial attack.",
                "classes": [
                    "trait"
                ],
                "value": "5 ft."
            }
        ],
