                        {
                            "name": "Critical Fusion",
                            "type": "trait",
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Treasure Vault",
                                    "link": {
                                        "type": "link",
                                        "name": "Treasure Vault pg. 217",
                                        "alt": "Treasure Vault pg. 217",
                                        "game-obj": "Sources",
                                        "aonid": 191
