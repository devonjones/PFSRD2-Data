                                    "type": "link",
                                    "name": "firearm",
                                    "alt": "firearm",
                                    "game-obj": "WeaponGroups",
                                    "aonid": 16
                                }
                            ],
                            "classes": [
                                "trait"
                            ]
                        },
                        {
                            "name": "Finesse",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 179,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 282",
                                        "alt": "Player Core pg. 282",
                                        "game-obj": "Sources",
                                        "aonid": 216
