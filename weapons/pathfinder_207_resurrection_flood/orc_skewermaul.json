        "links": [
          {
            "alt": "Ready",
            "aonid": 82,
            "game-obj": "Actions",
            "name": "Ready",
            "type": "link"
          }
        ],
        "name": "Brace",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 191,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Treasure Vault pg. 24",
              "aonid": 191,
              "game-obj": "Sources",
              "name": "Treasure Vault pg. 24",
              "type": "link"
            },
            "name": "Treasure Vault",
            "page": 24,
            "type": "source"
          }
        ],
        "text": "A brace weapon is effective at damaging moving opponents. When you Ready to Strike an opponent that moves within your reach, until the start of your next turn Strikes with the brace weapon deal an additional 2 precision damage for each weapon damage die it has.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 124,
          "game-obj": "Traits",
