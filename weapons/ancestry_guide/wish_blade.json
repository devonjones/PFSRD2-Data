                "game-obj": "Traits",
                "game-id": "c660bc84a0db63daa80053a2bfc68579",
                "text": "An umbrella term for planar scions descended from beings from the Elemental Planes. Geniekin craft and use these weapons.",
                "schema_version": 1.1,
