    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "Also called a \u201cslungshot,\u201d the monkey's fist is a short length of rope ending in a thick knot wrapped around a metal weight. You can tie the loose end of a monkey's fist to your wrist; if you are Disarmed, the weapon remains secured to your wrist rather than falling to the ground, though you must use an Interact action to grip it before using it again. A monkey's fist is a martial melee weapon.",
        "level": 0,
        "traits": [
            {
                "name": "Finesse",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
