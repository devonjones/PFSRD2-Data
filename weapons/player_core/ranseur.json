        "edition": "remastered",
        "game-id": "131678d51da8c778d796e57057176286",
        "game-obj": "Traits",
        "name": "Disarm",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 282",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 282",
              "type": "link"
            },
            "name": "Player Core",
            "page": 282,
            "type": "source"
          }
        ],
        "text": "You can use this weapon to Disarm with the Athletics skill even if you don\u2019t have a free hand. This uses the weapon\u2019s reach (if different from your own) and adds the weapon\u2019s item bonus to attack rolls (if any) as an item bonus to the Athletics check. If you critically fail a check to Disarm using the weapon, you can drop the weapon to take the effects of a failure instead of a critical failure. On a critical success, you still need a free hand if you want to take the item.",
        "type": "trait"
      },
      {
        "alternate_link": {
          "alternate_type": "legacy",
          "aonid": 192,
          "game-obj": "Traits",
          "type": "alternate_link"
        },
        "classes": [
          "trait"
        ],
        "edition": "remastered",
        "game-id": "1d6143e399ba5d4085ca236a97cf860c",
        "game-obj": "Traits",
        "name": "Reach",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 283",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 283",
              "type": "link"
            },
            "name": "Player Core",
            "page": 283,
            "type": "source"
          }
        ],
        "text": "This weapon can be used to attack enemies up to 10 feet away instead of only adjacent enemies. For creatures with reach, the weapon increases their reach by 5 feet.",
        "type": "trait"
      }
