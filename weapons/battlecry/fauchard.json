                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "c0d76f25881949145ec6769d79ad49b5",
                "text": "On a critical hit, the weapon adds a weapon damage die of the listed size. Roll this after doubling the weapon\u2019s damage. This increases to two dice if the weapon has a _greater striking rune_ and three dice if the weapon has a _major striking rune_. For instance, a rapier with a _greater striking rune_ deals 2d8 extra piercing damage on a critical hit. An ability that changes the size of the weapon\u2019s normal damage dice doesn\u2019t change the size of its deadly die.",
                "classes": [
                    "trait"
                ],
                "value": "d8"
            },
            {
                "name": "Reach",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 192,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 283",
                            "alt": "Player Core pg. 283",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 283,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "1d6143e399ba5d4085ca236a97cf860c",
                "text": "This weapon can be used to attack enemies up to 10 feet away instead of only adjacent enemies. For creatures with reach, the weapon increases their reach by 5 feet.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Sweep",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 194,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 283",
                            "alt": "Player Core pg. 283",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 283,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "435cbfa8d6a3da2e6b53b01082b49f7d",
                "text": "This weapon makes wide swinging attacks. When you attack with this weapon, you gain a +1 circumstance bonus to your attack roll if you already attempted to attack a different target this turn using this weapon.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Trip",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 196,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 283",
                            "alt": "Player Core pg. 283",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 283,
                        "errata": {
