    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "A fauchard is similar to a glaive, save that its cutting edge is along the concave side.",
        "level": 0,
        "traits": [
            {
                "name": "Deadly",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
