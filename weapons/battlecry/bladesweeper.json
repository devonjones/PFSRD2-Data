    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "Little more than three swords attached to a single hilt, a bladesweeper is a devastating weapon in the hands of a jotunborn warrior.",
        "level": 0,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
