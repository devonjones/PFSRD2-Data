    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "A deceptively simple weapon made from a length of cord attached to a weighted, conical metal spike. A rope dart can be whirled and manipulated at great speeds to attack in unexpected ways and from unexpected angles.",
        "level": 0,
        "image": {
            "type": "image",
            "name": "Rope Dart",
            "image": "Rope_Dart.webp"
        },
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 159,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
