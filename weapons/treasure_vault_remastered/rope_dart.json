                        "page": 11,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f31704572455b8d77a8bd97c0045fde6",
                "text": "Something of uncommon rarity requires special training or comes from a particular culture or part of the world. Some character choices give access to uncommon options, and the GM can choose to allow access for anyone. Less is known about uncommon creatures than common creatures. They typically can't be summoned. The DC of Recall Knowledge checks related to these creature is increased by 2.",
                "links": [
                    {
                        "type": "link",
                        "name": "Recall Knowledge",
                        "alt": "Recall Knowledge",
                        "game-obj": "Actions",
                        "aonid": 26
                    }
                ],
                "classes": [
                    "uncommon"
                ]
            },
            {
                "name": "Disarm",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 175,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
                            "alt": "Player Core pg. 282",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 282,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "131678d51da8c778d796e57057176286",
                "text": "You can use this weapon to Disarm with the Athletics skill even if you don\u2019t have a free hand. This uses the weapon\u2019s reach (if different from your own) and adds the weapon\u2019s item bonus to attack rolls (if any) as an item bonus to the Athletics check. If you critically fail a check to Disarm using the weapon, you can drop the weapon to take the effects of a failure instead of a critical failure. On a critical success, you still need a free hand if you want to take the item.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Finesse",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 179,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
                            "alt": "Player Core pg. 282",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 282,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "6a57956799f3d30121d529e48f12904c",
                "text": "You can use your Dexterity modifier instead of your Strength modifier on attack rolls using this melee weapon. You still calculate damage using Strength.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Sweep",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 194,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 283",
                            "alt": "Player Core pg. 283",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 283,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "435cbfa8d6a3da2e6b53b01082b49f7d",
                "text": "This weapon makes wide swinging attacks. When you attack with this weapon, you gain a +1 circumstance bonus to your attack roll if you already attempted to attack a different target this turn using this weapon.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Tethered",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 252,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core 2",
                        "link": {
                            "type": "link",
                            "name": "Player Core 2 pg. 274",
                            "alt": "Player Core 2 pg. 274",
                            "game-obj": "Sources",
                            "aonid": 227
                        },
                        "page": 274,
                        "errata": {
                            "type": "link",
                            "name": "1.1",
                            "alt": "1.1",
                            "game-obj": "Sources",
                            "aonid": 227
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "93ab405e7b3b5a2c09d54871ceacfe40",
                "text": "This weapon is attached to a length of rope or chain that allows you to retrieve it after it has left your hand. If you have a free hand (including if you've just thrown a two-handed tethered weapon and have a hand holding nothing but the weapon's tether), you can use an Interact action to pull the weapon back into your grasp after you have thrown it as a ranged attack or after it has been disarmed (unless it's being held by another creature).",
                "links": [
                    {
                        "type": "link",
                        "name": "Interact",
                        "alt": "Interact",
                        "game-obj": "Actions",
                        "aonid": 2297
                    },
                    {
                        "type": "link",
                        "name": "disarmed",
                        "alt": "disarmed",
                        "game-obj": "Actions",
                        "aonid": 2383
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Thrown",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 195,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
