                            "game-obj": "Traits",
                            "game-id": "b46c08b2d190882823c18fba71cc1d81",
                            "text": "You can use the momentum from a missed attack with this weapon to lead into your next attack. After missing with this weapon on your turn, you gain a +1 circumstance bonus to your next attack with this weapon before the end of your turn.",
                            "classes": [
                                "trait"
                            ]
                        },
                        {
                            "name": "Disarm",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 175,
                                "alternate_type": "legacy"
                            },
