    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "This massive bow is made from bone or wood reinforced with flexible metal strips and strung with reinforced cord. Designed by hobgoblin engineers to take down shielded opponents, the phalanx piercer fires heavy, iron-shod bolts.",
        "level": 1,
        "image": {
            "type": "image",
            "name": "Phalanx Piercer",
            "image": "Phalanx_Piercer.webp"
        },
        "traits": [
            {
                "name": "Concussive",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 401,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "NPC Core",
                        "link": {
                            "type": "link",
                            "name": "NPC Core pg. 50",
                            "alt": "NPC Core pg. 50",
                            "game-obj": "Sources",
                            "aonid": 236
                        },
                        "page": 50
                    }
                ],
                "game-obj": "Traits",
                "game-id": "e3ebabe03e8190448c5d613bf42a41d2",
                "text": "These weapons smash as much as puncture. When determining a creature's resistance or immunity to damage from this weapon, use the weaker of the target's resistance or immunity to piercing or to bludgeoning. For instance, if the creature were immune to piercing and had no resistance or immunity to bludgeoning damage, it would take full damage from a concussive weapon. Resistance or immunity to all physical damage, or all damage, applies as normal.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Hobgoblin",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 268,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core 2",
                        "link": {
                            "type": "link",
                            "name": "Player Core 2 pg. 316",
                            "alt": "Player Core 2 pg. 316",
                            "game-obj": "Sources",
                            "aonid": 227
                        },
                        "page": 316,
                        "errata": {
                            "type": "link",
                            "name": "1.1",
                            "alt": "1.1",
                            "game-obj": "Sources",
                            "aonid": 227
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "f98c4e0d86cb282388ecb3f6c20b3000",
                "text": "A creature with this trait is a tall, militaristic goblinoid. Hobgoblins tend to have darkvision. An ability with this trait can be used or selected only by hobgoblins. An item with this trait is created and used by hobgoblins.",
                "links": [
                    {
                        "type": "link",
                        "name": "Hobgoblins",
                        "alt": "Hobgoblins",
                        "game-obj": "Ancestries",
                        "aonid": 78
                    },
                    {
                        "type": "link",
                        "name": "darkvision",
                        "alt": "darkvision",
                        "game-obj": "Rules",
                        "aonid": 2410
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Propulsive",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 191,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
                            "alt": "Player Core pg. 282",
                            "game-obj": "Sources",
                            "aonid": 216
                        },
                        "page": 282,
                        "errata": {
                            "type": "link",
                            "name": "2.0",
                            "alt": "2.0",
                            "game-obj": "Sources",
                            "aonid": 216
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "75d7a94811530a56c9e064166c98e78d",
                "text": "You add half your Strength modifier (if positive) to damage rolls with a propulsive ranged weapon. If you have a negative Strength modifier, you add your full Strength modifier instead.",
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Razing",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 488,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core 2",
                        "link": {
                            "type": "link",
                            "name": "Player Core 2 pg. 274",
                            "alt": "Player Core 2 pg. 274",
                            "game-obj": "Sources",
                            "aonid": 227
                        },
                        "page": 274,
                        "errata": {
                            "type": "link",
                            "name": "1.1",
                            "alt": "1.1",
                            "game-obj": "Sources",
                            "aonid": 227
                        }
                    }
                ],
                "game-obj": "Traits",
                "game-id": "1e43c7605c9909b20b487f7dd05b5cee",
                "text": "Razing weapons are particularly good at damaging objects, structures, and vehicles. Whenever you deal damage to an object (including shields and animated objects), structure, or vehicle with a razing weapon, the object takes an amount of additional damage equal to double the number of weapon damage dice.",
                "links": [
                    {
                        "type": "link",
                        "name": "shields",
                        "alt": "shields",
                        "href": "Shields.aspx"
                    },
                    {
                        "type": "link",
                        "name": "animated objects",
                        "alt": "animated objects",
                        "game-obj": "MonsterFamilies",
                        "aonid": 360
                    }
                ],
                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Volley",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 201,
