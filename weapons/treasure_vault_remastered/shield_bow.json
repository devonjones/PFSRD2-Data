    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "As the name implies, a shield bow is a bow with an integrated shielding surface. While versatile and effective, a shield bow's architecture limits its flexibility somewhat, decreasing its total draw strength and penetrating power.",
        "level": 0,
        "image": {
            "type": "image",
            "name": "Shield Bow",
            "image": "Shield_Bow.webp"
        },
        "traits": [
            {
                "name": "Deadly",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 174,
                    "alternate_type": "legacy"
                },
                "edition": "remastered",
                "sources": [
                    {
                        "type": "source",
                        "name": "Player Core",
                        "link": {
                            "type": "link",
                            "name": "Player Core pg. 282",
                            "alt": "Player Core pg. 282",
