    "subtype": "weapon",
    "text": "This massive hammer's metal head is shaped or molded with heavy metal wedges along its primary striking surface, enabling it to tear through shields and armor with ease.",
    "traits": [
      {
        "alternate_link": {
          "alternate_type": "legacy",
