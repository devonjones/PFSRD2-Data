                "classes": [
                    "trait"
                ]
            },
            {
                "name": "Shove",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
                    "aonid": 193,
                    "alternate_type": "legacy"
