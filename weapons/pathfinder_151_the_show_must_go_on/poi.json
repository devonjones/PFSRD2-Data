        ],
        "name": "Nonlethal",
        "sources": [
          {
            "errata": {
              "alt": "2.0",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "2.0",
              "type": "link"
            },
            "link": {
              "alt": "Player Core pg. 282",
              "aonid": 216,
              "game-obj": "Sources",
              "name": "Player Core pg. 282",
              "type": "link"
            },
            "name": "Player Core",
            "page": 282,
            "type": "source"
          }
        ],
        "text": "Attacks with this weapon are nonlethal, and are used to knock creatures unconscious instead of kill them. You can use a nonlethal weapon to make a lethal attack with a \u20132 circumstance penalty.",
        "type": "trait"
      }
