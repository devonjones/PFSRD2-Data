    "stat_block": {
        "type": "stat_block",
        "subtype": "weapon",
        "text": "A scorpion whip has a series of razor-sharp blades set along its tip. Unlike ordinary whips, a scorpion whip doesn\u2019t have the nonlethal trait, making it deadlier in combat but less effective when the wielder seeks to bring in foes alive.",
        "level": 0,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
                    "type": "alternate_link",
                    "game-obj": "Traits",
