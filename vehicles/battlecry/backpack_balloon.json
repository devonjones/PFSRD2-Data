                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Stowable",
                    "ability_type": "offensive",
                    "text": "By spending 10 minutes repacking, the backpack balloons can be stowed after the pilot has disengaged them."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Wind-Up",
                    "ability_type": "offensive",
                    "text": "10 minutes of wind-up, 30 minutes of operational time, DC 22, standby"
