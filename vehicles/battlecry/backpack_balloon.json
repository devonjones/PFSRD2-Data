    "offense": {
      "collision": "fly 20 feet (alchemical, clockwork, wind)",
      "offensive_abilities": [
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "Three Actions",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "name": "Deploy Balloons",
          "subtype": "ability",
          "text": "The pilot engages a lever that activates the clockwork components to launch two large tethered balloons and fill them with lighter-than-air gas. On the outside of the backpack is a small clockwork propeller. This allows the wearer to wind up and pilot the vehicle. This transformation lasts until the pilot disengages the balloons by using this activity again.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
