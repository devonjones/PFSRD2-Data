          },
          "name": "Deploy Hydrofoil",
          "subtype": "ability",
          "text": "The skimmer\u2019s hydrofoils are deployed by pulling a lever, doubling the vehicle\u2019s normal Speed. However, this makes the vehicle less maneuverable, and it must move twice its length for each 90-degree turn it makes while the hydrofoils are deployed. The pilot can take this action again to retract the hydrofoils and return the skimmer to its normal Speed and maneuverability.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
