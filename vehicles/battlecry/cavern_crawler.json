            "name": "Three Actions",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "name": "Swallow",
          "subtype": "ability",
          "text": "Two crew members each perform a 3-action activity on their turn to open the caravan crawler\u2019s mouth and eat a Huge or smaller creature adjacent to the vehicle, who must attempt a DC 40 Fortitude save. A creature can choose to fail. On a failure, the creature is swallowed by the cavern crawler, moved into the passenger bay, and knocked prone. This action fails if the passenger bay is full.",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
