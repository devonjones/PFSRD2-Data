            "collision": "secret of souls",
            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Spirit Ship",
                    "ability_type": "offensive",
                    "text": "*Bunta* can be damaged by spells like *spirit blast* that damage a creature's spirit directly, and such effects ignore *Bunta's* hardness.",
                    "links": [
                        {
                            "type": "link",
                            "name": "spirit blast",
                            "alt": "spirit blast",
                            "game-obj": "Spells",
                            "aonid": 301
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Activate",
                    "ability_type": "offensive",
                    "requirement": "You are piloting *Bunta*",
                    "effect": "A silver river flows from your heart, traveling forward in a line that flows around obstacles as if it were water. If *Bunta* travels at least its speed along the river each round for 10 minutes, you arrive at another plane as if you cast *plane shift*. You arrive in a destination you specify, or a random location if you don't have a choice. If *Bunta* ever does not travel at least its Speed in a round, you can disrupt this activation. If you continue, you have a 1% cumulative chance of ending up in a random extraplanar location for each round that *Bunta* did not travel at least its Speed, to a maximum of a 60% chance if *Bunta* didn't travel at least its Speed for the full 10 minutes. As long as you remain on *Bunta*, you are protected from any harmful effects of the plane's environment.",
                    "text": "command, envision, Interact;",
                    "links": [
                        {
                            "type": "link",
                            "name": "plane shift",
                            "alt": "plane shift",
                            "game-obj": "Spells",
                            "aonid": 222
                        }
                    ],
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    }
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Secret of Souls",
                    "ability_type": "offensive",
                    "text": "You pilot *Bunta* into a creature's soul, finding and restoring its true nature. *Bunta* attempts to counteract all magical effects on the creature. Its counteract level is 20, with a counteract modifier of +40.",
                    "links": [
                        {
                            "type": "link",
                            "name": "counteract",
                            "alt": "counteract",
                            "game-obj": "Rules",
                            "aonid": 371
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Destruction",
                    "ability_type": "offensive",
                    "text": "*Bunta* can only be permanently destroyed if Old-Mage Jatembe unweaves it, then submerges each reed in the River Styx at the base of Pharasma's Spire."
                }
            ]
