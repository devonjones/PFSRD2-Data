    "level": 14,
    "offense": {
      "collision": "8d12 (DC 30)",
      "offensive_abilities": [
        {
          "ability_type": "offensive",
          "name": "Continuous Track",
          "subtype": "ability",
          "text": "This vehicle travels on a continuous band of heavy treads driven by a series of gears and wheels, enabling it to travel over rugged land with ease. Earth, rock, rubble, slopes, and underbrush are not difficult terrain to an ambling surveyor. The ambling surveyor ignores difficult terrain from earth, rock, rubble, slopes, and underbrush, and greater difficult terrain caused by those features is normal difficult terrain to the ambling surveyor.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "offensive",
          "name": "Sluggish",
          "subtype": "ability",
          "text": "This vehicle must move twice its length for each 90-degree turn it makes.",
          "type": "stat_block_section"
        },
        {
          "ability_type": "offensive",
          "effect": "The pilot and crew release a collection of six clockwork birds, which spend two hours flying over the surrounding area within a 1-mile radius around the ambling surveyor. Everything the birds see is magically transmitted back to the ambling surveyor's crew as illusory images, which the crew must catalogue in real-time if they want to use the information to fully survey the area and create a map. After two hours, the birds return. The birds use the base statistics of clockwork spies if they are attacked, or if their Perception is important to determine what they can see, although they only perform the Survey action and they don't have any of the other abilities of a clockwork spy. Replacement birds cost 250 gp each.",
          "links": [
            {
              "alt": "clockwork spies",
              "aonid": 1095,
              "game-obj": "Monsters",
              "name": "clockwork spies",
              "type": "link"
            }
          ],
          "name": "Survey",
          "requirement": "The ambling surveyor is not in motion",
          "subtype": "ability",
          "traits": [
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 32,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "e32d877417a40fe977d27634dc14f99f",
              "game-obj": "Traits",
              "name": "Concentrate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 454",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 454",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 454,
                  "type": "source"
                }
              ],
              "text": "An action with this trait requires a degree of mental concentration and discipline.",
              "type": "trait"
            },
            {
              "edition": "legacy",
              "game-id": "dc277f983a39bb74b92ffada679a9c8a",
              "game-obj": "Traits",
              "name": "Divination",
              "sources": [
                {
                  "errata": {
                    "alt": "4.0",
                    "aonid": 1,
                    "game-obj": "Sources",
                    "name": "4.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Core Rulebook pg. 631",
                    "aonid": 1,
                    "game-obj": "Sources",
                    "name": "Core Rulebook pg. 631",
                    "type": "link"
                  },
                  "name": "Core Rulebook",
                  "page": 631,
                  "type": "source"
                }
              ],
              "text": "The divination school of magic typically involves obtaining or transferring information, or predicting events.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 66,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "d01cf264e1e257b61098e6c60886b69d",
              "game-obj": "Traits",
              "name": "Exploration",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 456",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 456",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 456,
                  "type": "source"
                }
              ],
              "text": "An activity with this trait takes more than a turn to use, and can usually be used only during exploration mode.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 103,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "15e2d048ce93e7b648064b09972535bc",
              "game-obj": "Traits",
              "name": "Magical",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "You must physically manipulate an item or make gestures to use an action with this trait. Creatures without a suitable appendage can\u2019t perform actions with this trait. Manipulate actions often trigger reactions.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 163,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "abcdb0d656f37cebdbee9dca267ef899",
              "game-obj": "Traits",
              "name": "Visual",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 463",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 463",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 463,
                  "type": "source"
                }
              ],
              "text": "A visual effect can affect only creatures that can see it. This applies only to visible parts of the effect, as determined by the GM.",
              "type": "trait"
            }
          ],
          "type": "stat_block_section"
        },
        {
