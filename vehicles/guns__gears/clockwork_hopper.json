            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Hopper",
                    "ability_type": "offensive",
                    "text": "This vehicle hops across the terrain as it moves across the ground. The clockwork hopper ignores difficult terrain from earth, rock, rubble, slopes, and underbrush, and greater difficult terrain caused by those features is normal difficult terrain to the clockwork hopper."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Massive Jump",
                    "ability_type": "offensive",
                    "traits": [
                        {
                            "name": "Move",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 114,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "43fcaf1d1171371e823b967f56d0b7a2",
                            "text": "An action with this trait involves moving from one space to another."
                        },
                        {
                            "name": "Reckless",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 285,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "GM Core",
                                    "link": {
                                        "type": "link",
                                        "name": "GM Core pg. 212",
                                        "alt": "GM Core pg. 212",
                                        "game-obj": "Sources",
                                        "aonid": 218
                                    },
                                    "page": 212,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 218
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "c0a85803365a7164141fab4b4a1e7ba6",
                            "text": "Actions that have the reckless trait push the pilot and the vehicle beyond the normal parameters for safe operation, and the pilot risks losing control of the vehicle. When performing a reckless action, the pilot must first attempt an appropriate piloting check to keep control of the vehicle, with the following effects. Resolve this piloting check before resolving the action itself.  \n  \n__Success__ The action occurs as described.   \n__Failure__ The vehicle moves its Speed in a straight line along its most recent heading, drifting up to 45 degrees at the GM\u2019s discretion, and becomes uncontrolled."
                        }
                    ],
                    "text": "The pilot engages a spring-driven mechanism that rockets the clockwork hopper into the air, in a grand leap. The vehicle jumps in a straight line in the direction of its current heading without touching the ground, landing in a space of solid ground up to 70 feet forward and up to 30 feet up. Creatures adjacent to the spaces a hopper lands in take 4d10 bludgeoning damage with a DC 22 basic Reflex save, and are knocked prone on a critical failure. The clockwork hopper can't use Massive Jump again for 1 minute. Massive Jump stops working if the clockwork hopper is broken.",
                    "links": [
                        {
