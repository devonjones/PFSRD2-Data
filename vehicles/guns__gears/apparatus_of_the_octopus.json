            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 104,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "6a0bf3cdfe7c0fc427c7b8ea9310f113",
              "game-obj": "Traits",
              "name": "Manipulate",
              "sources": [
