            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Adamantine Drill",
                    "ability_type": "offensive",
                    "text": "While most burrow Speeds only allow a creature or vehicle to move through loose dirt or earth, this vehicle is equipped with an adamantine drill and can burrow through bedrock and stone at a rate of 5 feet per minute."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Pivoting Seats",
                    "ability_type": "offensive",
                    "text": "This vehicle's seats are mounted on a weighted platform that pivots as the vehicle moves, automatically adjusting position with gravity. Seated creatures remain upright no matter the position or angle of the vehicle."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Sluggish",
                    "ability_type": "offensive",
                    "text": "Because it is sluggish, this vehicle must move twice its length for each 90-degree turn it makes."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Wind-Up",
                    "ability_type": "offensive",
                    "text": "10 minutes of wind-up, 1 hour of operational time, DC 26, standby"
                }
            ]
        }
