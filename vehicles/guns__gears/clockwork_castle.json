            "collision": "11d10 (DC 35)",
            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Environmental Protections",
                    "ability_type": "offensive",
                    "text": "This vehicle's interior temperature is magically maintained. Creatures inside this vehicle are protected from severe cold, severe heat, extreme cold, and extreme heat.",
                    "links": [
                        {
                            "type": "link",
                            "name": "severe cold, severe heat, extreme cold, and extreme heat",
                            "alt": "severe cold, severe heat, extreme cold, and extreme heat",
                            "game-obj": "Rules",
                            "aonid": 642
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Luxurious Accommodations",
                    "ability_type": "offensive",
                    "text": "This vehicle contains a bridge, engineering room, private sleeping quarters for up to 13 creatures, and four additional rooms (typically a dining room, kitchen, lavatory, and meeting room)."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Maneuverable",
                    "ability_type": "offensive",
                    "text": "This vehicle is mounted on ten spider-like legs that enable it to turn swiftly, turn in place, and even move backward. Each 90-degree turn made in less than a vehicle length costs 5 extra feet of movement; so, for example, it costs 10 feet of movement for the vehicle to turn around and begin moving backward. This vehicle loses these benefits when broken.",
                    "links": [
                        {
                            "type": "link",
                            "name": "broken",
                            "alt": "broken",
                            "game-obj": "Conditions",
                            "aonid": 2
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Skewering Step",
                    "ability_type": "offensive",
                    "traits": [
                        {
                            "name": "Attack",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 15,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 452",
                                        "alt": "Player Core pg. 452",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 452,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "23c17a4eee189983083f41b20ff9ff92",
                            "text": "An ability with this trait involves an attack. For each attack you make beyond the first on your turn, you take a multiple attack penalty."
                        }
                    ],
                    "text": "Two crew members each perform a 3-action activity on their turn to skewer nearby enemies with the clockwork castle's legs. All creatures under or adjacent to the vehicle at the end of the second character's turn take 7d8 piercing damage (DC 35 basic Reflex save).",
                    "links": [
                        {
                            "type": "link",
                            "name": "basic",
                            "alt": "basic",
                            "game-obj": "Rules",
                            "aonid": 329
                        }
                    ],
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    }
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Weapon Mounts",
                    "ability_type": "offensive",
                    "text": "This vehicle has four rooftop weapon mounts; one mount on each corner of the vehicle. At purchase, these weapon mounts are initially empty. Installing or uninstalling a weapon into a weapon mount requires 10 minutes, a successful DC 35 Crafting check, and an appropriate weapon. Three of these weapon mounts can be equipped with ranged weapons, and the fourth can be equipped with a ranged siege weapon of size Large or smaller.",
                    "links": [
                        {
                            "type": "link",
                            "name": "Crafting",
                            "alt": "Crafting",
                            "game-obj": "Skills",
                            "aonid": 4
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Wind-Up",
                    "ability_type": "offensive",
                    "text": "10 minutes of wind-up, 1 hour of operational time, DC 35, standby"
                }
            ]
        }
    },
