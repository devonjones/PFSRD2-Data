                    "name": "Streamlined",
                    "ability_type": "offensive",
                    "text": "This lightweight vehicle has no additional storage space for cargo."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Wind-Up",
                    "ability_type": "offensive",
                    "text": "10 minutes of wind-up, 2 hours of operational time, DC 28, standby"
                }
