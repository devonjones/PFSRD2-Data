    "offense": {
      "collision": "3d8 (DC 20)",
      "offensive_abilities": [
        {
          "ability_type": "offensive",
          "action_type": {
            "name": "Three Actions",
            "subtype": "action_type",
            "type": "stat_block_section"
          },
          "links": [
            {
              "alt": "dazzled",
              "aonid": 7,
              "game-obj": "Conditions",
              "name": "dazzled",
              "type": "link"
            },
            {
              "alt": "broken",
