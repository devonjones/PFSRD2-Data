    "stat_block": {
        "type": "stat_block",
        "subtype": "vehicle",
        "text": "A firefly blends magic and technology, using electricity magic and magnetism to hover just above the ground. While a firefly is more box-like than insect-shaped, it gets its name from the constant glow of the light and electricity magic that power it, as well as from the stabilizing magnets that protrude from its sides in roughly the same position as wings would be.",
        "level": 0,
        "traits": [
            {
                "name": "Uncommon",
                "type": "trait",
                "alternate_link": {
