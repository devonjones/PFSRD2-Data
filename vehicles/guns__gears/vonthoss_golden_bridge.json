                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 453",
                                        "alt": "Player Core pg. 453",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 453,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "5315505cfd3f3ba2685e9747898193b2",
                            "text": "An aura is an emanation that continually ebbs out from you, affecting creatures within a certain radius. Aura can also refer to the magical signature of an item."
                        },
                        {
                            "name": "Enchantment",
                            "type": "trait",
                            "edition": "legacy",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Core Rulebook",
                                    "link": {
                                        "type": "link",
                                        "name": "Core Rulebook pg. 631",
                                        "alt": "Core Rulebook pg. 631",
                                        "game-obj": "Sources",
                                        "aonid": 1
                                    },
                                    "page": 631,
                                    "errata": {
                                        "type": "link",
                                        "name": "4.0",
                                        "alt": "4.0",
                                        "game-obj": "Sources",
                                        "aonid": 1
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "67a22784fdff12403013a5af60fb8621",
                            "text": "Effects and magic items with this trait are associated with the enchantment school of magic, typically involving mind control, emotion alteration, and other mental effects."
                        },
                        {
                            "name": "Magical",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 103,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "15e2d048ce93e7b648064b09972535bc",
                            "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical."
                        },
                        {
                            "name": "Mental",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 106,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "6a1f80610baa3617c1597f49c6406313",
                            "text": "A mental effect can alter the target\u2019s mind. It has no effect on an object or a mindless creature."
                        },
                        {
                            "name": "Visual",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 163,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 463",
                                        "alt": "Player Core pg. 463",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 463,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "abcdb0d656f37cebdbee9dca267ef899",
                            "text": "A visual effect can affect only creatures that can see it. This applies only to visible parts of the effect, as determined by the GM."
                        }
                    ],
                    "text": "40 feet. The gold, gems, and other embellishments that adorn this flying sphere emit a sparkling resplendence capable of enthralling creatures. Each creature that begins its turn within the aura must attempt a DC 36 Will save; on a failure, the creature is fascinated and stupefied 2 for as long as it remains within the aura. A creature that succeeds is temporarily immune for 1 hour. Each time Prismatic Defense is activated, the area of Captivating Wealth is reduced by 10 feet for 1 hour, to a minimum of 0 feet.",
                    "links": [
                        {
                            "type": "link",
                            "name": "fascinated",
                            "alt": "fascinated",
                            "game-obj": "Conditions",
                            "aonid": 14
                        },
                        {
                            "type": "link",
                            "name": "stupefied 2",
                            "alt": "stupefied 2",
                            "game-obj": "Conditions",
                            "aonid": 37
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Protective Barrier",
                    "ability_type": "offensive",
                    "text": "While the swirling rings of the vehicle don't fully cover the pilot, they offer incredible protection, magically maintaining the temperature within and ablating physical attacks. The pilot is protected from severe cold, severe heat, extreme cold, and extreme heat . The pilot also gains resistance 10 to all physical damage (except adamantine ).",
                    "links": [
                        {
                            "type": "link",
                            "name": "adamantine",
                            "alt": "adamantine",
                            "game-obj": "Equipment",
                            "aonid": 374
                        },
                        {
                            "type": "link",
                            "name": "severe cold, severe heat, extreme cold, and extreme heat",
                            "alt": "severe cold, severe heat, extreme cold, and extreme heat",
                            "game-obj": "Rules",
                            "aonid": 642
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Prismatic Defense",
                    "ability_type": "offensive",
                    "traits": [
                        {
                            "name": "Abjuration",
                            "type": "trait",
                            "edition": "legacy",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Core Rulebook",
                                    "link": {
                                        "type": "link",
                                        "name": "Core Rulebook pg. 628",
                                        "alt": "Core Rulebook pg. 628",
                                        "game-obj": "Sources",
                                        "aonid": 1
                                    },
                                    "page": 628,
                                    "errata": {
                                        "type": "link",
                                        "name": "4.0",
                                        "alt": "4.0",
                                        "game-obj": "Sources",
                                        "aonid": 1
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "fd5735184d8cc7e06debda7ae557fa0d",
                            "text": "Effects and magic items with this trait are associated with the abjuration school of magic, typically involving protection or wards."
                        },
                        {
                            "name": "Magical",
                            "type": "trait",
                            "alternate_link": {
                                "type": "alternate_link",
                                "game-obj": "Traits",
                                "aonid": 103,
                                "alternate_type": "legacy"
                            },
                            "edition": "remastered",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Player Core",
                                    "link": {
                                        "type": "link",
                                        "name": "Player Core pg. 458",
                                        "alt": "Player Core pg. 458",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    },
                                    "page": 458,
                                    "errata": {
                                        "type": "link",
                                        "name": "2.0",
                                        "alt": "2.0",
                                        "game-obj": "Sources",
                                        "aonid": 216
                                    }
                                }
                            ],
                            "game-obj": "Traits",
                            "game-id": "15e2d048ce93e7b648064b09972535bc",
                            "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical."
                        }
                    ],
                    "text": "The pilot harnesses power from the magical gemstones hidden among this vehicle's extravagant embellishments to grant the vehicle additional defenses. This vehicle gains resistance 20 to one of the following energy damage types: acid , cold , electricity , fire , force , or sonic . This immunity lasts until Prismatic Defense is next activated.",
                    "links": [
                        {
                            "type": "link",
                            "name": "acid",
                            "alt": "acid",
                            "game-obj": "Traits",
                            "aonid": 3
