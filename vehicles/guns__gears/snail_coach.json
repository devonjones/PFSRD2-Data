                            "name": "immobilized",
                            "alt": "immobilized",
                            "game-obj": "Conditions",
                            "aonid": 24
                        },
                        {
                            "type": "link",
                            "name": "Escape",
                            "alt": "Escape",
                            "game-obj": "Actions",
