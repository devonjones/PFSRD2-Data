            "collision": "9d12 (DC 32)",
            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Bolt Blast",
                    "ability_type": "offensive",
                    "text": "Two crew members each perform a three-action activity on their turn to fire a line of lightning at the end of the second character's turn. This line of lightning erupts from the front of the titanic stomper at an angle of the crew members' choice and deals 5d12 electricity damage to each creature in a 120-foot line (DC 34 basic Reflex save). The Bolt Blast stops working if the titanic stomper is broken .",
                    "links": [
                        {
                            "type": "link",
                            "name": "broken",
                            "alt": "broken",
                            "game-obj": "Conditions",
                            "aonid": 2
                        },
                        {
                            "type": "link",
                            "name": "basic",
                            "alt": "basic",
                            "game-obj": "Rules",
                            "aonid": 329
                        }
                    ],
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Three Actions"
                    }
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Electrical Absorption",
                    "ability_type": "offensive",
                    "trigger": "The titanic stomper is targeted by, or in the area of, an effect that deals electricity damage",
                    "effect": "The pilot uses their reaction to activate the Stasian coils, which funnels the electricity into the titanic stomper's electrical engine. The next time Bolt Blast is used within the next minute, the damage it deals increases to 7d12.",
                    "action_type": {
                        "type": "stat_block_section",
                        "subtype": "action_type",
                        "name": "Reaction"
                    }
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Quaking Step",
                    "ability_type": "offensive",
                    "text": "The ground shakes with every step a titanic stomper takes. Whenever this vehicle moves, creatures on the ground within 20 feet of its movement path must attempt a DC 32 Reflex save. On a failure, they are flat-footed for 1 round, and on a critical failure, they're knocked prone .",
                    "links": [
                        {
                            "type": "link",
