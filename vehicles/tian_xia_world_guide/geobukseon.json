            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Smoking Breath",
                    "ability_type": "offensive",
                    "text": "When the geobukseon Stops, it's concealed by the smoke for 1 round or until it next moves. The geobukseon can't use this concealment to Hide or Sneak."
                },
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Turtleback Spikes",
                    "ability_type": "offensive",
                    "text": "The roof of a geobukseon is difficult terrain and hazardous terrain. A creature that moves on the roof takes 1d6 piercing damage for every square of that area it moves into. Falling prone on the geobukseon's roof deals 5d6 piercing damage."
                }
            ]
