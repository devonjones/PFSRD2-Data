    "changes": [
      {
        "change_category": "weaknesses",
        "effects": [
          {
            "conditional": "$.creature_type.level <= 3",
            "item": {
              "name": "cold",
              "subtype": "weakness",
              "type": "stat_block_section",
              "value": 3
            },
            "operation": "add_item",
            "target": "$.defense.hitpoints[*].weaknesses"
