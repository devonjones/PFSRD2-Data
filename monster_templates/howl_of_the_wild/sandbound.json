          {
            "conditional": "$.creature_type.level >= 4 && $.creature_type.level <= 8",
            "item": {
              "name": "cold",
              "subtype": "weakness",
              "type": "stat_block_section",
              "value": 5
            },
            "operation": "add_item",
            "target": "$.defense.hitpoints[*].weaknesses"
          },
          {
            "conditional": "$.creature_type.level >= 9 && $.creature_type.level <= 13",
            "item": {
              "name": "cold",
              "subtype": "weakness",
              "type": "stat_block_section",
              "value": 10
            },
            "operation": "add_item",
            "target": "$.defense.hitpoints[*].weaknesses"
          },
          {
            "conditional": "$.creature_type.level >= 14",
            "item": {
              "name": "cold",
              "subtype": "weakness",
              "type": "stat_block_section",
              "value": 15
            },
            "operation": "add_item",
            "target": "$.defense.hitpoints[*].weaknesses"
          }
        ],
        "links": [
