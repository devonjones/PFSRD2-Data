                "name": "difficult terrain",
                "type": "link"
              }
            ],
            "name": "Desert Steps",
            "subtype": "ability",
            "text": "The creature ignores uneven ground and difficult terrain caused by sand (reducing greater difficult terrain from sand to ordinary difficult terrain).",
            "type": "stat_block_section"
          },
          {
