                "game-obj": "Sources",
                "aonid": 226
            }
        }
    ],
    "aonid": 24,
    "game-obj": "MonsterTemplates",
    "monster_template": {
        "name": "Amphibious",
        "type": "stat_block_section",
        "subtype": "monster_template",
        "changes": [
            {
                "type": "stat_block_section",
                "subtype": "change",
                "links": [
                    {
                        "type": "link",
                        "name": "amphibious",
                        "alt": "amphibious",
                        "game-obj": "Traits",
                        "aonid": 529
                    },
                    {
                        "type": "link",
                        "name": "aquatic",
                        "alt": "aquatic",
                        "game-obj": "Traits",
                        "aonid": 533
                    }
                ],
                "text": "- Add the amphibious trait. If the creature has the aquatic trait, remove it.",
                "change_category": "traits",
                "effects": [
                    {
                        "name": "Amphibious",
                        "operation": "remove_item",
                        "target": "$.creature_type.creature_types"
                    },
                    {
                        "name": "Aquatic",
                        "operation": "remove_item",
                        "target": "$.creature_type.creature_types"
                    },
                    {
                        "conditional": "$.creature_type.creature_types[?(@ == 'Aquatic')]",
                        "name": "Aquatic",
                        "operation": "remove_item",
                        "target": "$.creature_type.creature_types"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "links": [
                    {
                        "type": "link",
                        "name": "Athletics",
                        "alt": "Athletics",
                        "game-obj": "Skills",
                        "aonid": 36
                    }
                ],
                "text": "- Add Athletics with a modifier equal to the creature's highest skill modifier.",
                "change_category": "skills",
                "effects": [
                    {
                        "item": {
                            "name": "Athletics",
                            "subtype": "skill",
                            "type": "stat_block_section"
                        },
                        "operation": "add_item",
                        "target": "$.statistics.skills",
                        "value_from": "$.statistics.skills[*].value | max"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- If the creature doesn't have a swim Speed, add a swim Speed equal to half its land Speed (minimum 15 feet).",
                "change_category": "speed",
                "effects": [
                    {
                        "conditional": "$.offense.speed.movement[?(@.movement_type=='swim')] == null",
                        "item": {
                            "movement_type": "swim",
                            "name": "swim",
                            "subtype": "speed",
                            "type": "stat_block_section"
                        },
                        "minimum": 15,
                        "operation": "add_item",
                        "target": "$.offense.speed.movement",
                        "value_from": "$.offense.speed.movement[?(@.movement_type=='walk')].value / 2"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- If the creature doesn't have a land Speed, add a land Speed equal to half its swim Speed (minimum 15 feet).",
                "change_category": "speed",
                "effects": [
                    {
                        "conditional": "$.offense.speed.movement[?(@.movement_type=='walk')] == null",
                        "item": {
                            "movement_type": "walk",
                            "name": "walk",
                            "subtype": "speed",
                            "type": "stat_block_section"
                        },
                        "minimum": 15,
                        "operation": "add_item",
                        "target": "$.offense.speed.movement",
                        "value_from": "$.offense.speed.movement[?(@.movement_type=='swim')].value / 2"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "abilities": [
                    {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "name": "Low-light Vision",
                        "ability_type": "ability",
                        "link": {
                            "type": "link",
                            "name": "Low-light Vision",
                            "alt": "Low-light Vision",
                            "game-obj": "MonsterAbilities",
                            "aonid": 69
                        },
                        "universal_monster_ability": {
                            "name": "Low-Light Vision",
                            "type": "ability",
                            "text": "The monster can see in dim light as though it were bright light, so it ignores the concealed condition due to dim light.",
                            "ability_type": "universal_monster_ability",
                            "aonid": 23,
                            "game-obj": "MonsterAbilities",
                            "sources": [
                                {
                                    "type": "source",
                                    "name": "Bestiary",
                                    "link": {
                                        "type": "link",
                                        "name": "Bestiary pg. 343",
                                        "alt": "Bestiary pg. 343",
                                        "game-obj": "Sources",
                                        "aonid": 2
                                    },
                                    "page": 343
                                }
                            ],
                            "links": [
                                {
                                    "type": "link",
                                    "name": "concealed",
                                    "alt": "concealed",
                                    "game-obj": "Conditions",
                                    "aonid": 4
                                }
                            ],
                            "game-id": "2925971fb76ab7d097ed1fdfccb8a069"
                        },
                        "ability_category": "special_sense"
                    },
                    {
                        "type": "stat_block_section",
                        "subtype": "ability",
                        "name": "Drag Along",
                        "ability_type": "ability",
                        "action_type": {
                            "type": "stat_block_section",
                            "subtype": "action_type",
                            "name": "One Action"
                        },
                        "requirement": "The amphibious creature's previous action was a successful melee Strike",
                        "links": [
                            {
                                "type": "link",
                                "name": "Swims",
                                "alt": "Swims",
                                "game-obj": "Actions",
                                "aonid": 2381
                            }
                        ],
                        "effect": "The amphibious creature Strides or Swims 10 feet away from the target. The target moves the same direction and distance as forced movement.",
                        "ability_category": "offensive"
                    }
                ],
                "links": [
                    {
                        "type": "link",
                        "name": "Low-light Vision",
                        "alt": "Low-light Vision",
                        "game-obj": "MonsterAbilities",
                        "aonid": 69
                    },
                    {
                        "type": "link",
                        "name": "Swims",
                        "alt": "Swims",
                        "game-obj": "Actions",
                        "aonid": 2381
                    }
                ],
                "text": "- Add the following abilities:  **Low-light Vision**  **Drag Along** [one-action] **Requirements** The amphibious creature's previous action was a successful melee Strike; **Effect** The amphibious creature Strides or Swims 10 feet away from the target. The target moves the same direction and distance as forced movement.",
                "change_category": "abilities",
                "effects": [
                    {
                        "operation": "add_items",
                        "source": "$.changes[*].abilities",
                        "target": "$.defense.automatic_abilities"
                    }
                ]
            }
        ]
    },
    "game-id": "f5087ceecd864c377408d4baf72ae7e4",
    "text": "An amphibious creature has adapted to live both on land and in water.",
    "edition": "remastered",
