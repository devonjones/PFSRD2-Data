    "stat_block": {
        "type": "stat_block",
        "subtype": "siege_weapon",
        "text": "A less explosive version of black-powder weapons such as the ribauldequin and hwacha, the crossbow catapult consists of 16 crossbows arrayed in a square on a wooden frame with two large wheels. Aiming is done from behind, sighting through the center and wheeling the face back and forth. All the crossbow triggers are connected in sequence, firing a volley of bolts with a single pull of a wire.",
        "level": 3,
