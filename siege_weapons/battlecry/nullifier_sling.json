                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 452",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 452,
                  "type": "source"
                }
              ],
              "text": "An ability with this trait involves an attack. For each attack you make beyond the first on your turn, you take a multiple attack penalty.",
              "type": "trait"
            },
            {
              "alternate_link": {
                "alternate_type": "legacy",
                "aonid": 103,
                "game-obj": "Traits",
                "type": "alternate_link"
              },
              "edition": "remastered",
              "game-id": "15e2d048ce93e7b648064b09972535bc",
              "game-obj": "Traits",
              "name": "Magical",
              "sources": [
                {
                  "errata": {
                    "alt": "2.0",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "2.0",
                    "type": "link"
                  },
                  "link": {
                    "alt": "Player Core pg. 458",
                    "aonid": 216,
                    "game-obj": "Sources",
                    "name": "Player Core pg. 458",
                    "type": "link"
                  },
                  "name": "Player Core",
                  "page": 458,
                  "type": "source"
                }
              ],
              "text": "Something with the magical trait is imbued with magical energies not tied to a specific tradition of magic. Some items or effects are closely tied to a particular tradition of magic. In these cases, the item has the arcane, divine, occult, or primal trait instead of the magical trait. Any of these traits indicate that the item is magical.",
              "type": "trait"
            },
            {
              "edition": "legacy",
              "game-id": "104d6fc2d1d7f97108e1e9b4be5089b1",
              "game-obj": "Traits",
