            "offensive_abilities": [
                {
                    "type": "stat_block_section",
                    "subtype": "ability",
                    "name": "Ram",
                    "ability_type": "offensive",
                    "requirement": "The other members of the crew have \nReadied\n to Stride on your order",
                    "effect": "You and the crew Stride, with a maximum distance equal to the slowest crew member\u2019s Speed, then make a melee Strike with the ram against a structure or unattended, stationary object. This Strike deals 8d8 force damage. After taking this damage, an unattended, stationary object of 10 or fewer Bulk is pushed 10 feet away from the *arcane ram*\n. Once used to Ram, an *arcane ram*\n takes 1 minute to absorb enough ambient magic to deal force damage again; until then, it functions like a regular \nbattering ram\n.",
                    "links": [
                        {
