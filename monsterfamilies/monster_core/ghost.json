{
    "name": "Ghost",
    "type": "monster_family",
    "sections": [
        {
            "name": "Ghost",
            "type": "stat_block_section",
            "subtype": "monster_family"
        },
        {
            "name": "Creating a Ghost",
            "type": "section",
            "text": "You can also use the following guidelines to turn living creatures into ghosts. Increase the creature's level by 2 and change its statistics as follows.",
            "sources": [
                {
                    "type": "source",
                    "name": "Monster Core",
                    "link": {
                        "type": "link",
                        "name": "Monster Core pg. 160",
                        "alt": "Monster Core pg. 160",
                        "game-obj": "Sources",
                        "aonid": 221
                    },
                    "page": 160,
                    "errata": {
                        "type": "link",
                        "name": "1.1",
                        "alt": "1.1",
                        "game-obj": "Sources",
                        "aonid": 221
                    }
                }
            ],
            "changes": [
                {
                    "type": "stat_block_section",
                    "subtype": "change",
                    "text": "- Increase AC, saves, Perception, DCs, and skill modifiers by 2. Increase the most appropriate melee attack modifier by 4 to become ghostly hand (described below), and increase all other attack modifiers by 2.",
                    "change_category": "combat_stats",
                    "effects": [
                        {
                            "target": "$.defense.ac.value",
                            "operation": "adjustment",
                            "value": 2
                        },
                        {
                            "target": "$.offense.offensive_actions[*].attack.bonus.bonuses",
                            "operation": "adjustment",
                            "value": 2
                        },
                        {
                            "target": "$.offense.offensive_actions[*].spells.saving_throw.dc",
                            "operation": "adjustment",
                            "value": 2
                        },
                        {
                            "target": "$.senses.perception.value",
                            "operation": "adjustment",
                            "value": 2
                        },
                        {
                            "target": "$.skills[*].value",
                            "operation": "adjustment",
                            "value": 2
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "change",
                    "text": "- A ghost has a Strength modifier of \u20135 and a Constitution modifier of +0.",
                    "change_category": "attributes",
                    "effects": [
                        {
                            "target": "$.statistics.str",
                            "operation": "replace",
                            "value": -5
                        },
                        {
                            "target": "$.statistics.con",
                            "operation": "replace",
                            "value": 0
                        }
                    ]
                },
                {
                    "type": "stat_block_section",
                    "subtype": "change",
                    "text": "- Do not modify the ghost's Hit Points due to its new level.",
                    "change_category": "hit_points",
                    "effects": [
                        {
                            "operation": "no_op",
                            "target": "none"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Ghost Abilities",
            "type": "section",
            "text": "A ghost gains the ghost, incorporeal, spirit, and undead traits. Many become unholy. The base creature loses any traits that represented its life as a living creature, such as human and humanoid, and any abilities or traits that rely on it being a living, corporeal creature. You might also need to adjust some abilities that conflict with the theme of a ghost. All ghosts gain the following abilities.",
            "sources": [
                {
