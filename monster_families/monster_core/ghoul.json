        "subtype": "change",
        "text": "- Increase its AC, attack bonuses, DCs, saving throws, Perception, and skill modifiers by 1.",
        "type": "stat_block_section"
      },
      {
        "change_category": "damage",
        "effects": [
          {
            "conditional": "default",
            "item": {
              "formula": "+1",
              "notes": "Ghoul",
              "subtype": "attack_damage",
              "type": "stat_block_section"
            },
            "operation": "add_item",
            "target": "$.offense.offensive_actions[*].attack.damage"
          },
          {
            "conditional": "$.offense.offensive_actions[*].ability.damage != null && $.offense.offensive_actions[*].ability.frequency == null",
            "item": {
              "formula": "+1",
              "notes": "Ghoul",
              "subtype": "attack_damage",
              "type": "stat_block_section"
            },
            "operation": "add_item",
            "target": "$.offense.offensive_actions[*].ability.damage"
          }
        ],
        "subtype": "change",
        "text": "- Increase its damage with Strikes and other offensive abilities by 1. If the creature is limited in how often it can use an ability (such as dragon breath), increase that ability's damage by 2 instead.",
        "type": "stat_block_section"
      }
    ],
