                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.reactive_abilities[*].saving_throw[*].dc",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.offense.offensive_actions[*].ability.saving_throw[*].dc",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.saves.fort.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.saves.ref.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.saves.will.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.statistics.skills[*].value",
                        "value": 1
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- Increase its damage with Strikes and other offensive abilities by 1. If the werecreature is limited in how often it can use an ability (such as magical breath), increase the damage by 2 instead.",
                "change_category": "damage",
                "effects": [
                    {
                        "conditional": "default",
                        "item": {
                            "formula": "+1",
                            "notes": "Werecreature",
                            "subtype": "attack_damage",
                            "type": "stat_block_section"
                        },
                        "operation": "add_item",
                        "target": "$.offense.offensive_actions[*].attack.damage"
                    },
                    {
                        "conditional": "$.offense.offensive_actions[*].ability.damage != null && $.offense.offensive_actions[*].ability.frequency == null",
                        "item": {
                            "formula": "+1",
                            "notes": "Werecreature",
                            "subtype": "attack_damage",
                            "type": "stat_block_section"
                        },
                        "operation": "add_item",
                        "target": "$.offense.offensive_actions[*].ability.damage"
                    },
                    {
                        "conditional": "$.offense.offensive_actions[*].ability.damage != null && $.offense.offensive_actions[*].ability.frequency != null",
                        "item": {
                            "formula": "+2",
                            "notes": "Werecreature, limited use",
                            "subtype": "attack_damage",
                            "type": "stat_block_section"
                        },
                        "operation": "add_item",
                        "target": "$.offense.offensive_actions[*].ability.damage"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "links": [
                    {
                        "type": "link",
                        "name": "silver",
                        "alt": "silver",
                        "game-obj": "Equipment",
                        "aonid": 2920
