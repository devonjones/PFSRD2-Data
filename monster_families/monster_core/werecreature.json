                        "target": "$.defense.hitpoints[*].weaknesses"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- The creature gains weakness to silver as shown on the table.",
                "change_category": "weaknesses",
                "effects": [
