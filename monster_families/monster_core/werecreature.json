                                        },
                                        {
                                            "name": "Polymorph",
                                            "type": "trait",
                                            "alternate_link": {
                                                "type": "alternate_link",
                                                "game-obj": "Traits",
                                                "aonid": 127,
                                                "alternate_type": "legacy"
                                            },
