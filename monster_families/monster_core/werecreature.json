                ],
                "text": "- It gains the beast and werecreature traits.",
                "change_category": "traits",
                "effects": [
                    {
                        "name": "Beast",
                        "operation": "add_item",
                        "target": "$.creature_type.creature_types"
                    },
                    {
                        "name": "Werecreature",
                        "operation": "add_item",
                        "target": "$.creature_type.creature_types"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- Increase its size by one category if the animal is a larger size than the base humanoid.",
                "change_category": "size",
                "effects": [
                    {
                        "operation": "size_increment",
                        "target": "$.creature_type.size",
                        "value": 1
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- Increase its AC, attack bonuses, DCs, saving throws, and skill modifiers by 1.",
                "change_category": "combat_stats",
                "effects": [
                    {
                        "operation": "adjustment",
                        "target": "$.defense.ac.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.offense.offensive_actions[*].attack.bonus.bonuses",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.offense.offensive_actions[*].spells.saving_throw.dc",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.automatic_abilities[*].saving_throw[*].dc",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.reactive_abilities[*].saving_throw[*].dc",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.offense.offensive_actions[*].ability.saving_throw[*].dc",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.saves.fort.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.saves.ref.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.defense.saves.will.value",
                        "value": 1
                    },
                    {
                        "operation": "adjustment",
                        "target": "$.statistics.skills[*].value",
                        "value": 1
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- Increase its damage with Strikes and other offensive abilities by 1. If the werecreature is limited in how often it can use an ability (such as magical breath), increase the damage by 2 instead.",
                "change_category": "damage",
                "effects": [
                    {
                        "conditional": "default",
                        "item": {
                            "formula": "+1",
                            "notes": "Werecreature",
                            "subtype": "attack_damage",
                            "type": "stat_block_section"
                        },
                        "operation": "add_item",
                        "target": "$.offense.offensive_actions[*].attack.damage"
