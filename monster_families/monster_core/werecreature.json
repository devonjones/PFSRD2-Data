                        "target": "$.creature_type.creature_types"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- Increase its size by one category if the animal is a larger size than the base humanoid.",
                "change_category": "size",
                "effects": [
                    {
                        "operation": "size_increment",
                        "target": "$.creature_type.size",
                        "value": 1
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "text": "- Increase its AC, attack bonuses, DCs, saving throws, and skill modifiers by 1.",
                "change_category": "combat_stats",
                "effects": [
                    {
                        "operation": "adjustment",
                        "target": "$.defense.ac.value",
