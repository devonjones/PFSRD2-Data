    "monster_family": {
        "name": "Dragon, Umbral",
        "type": "stat_block_section",
        "subtype": "monster_family"
    },
    "game-id": "ab3cb43350f6afe82d7c0404ae914cbf",
    "text": "Stories across Golarion warn children about the monsters that dwell in the shadows, but no story captures the reality of the umbral dragon. Natives of the Netherworld, these occult dragons are at home in the darkness, using it to their advantage both in and out of battle. Umbral dragons rarely worry about fighting fairly, emerging from hiding to strike unwary foes and using their magical breath without compunction. Similarly, in social situations, they often remain in the shadows, operating through other creatures. Even in direct conversation, they frequently obscure their true intent, preferring to avoid ever being pinned down with a solid answer.",
    "links": [
        {
            "type": "link",
            "name": "the Netherworld",
            "alt": "the Netherworld",
            "game-obj": "Planes",
            "aonid": 36
        }
    ],
