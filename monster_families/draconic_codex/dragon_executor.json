                            "game-obj": "MonsterFamilies",
                            "aonid": 404
                        },
                        {
                            "type": "link",
                            "name": "linnorms",
                            "alt": "linnorms",
                            "game-obj": "MonsterFamilies",
                            "aonid": 439
                        }
                    ]
                },
                {
                    "name": "Shape-Changing Dragons",
                    "type": "section",
                    "text": "Though it's uncommon, some dragons can take humanoid forms. They gain the following ability:",
                    "sources": [
                        {
