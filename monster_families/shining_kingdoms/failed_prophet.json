                      "aonid": 561,
                      "game-obj": "Traits",
                      "name": "concentrate",
                      "type": "link"
                    },
                    "name": "concentrate",
                    "subtype": "trait",
                    "type": "stat_block_section"
                  }
                ],
                "type": "stat_block_section"
