          ],
          "effect": "Tiny spikes in the martial artist's gloves or footwear deal an additional 1d6 persistent bleed damage.",
          "links": [
            {
              "alt": "persistent bleed damage",
              "aonid": 29,
              "game-obj": "Conditions",
