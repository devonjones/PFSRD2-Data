            {
                "type": "stat_block_section",
                "subtype": "change",
                "links": [
                    {
                        "type": "link",
                        "name": "wood",
                        "alt": "wood",
                        "game-obj": "Traits",
                        "aonid": 508
                    },
                    {
                        "type": "link",
                        "name": "based on its level",
                        "alt": "based on its level",
                        "game-obj": "Rules",
                        "aonid": 2893
                    }
                ],
                "text": "- It gains the wood trait, as well as weakness to fire and mental based on its level.",
                "change_category": "traits",
                "effects": [
                    {
                        "name": "Wood",
                        "operation": "add_item",
                        "target": "$.creature_type.creature_types"
                    }
                ]
            },
            {
                "type": "stat_block_section",
                "subtype": "change",
                "links": [
                    {
                        "type": "link",
                        "name": "brawling",
                        "alt": "brawling",
                        "game-obj": "WeaponGroups",
                        "aonid": 4
                    },
                    {
                        "type": "link",
                        "name": "range increment",
                        "alt": "range increment",
                        "game-obj": "Traits",
                        "aonid": 248
                    }
                ],
                "text": "- It gains a splinter ranged Strike that deals piercing damage, is in the brawling group, and has a range increment of 30 feet.",
                "change_category": "damage",
                "effects": [
                    {
                        "item": {
                            "name": "Splinter",
                            "subtype": "offensive_action",
                            "type": "stat_block_section"
                        },
                        "operation": "add_item",
                        "target": "$.offense.offensive_actions",
                        "value_from": "$.offense.offensive_actions[*].attack.damage | min"
                    }
                ]
            }
        ],
        "subtypes": [
            {
                "name": "Woodblessed Abilities",
                "type": "stat_block_section",
                "subtype": "monster_family",
                "text": "All woodblessed gain the following abilities.",
                "changes": [
                    {
                        "type": "stat_block_section",
                        "subtype": "change",
                        "text": "Woodblessed Abilities",
                        "change_category": "abilities",
                        "abilities": [
                            {
                                "type": "stat_block_section",
                                "subtype": "ability",
                                "name": "Explosive End",
                                "ability_type": "ability",
                                "traits": [
                                    {
                                        "type": "stat_block_section",
                                        "subtype": "trait",
                                        "name": "primal",
                                        "link": {
                                            "type": "link",
                                            "name": "primal",
                                            "alt": "primal",
                                            "game-obj": "Traits",
                                            "aonid": 676
                                        }
                                    },
                                    {
                                        "type": "stat_block_section",
                                        "subtype": "trait",
                                        "name": "wood",
                                        "link": {
                                            "type": "link",
                                            "name": "wood",
                                            "alt": "wood",
                                            "game-obj": "Traits",
                                            "aonid": 508
                                        }
                                    }
                                ],
                                "links": [
                                    {
                                        "type": "link",
                                        "name": "basic",
                                        "alt": "basic",
                                        "game-obj": "Rules",
                                        "aonid": 329
                                    }
                                ],
                                "text": "When the woodblessed dies, the planar portal inside of them collapses, causing them to explode in a 20-foot burst of vines that deal 1d6 bludgeoning damage per level to all creatures with a basic Reflex save against the woodblessed's spell DC. The woodblessed's body is completely consumed, though their root network and gear remain behind."
                            },
                            {
                                "type": "stat_block_section",
                                "subtype": "ability",
                                "name": "Luminant Aura",
                                "ability_type": "ability",
                                "traits": [
                                    {
                                        "type": "stat_block_section",
                                        "subtype": "trait",
                                        "name": "aura",
                                        "link": {
                                            "type": "link",
                                            "name": "aura",
                                            "alt": "aura",
                                            "game-obj": "Traits",
                                            "aonid": 542
                                        }
                                    },
                                    {
                                        "type": "stat_block_section",
                                        "subtype": "trait",
                                        "name": "light",
                                        "link": {
                                            "type": "link",
                                            "name": "light",
                                            "alt": "light",
                                            "game-obj": "Traits",
                                            "aonid": 640
                                        }
                                    }
                                ],
                                "text": "The volatile planar energy coursing through a woodblessed's veins fills the area with dim light.",
                                "range": {
                                    "type": "stat_block_section",
                                    "subtype": "range",
                                    "text": "20 feet",
                                    "range": 20,
                                    "unit": "feet"
                                }
                            },
                            {
                                "type": "stat_block_section",
                                "subtype": "ability",
                                "name": "Primal Innate Spells",
                                "ability_type": "ability",
                                "links": [
                                    {
                                        "type": "link",
                                        "name": "timber",
                                        "alt": "timber",
                                        "game-obj": "Spells",
                                        "aonid": 1412
                                    }
                                ],
                                "text": "A woodblessed can cast *timber* as an innate primal cantrip."
                            },
                            {
                                "type": "stat_block_section",
                                "subtype": "ability",
                                "name": "Reactive Flare",
                                "ability_type": "ability",
                                "action_type": {
                                    "type": "stat_block_section",
                                    "subtype": "action_type",
                                    "name": "Reaction"
                                },
                                "trigger": "The woodblessed is damaged by a creature within their reach",
                                "links": [
                                    {
                                        "type": "link",
                                        "name": "basic",
                                        "alt": "basic",
                                        "game-obj": "Rules",
                                        "aonid": 329
                                    }
                                ],
                                "effect": "Distracted by the pain, the woodblessed's concentration slips and splinters erupt from their body as they temporarily lose control of the planar energy within them. Both the triggering creature and the woodblessed take 1d6 piercing damage + 1d6 per 2 levels the woodblessed has, with a basic Reflex save against the woodblessed's spell DC."
                            },
                            {
                                "type": "stat_block_section",
                                "subtype": "ability",
                                "name": "Tap Planar Gate",
                                "ability_type": "ability",
                                "action_type": {
                                    "type": "stat_block_section",
                                    "subtype": "action_type",
                                    "name": "One Action"
                                },
                                "traits": [
                                    {
                                        "type": "stat_block_section",
                                        "subtype": "trait",
                                        "name": "concentrate",
                                        "link": {
                                            "type": "link",
                                            "name": "concentrate",
                                            "alt": "concentrate",
                                            "game-obj": "Traits",
                                            "aonid": 561
                                        }
                                    },
                                    {
                                        "type": "stat_block_section",
                                        "subtype": "trait",
                                        "name": "primal",
                                        "link": {
                                            "type": "link",
                                            "name": "primal",
                                            "alt": "primal",
                                            "game-obj": "Traits",
                                            "aonid": 676
                                        }
                                    }
                                ],
                                "text": "The woodblessed empowers themself or their next attack."
                            }
                        ],
                        "effects": [
                            {
                                "target": "$.defense.automatic_abilities",
                                "operation": "add_items",
                                "source": "$.monster_family.subtypes[*].changes[*].abilities"
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "game-id": "80c50a08431515b85c7ef19c6a3e55bf",
    "text": "Woodblessed are those granted uncontrollable energy drawn from the Plane of Wood\u2014a blessing that brings pain and eventual death.",
    "links": [
        {
            "type": "link",
            "name": "Plane of Wood",
            "alt": "Plane of Wood",
            "game-obj": "Planes",
            "aonid": 25
        }
